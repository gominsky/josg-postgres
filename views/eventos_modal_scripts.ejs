<!-- ===== Modal flotante — cabecera negra + naranja (sin transparencias) ===== -->
<div class="modal fade modal-sheet" id="eventoModal" tabindex="-1" aria-labelledby="eventoModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <form id="eventoForm" class="modal-content" style="background-color: transparent; box-shadow: none;">
      <input type="hidden" name="id">

      <!-- Cabecera completa -->
      <div class="sheet-head">
        <!-- franja naranja superior -->
        <div class="sheet-accent" aria-hidden="true"></div>
        <h5 class="modal-title mb-0" id="eventoModalTitulo">Nuevo evento</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>

      <!-- Cuerpo -->
      <div class="modal-body">
        <div class="mb-3">
          <label for="titulo" class="form-label">Título</label>
          <input type="text" name="titulo" id="titulo" class="form-control" placeholder="Ensayo de cuerdas…" required>
        </div>
        <div class="mb-3">
          <label for="espacio_id" class="form-label">Espacio</label>
          <select name="espacio_id" id="espacio_id" class="form-select">
            <option value="">— Sin espacio —</option>
            <% (espacios || []).forEach(es => { %>
              <option value="<%= es.id %>"><%= es.nombre %></option>
            <% }) %>
          </select>
        </div>        
        <div class="mb-3">
          <label for="descripcion" class="form-label">Descripción</label>
          <textarea name="descripcion" id="descripcion" class="form-control" rows="3" placeholder="Notas, repertorio, etc."></textarea>
        </div>

        <div class="mb-3">
          <label for="grupo_id" class="form-label">Grupo</label>
          <select name="grupo_id" id="grupo_id" class="form-select" required>
            <% if (grupos && grupos.length > 0) { %>
              <option value="" disabled selected>Selecciona un grupo…</option>
              <% grupos.forEach(a => { %>
                <option value="<%= a.id %>"><%= a.nombre %></option>
              <% }) %>
            <% } else { %>
              <option disabled selected>No hay grupos disponibles</option>
            <% } %>
          </select>
        </div>
        <div class="mb-3">
          <label for="baremo_id" class="form-label">Peso del evento o factor de ponderación</label>
          <select name="baremo_id" id="baremo_id" class="form-select">
            <option value="">— Sin baremo —</option>
            <% (baremos || []).forEach(function(b) { 
                const tipoLower = (b.tipo || '').toString().toLowerCase();
                const esMaximo  = (tipoLower === 'máximo' || tipoLower === 'maximo');
            %>
              <option value="<%= b.id %>" <%= esMaximo ? 'selected' : '' %>>
                <%= b.tipo %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="row when-row">
          <div class="col-sm-6">
            <label for="fecha_inicio" class="form-label">Fecha y hora de inicio</label>
            <input type="datetime-local" name="fecha_inicio" id="fecha_inicio" class="form-control" required>
          </div>
          <div class="col-sm-6">
            <label for="fecha_fin" class="form-label">Fecha y hora de fin</label>
            <input type="datetime-local" name="fecha_fin" id="fecha_fin" class="form-control" required>
          </div>
        </div>

        <div class="form-check form-switch mt-3 qr-block">
          <input type="checkbox" name="activo" id="activo" class="form-check-input">
          <label for="activo" class="form-check-label ms-2">Activar QR para este evento</label>
        </div>
      </div>

      <!-- Pie -->
      <div class="modal-footer">
        <button type="submit" class="btn-primary-negro">Guardar</button>
        <button type="button" id="btnFirmaManual" class="btn-primary-negro d-none">Configuración</button>
        <button type="button" id="btnQR" class="btn-primary-negro d-none">Ver QR</button>
        <button type="button" id="btnEliminar" class="btn-primary-negro d-none">Eliminar</button>
      </div>
    </form>
  </div>
</div>

<script>
  // ------- Helpers para normalizar fecha/hora a <input type="datetime-local"> -------
  function normDate(v){
    if (!v) return '';
    const s = String(v).trim();
    if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
    if (s.includes('T')) return s.split('T')[0]; // YYYY-MM-DDTHH:MM:SS
    if (/^\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2}(:\d{2})?$/.test(s)) return s.slice(0,10); // YYYY-MM-DD HH:MM[:SS]
    const m = s.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
    if (m) return `${m[3]}-${m[2]}-${m[1]}`;
    const d = new Date(s);
    return isNaN(d) ? '' : d.toISOString().slice(0,10);
  }
  function normHM(v){
    if (!v) return '';
    const s = String(v).trim();
    const m = s.match(/^(\d{2}):(\d{2})(?::\d{2})?$/);
    if (m) return `${m[1]}:${m[2]}`;
    const t = s.match(/T(\d{2}:\d{2})/); if (t) return t[1];
    const u = s.match(/\s(\d{2}:\d{2})/); if (u) return u[1];
    return '';
  }
  function composeDTLocal(fechaVal, horaVal, fallbackHM='00:00'){
    const d = normDate(fechaVal);
    let hm  = normHM(horaVal);
    if (!hm) hm = normHM(fechaVal) || fallbackHM; // intenta extraer hora de la propia fecha si viene
    return d ? `${d}T${hm}` : '';
  }
</script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // ---- refs principales ----
  const form       = document.getElementById('eventoForm');
  const inputId    = form ? form.querySelector('input[name="id"]') : null;
  const modalEl    = document.getElementById('eventoModal');
  const modal      = modalEl ? bootstrap.Modal.getOrCreateInstance(modalEl) : null;
  const btnEliminar    = document.getElementById('btnEliminar');
  const btnQR          = document.getElementById('btnQR');
  const btnFirmaManual = document.getElementById('btnFirmaManual');
  const modalTitulo    = document.getElementById('eventoModalTitulo');

  if (!form || !modal) return; // seguridad

  // Mover modal al <body> (evita problemas de stacking/overflow)
  if (modalEl.parentNode !== document.body) document.body.appendChild(modalEl);

  // Helpers mostrar/ocultar botones de edición
  const ocultarBtns = () => {
    btnEliminar.classList.add('d-none');
    btnQR.classList.add('d-none');
    btnFirmaManual.classList.add('d-none');
  };
  const mostrarBtns = () => {
    btnEliminar.classList.remove('d-none');
    btnQR.classList.remove('d-none');
    btnFirmaManual.classList.remove('d-none');
  };

  // --------------- Abrir desde LISTA (click en fila) ---------------
  document.querySelectorAll('.evento-row').forEach(fila => {
    fila.style.cursor = 'pointer';
    fila.addEventListener('click', async () => {
      const id = fila.dataset.id;
      try {
        const res = await fetch(`/eventos/${id}`);
        if (!res.ok) throw new Error();
        const evento = await res.json();

        form.reset();
        inputId.value           = String(evento.id || '');
        form.titulo.value       = evento.titulo || '';
        form.espacio_id.value = (evento.espacio_id || '');
        form.descripcion.value  = evento.descripcion || '';
        form.grupo_id.value     = evento.grupo_id || '';
        form.baremo_id.value    = evento.baremo_id || '';
        form.fecha_inicio.value = composeDTLocal(evento.fecha_inicio, evento.hora_inicio, '09:00');
        form.fecha_fin.value    = composeDTLocal(evento.fecha_fin,   evento.hora_fin,   '10:00');
        form.activo.checked     = Number(evento.activo) === 1;
        // Guarda originales para detectar cambios y cuenta asignaciones
form.dataset.origInicio = form.fecha_inicio.value || '';
form.dataset.origFin    = form.fecha_fin.value || '';
try {
  const rResumen = await fetch(`/eventos/${evento.id}/asignaciones/resumen`);
  const jResumen = rResumen.ok ? await rResumen.json() : { asignados: 0 };
  form.dataset.asignados = String(jResumen.asignados || 0);
} catch {
  form.dataset.asignados = '0';
}

        mostrarBtns();
        btnQR.onclick = () => window.open(`/eventos/${evento.id}/qr`, '_blank');
        btnFirmaManual.onclick = () => window.location.href = `/eventos/${evento.id}/firma_manual`;

        modalTitulo.innerText = 'Editar evento';
        modal.show();
      } catch {
        alert('Error al cargar el evento');
      }
    });
  });

  // --------------- FULLCALENDAR (solo si existe el contenedor) ---------------
  const calendarEl = document.getElementById('calendar');
  if (typeof FullCalendar !== 'undefined' && calendarEl) {
    const calendar = new FullCalendar.Calendar(calendarEl, {
      locale: 'es',
      firstDay: 1,
      initialView: 'dayGridMonth',
      allDayText: 'Todo el día',
      headerToolbar: {
        left: 'prev,next today',
        center: 'title',
        right: 'dayGridMonth,timeGridWeek,customList'
      },
      customButtons: {
        customList: {
          text: 'Lista',
          click() {
            const v = calendar.view;
            const from = v.currentStart.toISOString().split('T')[0];
            const to   = v.currentEnd  .toISOString().split('T')[0];
            window.location.href = `/eventos?desde=${from}&hasta=${to}`;
          }
        }
      },
      buttonText: { today:'Hoy', month:'Mes', week:'Semana', day:'Día', list:'Lista' },
      events: '/eventos/listado',
      views: { dayGridMonth: { displayEventTime:false } },

     // ... dentro de la inicialización de FullCalendar

dateClick(info) {
  // Nuevo desde calendario
  form.reset();
  inputId.value = '';
  form.titulo.value       = '';
  form.espacio_id.value   = '';         // 👈 usar espacio_id
  form.descripcion.value  = '';
  form.grupo_id.value     = '';
  form.fecha_inicio.value = `${info.dateStr}T09:00`;
  form.fecha_fin.value    = `${info.dateStr}T10:00`;
  form.dataset.origInicio = form.fecha_inicio.value || '';
  form.dataset.origFin    = form.fecha_fin.value || '';
  form.dataset.asignados  = '0';
  form.activo.checked     = false;
  ocultarBtns();
  modalTitulo.innerText = 'Nuevo evento';
  modal.show();
},

eventClick: async function(info){
  // 1) Evitar navegación
  info.jsEvent?.preventDefault?.();

  const e = info.event;
  const x = e.extendedProps || {};

  // ¿Tenemos todo ya?
  const tieneTodo = typeof x.titulo !== 'undefined'
                 && typeof x.descripcion !== 'undefined'
                 && typeof x.grupo_id !== 'undefined';

  let evento = null;
  if (tieneTodo) {
    evento = {
      id: e.id,
      titulo: x.titulo || e.title || '',
      descripcion: x.descripcion || '',
      fecha_inicio: e.startStr || '',
      fecha_fin:    e.endStr   || '',
      hora_inicio:  '', // si te interesa, extrae de startStr
      hora_fin:     '',
      grupo_id:     x.grupo_id || '',
      activo:       x.activo,
      espacio_id:   x.espacio_id || '',   // 👈 usar espacio_id
      baremo_id:    x.baremo_id || ''
    };
  } else {
    // Respaldo al backend si faltan props
    try{
      const r = await fetch(`/eventos/${encodeURIComponent(e.id)}`, { credentials:'include' });
      if (!r.ok) throw new Error('HTTP '+r.status);
      evento = await r.json();
    } catch (err) {
      console.error('[cal] fallback evento error', err);
      // Fallback duro con lo disponible
      evento = {
        id: e.id,
        titulo: e.title || '',
        descripcion: x.descripcion || '',
        fecha_inicio: e.startStr || '',
        fecha_fin:    e.endStr   || '',
        grupo_id: x.grupo_id || '',
        activo: x.activo,
        espacio_id: x.espacio_id || ''
      };
    }
  }

  // 2) Rellenar form correctamente
  form.reset();
  inputId.value           = String(evento.id || '');
  form.titulo.value       = evento.titulo || '';
  form.descripcion.value  = evento.descripcion || '';
  form.grupo_id.value     = evento.grupo_id || '';
  form.baremo_id.value    = evento.baremo_id || '';
  form.espacio_id.value   = evento.espacio_id || ''; // 👈 CORRECTO

  // Normaliza a datetime-local (ya tienes helpers arriba)
  form.fecha_inicio.value = composeDTLocal(evento.fecha_inicio, evento.hora_inicio, '09:00');
  form.fecha_fin.value    = composeDTLocal(evento.fecha_fin,   evento.hora_fin,   '10:00');
  // Guarda originales para detectar cambios y cuenta asignaciones
form.dataset.origInicio = form.fecha_inicio.value || '';
form.dataset.origFin    = form.fecha_fin.value || '';
try {
  const rResumen = await fetch(`/eventos/${evento.id}/asignaciones/resumen`);
  const jResumen = rResumen.ok ? await rResumen.json() : { asignados: 0 };
  form.dataset.asignados = String(jResumen.asignados || 0);
} catch {
  form.dataset.asignados = '0';
}

  form.activo.checked     = Number(evento.activo) === 1 || evento.activo === true;

  mostrarBtns();
  btnQR.onclick = () => window.open(`/eventos/${evento.id}/qr`, '_blank');
  btnFirmaManual.onclick = () => window.location.href = `/eventos/${evento.id}/firma_manual`;

  modalTitulo.innerText = 'Editar evento';
  modal.show();
},

// Opcional: evita <a href="..."> navegables creados por FC
eventDidMount(arg){
  if (arg.el.tagName === 'A') {
    arg.el.removeAttribute('href');
    arg.el.style.cursor = 'pointer';
  }
},

    });
    calendar.render();
  }

  // --------------- GUARDAR (crear/editar) ---------------
form.addEventListener('submit', async e => {
  e.preventDefault();

  const data = new FormData(form);
  const body = Object.fromEntries(data.entries());
  body.activo = form.activo.checked ? '1' : '0';

  const id     = (inputId.value || '').trim();
  const method = id ? 'PUT' : 'POST';
  const url    = id ? `/eventos/${id}` : '/eventos';
  if (!id) delete body.id; else body.id = id;

  // ¿Han cambiado fecha/hora y hay asignaciones?
  const asignados   = Number(form.dataset.asignados || 0);
  const origInicio  = form.dataset.origInicio || '';
  const origFin     = form.dataset.origFin    || '';
  const changedTime = !!id && (
    (body.fecha_inicio || '') !== origInicio ||
    (body.fecha_fin    || '') !== origFin
  );

  let syncHoras = false;
  if (changedTime && asignados > 0) {
    syncHoras = confirm(
      `Este evento tiene ${asignados} asignación(es).\n\n` +
      `Has cambiado la fecha/hora del evento. Si continúas, se ` +
      `actualizarán las horas (inicio y fin) de TODAS las asignaciones actuales.\n\n` +
      `¿Quieres actualizar también las asignaciones?`
    );
    // Si cancelas, solo se guardará el evento
  }

  try {
    // 1) Guarda el evento
    const res = await fetch(url, {
      method,
      headers: { 'Content-Type':'application/json' },
      body: JSON.stringify(body)
    });
    if (!res.ok) {
      const t = await res.text().catch(()=> 'Error');
      throw new Error(t || 'Error al guardar');
    }

    // 2) Si procede, sincroniza horas en bloque
    if (syncHoras && id) {
      const r2 = await fetch(`/eventos/${encodeURIComponent(id)}/asignaciones/sincronizar-horas`, { method:'POST' });
      if (!r2.ok) alert('Evento guardado, pero no se pudieron actualizar las horas de las asignaciones.');
    }

    modal.hide();
    location.reload();
  } catch(err) {
    console.error(err);
    alert('Error al guardar el evento');
  }
});

  // --------------- ELIMINAR ---------------
  btnEliminar.addEventListener('click', async () => {
    if (!confirm('¿Deseas eliminar este evento?')) return;
    const id = (inputId.value || '').trim();
    if (!id) return alert('No hay id de evento.');
    try {
      const res = await fetch(`/eventos/${id}`, { method:'DELETE' });
      if (!res.ok) throw new Error('Error al eliminar');
      modal.hide();
      location.reload();
    } catch (err) {
      console.error(err);
      alert('Error al eliminar');
    }
  });

  // --------------- EVENTOS MASIVOS: robustez en Lista ---------------
  const masivoBtn   = document.querySelector('[data-bs-target="#eventoMasivoModal"]'); // tu botón existente
  const masivoModal = document.getElementById('eventoMasivoModal');

  // Si existen, aseguramos apertura incluso si falla el data API
  if (masivoBtn && masivoModal) {
    // Mueve el modal al body para evitar clipping/z-index
    if (masivoModal.parentNode !== document.body) document.body.appendChild(masivoModal);

    masivoBtn.addEventListener('click', (ev) => {
      // Forzamos apertura manual para evitar fallos por doble Bootstrap o data API
      ev.preventDefault();
      const instance = bootstrap.Modal.getOrCreateInstance(masivoModal);
      instance.show();
    });

    // Init Flatpickr al abrir (una única vez)
    function ensureMasivoFlatpickr(){
      if (!window.flatpickr || masivoModal._fpInited) return;
      const host  = masivoModal.querySelector('#multiDaysPickerHost');
      const input = masivoModal.querySelector('#multiDaysPicker');
      if (!host || !input) return;
      if (flatpickr.l10ns && flatpickr.l10ns.es) flatpickr.localize(flatpickr.l10ns.es);
      const fp = flatpickr(host, {
        inline:true, mode:'multiple', dateFormat:'Y-m-d', showMonths:2, clickOpens:false, defaultDate:[]
      });
      fp.set('onChange', (dates,_s,inst)=>{
        const iso = dates.map(d=>inst.formatDate(d,'Y-m-d')).sort();
        input.value = iso.join(', ');
        inst._selectedIso = iso;
      });
      masivoModal._fpInited = true;
      masivoModal._fp = fp;
    }

    masivoModal.addEventListener('shown.bs.modal', () => {
      ensureMasivoFlatpickr();

      // Si estás en vista Lista, salta al mes del filtro "desde"
      const fDesde = document.querySelector('#fecha'); // name="desde" en tu formulario de Lista
      if (masivoModal._fp && fDesde?.value) {
        try { masivoModal._fp.jumpToDate(fDesde.value, true); } catch {}
      }
    });

    masivoModal.addEventListener('hidden.bs.modal', () => {
      const input = masivoModal.querySelector('#multiDaysPicker');
      if (masivoModal._fp){
        masivoModal._fp.clear();
        if (input) input.value = '';
      }
    });
  }
});
</script>
