<!-- Modal flotante para nuevo/editar evento -->

<div class="modal fade" id="eventoModal" tabindex="-1" aria-labelledby="eventoModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form id="eventoForm">
        <input type="hidden" name="id">
        <div class="modal-header header-naranja text-white">
          <h5 class="modal-title mb-0" id="eventoModalTitulo">Nuevo evento</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label for="titulo" class="form-label fw-bold text-black">Título</label>
            <input type="text" name="titulo" id="titulo" class="form-control" required>
          </div>
          <div class="mb-3">
            <label for="descripcion" class="form-label fw-bold text-black">Descripción</label>
            <textarea name="descripcion" id="descripcion" class="form-control"></textarea>
          </div>
          <div class="mb-3">
            <label for="grupo_id" class="form-label fw-bold text-black">Grupos</label>
            <select name="grupo_id" id="grupo_id" class="form-select" required>
              <% if (grupos && grupos.length > 0) { %>
                <% grupos.forEach(a => { %>
                  <option value="<%= a.id %>"><%= a.nombre %></option>
                <% }) %>
              <% } else { %>
                <option disabled selected>No hay grupos disponibles</option>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label for="fecha_inicio" class="form-label fw-bold text-black">Fecha y hora de inicio</label>
            <input type="datetime-local" name="fecha_inicio" id="fecha_inicio" class="form-control" required>
          </div>
          <div class="mb-3">
            <label for="fecha_fin" class="form-label fw-bold text-black">Fecha y hora de fin</label>
            <input type="datetime-local" name="fecha_fin" id="fecha_fin" class="form-control" required>
          </div>
          <div class="form-check">
            <input type="checkbox" name="activo" id="activo" class="form-check-input">
            <label class="form-check-label fw-bold text-black" for="activo">Activar QR para este evento</label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn-primary-negro">Guardar</button>
          <button type="button" id="btnEliminar" class="btn-danger d-none">Eliminar</button>
          <button type="button" id="btnQR" class="btn-primary-negro d-none">Ver QR</button>
          <button type="button" id="btnFirmaManual" class="btn-primary-negro d-none">Listado alumnos</button>
        </div>
      </form>
    </div>
  </div>
</div>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/locales-all.global.min.js"></script>
  <script>
    const modalTitulo = document.getElementById('eventoModalTitulo');
    document.addEventListener('DOMContentLoaded', () => {
      const form             = document.getElementById('eventoForm');
      const modalEl          = document.getElementById('eventoModal');
      const modal            = new bootstrap.Modal(modalEl);
      const btnEliminar      = document.getElementById('btnEliminar');
      const btnQR            = document.getElementById('btnQR');
      const btnFirmaManual   = document.getElementById('btnFirmaManual');
    
      // Funciones helper
      const ocultarBtns = () => {
        btnEliminar.classList.add('d-none');
        btnQR.classList.add('d-none');
        btnFirmaManual.classList.add('d-none');
      };
      const mostrarBtns = () => {
        btnEliminar.classList.remove('d-none');
        btnQR.classList.remove('d-none');
        btnFirmaManual.classList.remove('d-none');
      };
    
      // Ocultar siempre al cargar
      ocultarBtns();
    
      // CLICK en fila de lista → EDITAR
      document.querySelectorAll('.evento-row').forEach(fila => {
        fila.style.cursor = 'pointer';
        fila.addEventListener('click', async () => {
          const id = fila.dataset.id;
          try {
            const res = await fetch(`/eventos/${id}`);
            if (!res.ok) throw new Error();
            const evento = await res.json();
    
            // Rellenar form
            form.reset();
            form.id.value          = evento.id;
            form.titulo.value      = evento.titulo || '';
            form.descripcion.value = evento.descripcion || '';
            form.grupo_id.value    = evento.grupo_id || '';
            form.fecha_inicio.value = evento.fecha_inicio.slice(0,16);
            form.fecha_fin.value    = evento.fecha_fin.slice(0,16);
            form.activo.checked     = evento.activo == 1;
    
            // Mostrar botones en edición
            mostrarBtns();
    
            btnQR.onclick = () => window.open(`/eventos/${evento.id}/qr`, '_blank');
            btnFirmaManual.onclick = () => window.location.href = `/eventos/${evento.id}/firma_manual`;
    
            modal.show();
          } catch {
            alert('Error al cargar el evento');
          }
        });
      });
    
      // FULLCALENDAR
      if (typeof FullCalendar !== 'undefined') {
        const calendarEl = document.getElementById('calendar');
        const calendar = new FullCalendar.Calendar(calendarEl, {
          locale: 'es',
          initialView: 'dayGridMonth',
          headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: 'dayGridMonth,timeGridWeek,customList'
          },
          customButtons: {
            customList: {
              text: 'Lista',
              click() {
                const v = calendar.view;
                const from = v.currentStart.toISOString().split('T')[0];
                const to   = v.currentEnd  .toISOString().split('T')[0];
                window.location.href = `/eventos?desde=${from}&hasta=${to}`;
              }
            }
          },
          buttonText: { today:'Hoy', month:'Mes', week:'Semana', day:'Día', list:'Lista' },
          events: '/eventos/listado',
          views: { dayGridMonth: { displayEventTime:false } },
          dateClick(info) {
            modalTitulo.innerText = 'Nuevo evento';
            // PREPARAR CREACIÓN
            form.reset();
            form.id.value         = '';
            form.titulo.value     = '';
            form.descripcion.value= '';
            form.grupo_id.value   = '';
            form.fecha_inicio.value = `${info.dateStr}T09:00`;
            form.fecha_fin.value    = `${info.dateStr}T10:00`;
            form.activo.checked     = false;
    
            ocultarBtns();
            modal.show();
          },
          eventClick(info) {
            // EDITAR desde calendario
            modalTitulo.innerText = 'Editar evento';
            const e = info.event;
            form.reset();
            form.id.value          = e.id;
            form.titulo.value      = e.extendedProps.titulo || '';
            form.descripcion.value = e.extendedProps.descripcion || '';
            form.grupo_id.value    = e.extendedProps.grupo_id || '';
            form.fecha_inicio.value= e.startStr?.slice(0,16) || '';
            form.fecha_fin.value   = e.endStr?.slice(0,16) || '';
            form.activo.checked    = e.extendedProps.activo == 1;
    
            mostrarBtns();
            btnQR.onclick = () => window.open(`/eventos/${e.id}/qr`, '_blank');
            btnFirmaManual.onclick = () => window.location.href = `/eventos/${e.id}/firma_manual`;
    
            modal.show();
          }
        });
        calendar.render();
      }
    
      // GUARDAR evento
      form.addEventListener('submit', async e => {
        e.preventDefault();
        const data = new FormData(form);
        const body = Object.fromEntries(data.entries());
        body.activo = form.activo.checked ? '1' : '0';
    
        const method = body.id ? 'PUT' : 'POST';
        const url    = body.id ? `/eventos/${body.id}` : '/eventos';
        const res    = await fetch(url, {
          method,
          headers: { 'Content-Type':'application/json' },
          body: JSON.stringify(body)
        });
    
        if (res.ok) {
          modal.hide();
          location.reload();
        } else {
          alert('Error al guardar el evento');
        }
      });
    
      // ELIMINAR evento
      btnEliminar.addEventListener('click', async () => {
        if (!confirm('¿Deseas eliminar este evento?')) return;
        const id  = form.id.value;
        const res = await fetch(`/eventos/${id}`, { method:'DELETE' });
        if (res.ok) {
          modal.hide();
          location.reload();
        } else {
          alert('Error al eliminar');
        }
      });
    });
    </script>
    