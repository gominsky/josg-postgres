<% title = 'Facturas' %>
<% hero  = false %>

<div id="fac-list-wrap" class="container my-4">
  <style>
    :root{ --accent-100:#ffeed7; --accent-400:#ffb554; --accent-700:#c26c00; --muted:#6c757d; --border:rgba(0,0,0,.08); }
    @media (min-width: 992px){ #fac-list-wrap.container{ max-width: 1320px; } }
    .panel-card{ background:#fff; border:1px solid var(--border); border-radius:18px; padding:16px 18px 18px; }
    .chips { display:flex; gap:.5rem; flex-wrap:wrap; }
    .chip{ background: var(--accent-100); color: var(--accent-700); border:1px solid #ffe0b3; border-radius:999px; padding:.35rem .7rem; font-size:.85rem; cursor:pointer; }
    .table-lite{ width:100%; border-collapse:collapse; margin-top:12px; }
    .table-lite th, .table-lite td{ border:1px solid #e9ecef; padding:8px 10px; vertical-align: middle; }
    .badge{display:inline-block;padding:.18rem .5rem;border-radius:999px;font-size:.78rem;font-weight:700}
    .badge-muted{background:#eef1f4;color:#5b6573}
    .badge-warn{background:#fff2cc;color:#8a6d3b}
    .badge-info{background:#e6f3ff;color:#1c5d99}
    .badge-ok{background:#e5f7e9;color:#2f7a3e}
    .badge-danger{background:#fde2e1;color:#9b1c1c}
    .badge-danger-outline{border:1px solid #e74c3c;color:#e74c3c;background:transparent}
    .num{white-space:nowrap}
    .pager{ display:flex; gap:6px; align-items:center; justify-content:flex-end; margin-top:12px; }
    .pager a, .pager span{ padding:.35rem .6rem; border:1px solid #e0e0e0; border-radius:8px; text-decoration:none; color:#333; }
    .pager .current{ background:#f3f4f6; font-weight:700; }
  </style>

  <div class="panel-card">
    <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;margin-bottom:8px;">
      <h1 class="h1-titulo" style="margin:0;">Facturas</h1>
      <% const enc = encodeURIComponent; %>
      <% const baseQS = `proveedor=${enc(filtros.proveedor||'')}&desde=${enc(filtros.desde||'')}&hasta=${enc(filtros.hasta||'')}&q=${enc(filtros.q||'')}&ordenar=${enc(filtros.ordenar||'')}&estado=${enc(filtros.estado||'')}&venc=${enc(filtros.venc||'')}`; %>
      <div class="d-flex gap-2">
        <a class="btn btn-outline" href="/contabilidad/facturas/export.csv?<%= baseQS %>">⬇️ Exportar CSV</a>
        <a class="btn-main" href="/contabilidad/facturas/nueva">+ Nueva</a>
      </div>
    </div>

    <!-- FILTROS (idénticos a los anteriores; omitidos por brevedad) -->
    <!-- CHIPS -->
    <div class="chips" style="margin-top:8px;">
      <span class="chip" data-range="30d">Últ. 30 días</span>
      <span class="chip" data-range="mes">Mes actual</span>
      <span class="chip" data-range="trim">Trimestre actual</span>
      <span class="chip" data-range="ytd">Año en curso</span>
      <a class="chip" href="/contabilidad/facturas">Quitar filtros</a>
    </div>

    <!-- RESUMEN -->
    <div class="small" style="margin-top:8px; color:var(--muted);">
      <strong><%= resumen.n %></strong> facturas · Base: <strong class="num"><%= Number(resumen.suma_base||0).toFixed(2) %> €</strong> · Total: <strong class="num"><%= Number(resumen.suma_total||0).toFixed(2) %> €</strong>
    </div>

    <!-- LISTA -->
    <% if ((facturas||[]).length === 0) { %>
      <p class="text-muted" style="margin-top:12px;">No hay resultados para esos filtros.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table-lite">
          <thead>
            <tr>
              <th>#</th><th>Proveedor</th><th>Emisión</th><th>Vencimiento</th><th>Base</th><th>IVA</th><th>Total</th><th>Estado</th>
            </tr>
          </thead>
          <tbody>
            <% const HOY = new Date().toISOString().slice(0,10); %>
            <% facturas.forEach(f => { const fechaV=(f.fecha_vencimiento||'').slice(0,10); const est=(f.estado||'').toLowerCase(); const esVencida = fechaV && (!['pagada','anulada'].includes(est)) && (fechaV < HOY); %>
              <tr class="clickable-row" onclick="location.href='/contabilidad/facturas/<%= f.id %>'">
                <td><%= f.numero || f.id %></td>
                <td><%= f.proveedor || '—' %></td>
                <td><%= (f.fecha_emision||'').slice(0,10) %></td>
                <td><%= fechaV %></td>
                <td class="num"><%= Number(f.base||0).toFixed(2) %> €</td>
                <td class="num"><%= Number(f.iva||0).toFixed(2) %> €</td>
                <td class="num"><strong><%= Number(f.total||0).toFixed(2) %> €</strong></td>
                <td>
                  <% if (est==='borrador')  { %><span class="badge badge-muted">Borrador</span><% } %>
                  <% if (est==='pendiente') { %><span class="badge badge-warn">Pendiente</span><% } %>
                  <% if (est==='parcial')   { %><span class="badge badge-info">Parcial</span><% } %>
                  <% if (est==='pagada')    { %><span class="badge badge-ok">Pagada</span><% } %>
                  <% if (est==='anulada')   { %><span class="badge badge-danger">Anulada</span><% } %>
                  <% if (esVencida)         { %> <span class="badge badge-danger-outline">Vencida</span> <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <!-- PAGINACIÓN -->
    <% const p = paginacion||{page:1,per_page:50,total_pages:1}; %>
    <div class="pager">
      <% if (p.page > 1) { %>
        <a href="/contabilidad/facturas?<%= baseQS %>&per_page=<%= p.per_page %>&page=1">« Primero</a>
        <a href="/contabilidad/facturas?<%= baseQS %>&per_page=<%= p.per_page %>&page=<%= p.page-1 %>">‹ Anterior</a>
      <% } else { %>
        <span>« Primero</span><span>‹ Anterior</span>
      <% } %>
      <span class="current">Página <%= p.page %> / <%= p.total_pages %></span>
      <% if (p.page < p.total_pages) { %>
        <a href="/contabilidad/facturas?<%= baseQS %>&per_page=<%= p.per_page %>&page=<%= p.page+1 %>">Siguiente ›</a>
        <a href="/contabilidad/facturas?<%= baseQS %>&per_page=<%= p.per_page %>&page=<%= p.total_pages %>">Última »</a>
      <% } else { %>
        <span>Siguiente ›</span><span>Última »</span>
      <% } %>
    </div>
  </div>
</div>

<script>
  (function(){
    const f = document.querySelector('form#filtrosFacturas') || document.getElementById('filtros');
    const elDesde = f?.elements['desde'];
    const elHasta = f?.elements['hasta'];
    function fmt(d){ return d.toISOString().slice(0,10); }
    function setRange(a,b){ if (elDesde) elDesde.value=fmt(a); if (elHasta) elHasta.value=fmt(b); f.submit(); }
    document.querySelectorAll('.chip[data-range]').forEach(chip=>{
      chip.addEventListener('click', ()=>{
        const now=new Date(); const today=new Date(now.getFullYear(),now.getMonth(),now.getDate());
        if (chip.dataset.range==='30d'){ const s=new Date(today); s.setDate(s.getDate()-29); setRange(s,today); }
        if (chip.dataset.range==='mes'){ const s=new Date(today.getFullYear(),today.getMonth(),1); const e=new Date(today.getFullYear(),today.getMonth()+1,0); setRange(s,e); }
        if (chip.dataset.range==='trim'){ const m=today.getMonth(); const q=Math.floor(m/3); const s=new Date(today.getFullYear(),q*3,1); const e=new Date(today.getFullYear(),q*3+3,0); setRange(s,e); }
        if (chip.dataset.range==='ytd'){ const s=new Date(today.getFullYear(),0,1); setRange(s,today); }
      });
    });
  })();
</script>

