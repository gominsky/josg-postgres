<% title = 'Facturas' %>
<% hero  = false %>

<div id="fac-list-wrap" class="container my-4">
  <style>
    :root{
      --accent-50:#fff6e8; --accent-100:#ffeed7; --accent-200:#ffe0b3; --accent-300:#ffd08a;
      --accent-400:#ffb554; --accent-500:#ff9500; --accent-600:#e07f00; --accent-700:#c26c00;
      --text-main:#212529; --muted:#6c757d; --border:rgba(0,0,0,.08);
      --shadow:0 1px 2px rgba(0,0,0,.04); --shadow-lg:0 6px 18px rgba(0,0,0,.08);
    }
    @media (min-width: 992px){ #fac-list-wrap.container{ max-width: 1320px; } }

    .panel-card{ background:#fff; color:var(--text-main); border:1px solid var(--border);
      border-radius:18px; box-shadow:var(--shadow); padding:16px 18px 18px; }
    .panel-header{ display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:10px; }
    .panel-header .h1-titulo{ margin:0; font-size:clamp(1.4rem, 1.1rem + 1.2vw, 2rem); font-weight:700; }
    .volver-link{ color:var(--accent-700); text-decoration:none; font-weight:600; }
    .volver-link:hover{ text-decoration:underline; }

    .chips { display:flex; gap:.5rem; flex-wrap:wrap; }
    .chip{
      background: var(--accent-100); color: var(--accent-700);
      border: 1px solid var(--accent-200); border-radius: 999px;
      padding: .35rem .7rem; font-size: .85rem; cursor: pointer; user-select:none;
      transition: background .15s ease, border-color .15s ease, color .15s ease, transform .05s ease;
    }
    .chip:hover{ background: var(--accent-200); }
    .chip:active{ transform: scale(.98); }
    .chip.active{ background: var(--accent-400); color:#5b2b00; border-color: var(--accent-500); }

    .table-lite{ width:100%; border-collapse:collapse; margin-top:12px; }
    .table-lite th, .table-lite td{ border:1px solid #e9ecef; padding:8px 10px; vertical-align: middle; }
    .table-lite thead th{ background:#f7f7f7; font-weight:700; }
    .clickable-row{ cursor: pointer; }
    .badge-soft{ display:inline-block; padding:.12rem .45rem; border-radius:999px; font-size:.78rem; font-weight:700; }
    .badge-emit{ background:var(--accent-100); color:var(--accent-700); border:1px solid var(--accent-300); }
    .badge-venc{ background:#fde8ea; color:#9b1c29; border:1px solid #f3b7bf; }

    .toolbar{ display:flex; gap:8px; flex-wrap:wrap; align-items:end; }
    .toolbar .form-label{ font-weight:700; color:var(--text-main); margin-bottom:.35rem; }
    .num{ white-space:nowrap; }
  </style>

  <div class="panel-card">
    <div class="panel-header">
      <h1 class="h1-titulo"><%= title %></h1>
      <div style="display:flex; gap:10px;">
        <a href="/contabilidad" class="volver-link">← Volver</a>
      </div>
    </div>

    <!-- FILTROS -->
    <form method="GET" class="toolbar" id="filtros">
      <div>
        <label class="form-label">Proveedor</label>
        <select name="proveedor" class="form-select form-select-sm" style="min-width:220px;">
          <option value="">Todos</option>
          <% (proveedores||[]).forEach(pr => { %>
            <option value="<%= pr.id %>" <%= (filtros.proveedor==pr.id)?'selected':'' %>><%= pr.nombre %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="form-label">Desde</label>
        <input type="date" name="desde" class="form-control form-control-sm" value="<%= filtros.desde || '' %>">
      </div>
      <div>
        <label class="form-label">Hasta</label>
        <input type="date" name="hasta" class="form-control form-control-sm" value="<%= filtros.hasta || '' %>">
      </div>

      <div style="flex:1 1 260px;">
        <label class="form-label">Buscar</label>
        <input type="text" name="q" class="form-control form-control-sm" value="<%= filtros.q || '' %>" placeholder="Nº, proveedor o concepto…">
      </div>

      <div>
        <label class="form-label">Orden</label>
        <select name="ordenar" class="form-select form-select-sm">
          <option value="fecha_emision_desc" <%= filtros.ordenar==='fecha_emision_desc'?'selected':'' %>>Emisión ↓</option>
          <option value="fecha_emision_asc"  <%= filtros.ordenar==='fecha_emision_asc'?'selected':'' %>>Emisión ↑</option>
          <option value="proveedor_asc"      <%= filtros.ordenar==='proveedor_asc'?'selected':'' %>>Proveedor A→Z</option>
          <option value="proveedor_desc"     <%= filtros.ordenar==='proveedor_desc'?'selected':'' %>>Proveedor Z→A</option>
          <option value="total_desc"         <%= filtros.ordenar==='total_desc'?'selected':'' %>>Total ↑</option>
          <option value="total_asc"          <%= filtros.ordenar==='total_asc'?'selected':'' %>>Total ↓</option>
        </select>
      </div>

      <div>
        <button class="btn-main" type="submit">Filtrar</button>
      </div>
    </form>

    <!-- CHIPS RÁPIDOS -->
    <div class="chips" style="margin-top:8px;">
      <span class="chip" data-range="30d">Últ. 30 días</span>
      <span class="chip" data-range="mes">Mes actual</span>
      <span class="chip" data-range="trim">Trimestre actual</span>
      <span class="chip" data-range="ytd">Año en curso</span>
      <a class="chip" href="/contabilidad/facturas">Quitar filtros</a>
    </div>

    <!-- RESUMEN -->
    <div class="small" style="margin-top:8px; color:var(--muted);">
      <strong><%= resumen.n %></strong> facturas · Base: <strong class="num"><%= Number(resumen.suma_base||0).toFixed(2) %> €</strong> · Total: <strong class="num"><%= Number(resumen.suma_total||0).toFixed(2) %> €</strong>
    </div>

    <!-- LISTA -->
    <% if ((facturas||[]).length === 0) { %>
      <p class="text-muted" style="margin-top:12px;">No hay resultados para esos filtros.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table-lite">
          <thead>
            <tr>
              <th style="width:10%;">#</th>
              <th style="width:26%;">Proveedor</th>
              <th style="width:14%;">Emisión</th>
              <th style="width:14%;">Vencimiento</th>
              <th style="width:12%;">Base</th>
              <th style="width:12%;">IVA</th>
              <th style="width:12%;">Total</th>
              <th style="width:10%;">Estado</th>
            </tr>
          </thead>
          <tbody>
            <% facturas.forEach(f => { %>
              <tr class="clickable-row" onclick="location.href='/contabilidad/facturas/<%= f.id %>'">
                <td><%= f.numero || f.id %></td>
                <td><%= f.proveedor || '—' %></td>
                <td><%= (f.fecha_emision||'').slice(0,10) %></td>
                <td><%= (f.fecha_vencimiento||'').slice(0,10) %></td>
                <td class="num"><%= Number(f.base||0).toFixed(2) %> €</td>
                <td class="num"><%= Number(f.iva||0).toFixed(2) %> €</td>
                <td class="num"><strong><%= Number(f.total||0).toFixed(2) %> €</strong></td>
                <td>
                  <% if (f.estado === 'Vencida') { %>
                    <span class="badge-soft badge-venc">Vencida</span>
                  <% } else { %>
                    <span class="badge-soft badge-emit">Emitida</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<script>
  (function(){
    const f = document.getElementById('filtros');
    const elDesde = f?.elements['desde'];
    const elHasta = f?.elements['hasta'];

    function fmt(d){ return d.toISOString().slice(0,10); }

    function setRange(a,b){
      if (elDesde) elDesde.value = fmt(a);
      if (elHasta) elHasta.value = fmt(b);
      f.submit();
    }

    document.querySelectorAll('.chip[data-range]').forEach(chip=>{
      chip.addEventListener('click', ()=>{
        const now = new Date();
        const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        const kind = chip.dataset.range;

        if (kind === '30d'){
          const start = new Date(today); start.setDate(start.getDate() - 29);
          setRange(start, today);
          return;
        }

        if (kind === 'mes'){
          const start = new Date(today.getFullYear(), today.getMonth(), 1);
          const end   = new Date(today.getFullYear(), today.getMonth()+1, 0);
          setRange(start, end);
          return;
        }

        if (kind === 'trim'){
          const m = today.getMonth();                // 0..11
          const q = Math.floor(m / 3);               // 0..3
          const start = new Date(today.getFullYear(), q*3, 1);
          const end   = new Date(today.getFullYear(), q*3 + 3, 0);
          setRange(start, end);
          return;
        }

        if (kind === 'ytd'){
          const start = new Date(today.getFullYear(), 0, 1);
          setRange(start, today);
          return;
        }
      });
    });
  })();
</script>
