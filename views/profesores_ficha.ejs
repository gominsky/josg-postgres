<% title = `${profesor.nombre} ${profesor.apellidos}` %>
<% hero = false %>

<div class="header-compact">
  <h1 class="h1-titulo"><%= profesor.nombre %> <%= profesor.apellidos %></h1>
  <div class="header-actions">
    <a href="/profesores/<%= profesor.id %>/editar" class="btn-main-blanco">Editar</a>
    <a href="/profesores" class="enlace-final">← Volver</a>
  </div>
</div>

<div class="formulario-alumno contenedor-borde">

  <div class="grupo-campos">
    <h2>Información personal</h2>
    <div class="info-flex">
      <% if (profesor.foto) { %>
        <img src="/uploads/<%= profesor.foto %>" alt="Foto" class="foto-perfil" loading="lazy" width="96" height="96">
      <% } else { %>
        <div class="foto-perfil d-flex align-items-center justify-content-center bg-light text-muted" style="width:96px;height:96px;border-radius:50%;font-size:.8rem">
          Sin foto
        </div>
      <% } %>
      <div class="info-detalles info-grid">
        <div><strong>Email:</strong> <%= profesor.email || '—' %></div>
        <div><strong>Teléfono:</strong> <%= profesor.telefono || '—' %></div>
        <div><strong>Dirección:</strong> <%= profesor.direccion || '—' %></div>
        <div><strong>Fecha de nacimiento:</strong> <%= formatDate(profesor.fecha_nacimiento) %></div>
        <div><strong>Estado:</strong>
          <span class="badge bg-<%= profesor.activo ? 'success' : 'danger' %>">
            <%= profesor.activo ? 'Activo' : 'No activo' %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <% if (instrumentos.length > 0) { %>
    <div class="grupo-campos">
      <h2>Instrumentos</h2>
      <div class="tags-wrap">
        <% instrumentos.forEach(nombre => { %>
          <span class="tag"><%= nombre %></span>
        <% }) %>
      </div>
    </div>
  <% } %>

  <% if (grupos.length > 0) { %>
    <div class="grupo-campos">
      <h2>Grupos</h2>
      <div class="tags-wrap">
        <% grupos.forEach(nombre => { %>
          <span class="tag"><%= nombre %></span>
        <% }) %>
      </div>
    </div>
  <% } %>

</div>
