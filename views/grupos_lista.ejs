<% title = 'Grupos'; hero = false %>

<div class="header-compact">
  <h1 class="h1-titulo">Grupos</h1>
  <a href="/grupos/nuevo" class="btn-main-blanco">+ Añadir grupo</a>
</div>

<% if (!grupos || grupos.length === 0) { %>
  <p class="text-muted mt-3 text-center">No hay grupos registrados.</p>
<% } else { %>
  <div class="dashboard-grid">
    <% grupos.forEach(g => { %>
      <a href="/grupos/editar/<%= g.id %>"
         class="card activo"
         style="background:#7B9E87;text-decoration:none;">
        <div class="alumno-nombre"><%= g.nombre %></div>
        <% if (g.descripcion) { %>
          <div class="alumno-instrumento" style="color:rgba(255,255,255,.85)"><%= g.descripcion %></div>
        <% } %>
      </a>
    <% }) %>
  </div>
<% } %>

<div class="volver-bloque-izquierda">
  <a href="/configuracion" class="enlace-final">← Volver a configuración</a>
</div>
