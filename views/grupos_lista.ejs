<% title = 'Grupos' %>
<% hero = false %>
<div class="header-compact">
  <h1 class="h1-titulo">Grupos de trabajo</h1>
  <a href="/grupos/nuevo" class="btn-main-blanco">+ Añadir grupo</a>
</div>

<% if (grupos.length === 0) { %>
  <p class="enlace-final" style="text-align: center; margin-top: 2rem;">No hay grupos registrados.</p>
<% } else { %>
  <div class="dashboard-grid">
    <% grupos.forEach(i => { %>
      <a href="/grupos/editar/<%= i.id %>" class="card-oro" style="text-decoration: none;">
        <div style="font-weight: 600; font-size: 1rem;"><%= i.nombre %></div>
      </a>
    <% }) %>
  </div>
<% } %>

<div class="volver-bloque-izquierda">
  <a href="/configuracion" class="enlace-final">← Volver a configuración</a>
</div>




