<% title = 'Configuración'; hero = false %>

<div id="cfg-wrap" class="container my-4">
  <style>
    :root{
      --accent-50:#fff6e8; --accent-100:#ffeed7; --accent-200:#ffe0b3; --accent-300:#ffd08a;
      --accent-400:#ffb554; --accent-500:#ff9500; --accent-600:#e07f00; --accent-700:#c26c00;
      --text-main:#212529; --muted:#6c757d; --border:rgba(0,0,0,.08);
      --shadow:0 1px 2px rgba(0,0,0,.04); --shadow-lg:0 6px 18px rgba(0,0,0,.08);
    }
    @media (min-width: 992px){ #cfg-wrap.container{ max-width:1320px; } }

    .panel-card{
      background:#fff; color:var(--text-main);
      border:1px solid var(--border);
      border-radius:18px;
      box-shadow:var(--shadow);
      padding:14px 16px 18px;
    }
    .panel-header{
      display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:10px;
    }
    .panel-header .h1-titulo{
      margin:0; font-size:clamp(1.4rem,1.1rem + 1.2vw,2rem); font-weight:700; color:var(--text-main);
    }
    .volver-link{ color:var(--accent-700); text-decoration:none; font-weight:600; }
    .volver-link:hover{ text-decoration:underline; }

    /* === Rejilla: 1 / 2 / 3 columnas === */
    .action-grid{ display:grid; gap:16px; margin-top:12px; grid-template-columns:1fr; }
    @media (min-width:768px){ .action-grid{ grid-template-columns:repeat(2,1fr); } }
    @media (min-width:1200px){ .action-grid{ grid-template-columns:repeat(3,1fr); } }

    .action-card{
      width:100%; display:flex; align-items:center; gap:14px;
      background:linear-gradient(180deg,#ffffff,#fdfcfa);
      border:1px solid var(--border); border-radius:16px; padding:14px 16px;
      box-shadow:var(--shadow);
      transition:transform .15s ease, box-shadow .15s ease, border-color .15s ease;
      color:inherit; text-decoration:none; min-height:84px;
    }
    .action-card:hover,.action-card:focus{
      transform:translateY(-2px); box-shadow:var(--shadow-lg); border-color:var(--accent-200); text-decoration:none;
    }

    .icon-badge{
      width:48px; height:48px; border-radius:999px; flex-shrink:0;
      display:flex; align-items:center; justify-content:center;
      background:var(--accent-100); border:1px solid var(--accent-200); color:var(--accent-700);
    }
    .action-title{ font-weight:700; margin:0; color:var(--text-main); }
    .action-desc{ margin:.15rem 0 0; color:var(--muted); font-size:.92rem; }
  </style>

  <div class="panel-card">
    <div class="panel-header">
      <h1 class="h1-titulo"><%= title %></h1>
    </div>

    <div class="action-grid">
      <!-- Instrumentos -->
      <a href="/instrumentos" class="action-card" aria-label="Gestionar instrumentos">
        <div class="icon-badge" aria-hidden="true" title="Instrumentos">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
               width="22" height="22" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" role="img">
            <circle cx="7" cy="16" r="2.2" fill="currentColor" stroke="none"/>
            <circle cx="13" cy="13.2" r="2.2" fill="currentColor" stroke="none"/>
            <line x1="9"  y1="14.4" x2="9"  y2="6"/>
            <line x1="15" y1="11.6" x2="15" y2="6"/>
            <path d="M9 6h6v1.8H9z" fill="currentColor" stroke="none"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Instrumentos</p>
          <p class="action-desc">Altas, bajas y familias.</p>
        </div>
      </a>

      <!-- Grupos -->
      <a href="/grupos" class="action-card" aria-label="Gestionar grupos">
        <div class="icon-badge" aria-hidden="true" title="Grupos">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
               width="22" height="22" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" role="img">
            <circle cx="12"  cy="7.5" r="2.8"/>
            <circle cx="6.2" cy="10.2" r="2.2"/>
            <circle cx="17.8" cy="10.2" r="2.2"/>
            <path d="M4 18.5c0-3 5-4.5 8-4.5s8 1.5 8 4.5"/>
            <path d="M2.2 18.5c0-2.2 3-3.4 5-3.4"/>
            <path d="M16.8 15.1c2 .2 5 1.4 5 3.4"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Grupos</p>
          <p class="action-desc">Crear y editar grupos de trabajo.</p>
        </div>
      </a>

      <!-- Usuarios -->
      <a href="/usuarios" class="action-card" aria-label="Gestionar usuarios">
        <div class="icon-badge" aria-hidden="true" title="Usuarios">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
               width="22" height="22" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" role="img">
            <circle cx="12" cy="7.5" r="3"/>
            <path d="M4 19c0-3.3 4.7-5 8-5s8 1.7 8 5"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Usuarios</p>
          <p class="action-desc">Permisos y datos de acceso.</p>
        </div>
      </a>
      <!-- Listado de categorías -->
      <a href="/categorias" class="action-card" aria-label="Listado de categorías de gasto">
        <div class="icon-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
               viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.59 13.41 11 3H4v7l9.59 9.59a2 2 0 0 0 2.82 0l4.18-4.18a2 2 0 0 0 0-2.82z"/>
            <circle cx="6.5" cy="6.5" r="1.5"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Categorías de gasto</p>
          <p class="action-desc">Gestiona las categorías de gasto.</p>
        </div>
      </a>
      <!-- Listado de cuentas-->
      <a href="/cuentas" class="action-card" aria-label="Listado de cuentas">
        <div class="icon-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
              viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 10h18M4 7l8-4 8 4M5 10v9a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-9"/>
            <path d="M9 16h6"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Cuentas contables</p>
          <p class="action-desc">Consulta y gestiona el plan de cuentas contables.</p>
        </div>
      </a>
    </div>
  </div>

      </a>
  <div class="panel-header">
    <a href="/" class="enlace-final">← Volver al inicio</a>
  </div>
</div>
