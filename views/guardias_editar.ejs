<% const isEdicion = Boolean(guardia && guardia.id); %>
<% title = isEdicion ? 'Editar Guardia' : 'Nueva Guardia'; %>
<% hero = false; %>

<h1 class="h1-titulo"><%= title %></h1>

<form id="form-guardia" method="POST" action="<%= isEdicion ? '/guardias/guardar' : '/guardias/crear' %>" class="formulario-alumno" style="border: 2px solid #FF9501; border-radius: 0.75rem; padding: 1rem;">
  <% if (isEdicion) { %>
    <input type="hidden" name="id" value="<%= guardia.id %>">
    <input type="hidden" name="evento_id" value="<%= guardia.evento_id %>">
    <input type="hidden" name="curso" value="<%= guardia.curso %>">
    <input type="hidden" name="desde" value="<%= desde %>">
    <input type="hidden" name="hasta" value="<%= hasta %>">
    <input type="hidden" name="grupo" value="<%= grupo %>">
  <% } %>

  <div class="grupo-campos">
    <h2>Miembros de Guardia</h2>
    <div class="form-grid-2">
      <label>Miembro 1:
        <select name="alumno_id_1" required class="form-centrado-select">
          <option value="">Selecciona un alumno</option>
          <% alumnos.filter(a => a.grupo_id === guardia.grupo_id).forEach(a => { %>
            <option value="<%= a.alumno_id %>" <%= a.alumno_id == guardia.alumno_id_1 ? 'selected' : '' %>>
              <%= a.apellidos %>, <%= a.nombre %>
            </option>
          <% }) %>
        </select>
      </label>

      <label>Miembro 2:
        <select name="alumno_id_2" required class="form-centrado-select">
          <option value="">Selecciona un alumno</option>
          <% alumnos.filter(a => a.grupo_id === guardia.grupo_id).forEach(a => { %>
            <option value="<%= a.alumno_id %>" <%= a.alumno_id == guardia.alumno_id_2 ? 'selected' : '' %>>
              <%= a.apellidos %>, <%= a.nombre %>
            </option>
          <% }) %>
        </select>
      </label>
    </div>
  </div>

  <div class="grupo-campos">
    <h2>Notas</h2>
    <textarea name="notas" rows="4" class="form-control"><%= guardia.notas || '' %></textarea>
  </div>

  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/guardias?<%= desde ? 'desde=' + desde + '&' : '' %><%= hasta ? 'hasta=' + hasta : '' %>" class="enlace-final-naranja">← Volver</a>
    <div class="d-flex gap-2">
      <button type="submit" class="btn-main"><%= isEdicion ? 'Actualizar' : 'Crear' %></button>
      <% if (isEdicion) { %>
        <form method="POST" action="/guardias/eliminar/<%= guardia.id %>?desde=<%= desde %>&hasta=<%= hasta %>" onsubmit="return confirm('¿Eliminar esta guardia?');" class="ms-2" style="display:inline;">
          <button type="submit" class="btn-rojo">Eliminar</button>
        </form>
      <% } %>
    </div>
  </div>
</form>

