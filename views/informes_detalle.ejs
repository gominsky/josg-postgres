<% title = 'Detalle del Informe' %>
<% hero = false %>

<div class="row align-items-start mb-3">
  <!-- Columna izquierda -->
  <div class="col-md-8 offset-md-1">
    <h1 class="h1-titulo mb-2"><%= informe.informe %></h1>
    <ul class="list-unstyled texto-base mb-0">
      <li><strong>Fecha:</strong> <%= new Date(informe.fecha).toLocaleDateString('es-ES') %></li>
      <li><strong>Grupo:</strong> <%= informe.grupo || 'Ninguno' %></li>
      <li><strong>Instrumento:</strong> <%= informe.instrumento || 'Ninguno' %></li>
    </ul>
  </div>
  <!-- Columna derecha -->
  <div class="col-md-3 d-flex justify-content-end align-items-center gap-3"
    <a href="/informes/pdf/<%= informe.id %>" class="card-variacion2"><div style="font-weight: 600; font-size: 1rem;">Exportar PDF</div></a>
    <form method="POST" action="/informes/eliminar/<%= informe.id %>" style="background-color:transparent;" onsubmit="return confirm('¿Eliminar informe completo?')">
      <button type="submit" class="card-eliminar"><div style="font-weight: 600; font-size: 1rem;">Eliminar informe</div></button>
    </form>
  </div>
</div>


<form id="form-guardar" method="POST" action="/informes/detalle/<%= informe.id %>" style="background-color: rgba(12, 233, 93, 1)">
    <input type="hidden" name="resultados" id="resultados-json">

    <% if (!tieneAlumnos) { %>
      <div class="text-center mt-3" style="margin-bottom: 2rem;">
           <button type="button" class="btn btn-dark btn-sm" onclick="addFila()">+ Añadir fila</button>
      </div>
      <% } %>
    <div class="table-responsive">
      <table class="table table-bordered table-sm align-middle">
        <thead class="table-light text-center">
          <tr>
            <% if (tieneAlumnos) { %>
              <th>Alumno</th>
            <% } %>
            <% campos.forEach(campo => { %>
              <th><%= campo.nombre %></th>
            <% }) %>
            <th></th>
          </tr>
        </thead>
        <tbody id="tabla-resultados-body">
          <% filas.forEach((fila, filaIndex) => { %>
            <tr>
              <% if (tieneAlumnos) { %>
                <td><%= fila.apellidos %>, <%= fila.nombre %></td>
              <% } %>
              <% campos.forEach(campo => {
                   const valor = fila.valores[campo.id] || '';
                   const name = `r_${fila.alumno_id !== null ? fila.alumno_id : 'null'}_${fila.fila || filaIndex}_${campo.id}`;
              %>
                <td>
                  <% if (campo.tipo === 'texto') { %>
                    <input type="text" class="form-control form-control-sm" name="<%= name %>" value="<%= valor %>">
                  <% } else if (campo.tipo === 'numero') { %>
                    <input type="number" step="0.01" class="form-control form-control-sm" name="<%= name %>" value="<%= valor %>">
                  <% } else if (campo.tipo === 'booleano') { %>
                    <input type="checkbox" class="form-check-input" name="<%= name %>" <%= valor === '1' ? 'checked' : '' %> >
                  <% } else { %>
                    <input type="text" class="form-control form-control-sm" name="<%= name %>" value="<%= valor %>">
                  <% } %>
                </td>
              <% }) %>
              <td><button type="button" class="btn btn-sm text-danger fw-bold" style="font-size: 1rem;" onclick="this.closest('tr').remove()">X</button></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="text-center mt-3">
        <button type="submit" class="btn btn-dark btn-sm">Guardar cambios</button>
      </div>
  </form>
  <div class="volver-bloque-izquierda mt-4">
    <a href="/informes" class="enlace-final">← Volver</a>
  </div>
</div>
</div>

<script>
  let nextFila = <%= filas.length %>;
  const campos = <%- JSON.stringify(campos) %>;

  function addFila() {
    const tbody = document.getElementById('tabla-resultados-body');
    const fila = document.createElement('tr');
    const filaId = 'null_' + nextFila++;

    let html = '';
    <% if (tieneAlumnos) { %>
      html += `<td>-</td>`;
    <% } %>

    campos.forEach(campo => {
      const name = `r_null_${filaId}_${campo.id}`;
      if (campo.tipo === 'texto') {
        html += `<td><input type="text" class="form-control form-control-sm" name="${name}"></td>`;
      } else if (campo.tipo === 'numero') {
        html += `<td><input type="number" step="0.01" class="form-control form-control-sm" name="${name}"></td>`;
      } else if (campo.tipo === 'booleano') {
        html += `<td><input type="checkbox" class="form-check-input" name="${name}"></td>`;
      } else {
        html += `<td><input type="text" class="form-control form-control-sm" name="${name}"></td>`;
      }
    });
    html += `<td><button type="button" class="btn btn-sm text-danger fw-bold" style="font-size: 1rem;" onclick="this.closest('tr').remove()">×</button></td>`;
    fila.innerHTML = html;
    tbody.appendChild(fila);
  }

  document.getElementById('form-guardar').addEventListener('submit', function (e) {
    const resultados = [];
    const inputs = document.querySelectorAll('#tabla-resultados-body input');

    inputs.forEach(el => {
      const match = el.name.match(/^r_(.+?)_(\d+)_([\d]+)$/);
      if (!match) return;
      const alumno_id = match[1] !== 'null' ? parseInt(match[1]) : null;
      const fila = parseInt(match[2]);
      const campo_id = parseInt(match[3]);
      const valor = el.type === 'checkbox' ? (el.checked ? '1' : '0') : el.value;
      resultados.push({ alumno_id, fila, campo_id, valor });
    });

    document.getElementById('resultados-json').value = JSON.stringify(resultados);
  });
</script>
