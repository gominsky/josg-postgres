    <script>
(() => {
  const INFORME_ID = <%= Number(informe.id) %>;

  // Autoaltura con límite de líneas (data-max-rows)
  function autoResizeTitulo() {
    const ta = document.getElementById('titulo-informe');
    if (!ta) return;
    ta.style.height = 'auto';
    const lh = parseFloat(getComputedStyle(ta).lineHeight || '24'); // px
    const maxRows = parseInt(ta.dataset.maxRows || '3', 10);
    const maxH = lh * maxRows;
    const target = Math.min(ta.scrollHeight, maxH);
    ta.style.height = target + 'px';
  }

  // Guarda por fetch (POST) y muestra estado
  let saving = null;
  async function guardarTitulo() {
    const el = document.getElementById('titulo-informe');
    const st = document.getElementById('estado-titulo');
    if (!el) return;

    const titulo = (el.value || '').trim();
    if (!titulo) { st.textContent = 'Título vacío'; return; }

    // evita múltiples envíos seguidos
    if (saving) clearTimeout(saving);
    st.textContent = 'Guardando…';

    try {
      const res = await fetch(`/informes/${INFORME_ID}/titulo`, {
        method: 'POST',
        headers: { 'Content-Type':'application/json' },
        body: JSON.stringify({ titulo })
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      st.textContent = '✓ guardado';
    } catch (e) {
      console.error('Error guardando título:', e);
      st.textContent = '⚠️ error al guardar';
    }

    // limpia el mensaje tras un rato
    saving = setTimeout(() => { st.textContent = ''; }, 2500);
  }

  // Exponer globalmente para los atributos oninput/onblur
  window.autoResizeTitulo = autoResizeTitulo;
  window.guardarTitulo    = guardarTitulo;

  // Inicializa tamaño al cargar
  document.addEventListener('DOMContentLoaded', autoResizeTitulo);
})();
</script>
<script>
(() => {
  const id = <%= Number(informe.id) %>;
  const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';

  async function createSlug(){
    const res = await fetch(`/api/informes/${id}/slug`, {
      method:'POST',
      headers:{ 'Content-Type':'application/json', 'CSRF-Token': csrf }
    });
    const data = await res.json();
    const wrap = document.getElementById('share-wrap');
    wrap.innerHTML = `
      <input id="publicUrl" class="form-control form-control-sm" style="width:360px;" readonly
             value="/i/${data.slug}.pdf" />
      <button type="button" id="btnCopy" class="btn-ghost-sm">Copiar</button>
      <button type="button" id="btnRevoke" class="btn-outline-danger-neutral">Revocar</button>`;
    hook();
  }
  async function revokeSlug(){
    await fetch(`/api/informes/${id}/slug`, {
      method:'DELETE',
      headers:{ 'Content-Type':'application/json', 'CSRF-Token': csrf }
    });
    const wrap = document.getElementById('share-wrap');
    wrap.innerHTML = `<button type="button" id="btnShare" class="btn-ghost-sm">
      Generar enlace público</button>`;
    hook();
  }
  function copyUrl(){
    const input = document.getElementById('publicUrl');
    const u = input.value.startsWith('http') ? input.value : (location.origin + input.value);
    navigator.clipboard.writeText(u);
  }
  function hook(){
    document.getElementById('btnShare')?.addEventListener('click', createSlug);
    document.getElementById('btnCopy') ?.addEventListener('click', copyUrl);
    document.getElementById('btnRevoke')?.addEventListener('click', revokeSlug);
  }
  document.addEventListener('DOMContentLoaded', hook);
})();
</script>
<script>
  document.getElementById('btnVerPDF').addEventListener('click', (e) => {
    e.preventDefault();
    const tabla = document.getElementById('tabla-principal');
    const showGroup      = !tabla?.classList?.contains('hide-grupo');
    const showInstrument = !tabla?.classList?.contains('hide-inst');
    const url = `/pdf/informe/<%= informe.id %>?showGroup=${showGroup?1:0}&showInstrument=${showInstrument?1:0}`;
    window.open(url, '_blank', 'noopener');
  });
</script>

  