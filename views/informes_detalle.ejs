<% title = 'Detalle del Informe' %>
<% hero  = false %>
<%
  // Determina si es informe estático de porcentaje
  const isHoras       = informe.informe.startsWith('Porcentaje de horas de asistencia');
  // Si es porcentaje, omitimos el primer campo (Alumno), si no, mostramos todos
  const camposMostrar = isHoras ? campos.slice(1) : campos;
%>
<div class="row align-items-start mb-3">
  <div class="col-md-8 offset-md-1">
    <h1 class="h1-titulo mb-2"><%= informe.informe %></h1>
    <ul class="list-unstyled texto-base mb-0">
      <li><strong>Fecha:</strong> <%= new Date(informe.fecha).toLocaleDateString('es-ES') %></li>
      <% if (showGroup) { %>
        <li><strong>Grupo:</strong> <%= informe.informeGrupo %></li>
      <% } %>
      <% if (showInstrument) { %>
        <li><strong>Instrumento:</strong> <%= informe.informeInstrumento %></li>
      <% } %>
    </ul>
  </div>
  <div class="col-md-3 d-flex justify-content-end align-items-center gap-3">
    <form method="POST" action="/informes/eliminar/<%= informe.id %>" onsubmit="return confirm('¿Eliminar informe completo?')" style="background-color: transparent;">
      <button type="submit" class="btn-main"><div>Eliminar informe</div></button>
    </form>
  </div>
</div>

<form id="form-guardar" method="POST" action="/informes/detalle/<%= informe.id %>" class="formulario-centrado" style="background-color: transparent;">
  <input type="hidden" name="resultados" id="resultados-json">

  <% if (!tieneAlumnos) { %>
    <div class="text-center mt-3 mb-4">
      <button type="button" class="btn-main" onclick="addCampo()">+ Añadir campo</button>
    </div>
  <% } %>

  <!-- Botones para ocultar/mostrar columnas -->
  <div class="text-end mb-2">
    <button id="toggleGrupo" type="button" class="btn btn-sm btn-outline-secondary me-2">
      Ocultar/Mostrar Grupo
    </button>
    <button id="toggleInst" type="button" class="btn btn-sm btn-outline-secondary">
      Ocultar/Mostrar Instrumento
    </button>
  </div>

  <div class="table-responsive">
    <table class="tabla-estilizada table-sm align-middle text-center">
      <thead class="table-light">
        <tr>
          <th class="sortable" style="width: 200px; min-width: 200px; text-align: left;">Alumno</th>
          <th class="col-grupo sortable">Grupo</th>
          <th class="col-inst sortable">Instrumento</th>
          <% camposMostrar.forEach(campo => { %>
            <th class="sortable"><%= campo.nombre %></th>
          <% }) %>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="tabla-resultados-body">
        <% filas.forEach((fila, filaIndex) => { %>
          <tr>
            <td class="text-start" style="width: 200px; min-width: 200px;"><%= fila.apellidos %>, <%= fila.nombre %></td>
            <td class="col-grupo"><%= fila.grupos      || '—' %></td>
            <td class="col-inst"><%= fila.instrumentos || '—' %></td>
            <% camposMostrar.forEach(campo => {
                 const valor = fila.valores[campo.id] || '';
                 const name  = `r_${fila.alumno_id !== null ? fila.alumno_id : 'null'}_${fila.fila ?? filaIndex}_${campo.id}`;
            %>
              <td>
                <% if (campo.tipo === 'texto') { %>
                  <input type="text" class="form-control form-control-sm" name="<%= name %>" value="<%= valor %>">
                <% } else if (campo.tipo === 'numero') { %>
                  <input type="number" step="0.01" class="form-control form-control-sm" name="<%= name %>" value="<%= valor %>">
                <% } else if (campo.tipo === 'booleano') { %>
                  <input type="checkbox" class="form-check-input" name="<%= name %>" <%= valor === '1' ? 'checked' : '' %>>
                <% } else { %>
                  <input type="text" class="form-control form-control-sm" name="<%= name %>" value="<%= valor %>">
                <% } %>
              </td>
            <% }) %>
            <td>
              <button type="button" class="btn btn-sm text-danger fw-bold" onclick="this.closest('tr').remove()">×</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="text-center mt-3 mb-4">
    <!-- Botón Guardar Cambios -->
    <button type="submit" class="btn btn-dark btn-sm me-2">
      Guardar cambios
    </button>


<div id="pdf-content" style="display:none; background: white; padding: 2rem; color: black; font-size: 12px;">
  <!-- Header con logo y título -->
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <div style="display: flex; align-items: center;">
      <img src="/imagenes/logoJOSG.png" alt="Logo JOSG" style="height: 80px; margin-right: 20px;">
      <div>
        <h1 style="margin: 0; font-size: 1.4rem;"><strong>Asociación Joven Orquesta de Granada</strong></h1>
        <p style="margin: 0; font-size: 10px;">www.josg.org – info@josg.org</p>
      </div>
    </div>
  </div>
  <!-- Título principal -->
  <h2 style="text-align: center; margin-top: 1rem; font-size: 1.1rem;"><strong><%= informe.informe %></strong></h2>

  <!-- Subtítulos informativos -->
  <p style="font-size: 10px; margin: 0.2rem 0;"><strong>Fecha del informe:</strong> <%= new Date(informe.fecha).toLocaleDateString('es-ES') %></p>
  <% if (showGroup) { %>
    <p class="pdf-grupo" style="font-size: 10px; margin: 0.2rem 0;"><strong>Grupo:</strong> <%= informe.informeGrupo %></p>
  <% } %>
  <% if (showInstrument) { %>
    <p class="pdf-inst" style="font-size: 10px; margin: 0.2rem 0;"><strong>Instrumento:</strong> <%= informe.informeInstrumento %></p>
  <% } %>

  <!-- Tabla -->
    <div style="height: 40px;"></div>
  <table style="width: 100%; border-collapse: collapse; margin-top: 1rem; font-size: 11px;">
    <thead>
      <tr style="background-color: #f0f0f0;">
        <th style="border: 1px solid #ccc; padding: 6px;">Alumno</th>
        <% if (showGroup) { %><th class="pdf-grupo" style="border: 1px solid #ccc; padding: 6px;">Grupo</th><% } %>
        <% if (showInstrument) { %><th class="pdf-inst" style="border: 1px solid #ccc; padding: 6px;">Instrumento</th><% } %>
        <% camposMostrar.forEach(campo => { %>
          <th style="border: 1px solid #ccc; padding: 6px;"><%= campo.nombre %></th>
        <% }) %>
      </tr>
    </thead>
    <tbody>
      <% filas.forEach(fila => { %>
        <tr>
          <td style="border: 1px solid #ccc; padding: 6px;"><%= fila.apellidos %>, <%= fila.nombre %></td>
          <% if (showGroup) { %><td class="pdf-grupo" style="border: 1px solid #ccc; padding: 6px;"><%= fila.grupos || '—' %></td><% } %>
          <% if (showInstrument) { %><td class="pdf-inst" style="border: 1px solid #ccc; padding: 6px;"><%= fila.instrumentos || '—' %></td><% } %>
          <% camposMostrar.forEach(campo => { %>
            <td style="border: 1px solid #ccc; padding: 6px;"><%= fila.valores[campo.id] || '' %></td>
          <% }) %>
        </tr>
      <% }) %>
    </tbody>
  </table>
<p style="text-align: center; font-size: 10px; margin-top: 30px;">
  Granada, <%= new Date().toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' }) %>
</p>
  <!-- Footer -->
  <hr style="margin-top: 20px;">
   <div style="height: 400px;"></div> <!-- espacio antes del footer -->
  
  <div style="position: relative; bottom: 0; margin-top: 130px; font-size: 10px; text-align: right; color: #666;">
    Asociación Joven Orquesta de Granada · CIF: G-18651067<br>
    C/ Andrés Segovia 60, 18007 Granada · Tfno: 682 445 971<br>
    Sede de ensayos: Teatro Maestro Francisco Alonso, C/ Ribera del Beiro 34, 18012 Granada
  </div>
</div>
    <!-- Botón Exportar PDF -->
    <button type="button" id="btnPDF"class="btn btn-dark btn-sm">Exportar PDF</button>
  </div>

</form>

<div class="volver-bloque-izquierda mb-4">
  <a href="/informes" class="enlace-final">← Volver</a>
</div>
</div>
<script>
  document.querySelectorAll('.tabla-estilizada th.sortable').forEach((th, idx) => {
    let asc = true;
    th.style.cursor = 'pointer';
    th.addEventListener('click', () => {
      const table = th.closest('table');
      const tbody = table.querySelector('tbody');
      const rows  = Array.from(tbody.querySelectorAll('tr'));
      rows.sort((a, b) => {
        const cellA = a.children[idx].dataset.value ?? a.children[idx].textContent.trim();
        const cellB = b.children[idx].dataset.value ?? b.children[idx].textContent.trim();
        const numA  = parseFloat(cellA);
        const numB  = parseFloat(cellB);
        let res;
        if (!isNaN(numA) && !isNaN(numB)) {
          res = numA - numB;
        } else {
          res = String(cellA).localeCompare(cellB);
        }
        return asc ? res : -res;
      });
      rows.forEach(r => tbody.appendChild(r));
      asc = !asc;
    });
  });
</script>

<script>
  // Inyectamos los flags de visibilidad desde el servidor
  const showGroup      = <%= showGroup ? 'true' : 'false' %>;
  const showInstrument = <%= showInstrument ? 'true' : 'false' %>;

  let nextFila = <%= filas.length %>;
  const campos       = <%- JSON.stringify(campos) %>;
  const camposMostrar= <%- JSON.stringify(camposMostrar) %>;

  function addCampo() {
    const tbody = document.getElementById('tabla-resultados-body');
    const fila  = document.createElement('tr');
    const id    = nextFila++;
    let html    = `<td class="text-start">-</td>`;
    if (showGroup)      html += `<td class="col-grupo">—</td>`;
    if (showInstrument) html += `<td class="col-inst">—</td>`;
    camposMostrar.forEach(campo => {
      const name = `r_null_${id}_${campo.id}`;
      if (campo.tipo === 'texto')    html += `<td><input type="text" class="form-control form-control-sm" name="${name}"></td>`;
      else if (campo.tipo === 'numero') html += `<td><input type="number" step="0.01" class="form-control form-control-sm" name="${name}"></td>`;
      else if (campo.tipo === 'booleano') html += `<td><input type="checkbox" class="form-check-input" name="${name}"></td>`;
      else html += `<td><input type="text" class="form-control form-control-sm" name="${name}"></td>`;
    });
    html += `<td><button type="button" class="btn btn-sm text-danger fw-bold" onclick="this.closest('tr').remove()">×</button></td>`;
    fila.innerHTML = html;
    tbody.appendChild(fila);
  }

  // Recopila los valores antes de enviar
  document.getElementById('form-guardar').addEventListener('submit', function() {
    const resultados = [];
    document.querySelectorAll('#tabla-resultados-body input').forEach(el => {
      const m = el.name.match(/^r_(.+?)_(.+?)_(\d+)$/);
      if (!m) return;
      const alumno_id = m[1] === 'null' ? null : parseInt(m[1], 10);
      const filaIdx   = isNaN(m[2]) ? null : parseInt(m[2], 10);
      const campo_id  = parseInt(m[3], 10);
      const valor     = el.type === 'checkbox' ? (el.checked ? '1' : '0') : el.value;
      resultados.push({ alumno_id, fila: filaIdx, campo_id, valor });
    });
    document.getElementById('resultados-json').value = JSON.stringify(resultados);
  });

  // Toggle de columnas de Grupo e Instrumento
  function toggleCol(selector) {
    document.querySelectorAll(selector).forEach(el => {
      el.style.display = (el.style.display === 'none' ? '' : 'none');
    });
  }

  document.getElementById('toggleGrupo').addEventListener('click', () => {
    toggleCol('.col-grupo');
  });
  document.getElementById('toggleInst').addEventListener('click', () => {
    toggleCol('.col-inst');
  });
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('btnPDF');
    const pdfContent = document.getElementById('pdf-content');

    if (!btn || !pdfContent) return;

    btn.addEventListener('click', () => {
      // Clonar el contenido del PDF
      const clone = pdfContent.cloneNode(true);
      clone.style.display = 'block';

      // Ocultar columnas si no están visibles en pantalla
      const hideGroup = document.querySelector('.col-grupo')?.offsetParent === null;
      const hideInst  = document.querySelector('.col-inst')?.offsetParent === null;

      if (hideGroup) {
        clone.querySelectorAll('.pdf-grupo').forEach(el => el.remove());
      }
      if (hideInst) {
        clone.querySelectorAll('.pdf-inst').forEach(el => el.remove());
      }

      // Fecha actual (como pie de página)
      const fecha = new Date().toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' });
      const footer = document.createElement('div');
      footer.style.cssText = "text-align:center; margin-top:40px; font-size:10px; color:#333;";
      
      clone.appendChild(footer);

      // Opciones de exportación
      const opt = {
        margin: [0.6, 0.5],
        filename: `informe_<%= informe.id %>.pdf`,
        image: { type: 'jpeg', quality: 1 },
        html2canvas: { scale: 3, useCORS: true },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
      };

      html2pdf().set(opt).from(clone).save();
    });
  });
</script>