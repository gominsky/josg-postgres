<% title = 'Detalle del Informe' %>
<% hero  = false %>

<%
  // Informe "Porcentaje de horas de asistencia" omite columna Alumno
  const isHoras       = informe.informe.startsWith('Porcentaje de horas de asistencia');
  const camposMostrar = isHoras ? campos.slice(1) : campos;
%>

<div class="row align-items-start mb-3">
  <div class="col-md-8 offset-md-1">
    <h1 class="h1-titulo mb-2"><%= informe.informe %></h1>
    <ul class="list-unstyled texto-base mb-0">
      <li><strong>Fecha:</strong> <%= new Date(informe.fecha).toLocaleDateString('es-ES') %></li>
      <% if (showGroup) { %><li><strong>Grupo:</strong> <%= informe.informeGrupo %></li><% } %>
      <% if (showInstrument) { %><li><strong>Instrumento:</strong> <%= informe.informeInstrumento %></li><% } %>
    </ul>
  </div>
  <div class="col-md-3 d-flex justify-content-end align-items-center gap-3">
    <form method="POST" action="/informes/eliminar/<%= informe.id %>" onsubmit="return confirm('¿Eliminar informe completo?')" style="background-color: transparent;">
      <button type="submit" class="btn-main"><div>Eliminar informe</div></button>
    </form>
  </div>
</div>

<form id="form-guardar" method="POST" action="/informes/detalle/<%= informe.id %>" class="formulario-centrado" style="background-color: transparent;">
  <input type="hidden" name="resultados" id="resultados-json">

  <% if (tieneAlumnos) { %>
  <div class="text-end mb-2">
    <button id="toggleGrupo" type="button" class="btn btn-sm btn-outline-secondary me-2">Ocultar/Mostrar Grupo</button>
    <button id="toggleInst"  type="button" class="btn btn-sm btn-outline-secondary">Ocultar/Mostrar Instrumento</button>
  </div>
  <% } %>

  <div class="table-responsive">
    <table class="tabla-estilizada table-sm align-middle text-center">
      <thead class="table-light">
        <tr>
          <% if (tieneAlumnos) { %>
            <th class="sortable" style="width:200px;min-width:200px;text-align:left;">Alumno</th>
            <th class="col-grupo sortable">Grupo</th>
            <th class="col-inst  sortable">Instrumento</th>
          <% } %>
          <% camposMostrar.forEach(campo => { %>
            <th class="sortable"><%= campo.nombre %></th>
          <% }) %>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody id="tabla-resultados-body">
        <% filas.forEach((fila, filaIndex) => { %>
          <tr>
            <% if (tieneAlumnos) { %>
              <td class="text-start" style="width:200px;min-width:200px;"><%= fila.apellidos %>, <%= fila.nombre %></td>
              <td class="col-grupo"><%= fila.grupos      || '—' %></td>
              <td class="col-inst"><%= fila.instrumentos || '—' %></td>
            <% } %>
            <% camposMostrar.forEach(campo => {
                 const valor = fila.valores[campo.id] || '';
                 const name  = `r_${fila.alumno_id !== null ? fila.alumno_id : 'null'}_${fila.fila ?? filaIndex}_${campo.id}`;
            %>
              <td>
                <% if (campo.tipo === 'texto') { %>
                  <input type="text"   class="form-control form-control-sm" name="<%= name %>" value="<%= valor %>">
                <% } else if (campo.tipo === 'numero') { %>
                  <input type="number" step="0.01" class="form-control form-control-sm" name="<%= name %>" value="<%= valor %>">
                <% } else if (campo.tipo === 'booleano') { %>
                  <input type="checkbox" class="form-check-input" name="<%= name %>" <%= valor === '1' ? 'checked' : '' %>>
                <% } else { %>
                  <input type="text"   class="form-control form-control-sm" name="<%= name %>" value="<%= valor %>">
                <% } %>
              </td>
            <% }) %>
            <td>
              <button type="button" class="btn btn-sm text-danger fw-bold" onclick="this.closest('tr').remove()">×</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="text-center mt-3 mb-4">
    <% if (!tieneAlumnos) { %>
      <button type="button" class="btn-main" onclick="addCampo()">+ Añadir registro</button>
    <% } %>
    <button type="submit" class="btn btn-dark btn-sm me-2">Guardar cambios</button>
    <button type="button" id="btnPDF" class="btn btn-dark btn-sm">Exportar PDF</button>
  </div>

  <!-- Contenido base para el PDF (oculto en pantalla; se usa para exportar) -->
  <div id="pdf-content" style="display:none; background:white; color:black; font-size:12px;">
    <!-- Título/subtítulos -->
    <h2 style="text-align:center;margin:8px 0 0;font-size:1.05rem;"><strong><%= informe.informe %></strong></h2>
    <p style="font-size:10px;margin:16px 0;"><strong>Fecha del informe:</strong> <%= new Date(informe.fecha).toLocaleDateString('es-ES') %></p>
    <% if (showGroup) { %><p class="pdf-grupo" style="font-size:10px;margin:4px 0;"><strong>Grupo:</strong> <%= informe.informeGrupo %></p><% } %>
    <% if (showInstrument) { %><p class="pdf-inst"  style="font-size:10px;margin:4px 0;"><strong>Instrumento:</strong> <%= informe.informeInstrumento %></p><% } %>

    <!-- Tabla (Grupo/Instrumento SIEMPRE presentes en el HTML del PDF;
         luego el script los quitará si en pantalla están ocultos) -->
    <table style="width:100%;border-collapse:collapse;margin-top:12px;font-size:11px;">
      <thead>
        <tr style="background-color:#f0f0f0;">
          <% if (tieneAlumnos) { %><th style="border:1px solid #ccc;padding:6px;width:180mm;min-width:180mm;">Alumno</th><% } %>
          <th class="pdf-grupo" style="border:1px solid #ccc;padding:6px;">Grupo</th>
          <th class="pdf-inst"  style="border:1px solid #ccc;padding:6px;">Instrumento</th>
          <% camposMostrar.forEach(campo => { %>
            <th style="border:1px solid #ccc;padding:6px;"><%= campo.nombre %></th>
          <% }) %>
        </tr>
      </thead>
      <tbody>
        <% filas.forEach(fila => { %>
          <tr>
            <% if (tieneAlumnos) { %><td style="border:1px solid #ccc;padding:6px;width:180mm;min-width:180mm;"><%= fila.apellidos %>, <%= fila.nombre %></td><% } %>
            <td class="pdf-grupo" style="border:1px solid #ccc;padding:6px;"><%= fila.grupos || '—' %></td>
            <td class="pdf-inst"  style="border:1px solid #ccc;padding:6px;"><%= fila.instrumentos || '—' %></td>
            <% camposMostrar.forEach(campo => { %>
              <td style="border:1px solid #ccc;padding:6px;"><%= fila.valores[campo.id] || '' %></td>
            <% }) %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</form>

<div class="volver-bloque-izquierda mb-4">
  <a href="/informes" class="enlace-final">← Volver</a>
</div>

<script>
  // Ordenación de columnas en pantalla
  document.querySelectorAll('.tabla-estilizada th.sortable').forEach((th, idx) => {
    let asc = true;
    th.style.cursor = 'pointer';
    th.addEventListener('click', () => {
      const table = th.closest('table');
      const tbody = table.querySelector('tbody');
      const rows  = Array.from(tbody.querySelectorAll('tr'));
      rows.sort((a, b) => {
        const cellA = a.children[idx].dataset.value ?? a.children[idx].textContent.trim();
        const cellB = b.children[idx].dataset.value ?? b.children[idx].textContent.trim();
        const numA  = parseFloat(cellA);
        const numB  = parseFloat(cellB);
        let res;
        if (!isNaN(numA) && !isNaN(numB)) res = numA - numB;
        else res = String(cellA).localeCompare(cellB);
        return asc ? res : -res;
      });
      rows.forEach(r => tbody.appendChild(r));
      asc = !asc;
    });
  });

  // Flags de visibilidad desde servidor
  const showGroup      = <%= showGroup ? 'true' : 'false' %>;
  const showInstrument = <%= showInstrument ? 'true' : 'false' %>;

  let nextFila = <%= filas.length %>;
  const campos        = <%- JSON.stringify(campos) %>;
  const camposMostrar = <%- JSON.stringify(camposMostrar) %>;

  function addCampo() {
    const tbody = document.getElementById('tabla-resultados-body');
    const fila  = document.createElement('tr');
    const id    = nextFila++;
    let html    = `<td class="text-start">-</td>`;
    if (showGroup)      html += `<td class="col-grupo">—</td>`;
    if (showInstrument) html += `<td class="col-inst">—</td>`;
    camposMostrar.forEach(campo => {
      const name = `r_null_${id}_${campo.id}`;
      if (campo.tipo === 'texto')         html += `<td><input type="text" class="form-control form-control-sm" name="\${name}"></td>`;
      else if (campo.tipo === 'numero')   html += `<td><input type="number" step="0.01" class="form-control form-control-sm" name="\${name}"></td>`;
      else if (campo.tipo === 'booleano') html += `<td><input type="checkbox" class="form-check-input" name="\${name}"></td>`;
      else                                html += `<td><input type="text" class="form-control form-control-sm" name="\${name}"></td>`;
    });
    html += `<td><button type="button" class="btn btn-sm text-danger fw-bold" onclick="this.closest('tr').remove()">X</button></td>`;
    fila.innerHTML = html;
    tbody.appendChild(fila);
  }

  // Recopila valores antes de enviar
  document.getElementById('form-guardar').addEventListener('submit', function() {
    const resultados = [];
    document.querySelectorAll('#tabla-resultados-body input').forEach(el => {
      const m = el.name.match(/^r_(.+?)_(.+?)_(\d+)$/);
      if (!m) return;
      const alumno_id = m[1] === 'null' ? null : parseInt(m[1], 10);
      const filaIdx   = isNaN(m[2]) ? null : parseInt(m[2], 10);
      const campo_id  = parseInt(m[3], 10);
      const valor     = el.type === 'checkbox' ? (el.checked ? '1' : '0') : el.value;
      resultados.push({ alumno_id, fila: filaIdx, campo_id, valor });
    });
    document.getElementById('resultados-json').value = JSON.stringify(resultados);
  });

  // Toggle columnas (pantalla)
  function toggleCol(selector) {
    document.querySelectorAll(selector).forEach(el => {
      el.style.display = (el.style.display === 'none' ? '' : 'none');
    });
  }
  const tg = document.getElementById('toggleGrupo');
  const ti = document.getElementById('toggleInst');
  if (tg) tg.addEventListener('click', () => toggleCol('.col-grupo'));
  if (ti) ti.addEventListener('click', () => toggleCol('.col-inst'));
</script>
<!-- jsPDF + AutoTable -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const btn   = document.getElementById('btnPDF');
  const srcEl = document.getElementById('pdf-content');
  if (!btn || !srcEl) return;

  btn.type = 'button';
  btn.addEventListener('click', async () => {
    const { jsPDF } = window.jspdf;

    // 1) Clona el contenido base (no tocamos la vista)
    const clone = srcEl.cloneNode(true);
    clone.style.display = 'block';

    // Quita wrappers que rompen medición/autotable
    clone.querySelectorAll('.table-responsive').forEach(w => {
      const t = w.querySelector('table');
      if (t) w.replaceWith(t);
    });

    // 2) Respeta visibilidad (como en pantalla)
    const isVisible = (selector) => {
      const els = [...document.querySelectorAll(selector)];
      return els.some(el => {
        const cs = getComputedStyle(el);
        return el.offsetParent !== null && cs.display !== 'none' && cs.visibility !== 'hidden';
      });
    };
    const showGroup = isVisible('.col-grupo');
    const showInst  = isVisible('.col-inst');
    if (!showGroup) clone.querySelectorAll('.pdf-grupo').forEach(el => el.remove());
    if (!showInst)  clone.querySelectorAll('.pdf-inst') .forEach(el => el.remove());

    // 3) Mantén el mismo ORDEN que en pantalla
    const screenBody = document.querySelector('#tabla-resultados-body');
    if (screenBody) {
      const firma = (tr, ths) => {
        const cells = [...tr.children].map(td => td.textContent.trim());
        const idxA = ths.findIndex(th => /\bAlumno\b/i.test(th.textContent));
        const idxG = ths.findIndex(th => /\bGrupo\b/i.test(th.textContent));
        const idxI = ths.findIndex(th => /\bInstrumento\b/i.test(th.textContent));
        const pick = [];
        if (idxA >= 0 && cells[idxA]) pick.push(cells[idxA]);
        if (idxG >= 0 && cells[idxG]) pick.push(cells[idxG]);
        if (idxI >= 0 && cells[idxI]) pick.push(cells[idxI]);
        return pick.length ? pick.join('|') : cells.join('|');
      };
      const thsScreen = [...document.querySelectorAll('.tabla-estilizada thead th')];
      const orderKeys = [...screenBody.querySelectorAll('tr')].map(tr => firma(tr, thsScreen));

      const thsClone  = [...clone.querySelectorAll('table thead th')];
      const bodyClone = clone.querySelector('tbody');
      if (bodyClone) {
        const rows   = [...bodyClone.querySelectorAll('tr')];
        const withK  = rows.map(tr => ({ tr, key: firma(tr, thsClone) }));
        const posMap = new Map(orderKeys.map((k,i)=>[k,i]));
        withK.sort((a,b) => (posMap.get(a.key) ?? 1e9) - (posMap.get(b.key) ?? 1e9));
        withK.forEach(({tr}) => bodyClone.appendChild(tr));
      }
    }

    // 4) Mete el clon para medir
    document.body.appendChild(clone);
    const tableEl = clone.querySelector('table');
    if (!tableEl) { alert('No se encontró la tabla en #pdf-content'); clone.remove(); return; }

    // 5) Mide anchos del THEAD para fijarlos en todas las páginas
    const headRow = tableEl.querySelector('thead tr');
    const headCells = headRow ? [...headRow.children] : [];
    const cellWidthsPx = headCells.map(th => th.getBoundingClientRect().width || 100);
    const totalPx = cellWidthsPx.reduce((a,b)=>a+b,0) || 1;

    // 6) Crea PDF y define márgenes/espacios
    const pdf = new jsPDF({ unit: 'mm', format: 'a4', orientation: 'portrait' });
    const wmm = pdf.internal.pageSize.getWidth();
    const hmm = pdf.internal.pageSize.getHeight();

    const LEFT_MM   = 20;
    const RIGHT_MM  = 20;
    const FOOTER_MM = 20;

    // Header de página (logo/títulos) — reserva arriba
    const PAGE_HEADER_MM = 32;      // aire superior para header
    const START_Y = PAGE_HEADER_MM + 2; // tabla arranca justo debajo del header

    // Logo opcional
    async function loadLogo(){
      return new Promise(res=>{
        const img=new Image();
        img.crossOrigin='anonymous'; img.referrerPolicy='no-referrer';
        img.onload=()=>{
          try{
            const c=document.createElement('canvas'); c.width=img.naturalWidth; c.height=img.naturalHeight;
            c.getContext('2d').drawImage(img,0,0);
            res({ dataURL:c.toDataURL('image/png'), w:img.naturalWidth, h:img.naturalHeight });
          }catch{ res(null); }
        };
        img.onerror=()=>res(null);
        img.src='/imagenes/logoJOSG.png';
      });
    }
    const logoInfo = await loadLogo();

    // Header/Footer por página
    const drawPageDecor = (data) => {
      const { pageNumber } = data;
      // HEADER (sin línea)
      if (logoInfo) {
        const targetH = 12; // mm (ajusta 14/16 si lo quieres más grande)
        const lw = targetH * (logoInfo.w / logoInfo.h);
        const lx = LEFT_MM;
        const ly = PAGE_HEADER_MM - (targetH + 2); // un poco por encima del contenido
        try { pdf.addImage(logoInfo.dataURL, 'PNG', lx, ly, lw, targetH); } catch {}
      }
      const textX = LEFT_MM + (logoInfo ? 28 : 0);
      const textBaseY = PAGE_HEADER_MM - 4;
      pdf.setTextColor(0,0,0);
      pdf.setFont('helvetica','bold'); pdf.setFontSize(11);
      pdf.text('Asociación Joven Orquesta de Granada', textX, textBaseY - 5);
      pdf.setFont('helvetica','normal'); pdf.setFontSize(8);
      pdf.text('www.josg.org – info@josg.org',        textX, textBaseY - 0);

      // FOOTER
      const footerTop = hmm - FOOTER_MM;
      pdf.setDrawColor(180);
      pdf.line(LEFT_MM, footerTop, wmm - RIGHT_MM, footerTop);
      pdf.setFont('helvetica','normal'); pdf.setFontSize(7);
      const footerText =
'Asociación Joven Orquesta de Granada\n' +
'CIF: G-18651067 · www.josg.org · Tfno: 682445971\n' +
'C/ Andrés Segovia 60, 18007 Granada\n' +
'Sede de ensayos: Teatro Maestro Francisco Alonso, C/ Ribera del Beiro 34, 18012 Granada';
      pdf.text(footerText, LEFT_MM, footerTop + 5, { maxWidth: wmm - LEFT_MM - RIGHT_MM });
      pdf.setFontSize(8);
      pdf.text('Página ' + pageNumber + ' de ' + pdf.internal.getNumberOfPages(), wmm/2, hmm - FOOTER_MM/2, { align:'center' });
    };

    // 7) AutoTable: usa tu HTML, repite CABECERA en TODAS las páginas
    const usableWidthMM = wmm - LEFT_MM - RIGHT_MM;

    // Fijamos los anchos proporcionales en mm para que todas las páginas coincidan
    const columnStyles = {};
    headCells.forEach((th, i) => {
      columnStyles[i] = { cellWidth: usableWidthMM * (cellWidthsPx[i] / totalPx) };
    });

    const headStyles = { fillColor: [240,240,240], textColor: [0,0,0], halign: 'left', fontStyle: 'bold', fontSize: 9 };
    const bodyStyles = { fontSize: 9, cellPadding: 2, overflow: 'linebreak' };

    pdf.autoTable({
      html: tableEl,                           // lee <thead>/<tbody> de tu clon
      startY: START_Y,                         // tabla empieza bajo el header
      margin: { left: LEFT_MM, right: RIGHT_MM, bottom: FOOTER_MM },
      styles: bodyStyles,
      headStyles,
      columnStyles,
      theme: 'grid',
      showHead: 'everyPage',                   // 👈 AutoTable repite cabecera en TODAS
      rowPageBreak: 'avoid',                   // intenta no partir filas
      willDrawPage: drawPageDecor              // solo header/footer globales (sin cabecera manual)
    });

    pdf.save('informe.pdf');
    clone.remove();
  });
});
</script>
