<% title = 'Inicio - JOSG MANAGER' %>
<% hero  = true %>
<style>
  /* === Core reset & layout === */
*,*::before,*::after{ box-sizing: border-box; }
html, body{ height:100%; margin:0; }
body{
  min-height:100vh; display:flex; flex-direction:column;
  font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Syne", sans-serif;
  color:#111; background:#fff;
}
footer{ margin-top:auto; }

/* === Vars (palette & layout) === */
:root{
  --sb-black:#111827; --sb-orange:#FF9501; --sb-yellow:#ffb020; --sb-cream:#fff3dc; --sb-blue:#1f3a8a; --sb-rust:#c8472c;
  --lift:-16px; --footer-h:110px; --top-offset:50px;
  --bg-image: url("/imagenes/Cortinas.png");
}

/* === Accessibility === */
.skip-link{ position:absolute; left:-9999px; top:auto; width:1px; height:1px; overflow:hidden; }
.skip-link:focus{ left:16px; top:12px; width:auto; height:auto; padding:.5rem .75rem; background:#fff; border:2px solid var(--sb-black); border-radius:10px; z-index:9999; }
:where(a,button,input,select,textarea,.tile-sb,.sb-exit):focus-visible{ outline:3px solid var(--sb-yellow); outline-offset:2px; }

/* === Page scaffolding === */
.hero-header{ padding-top: var(--top-offset); min-height: calc(100vh - var(--footer-h)); position:relative; display:grid; place-items:center; overflow:hidden; }
.container{ max-width:1100px; width:min(1100px,100%); margin-inline:auto; padding-inline:16px; }
.page-wrap{ margin-top: var(--lift); padding-bottom:48px; }
.hero-header .panel-usuario-overlay{ position:absolute; top:var(--top-offset); left:50%; transform:translateX(-50%); margin-top:0; }

/* === Tiles & grid === */
.tile-sb{
  position:relative; display:flex; align-items:center; justify-content:center; text-align:center;
  padding:16px; text-decoration:none; font-weight:900; text-transform:uppercase; letter-spacing:.5px;
  color:var(--sb-black); background:var(--sb-cream); border:2px solid var(--sb-black); border-radius:16px;
  transition:transform .15s ease, filter .15s ease;
}
.tile-sb:hover{ transform:translateY(-2px); filter:brightness(1.02); }
.tile-sb.is-orange{ background:var(--sb-orange); color:#111; }
.tile-sb.is-yellow{ background:var(--sb-yellow); color:#111; }
.tile-sb.is-cream{ background:var(--sb-cream); color:#111; }
.tile-sb.is-black{ background:var(--sb-black); color:#fff; }
.tile-sb.is-blue{ background:var(--sb-blue); color:#fff; }
.tile-sb.is-rust{ background:var(--sb-rust); color:#fff; }
.tile-sb.h1{ grid-row:span 1; } .tile-sb.h2{ grid-row:span 2; }
.tile-sb.w1{ grid-column:span 1; } .tile-sb.w2{ grid-column:span 2; }
@media (max-width:799px){ .tile-sb.w2{ grid-column:span 1; } }
.tile-sb span{ display:block; line-height:1.1; font-size:clamp(1.05rem, .9rem + 1.2vw, 1.6rem); letter-spacing:.6px; }

/* === Tema cortinas (activado por JS) === */
body.theme-curtains{
  background-color: var(--sb-black) !important;
  background-image:
    linear-gradient(90deg, var(--curtain-left, var(--sb-blue)) 0 14%, transparent 14%),
    linear-gradient(270deg, var(--sb-yellow) 0 14%, transparent 14%),
    linear-gradient(0deg, transparent 0 74%, var(--sb-rust) 74% 88%, transparent 88%);
  background-repeat: no-repeat, no-repeat, no-repeat;
  background-position: left top, right top, center bottom;
  background-size: 16% 100%, 16% 100%, 100% 28%;
  background-attachment: fixed, fixed, fixed;
}
@media (max-width:768px){ body.theme-curtains{ background-attachment: scroll !important; } }
body.theme-curtains.theme-image{
  background-image: var(--bg-image) !important;
  background-size: cover !important; background-repeat: no-repeat !important;
  background-position: center !important; background-attachment: fixed !important;
}
@media (max-width:768px){ body.theme-curtains.theme-image{ background-attachment: scroll !important; } }

/* === Login (estructura una ficha + acciones) === */
.sb-auth{ max-width: 720px; margin: 16px auto 32px; }
.sb-auth-form{ display:grid; gap:14px; grid-template-columns:1fr; } /* una columna fija */
.sb-auth .tile-sb{ padding:16px; align-items:flex-start; }          /* tamaño original de ficha */

/* Cabecera del login (sin marco, look original) */
.sb-auth-card{ display:grid; gap:12px; }
.sb-form-head{ display:flex; align-items:center; gap:10px; margin-bottom:8px; }
.sb-form-head--framed{ border:0; padding:0; background:transparent; border-radius:0; gap:10px; margin-bottom:8px; }
.sb-login-logo{ height:34px; width:auto; border:2px solid var(--sb-black); border-radius:10px; }
.sb-form-head .h{ font-weight:900; letter-spacing:.5px; font-size:1rem; }

/* Campos */
.tile-sb .field-label{
  display:inline-block; margin-bottom:8px; font-size:.7rem; font-weight:900; letter-spacing:.4px;
  border:2px solid var(--sb-black); border-radius:8px; padding:3px 8px; background:#fff8e8; color:var(--sb-black);
}
.tile-sb .field-input{
  width:100%; font-size:.78rem; padding:.38rem .54rem; border:2px solid var(--sb-black); border-radius:8px; background:#fff; color:#111;
}

/* Alinear etiquetas y campos verticalmente en 2 columnas (sin cambiar tamaños) */
.sb-fields.align-vertical{
  --label-w: 120px;
  display:grid; grid-template-columns: var(--label-w) 1fr;
  column-gap:10px; row-gap:12px; align-items:center;
}
.sb-fields.align-vertical .field-wrap{ display: contents; }
.sb-fields.align-vertical .field-label{ grid-column:1; }
.sb-fields.align-vertical .field-input{ grid-column:2; min-width:0; }
.sb-fields.align-vertical .show-pass{ grid-column:2; margin:6px 0 0 0; }

/* Mostrar contraseña: tamaño/casing original (evita heredado de tile uppercase) */
.sb-auth .show-pass{
  display:inline-flex; align-items:center; gap:.5rem;
  margin-top:12px; font-size:.7rem; font-weight:600;
  text-transform:none; letter-spacing:0;
}

@media (max-width: 899px){
  .sb-fields.align-vertical{ grid-template-columns: 1fr; }
  .sb-fields.align-vertical .field-label,
  .sb-fields.align-vertical .field-input,
  .sb-fields.align-vertical .show-pass{ grid-column:1; }
}

/* Acciones */
.sb-auth-actions{
  display:flex; align-items:center; justify-content:space-between; gap:12px; width:100%;
}
.btn-auth{
  display:inline-flex; align-items:center; justify-content:center; gap:8px;
  padding:.55rem .95rem; border:2px solid var(--sb-black); border-radius:10px;
  background:var(--sb-black); color:#fff; font-weight:900; letter-spacing:.6px; text-transform:uppercase;
}
.btn-auth:hover{ filter:brightness(1.03); transform:translateY(-2px); }
.link-aux{ font-size:.68rem; font-weight:600; letter-spacing:.2px; color:inherit; text-decoration:underline; opacity:.95; text-transform:none; }

/* === Estado logado (banner + grid) === */
.sb-banner{
  position:relative; display:flex; align-items:center; justify-content:space-between; gap:12px;
  padding:10px 12px; border:2px solid var(--sb-black); background:var(--sb-orange); color:var(--sb-black);
  border-radius:16px; margin:0 0 6px;
}
/* Logo “plano” (sin ficha crema) sólo en la parte logada */
.sb-logo{ height:44px; object-fit:contain; background:var(--sb-cream); padding:6px 10px; border:2px solid var(--sb-black); border-radius:12px; }
.panel-usuario-overlay .sb-logo{ background:transparent; border:0; padding:0; border-radius:0; height:48px; }

.sb-greet{ display:flex; align-items:center; gap:10px; }
.sb-avatar{ width:40px; height:40px; border-radius:999px; border:2px solid var(--sb-black); background:var(--sb-black); color:#fff; font-weight:900; display:flex; align-items:center; justify-content:center; }
.sb-greet-text .hello{ margin:0; font-size:1rem; line-height:1.1; color:#000; }
.sb-greet-text .role{ margin:.15rem 0 0; color:#1f2937; font-size:.9rem; opacity:.9; }
.sb-exit{ display:inline-flex; align-items:center; gap:8px; padding:.5rem .8rem; border:2px solid var(--sb-black); background:#fff; color:var(--sb-black); border-radius:10px; text-decoration:none; }
.sb-exit:hover{ filter:brightness(1.02); transform:translateY(-1px); }
@media (max-width:640px){ .sb-banner{ flex-direction:column; align-items:stretch; gap:10px; } .sb-logo{ height:42px; align-self:flex-start; } .sb-exit{ align-self:flex-end; } }

.sb-grid{ display:grid; gap:16px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); grid-auto-rows:108px; margin:8px 0 40px; }
/* 1) Acortar ancho de las fichas del login (primera parte)
      – aplica SOLO al tile crema (usuario+contraseña) y al tile amarillo (botón) */
      @media (min-width:900px){
  .sb-auth .sb-auth-card,
  .sb-auth .sb-auth-actions{
    width: var(--auth-tile-w, 60%);   /* ajusta 60% si lo quieres más/menos estrecho */
    max-width: 820px;                 /* techo por si crece mucho el contenedor */
    margin-inline: auto;
  }
}

/* 2) Poner borde a la fila de logo + ACCESO (sin cambiar alturas)
      – usamos “borde” simulado para no alterar el layout */
.sb-auth-card .sb-form-head{
  box-shadow: inset 0 0 0 2px var(--sb-black); /* como un borde negro */
  border-radius: 12px;
  background: var(--sb-cream);
  /* sin padding extra: así no varía la altura total */
}

/* 3) Centrar verticalmente “¿Olvidaste la contraseña?” en su ficha (acciones) */
.sb-auth .sb-auth-actions{
  align-items: center !important;   /* vence el align-items:flex-start del tile */
  justify-content: space-between;   /* se mantiene el reparto original */
}

/* Primer bloque (login): logo sin borde derecho, resto igual */
.sb-auth-card .sb-login-logo{
  border-right: 0 !important;
  border-top-right-radius: 0 !important;
  border-bottom-right-radius: 0 !important;
  background: transparent !important; /* se funde con el fondo naranja */
  height: 34px !important;  /* conserva tamaño exacto */
  width: auto !important;
}

/* Cabecera (logo + ACCESO) con interior naranja y “marco” negro */
.sb-auth-card .sb-form-head{
  box-shadow: inset 0 0 0 2px var(--sb-black); /* borde interior negro */
  border-radius: 12px;
  background: var(--sb-orange); /* #FF9501 */
  color: var(--sb-black);
}

/* (opcional) si ves una microseparación, compénsalo 1px */
@supports (margin-inline-start: -1px){
  .sb-auth-card .sb-login-logo{ margin-inline-end: -1px; } /* elimina cualquier “hilo” de 1px */
}


</style>
<header class="hero-header">
  <a class="skip-link" href="#menu-principal">Saltar al contenido principal</a>

  <% if (!usuario) { %>
  <div class="container page-wrap">
    <section class="sb-auth" aria-labelledby="auth-title">
      <!-- Banner de acceso, igual estilo que el logado -->

      <% if (error) { %>
        <div class="tile-sb is-yellow h1 w2" role="alert" aria-live="polite"><span><%= error %></span></div>
      <% } %>
      <form method="POST" action="/login" class="sb-auth-form" autocomplete="on" novalidate style="background-color: transparent;">

        <!-- Fila 1+2 unificadas en una sola ficha crema -->
        <div class="tile-sb is-cream h1 w2 sb-auth-card">
          <div class="sb-form-head sb-form-head--framed">
            <img src="/imagenes/logoJOSG.png" alt="JOSG" class="sb-login-logo" loading="lazy">
            <div class="h">Acceso restringido</div>
          </div>
      
          <!-- Campos (usuario + contraseña) en la misma ficha -->
          <div class="sb-fields sb-fields--inline align-vertical">
            <div class="field-wrap">
              <label class="field-label" for="email">Usuario</label>
              <input id="email" type="email" name="email" class="field-input" ...>
            </div>
          
            <div class="field-wrap">
              <label class="field-label" for="password">Contraseña</label>
              <input id="password" type="password" name="password" class="field-input" ...>
              <label class="show-pass">
                <input type="checkbox" id="toggle-pass" ...> Mostrar contraseña
              </label>
            </div>
          </div>
          
        </div>
      
        <!-- Fila 3: acciones (sin moverla) -->
        <div class="tile-sb is-yellow h1 w2 sb-auth-actions">
          <button type="submit" class="btn-auth">Entrar</button>
          <a href="/obras" class="link-aux">¿Olvidaste la contraseña?</a>
        </div>
      </form>
      
    </section>
  </div>
<% } else { %>
    <div class="panel-usuario-overlay">
      <div class="container page-wrap">
        <!-- Banner -->
        <div class="sb-banner">
          <img src="/imagenes/logoJOSG.png" alt="JOSG" class="sb-logo" loading="lazy">

          <div class="sb-greet">
            <div class="sb-avatar">
              <%= (usuario.nombre || '?').trim().slice(0,1).toUpperCase() %>
            </div>
            <div class="sb-greet-text">
              <p class="hello">Hola, <strong style="color:#000;"><%= usuario.nombre %></strong></p>
            </div>
          </div>

          <a href="/logout" class="sb-exit" title="Cerrar sesión" aria-label="Cerrar sesión">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" fill="none" stroke="currentColor" stroke-width="2"/>
              <path d="M16 17l5-5-5-5" fill="none" stroke="currentColor" stroke-width="2"/>
              <path d="M21 12H9" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
            Salir
          </a>
        </div>

        <!-- Grid -->
        <div id="menu-principal" class="sb-grid">
          <% if (usuario.rol === 'admin' || usuario.rol === 'docente') { %>
            <a href="/alumnos"       class="tile-sb is-yellow h2 w1"><span>Músicos</span></a>
            <a href="/profesores"    class="tile-sb is-cream  h1 w1"><span>Docentes</span></a>
            <a href="/guardias"       class="tile-sb is-blue   h1 w1"><span>Guardias</span></a>
            <a href="/eventos"       class="tile-sb is-rust   h1 w2"><span>Eventos</span></a>
            <a href="/informes"      class="tile-sb is-black  h1 w1"><span>Informes</span></a>
            <a href="/contabilidad"  class="tile-sb is-orange h2 w2"><span>Contabilidad / Cuotas</span></a>
            <a href="/configuracion" class="tile-sb is-yellow h1 w1"><span>Configuración</span></a>
          <% } else { %>
            <a href="/eventos" class="tile-sb is-blue h2 w2"><span>Eventos</span></a>
          <% } %>
        </div>

      </div>
    </div>
  <% } %>
</header>

<script>
  // Toggle mostrar contraseña (accesible)
  (function(){
    var t = document.getElementById('toggle-pass');
    var p = document.getElementById('password');
    if(t && p){
      t.addEventListener('change', function(){
        var showing = t.checked;
        p.type = showing ? 'text' : 'password';
        t.setAttribute('aria-pressed', showing ? 'true' : 'false');
      });
    }
  })();

  // Fijar tema + modo visual
  document.addEventListener('DOMContentLoaded', function(){
  document.body.classList.add('theme-curtains');
  document.body.classList.add('shapes-rect'); // activar modo rectangular simétrico
  document.body.classList.add('theme-image');  // ← activa la capa de imagen
  });
</script>
