<% title = 'Inicio - JOSG MANAGER' %>
<% hero  = true %>

<header class="hero-header">
  <a class="skip-link" href="#menu-principal">Saltar al contenido principal</a>

  <% if (!usuario) { %>
  <!-- =================== SIN SESIÓN: LOGIN =================== -->
  <div class="container page-wrap">
    <section class="sb-auth" aria-labelledby="auth-title">
      <% if (error) { %>
        <div class="tile-sb is-yellow h1 w2" role="alert" aria-live="polite"><span><%= error %></span></div>
      <% } %>

      <form method="POST" action="/login" class="sb-auth-form" autocomplete="on" novalidate style="background-color: transparent;">
        <div class="tile-sb is-cream h1 w2 sb-auth-card">
          <div class="sb-form-head sb-form-head--framed">
            <img src="/imagenes/logoJOSG.png" alt="JOSG" class="sb-login-logo" loading="lazy">
            <div class="h">Acceso restringido</div>
          </div>

          <div class="sb-fields sb-fields--inline align-vertical">
            <div class="field-wrap">
              <label class="field-label" for="email">Usuario</label>
              <input id="email" type="email" name="email" class="field-input" required>
            </div>

            <div class="field-wrap">
              <label class="field-label" for="password">Contraseña</label>
              <input id="password" type="password" name="password" class="field-input" required>
              <label class="show-pass">
                <input type="checkbox" id="toggle-pass"> Mostrar contraseña
              </label>
            </div>
          </div>
        </div>

        <div class="tile-sb is-yellow h1 w2 sb-auth-actions">
          <button type="submit" class="btn-auth">Entrar</button>
          <a href="/obras" class="link-aux">¿Olvidaste la contraseña?</a>
        </div>
      </form>
    </section>
  </div>

  <% } else { %>
  <!-- =================== CON SESIÓN: PANEL + MENÚ =================== -->
  <div class="panel-usuario-overlay">
    <div class="container page-wrap">
      <!-- Banner superior -->
      <div class="sb-banner">
        <img src="/imagenes/logoJOSG.png" alt="JOSG" class="sb-logo" loading="lazy">
        <div class="sb-greet">
          <div class="sb-avatar"><%= (usuario.nombre || '?').trim().slice(0,1).toUpperCase() %></div>
          <div class="sb-greet-text">
            <p class="hello">Hola, <strong style="color:#000;"><%= usuario.nombre %></strong></p>
          </div>
        </div>
        <a href="/logout" class="sb-exit" title="Cerrar sesión" aria-label="Cerrar sesión">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" fill="none" stroke="currentColor" stroke-width="2"/>
            <path d="M16 17l5-5-5-5" fill="none" stroke="currentColor" stroke-width="2"/>
            <path d="M21 12H9" fill="none" stroke="currentColor" stroke-width="2"/>
          </svg>
          Salir
        </a>
      </div>

      <!-- Barra de controles del lienzo -->
      <div class="ctb-head d-flex align-items-center justify-content-between" style="max-width:1200px;margin:12px auto 6px;padding:0 12px;">
        <div class="d-flex align-items-center gap-2">
          <button id="btnLibre" class="btn btn-sm btn-outline-dark">Modo libre</button>
          <button id="btnReset" class="btn btn-sm btn-outline-secondary">Restablecer</button>
        </div>
      </div>

      <!-- Lienzo de fichas -->
      <div id="canvas-wrap" class="canvas-wrap" data-menu="index">
        <div id="menu-principal" class="sb-grid">
          <% if (usuario.rol === 'admin' || usuario.rol === 'docente') { %>
            <a data-id="alumnos"        href="/alumnos"       class="tile-sb is-yellow h2 w1"><span>Músicos</span></a>
            <a data-id="profesores"     href="/profesores"    class="tile-sb is-cream  h1 w1"><span>Docentes</span></a>
            <a data-id="guardias"       href="/guardias"      class="tile-sb is-blue   h1 w1"><span>Guardias</span></a>
            <a data-id="eventos"        href="/eventos"       class="tile-sb is-rust   h1 w2"><span>Eventos</span></a>
            <a data-id="informes"       href="/informes"      class="tile-sb is-black  h2 w1"><span>Informes</span></a>
            <a data-id="contabilidad"   href="/contabilidad"  class="tile-sb is-orange h2 w2"><span>Contabilidad / Cuotas</span></a>
            <a data-id="config"         href="/configuracion" class="tile-sb is-yellow h1 w2"><span>Configuración</span></a>
            <a data-id="ayuda"          href="/configuracion/ayuda" class="tile-sb is-cream h1 w3"><span>Ayuda</span></a>
          <% } else { %>
            <a data-id="alumnos"        href="/alumnos"       class="tile-sb is-yellow h2 w1"><span>Músicos</span></a>
            <a data-id="profesores"     href="/profesores"    class="tile-sb is-cream  h1 w1"><span>Docentes</span></a>
            <a data-id="guardias"       href="/guardias"      class="tile-sb is-blue   h1 w1"><span>Guardias</span></a>
            <a data-id="eventos"        href="/eventos"       class="tile-sb is-rust   h1 w2"><span>Eventos</span></a>
            <a data-id="informes"       href="/informes"      class="tile-sb is-black  h2 w2"><span>Informes</span></a>
            <a data-id="ayuda"          href="/configuracion/ayuda" class="tile-sb is-cream h2 w1"><span>Ayuda</span></a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <% } %>
</header>

<style>
  /* Un poco de aire extra como en otros menús */
  .container.page-wrap .sb-grid { margin-top: 22px; }

  /* Lienzo común: modo libre y modo “ver” comparten posicionamiento absoluto */
  .canvas-wrap{ position: relative; }
  .canvas-wrap.free,
  .canvas-wrap.free-view{
    height: 1200px;
    border: 1px dashed rgba(0,0,0,.08);
    border-radius: 12px;
    padding: 8px;
  }
  .canvas-wrap.free  #menu-principal,
  .canvas-wrap.free-view #menu-principal{
    display: block !important;
    position: relative;
    height: 100%;
  }
  .canvas-wrap.free #menu-principal .tile-sb,
  .canvas-wrap.free-view #menu-principal .tile-sb{
    position: absolute !important;
    margin: 0 !important;
    min-width: 180px; min-height: 120px;
    box-shadow: 0 4px 18px rgba(0,0,0,.08);
    user-select: none;
    touch-action: none;
  }

  /* Contraste de texto como en las otras vistas */
  .sb-grid .tile-sb.is-black,
  .sb-grid .tile-sb.is-blue,
  .sb-grid .tile-sb.is-orange,
  .sb-grid .tile-sb.is-rust { color:#fff; }
  .sb-grid .tile-sb.is-cream,
  .sb-grid .tile-sb.is-yellow { color:#111; }

  /* Toolbars por ficha — ocultas siempre fuera del modo libre; visibles en .free */
  .tile-tools{ display:none; }
  .canvas-wrap:not(.free) .tile-tools { display: none !important; }
  .canvas-wrap.free .tile-tools{
    position:absolute; top:6px; right:6px; display:flex; gap:6px; z-index:2;
  }
  .canvas-wrap.free .tile-tools button{
    border:1px solid rgba(0,0,0,.15); background:#fff; border-radius:6px;
    padding:4px 8px; font-size:12px; line-height:1; cursor:pointer;
    box-shadow:0 1px 2px rgba(0,0,0,.08);
  }
  .canvas-wrap.free .tile-tools button:hover{ background:#f5f5f5; }

  .dragging{ outline: 2px dashed rgba(0,0,0,.25); outline-offset: 0; }
</style>

<script>
  // Toggle mostrar contraseña (accesible)
  (function(){
    var t = document.getElementById('toggle-pass');
    var p = document.getElementById('password');
    if(t && p){
      t.addEventListener('change', function(){
        var showing = t.checked;
        p.type = showing ? 'text' : 'password';
        t.setAttribute('aria-pressed', showing ? 'true' : 'false');
      });
    }
  })();

  // Fijar tema + modo visual
  document.addEventListener('DOMContentLoaded', function(){
    document.body.classList.add('theme-curtains');
    document.body.classList.add('shapes-rect');
    document.body.classList.add('theme-image');
  });
</script>

<!-- ===== Interact.js + Modo libre para INDEX (solo si hay usuario) ===== -->
<% if (usuario) { %>
<script src="https://cdn.jsdelivr.net/npm/interactjs/dist/interact.min.js"></script>
<script>
(()=> {
  const wrap = document.getElementById('canvas-wrap');
  const grid = document.getElementById('menu-principal');
  const btn  = document.getElementById('btnLibre');
  const btnReset = document.getElementById('btnReset');
  if (!wrap || !grid || !btn) return;

  const menuKey = 'layout:' + (wrap.dataset.menu || 'index');
  const COLORS  = ['is-cream','is-yellow','is-blue','is-orange','is-rust','is-black'];

  const load = () => { try{ const r=localStorage.getItem(menuKey); return r?JSON.parse(r):null; } catch { return null; } };
  const save = (o) => { try{ localStorage.setItem(menuKey, JSON.stringify(o)); } catch {} };
  const clear= () => { try{ localStorage.removeItem(menuKey); } catch {} };
  const def  = () => ({ mode:'grid', items:{} });

  function applyItemStyles(tile, it){
    if(!it) return;
    COLORS.forEach(c=>tile.classList.remove(c));
    if(it.color) tile.classList.add(it.color);
    if(typeof it.x==='number') tile.style.left  = it.x+'px';
    if(typeof it.y==='number') tile.style.top   = it.y+'px';
    if(typeof it.w==='number') tile.style.width = it.w+'px';
    if(typeof it.h==='number') tile.style.height= it.h+'px';
    if(typeof it.z==='number') tile.style.zIndex= String(it.z);
  }

  function snapshot(){
    const rw=wrap.getBoundingClientRect(), items={};
    for(const t of grid.querySelectorAll('.tile-sb')){
      const id=t.dataset.id; if(!id) continue;
      const r=t.getBoundingClientRect();
      items[id]={ x:Math.max(0,r.left-rw.left), y:Math.max(0,r.top-rw.top),
                  w:r.width, h:r.height,
                  color:COLORS.find(c=>t.classList.contains(c))||null,
                  z:0 };
    }
    return items;
  }

  function collect(){
    const items={};
    for(const t of grid.querySelectorAll('.tile-sb')){
      const id=t.dataset.id; if(!id) continue;
      items[id]={ x:parseFloat(t.style.left)||0,
                  y:parseFloat(t.style.top)||0,
                  w:parseFloat(t.style.width)||t.getBoundingClientRect().width,
                  h:parseFloat(t.style.height)||t.getBoundingClientRect().height,
                  color:COLORS.find(c=>t.classList.contains(c))||null,
                  z:parseInt(t.style.zIndex||'0',10) };
    }
    return items;
  }

  function persistTile(tile){
    const cur=load()||def(); if(cur.mode!=='free'&&cur.mode!=='free-view') cur.mode='free-view';
    const id=tile.dataset.id; if(!id) return;
    cur.items[id]={ x:parseFloat(tile.style.left)||0,
                    y:parseFloat(tile.style.top)||0,
                    w:parseFloat(tile.style.width)||tile.getBoundingClientRect().width,
                    h:parseFloat(tile.style.height)||tile.getBoundingClientRect().height,
                    color:COLORS.find(c=>tile.classList.contains(c))||null,
                    z:parseInt(tile.style.zIndex||'0',10) };
    save(cur);
  }

  // === Herramientas (Color / Frente) ===
  function cycleColor(tile){
    const cur = COLORS.find(c => tile.classList.contains(c));
    const idx = cur ? COLORS.indexOf(cur) : -1;
    const next = COLORS[(idx+1) % COLORS.length];
    COLORS.forEach(c => tile.classList.remove(c));
    tile.classList.add(next);
  }
  function addTools(tile){
    if (tile.querySelector('.tile-tools')) return;
    const tools = document.createElement('div');
    tools.className = 'tile-tools';
    const bColor = document.createElement('button'); bColor.type='button'; bColor.textContent='Color';
    const bFront = document.createElement('button'); bFront.type='button'; bFront.textContent='⇪ Frente';
    bColor.addEventListener('click', (e)=>{ e.preventDefault(); e.stopPropagation(); cycleColor(tile); persistTile(tile); });
    bFront.addEventListener('click', (e)=>{ e.preventDefault(); e.stopPropagation(); tile.style.zIndex=String(Date.now()); persistTile(tile); });
    tools.append(bColor,bFront);
    tile.appendChild(tools);
  }

  // === Interact (drag/resize) ===
  function enableInteract(){
    const c=wrap;
    interact('.canvas-wrap.free #menu-principal .tile-sb')
      .draggable({
        listeners:{
          start:e=>e.target.classList.add('dragging'),
          move:e=>{
            const t=e.target;
            const x=(parseFloat(t.style.left)||0)+e.dx;
            const y=(parseFloat(t.style.top)||0)+e.dy;
            const rc=c.getBoundingClientRect(), rt=t.getBoundingClientRect();
            t.style.left=Math.max(0,Math.min(x,rc.width-rt.width))+'px';
            t.style.top =Math.max(0,Math.min(y,rc.height-rt.height))+'px';
          },
          end:e=>{e.target.classList.remove('dragging'); persistTile(e.target);}
        },
        modifiers:[interact.modifiers.restrictRect({restriction:c,endOnly:true})]
      })
      .resizable({
        edges:{left:true,right:true,top:true,bottom:true},
        listeners:{
          move:e=>{
            const t=e.target;
            const ox=parseFloat(t.style.left)||0, oy=parseFloat(t.style.top)||0;
            let w=Math.max(180,e.rect.width), h=Math.max(120,e.rect.height);
            t.style.width=w+'px'; t.style.height=h+'px';
            const nx=ox+e.deltaRect.left, ny=oy+e.deltaRect.top;
            const rc=c.getBoundingClientRect();
            t.style.left=Math.max(0,Math.min(nx,rc.width-w))+'px';
            t.style.top =Math.max(0,Math.min(ny,rc.height-h))+'px';
          },
          end:e=>persistTile(e.target)
        },
        modifiers:[interact.modifiers.restrictEdges({outer:c,endOnly:true})]
      });
  }

  function preventWhileFree(e){ if(wrap.classList.contains('free')){ e.preventDefault(); e.stopPropagation(); } }

  // === Modos ===
  function enterView(){
    // Asegura que no queden toolbars visibles en modo vista
    grid.querySelectorAll('.tile-sb .tile-tools').forEach(t => t.remove());

    wrap.classList.add('free-view');
    const cur=load(), items=cur?.items||{};
    for(const a of grid.querySelectorAll('a.tile-sb')){
      a.style.position='absolute';
      a.style.margin='0';
      applyItemStyles(a, items[a.dataset.id]);
    }
  }
  function exitView(){
    wrap.classList.remove('free-view');
    for(const a of grid.querySelectorAll('a.tile-sb')){
      a.style.position='';
      a.style.left=a.style.top=a.style.width=a.style.height=a.style.zIndex='';
    }
  }

  function enterFree(){
    if(!wrap.classList.contains('free-view')) enterView();
    wrap.classList.add('free'); btn.textContent='Guardar';
    const cur=load()||def();
    if(!cur.items||!Object.keys(cur.items).length){
      cur.items=snapshot(); cur.mode='free-view'; save(cur);
    }
    grid.querySelectorAll('a.tile-sb').forEach(a=>a.addEventListener('click',preventWhileFree));
    grid.querySelectorAll('.tile-sb').forEach(addTools);
    enableInteract();
  }

  function exitFree(saveLayout = true){
    if (saveLayout){
      const cur = load() || def();
      cur.mode  = 'free-view';
      cur.items = collect();
      save(cur);
    }
    // Salir de edición
    wrap.classList.remove('free');
    btn.textContent = 'Modo libre';

    // Limpieza agresiva de toolbars
    grid.querySelectorAll('.tile-sb .tile-tools').forEach(t => t.remove());

    // Desbloquear enlaces
    grid.querySelectorAll('a.tile-sb').forEach(a => a.removeEventListener('click', preventWhileFree));

    // Desactivar interact
    if (window.interact) interact('.tile-sb').unset();
  }

  // Hotkey: guardar sin salir (Ctrl/Cmd+S)
  document.addEventListener('keydown',(e)=>{
    if(!wrap.classList.contains('free')) return;
    const isMac=/Mac/i.test(navigator.platform); const mod=isMac?e.metaKey:e.ctrlKey;
    if(mod && e.key.toLowerCase()==='s'){
      e.preventDefault();
      const cur=load()||def(); cur.mode='free-view'; cur.items=collect(); save(cur);
      btn.textContent='Guardado'; setTimeout(()=>btn.textContent='Guardar',700);
      // Si quieres ocultar toolbars también aquí:
      // grid.querySelectorAll('.tile-sb .tile-tools').forEach(t => t.remove());
    }
  });

  // Estado inicial: si había un layout guardado, entrar en modo “ver”
  (()=>{
    const cur=load();
    if(cur?.mode==='free' || cur?.mode==='free-view'){
      enterView();
      btn.textContent='Modo libre';
    }
  })();

  // Botones
  btn.addEventListener('click', ()=>{ if(wrap.classList.contains('free')) exitFree(true); else enterFree(); });
  btnReset?.addEventListener('click', ()=>{ if(wrap.classList.contains('free')) exitFree(false); exitView(); clear(); });
})();
</script>
<% } %>

