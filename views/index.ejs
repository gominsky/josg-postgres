<% title = 'Inicio - JOSG MANAGER' %>
<% hero  = true %>
<style>

</style>
<header class="hero-header">
  <a class="skip-link" href="#menu-principal">Saltar al contenido principal</a>

  <% if (!usuario) { %>
  <div class="container page-wrap">
    <section class="sb-auth" aria-labelledby="auth-title">
      <!-- Banner de acceso, igual estilo que el logado -->

      <% if (error) { %>
        <div class="tile-sb is-yellow h1 w2" role="alert" aria-live="polite"><span><%= error %></span></div>
      <% } %>
      <form method="POST" action="/login" class="sb-auth-form" autocomplete="on" novalidate style="background-color: transparent;">

        <!-- Fila 1+2 unificadas en una sola ficha crema -->
        <div class="tile-sb is-cream h1 w2 sb-auth-card">
          <div class="sb-form-head sb-form-head--framed">
            <img src="/imagenes/logoJOSG.png" alt="JOSG" class="sb-login-logo" loading="lazy">
            <div class="h">Acceso restringido</div>
          </div>
      
          <!-- Campos (usuario + contraseña) en la misma ficha -->
          <div class="sb-fields sb-fields--inline align-vertical">
            <div class="field-wrap">
              <label class="field-label" for="email">Usuario</label>
              <input id="email" type="email" name="email" class="field-input" ...>
            </div>
          
            <div class="field-wrap">
              <label class="field-label" for="password">Contraseña</label>
              <input id="password" type="password" name="password" class="field-input" ...>
              <label class="show-pass">
                <input type="checkbox" id="toggle-pass" ...> Mostrar contraseña
              </label>
            </div>
          </div>
          
        </div>
      
        <!-- Fila 3: acciones (sin moverla) -->
        <div class="tile-sb is-yellow h1 w2 sb-auth-actions">
          <button type="submit" class="btn-auth">Entrar</button>
          <a href="/obras" class="link-aux">¿Olvidaste la contraseña?</a>
        </div>
      </form>
      
    </section>
  </div>
<% } else { %>
    <div class="panel-usuario-overlay">
      <div class="container page-wrap">
        <!-- Banner -->
        <div class="sb-banner">
          <img src="/imagenes/logoJOSG.png" alt="JOSG" class="sb-logo" loading="lazy">

          <div class="sb-greet">
            <div class="sb-avatar">
              <%= (usuario.nombre || '?').trim().slice(0,1).toUpperCase() %>
            </div>
            <div class="sb-greet-text">
              <p class="hello">Hola, <strong style="color:#000;"><%= usuario.nombre %></strong></p>
            </div>
          </div>

          <a href="/logout" class="sb-exit" title="Cerrar sesión" aria-label="Cerrar sesión">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" fill="none" stroke="currentColor" stroke-width="2"/>
              <path d="M16 17l5-5-5-5" fill="none" stroke="currentColor" stroke-width="2"/>
              <path d="M21 12H9" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
            Salir
          </a>
        </div>

        <!-- Grid -->
        <div id="menu-principal" class="sb-grid">
          <% if (usuario.rol === 'admin' || usuario.rol === 'docente') { %>
            <a href="/alumnos"       class="tile-sb is-yellow h2 w1"><span>Músicos</span></a>
            <a href="/profesores"    class="tile-sb is-cream  h1 w1"><span>Docentes</span></a>
            <a href="/guardias"       class="tile-sb is-blue   h1 w1"><span>Guardias</span></a>
            <a href="/eventos"       class="tile-sb is-rust   h1 w2"><span>Eventos</span></a>
            <a href="/informes"      class="tile-sb is-black  h1 w1"><span>Informes</span></a>
            <a href="/contabilidad"  class="tile-sb is-orange h2 w2"><span>Contabilidad / Cuotas</span></a>
            <a href="/configuracion" class="tile-sb is-yellow h1 w1"><span>Configuración</span></a>
            <a href="/configuracion/ayuda" class="tile-sb is-cream h1 w3"><span>Ayuda</span></a>
          <% } else { %>
            <a href="/alumnos"       class="tile-sb is-yellow h2 w1"><span>Músicos</span></a>
            <a href="/profesores"    class="tile-sb is-cream  h1 w1"><span>Docentes</span></a>
            <a href="/eventos" class="tile-sb is-blue h2 w2"><span>Eventos</span></a>
            <a href="/configuracion/ayuda" class="tile-sb is-cream h1 w3"><span>Ayuda</span></a>
          <% } %>
        </div>

      </div>
    </div>
  <% } %>
</header>

<script>
  // Toggle mostrar contraseña (accesible)
  (function(){
    var t = document.getElementById('toggle-pass');
    var p = document.getElementById('password');
    if(t && p){
      t.addEventListener('change', function(){
        var showing = t.checked;
        p.type = showing ? 'text' : 'password';
        t.setAttribute('aria-pressed', showing ? 'true' : 'false');
      });
    }
  })();

  // Fijar tema + modo visual
  document.addEventListener('DOMContentLoaded', function(){
  document.body.classList.add('theme-curtains');
  document.body.classList.add('shapes-rect'); // activar modo rectangular simétrico
  document.body.classList.add('theme-image');  // ← activa la capa de imagen
  });
</script>
