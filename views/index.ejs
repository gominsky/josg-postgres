<%
  title = 'Inicio - JOSG MANAGER';
  hero  = usuario ? false : true;
%>

<% if (!usuario) { %>
<!-- ═══════════════════════════════════════════════════════
     SIN SESIÓN — LOGIN
     ═══════════════════════════════════════════════════════ -->
<header class="hero-header">
  <a class="skip-link" href="#menu-principal">Saltar al contenido principal</a>
  <div class="container page-wrap">
    <section class="sb-auth" aria-labelledby="auth-title">
      <% if (error) { %>
        <div class="tile-sb is-yellow h1 w2" role="alert" aria-live="polite"><span><%= error %></span></div>
      <% } %>
      <form method="POST" action="/login" class="sb-auth-form" autocomplete="on" novalidate>
        <div class="tile-sb is-yellow h1 w2 sb-auth-card">
          <div class="sb-form-head sb-form-head--framed">
            <img src="/imagenes/logoJOSG.png" alt="JOSG" class="sb-login-logo" loading="lazy">
            <div class="h">Acceso restringido</div>
          </div>
          <div class="sb-fields sb-fields--inline align-vertical">
            <div class="field-wrap">
              <label class="field-label" for="email">Usuario</label>
              <input id="email" type="email" name="email" class="field-input" required autocomplete="username">
            </div>
            <div class="field-wrap">
              <label class="field-label" for="password">Contraseña</label>
              <input id="password" type="password" name="password" class="field-input" required autocomplete="current-password">
              <label class="show-pass">
                <input type="checkbox" id="toggle-pass"> Mostrar contraseña
              </label>
            </div>
          </div>
        </div>
        <div class="tile-sb is-yellow h1 w2 sb-auth-actions">
          <button type="submit" class="btn-auth">Entrar</button>
          <a href="/recuperar" class="link-aux">¿Olvidaste la contraseña?</a>
        </div>
      </form>
    </section>
  </div>
</header>

<script>
(function(){
  var t = document.getElementById('toggle-pass');
  var p = document.getElementById('password');
  if (t && p) t.addEventListener('change', function(){
    p.type = t.checked ? 'text' : 'password';
    t.setAttribute('aria-pressed', t.checked ? 'true' : 'false');
  });
})();
document.addEventListener('DOMContentLoaded', function(){
  document.body.classList.add('theme-curtains', 'shapes-rect', 'theme-image');
});
</script>

<% } else { %>
<!-- ═══════════════════════════════════════════════════════
     CON SESIÓN — usa header-simple y footer normales
     ═══════════════════════════════════════════════════════ -->

<!-- Botones fuera del canvas -->
<div class="idx-controls">
  <button id="btnLibre" class="idx-btn">☰ Modo libre</button>
  <button id="btnReset" class="idx-btn">↺ Restablecer</button>
</div>

<!-- Canvas — ocupa todo el ancho de page-main -->
<div id="canvas-wrap" class="canvas-wrap idx-canvas" data-menu="index">
  <div id="menu-principal" class="sb-grid">
    <% if (usuario.rol === 'admin' || usuario.rol === 'docente') { %>
      <a data-id="alumnos"    href="/alumnos"             class="tile-sb is-yellow h1 w1"><span>Músicos</span></a>
      <a data-id="eventos"    href="/eventos"             class="tile-sb is-rust   h1 w1"><span>Eventos</span></a>
      <a data-id="informes"   href="/informes"            class="tile-sb is-black  h1 w1"><span>Informes</span></a>
      <a data-id="mensajes"   href="/mensajes/nuevo"      class="tile-sb is-blue   h1 w1"><span>Mensajes</span></a>
      <a data-id="partituras" href="/partituras"          class="tile-sb is-orange h1 w1"><span>Partituras</span></a>
      <a data-id="config"     href="/configuracion"       class="tile-sb is-cream  h1 w1"><span>Configuración</span></a>
      <a data-id="ayuda"      href="/configuracion/ayuda" class="tile-sb is-rust   h1 w1"><span>Ayuda</span></a>
    <% } else { %>
      <a data-id="alumnos"  href="/alumnos"             class="tile-sb is-yellow h2 w1"><span>Músicos</span></a>
      <a data-id="eventos"  href="/eventos"             class="tile-sb is-rust   h1 w2"><span>Eventos</span></a>
      <a data-id="informes" href="/informes"            class="tile-sb is-black  h2 w2"><span>Informes</span></a>
      <a data-id="ayuda"    href="/configuracion/ayuda" class="tile-sb is-cream  h2 w1"><span>Ayuda</span></a>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/interactjs/dist/interact.min.js"></script>
<script src="/menu/layoutMenus.js"></script>
<script>
LayoutMenus.init({
  wrapSelector:    '#canvas-wrap',
  gridSelector:    '#menu-principal',
  tileSelector:    'a.tile-sb',
  btnFreeSelector: '#btnLibre',
  btnResetSelector:'#btnReset',
  menuSlug:        'index'
});
</script>

<% } %>
