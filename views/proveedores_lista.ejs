<% title = 'Proveedores' %>
<% hero  = false %>

<div id="prov-wrap" class="container my-4">
  <style>
    :root{
      --ink:#111827; --border:#e5e7eb; --shadow:0 1px 2px rgba(0,0,0,.05);
      --acc1:#0ea5e9; --acc2:#22c55e;
    }
  
    /* ===================== FORMULARIO (look informes) ===================== */
    #prov-wrap .form-panel{
      background:#fff; border:1px solid rgba(0,0,0,.08);
      border-radius:16px; box-shadow:var(--shadow);
      padding:14px 16px 18px; margin-bottom:14px;
      display:grid; grid-template-columns:1fr;
    }
    #prov-wrap .form-panel > .form-head,
    #prov-wrap .form-panel > .form-fields,
    #prov-wrap .form-panel > .form-toolbar{ grid-column:1 / -1; width:100%; }
  
    #prov-wrap .form-head{
      display:flex; align-items:center; justify-content:space-between;
      gap:12px; flex-wrap:wrap; margin-bottom:10px;
    }
    #prov-wrap .form-title{
      margin:0; font-weight:700; color:var(--ink);
      font-size:clamp(1.4rem,1.1rem + 1.2vw,2rem);
    }
    #prov-wrap .btn.btn-outline{
      border:1px solid rgba(0,0,0,.12); background:#fff; color:#111;
      border-radius:10px; padding:.48rem .9rem; text-decoration:none; white-space:nowrap;
      box-shadow:var(--shadow);
    }
    #prov-wrap .btn.btn-outline:hover{ background:#f3f4f6; }
  
    /* Filtros */
    #prov-wrap .form-fields{
      display:grid; gap:14px; padding-top:8px; border-top:1px dashed rgba(0,0,0,.08);
      grid-template-columns:1fr; margin-bottom:10px;
    }
    @media (min-width:992px){
      #prov-wrap .form-fields{ grid-template-columns:2fr 5fr; align-items:end; gap:18px; }
    }
    #prov-wrap .form-label{ font-weight:600; color:var(--ink); margin-bottom:.35rem; }
    #prov-wrap .control{
      width:100%; padding:.56rem .75rem; font-size:1rem;
      border:1px solid var(--border); border-radius:10px; background:#fff;
      box-shadow:var(--shadow);
    }
    /* Altura del select Estado para igualar al buscador */
    #prov-wrap #estado.control,
    #prov-wrap select#estado.form-select{
      padding-top:.66rem; padding-bottom:.66rem;
      min-height:44px; line-height:1.25;
    }
  
    /* Barras Diseño / Exportación */
    #prov-wrap .form-toolbar{
      display:flex; align-items:center; gap:10px; flex-wrap:wrap;
      margin:10px 0 0;
    }
    #prov-wrap .form-toolbar .label{ color:#6b7280; font-weight:600; margin:0; line-height:1; }
  
    /* ===================== CHIPS (diseño/export/selección) ===================== */
    .btn-chip{
      border:1px solid var(--border); background:#fff; color:var(--ink);
      border-radius:999px; padding:.36rem .72rem; cursor:pointer; white-space:nowrap;
    }
    .btn-chip:hover{ background:#f3f4f6; }
  
    /* ===================== GRID + TARJETAS ===================== */
    .grid{
      display:grid; gap:18px; padding:8px 8px 0;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    }
    @media (min-width:1024px){ .grid{ grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  
    .card{
      display:grid; grid-template-columns:110px 1fr; min-height:190px;
      background:#fff; border:1px solid var(--border); border-radius:16px;
      box-shadow:var(--shadow); color:var(--ink); position:relative; overflow:hidden;
      text-decoration:none; transition:transform .12s ease, box-shadow .12s ease;
    }
    .card:hover{ transform:translateY(-2px); box-shadow:0 10px 20px rgba(0,0,0,.08); }
  
    .media{
      display:flex; align-items:center; justify-content:center; padding:14px;
      background:
        radial-gradient(110px 110px at 25% 25%, rgba(255,255,255,.45), transparent),
        linear-gradient(160deg, var(--acc1), var(--acc2));
    }
    .grid[data-look="b"] .card{ border-color:#d1d5db; }
    .grid[data-look="b"] .media{
      background:repeating-linear-gradient(45deg, rgba(0,0,0,.05) 0 10px, rgba(0,0,0,.025) 10px 20px);
    }
    .grid[data-look="c"] .card{ background:rgba(255,255,255,.85); backdrop-filter:blur(6px); }
    .grid[data-look="c"] .media{
      background:linear-gradient(135deg, rgba(255,255,255,.7), rgba(255,255,255,.2));
    }
  
    .avatar{
      width:72px; height:72px; border-radius:16px; display:flex; align-items:center; justify-content:center;
      background:#ffffffc9; border:1px solid #e5e7eb; font-weight:800; font-size:26px; color:#0b1220;
    }
    .body{ padding:14px 16px 12px 6px; display:flex; flex-direction:column; gap:8px; min-width:0; }
    .top{ display:flex; align-items:center; gap:8px; position:relative; padding-right:44px; } /* hueco para check */
    .title{ font-weight:800; font-size:1.12rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .sub{ color:#6b7280; }
    .meta{ display:flex; gap:12px; flex-wrap:wrap; color:#475569; font-size:.95rem; }
    .meta .i{ width:16px; height:16px; fill:currentColor; opacity:.8; }
  
    .actions{ display:flex; align-items:center; gap:10px; margin-top:auto; }
    .btn-ghost{
      border:1px solid var(--border); background:#fff; border-radius:999px; padding:.32rem .65rem; font-size:.9rem;
    }
    .btn-ghost:hover{ background:#f9fafb; }
    .spacer{ flex:1; }
    .cif{
      font-family:ui-monospace, Menlo, monospace; background:#f9fafb; border:1px dashed #d1d5db;
      padding:.18rem .45rem; border-radius:8px; color:#334155;
    }
  
    /* Selección */
    .sel{ display:flex; align-items:center; gap:8px; margin:8px 8px 12px; }
    .count{ color:#6b7280; font-size:.94rem; }
    .check{ position:absolute; top:10px; right:10px; width:18px; height:18px; accent-color:#0ea5e9; }
    .card.selected{ outline:2px solid #0ea5e9; outline-offset:2px; }
  
    /* Punto de estado */
    #prov-wrap .card .top .status-dot{
      position:static !important; margin:0 6px 0 0; width:10px; height:10px; border-radius:50%;
      display:inline-block; vertical-align:middle;
      box-shadow:0 0 0 2px rgba(0,0,0,.06) inset, 0 0 8px rgba(0,0,0,.15);
    }
    .status-dot.is-ok{  background:#22c55e; }
    .status-dot.is-off{ background:#ef4444; }
  
    /* Paletas alternas */
    .grid .card:nth-child(6n+1){ --acc1:#0ea5e9; --acc2:#22c55e; }
    .grid .card:nth-child(6n+2){ --acc1:#a855f7; --acc2:#06b6d4; }
    .grid .card:nth-child(6n+3){ --acc1:#f59e0b; --acc2:#ef4444; }
    .grid .card:nth-child(6n+4){ --acc1:#14b8a6; --acc2:#3b82f6; }
    .grid .card:nth-child(6n+5){ --acc1:#ef4444; --acc2:#f97316; }
    .grid .card:nth-child(6n+6){ --acc1:#6366f1; --acc2:#22c55e; }
  
    /* Responsive tarjeta */
    @media (max-width:640px){
      .card{ grid-template-columns:90px 1fr; }
      .avatar{ width:60px; height:60px; font-size:22px; }
    }
  </style>
  
  <form id="filtro-form" method="GET" class="form-panel">
    <div class="form-head">
      <h1 class="form-title">Proveedores</h1>
      <a href="/proveedores/nuevo" class="btn btn-outline">＋ Nuevo proveedor</a>
    
    </div>
  
    <!-- Fila 2: Filtros -->
    <div class="form-fields">
      <div>
        <label for="estado" class="form-label">Estado</label>
        <select id="estado" name="estado" class="control"
                onchange="document.getElementById('filtro-form').submit()">
          <option value="">Todos</option>
          <option value="1" <%= estado === '1' ? 'selected' : '' %>>Activos</option>
          <option value="0" <%= estado === '0' ? 'selected' : '' %>>Inactivos</option>
        </select>
      </div>
      <div>
        <label for="busqueda-proveedores" class="form-label">Buscar</label>
        <input id="busqueda-proveedores" type="text" name="q"
               value="<%= q || '' %>" class="control"
               placeholder="Nombre, CIF/NIF, email, teléfono…">
      </div>
    </div>
  
    <!-- Fila 3: Diseño (usa tus .btn-chip existentes) -->
    <div class="form-toolbar">
      <span class="label">Diseño:</span>
      <button type="button" class="btn-chip" data-look="a">Color</button>
      <button type="button" class="btn-chip" data-look="b">Contorno</button>
      <button type="button" class="btn-chip" data-look="c">Glass</button>
    </div>
  </form>
   
  <!-- Exportación -->
  <div class="form-toolbar">
    <span class="label">Exportar:</span>
    <button type="button" class="btn-chip" onclick="exportar('pdf')">PDF</button>
    <button type="button" class="btn-chip" onclick="exportar('png')">PNG</button>
    <button type="button" class="btn-chip" onclick="exportar('vcf')">vCard</button>
  </div>
  <!-- Selección -->
  <div class="sel">
    <button type="button" class="btn-chip" id="selVis">Seleccionar visibles</button>
    <button type="button" class="btn-chip" id="selNone">Quitar selección</button>
    <span class="count" id="selCount">0 seleccionados</span>
  </div>

  <!-- Grid tarjetas -->
  <% if ((proveedores || []).length > 0) { %>
    <div class="grid" id="grid" data-look="a">
      <% const initials = (s='') => s.trim().split(/\s+/).slice(0,2).map(x => (x[0]||'').toUpperCase()).join(''); %>
      <% proveedores.forEach(p => { %>
        <a href="/proveedores/<%= p.id %>" class="card"
           data-id="<%= p.id %>"
           data-activo="<%= p.activo ? '1':'0' %>"
           data-texto="<%= (p.nombre + ' ' + (p.cif||'') + ' ' + (p.email||'') + ' ' + (p.telefono||'') + ' ' + (p.contacto||'')).toLowerCase() %>">

          <input type="checkbox" class="check" aria-label="Seleccionar <%= p.nombre %>">

          <div class="media" aria-hidden="true">
            <div class="avatar"><%= initials(p.nombre) %></div>
          </div>

          <div class="body">
            <div class="top">
              <span class="status-dot <%= p.activo ? 'is-ok' : 'is-off' %>"
                    title="<%= p.activo ? 'Activo' : 'Inactivo' %>"></span>
              <span class="title"><%= p.nombre %></span>
            </div>

            <% if (p.contacto) { %>
              <div class="sub">Contacto: <strong><%= p.contacto %></strong></div>
            <% } %>

            <div class="meta">
              <% if (p.email) { %>
                <span><svg class="i"><use href="#i-mail"/></svg> <%= p.email %></span>
              <% } %>
              <% if (p.telefono) { %>
                <span><svg class="i"><use href="#i-phone"/></svg> <%= p.telefono %></span>
              <% } %>
            </div>

            <div class="actions">
              <% if (p.email) { %>
                <button type="button" class="btn-ghost" onclick="event.stopPropagation(); window.location='mailto:<%= p.email %>'">Email</button>
              <% } %>
              <% if (p.telefono) { %>
                <button type="button" class="btn-ghost" onclick="event.stopPropagation(); window.location='tel:<%= p.telefono %>'">Llamar</button>
              <% } %>
              <span class="spacer"></span>
              <span class="cif"><%= p.cif || '—' %></span>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } else { %>
    <p class="mt-4" style="text-align:center;">No hay proveedores con esos filtros.</p>
  <% } %>
</div>

<!-- SVG icons -->
<svg width="0" height="0" style="position:absolute;visibility:hidden">
  <symbol id="i-mail" viewBox="0 0 24 24"><path d="M4 6h16v12H4z"/><path d="M22 6l-10 7L2 6"/></symbol>
  <symbol id="i-phone" viewBox="0 0 24 24"><path d="M6 2h4l2 5-3 2a14 14 0 0 0 6 6l2-3 5 2v4a2 2 0 0 1-2 2 18 18 0 0 1-18-18 2 2 0 0 1 2-2z"/></symbol>
</svg>

<script>
(()=>{
  const grid   = document.getElementById('grid');
  const input  = document.getElementById('busqueda-proveedores');
  const estado = document.getElementById('estado');
  const lookBtns = document.querySelectorAll('.btn-chip[data-look]');
  const selCount = document.getElementById('selCount');
  const cards  = () => Array.from(document.querySelectorAll('#grid .card'));

  // Filtro
  function filtrar(){
    const q = (input?.value || '').toLowerCase().trim();
    const est = estado?.value || '';
    cards().forEach(card => {
      const txt = card.getAttribute('data-texto') || '';
      const act = card.getAttribute('data-activo') || '';
      const ok = (!q || txt.includes(q)) && (!est || act === est);
      card.style.display = ok ? '' : 'none';
    });
    contarSel();
  }
  input?.addEventListener('input', filtrar);

  // Selección
  function contarSel(){ selCount.textContent = cards().filter(c=>c.classList.contains('selected')).length + ' seleccionados'; }
  grid?.addEventListener('change', e => {
    const cb = e.target.closest('.check'); if(!cb) return;
    const card = e.target.closest('.card'); card?.classList.toggle('selected', cb.checked);
    contarSel();
  });
  grid?.addEventListener('click', e => { if (e.target.closest('.check')) e.stopPropagation(); });

  document.getElementById('selVis')?.addEventListener('click', () => {
    cards().forEach(c => { const v = c.offsetParent !== null; const cb = c.querySelector('.check'); if(cb) cb.checked=v; c.classList.toggle('selected', v); });
    contarSel();
  });
  document.getElementById('selNone')?.addEventListener('click', () => {
    cards().forEach(c => { const cb=c.querySelector('.check'); if(cb) cb.checked=false; c.classList.remove('selected'); });
    contarSel();
  });

  // Look (3 diseños)
  function applyLook(v){ if(!grid) return; grid.setAttribute('data-look', v); lookBtns.forEach(b=>b.classList.toggle('active', b.dataset.look===v)); localStorage.setItem('prov-look', v); }
  lookBtns.forEach(b => b.addEventListener('click', ()=>applyLook(b.dataset.look)));
  applyLook(localStorage.getItem('prov-look') || 'a');

  // Exportar
  window.exportar = function(tipo){
    const sel = cards().filter(c=>c.classList.contains('selected') && c.offsetParent!==null).map(c=>c.getAttribute('data-id'));
    const vis = cards().filter(c=>c.offsetParent!==null).map(c=>c.getAttribute('data-id'));
    const ids = (sel.length ? sel : vis).filter(Boolean);
    const look = grid?.getAttribute('data-look') || 'a';
    const qs = new URLSearchParams(); if(ids.length) qs.set('ids', ids.join(',')); qs.set('look', look);
    const url = tipo==='vcf' ? `/proveedores/export/vcf?${qs}` : tipo==='png' ? `/proveedores/export/png?${qs}` : `/proveedores/export/pdf?${qs}`;
    window.location = url;
  };

  filtrar();
})();
</script>