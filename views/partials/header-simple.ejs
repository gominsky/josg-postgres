<header class="header-simple d-flex align-items-center justify-content-between px-3 py-2 flex-wrap">
  <div class="header-logo me-4">JOSG</div>

  <div class="header-nav-wrapper flex-grow-1 me-3">
    <div class="header-nav d-flex align-items-center gap-3 justify-content-end pt-2">
      <a href="/alumnos" class="card-cabecera">Alumnos</a>
      <a href="/profesores" class="card-cabecera">Docentes</a>
      <a href="/eventos" class="card-cabecera">Eventos</a>
      <a href="/guardias" class="card-cabecera">Guardias</a>
      <a href="/informes" class="card-cabecera">Informes</a>
      <a href="/cuotas" class="card-cabecera">Cuotas</a>
      <a href="/grupos" class="card-cabecera">Grupos</a>
      <a href="/instrumentos" class="card-cabecera">Instrumentos</a>
      <a href="/" class="card-cabecera">Inicio</a>
    </div>
  </div>

  <% if (usuario) { %>
    <div class="user-info d-flex flex-column align-items-end">
      <span class="fw-bold"><%= usuario.nombre %> (<%= usuario.rol %>)</span>
      <a href="/logout" class="btn-mini btn-main-verde mt-1">Cerrar sesión</a>
    </div>
  <% } %>
</header>
