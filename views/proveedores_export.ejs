<% /* views/proveedores_export.ejs */ %>
<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title><%= title %></title>
  <style>
    :root{
      /* base */
      --ink:#0b1220; --muted:#475569; --border:rgba(0,0,0,.12);
      /* marca */
      --brand-orange:#FF9501; --brand-yellow:#ffb020; --brand-cream:#fff3dc;
      --brand-black:#111827;
    }
    *{ box-sizing:border-box; }
    body{
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, Arial, "Apple Color Emoji", "Segoe UI Emoji";
      margin:0; color:var(--ink); background:#f7f8fb;
    }

    /* === Lienzo (más ancho por tarjeta) === */
    .page{
      padding:10mm;
      display:grid;
      /* tarjetas algo más anchas: 100mm vs 92mm */
      grid-template-columns: repeat(auto-fill, minmax(100mm, 1fr));
      gap: 8mm;
    }

    /* === Tarjeta base (forma/contorno) === */
    .bizcard{
      display:grid; grid-template-columns: 36mm 1fr;
      width: 100%; min-height: 62mm;
      background:#fff; border:1.2px solid var(--border); border-radius: 12px;
      overflow:hidden; color:inherit; position:relative;
      box-shadow: 0 4px 14px rgba(0,0,0,.06);
      break-inside: avoid;
    }
    .biz-media{ display:flex; align-items:center; justify-content:center; padding:6mm; }
    .biz-avatar{
      width:22mm; height:22mm; border-radius:6mm; display:flex; align-items:center; justify-content:center;
      font-weight:800; font-size:8mm; color:#0b1220; background:#f3f4f6; border:1px solid rgba(0,0,0,.06);
    }

    .biz-body{ padding:6mm 6mm 5mm 5mm; display:flex; flex-direction:column; gap:2.2mm; min-width:0; }
    .title-row{ display:flex; align-items:center; gap:3mm; min-width:0; }
    .biz-title{ font-size:5mm; font-weight:800; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; }
    .status-dot{ width:3.2mm; height:3.2mm; border-radius:50%; display:inline-block; box-shadow:0 0 0 .5mm rgba(0,0,0,.06) inset; }
    .status-ok{ background:#22c55e; } .status-off{ background:#ef4444; }

    .biz-sub{ color:#64748b; font-size:3.8mm; }
    .meta-line{ display:flex; gap:6mm; flex-wrap:wrap; color:#334155; font-size:3.6mm; }
    .meta-item{ display:inline-flex; align-items:center; gap:2.5mm; }
    .i{ width:4mm; height:4mm; fill:currentColor; opacity:.85; }

    /* ===== Estilos (server-side por style o compat por look) ===== */
    <% var __style = (typeof style !== 'undefined' && style)
         ? style
         : ((typeof look !== 'undefined' && look)
              ? (look==='a' ? 'classic' : look==='b' ? 'cream' : 'gradient')
              : 'classic'); %>

    /* 0) Classic */
    <% if (__style==='classic') { %>
      .bizcard{ background:#fff; border-color:#d1d5db; box-shadow:0 4px 12px rgba(0,0,0,.06); color:#111827; }
      .biz-media{ background:#f9fafb; }
    <% } %>

    /* 1) Naranja Pro */
    <% if (__style==='orange') { %>
      .bizcard{ background:var(--brand-orange); border-color:#d97706; color:#111; box-shadow:0 8px 18px rgba(255,149,1,.25); }
      .biz-media{ background:rgba(255,255,255,.18); }
      .biz-avatar{ background:#fff; }
      .biz-sub, .meta-line{ color:#111827; }
    <% } %>

    /* 2) Noir */
    <% if (__style==='noir') { %>
      .bizcard{ background:#0d1117; border-color:#1f2937; color:#f8fafc; box-shadow:0 8px 22px rgba(0,0,0,.35); }
      .bizcard::before{ content:""; position:absolute; left:0; right:0; top:0; height:3mm; background: var(--brand-orange); }
      .biz-media{ background:#11161c; }
      .biz-avatar{ background:#0f172a; color:#e2e8f0; border-color:#111820; }
      .biz-sub, .meta-line{ color:#cbd5e1; }
      .status-dot{ box-shadow:0 0 0 .5mm rgba(255,255,255,.2) inset; }
    <% } %>

    /* 3) Cream Pattern */
    <% if (__style==='cream') { %>
      .bizcard{
        background:
          repeating-linear-gradient(135deg, rgba(0,0,0,.035) 0 4mm, transparent 4mm 8mm),
          var(--brand-cream);
        border-color: rgba(0,0,0,.18); color:#0f172a; box-shadow:0 6px 16px rgba(0,0,0,.08);
      }
      .biz-media{ background:#fff9f0; }
      .biz-avatar{ background:#fff; }
      .biz-sub{ color:#334155; } .meta-line{ color:#475569; }
    <% } %>

    /* 4) Gradient Bold */
    <% if (__style==='gradient') { %>
      .bizcard{
        background: linear-gradient(160deg, var(--brand-orange) 0%, var(--brand-yellow) 100%);
        border-color: rgba(17,24,39,.25); color:#111; box-shadow:0 10px 26px rgba(255,149,1,.25);
      }
      .bizcard::before{ content:""; position:absolute; inset:0 auto 0 0; width:3mm; background:#000; opacity:.75; }
      .biz-media{ background: rgba(255,255,255,.2); }
      .biz-avatar{ background:#fff; }
      .biz-sub, .meta-line{ color:#111827; }
    <% } %>

    @page{ size: A4; margin: 0; }
    @media print{
      body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .page{ padding:10mm; background:none; }
    }
  </style>
</head>
<body>
  <div class="page">
    <%
      const initials = s => (s||'').trim().split(/\s+/).slice(0,2).map(x => (x[0]||'').toUpperCase()).join('');
    %>
    <% (proveedores||[]).forEach(p => { %>
      <div class="bizcard" data-id="<%= p.id %>" data-name="<%= p.nombre %>">
        <div class="biz-media">
          <div class="biz-avatar"><%= initials(p.nombre) %></div>
        </div>
        <div class="biz-body">
          <div class="title-row">
            <span class="biz-title"><%= p.nombre %></span>
            <span class="status-dot <%= p.activo ? 'status-ok' : 'status-off' %>"
                  title="<%= p.activo ? 'Activo' : 'Inactivo' %>"></span>
          </div>

          <% if (p.contacto) { %>
            <div class="biz-sub">Contacto: <strong><%= p.contacto %></strong></div>
          <% } %>

          <div class="meta-line">
            <span class="meta-item">
              <svg class="i" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="12" r="3"/><path d="M14 10h5M14 14h5"/></svg>
              <%= p.cif || '—' %>
            </span>
            <% if (p.email) { %>
              <span class="meta-item">
                <svg class="i" viewBox="0 0 24 24"><path d="M4 6h16v12H4z"/><path d="M22 6l-10 7L2 6"/></svg>
                <%= p.email %>
              </span>
            <% } %>
            <% if (p.telefono) { %>
              <span class="meta-item">
                <svg class="i" viewBox="0 0 24 24"><path d="M6 2h4l2 5-3 2a14 14 0 0 0 6 6l2-3 5 2v4a2 2 0 0 1-2 2 18 18 0 0 1-18-18 2 2 0 0 1 2-2z"/></svg>
                <%= p.telefono %>
              </span>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</body>
</html>
