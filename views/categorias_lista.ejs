<% title = 'Categorías de gasto' %>
<% hero  = false %>

<div id="cats-list-wrap" class="container my-4">
  <div class="panel-card panel-narrow">
    <div class="list-header">
      <h1 class="h1-titulo" style="margin:0;">Categorías de gasto</h1>
      <div class="header-actions" style="display:flex; gap:8px; align-items:center;">
        <form action="/categorias" method="GET" style="display:flex; gap:6px; align-items:center; background:transparent;">
          <input type="search" name="q" value="<%= q || '' %>" placeholder="Buscar nombre…" class="form-control" style="max-width:220px;">
          <button class="btn btn-outline" type="submit">Buscar</button>
        </form>
        <a class="btn btn-outline" href="/categorias/nuevo">＋ Nueva categoría</a>
      </div>
    </div>

    <% const _cats = Array.isArray(categorias) ? categorias : []; %>
    <div class="small" style="margin-top:8px; color:var(--muted);">
      <strong><%= _cats.length %></strong> categorías
    </div>

    <% if (_cats.length === 0) { %>
      <p class="text-muted" style="margin-top:12px;">No hay resultados.</p>
    <% } else { %>
      <table class="table-lite table-no-scroll table-compact">
        <colgroup>
          <col style="width: 72%">     <!-- Nombre -->
          <col style="width: 22%">     <!-- Padre -->
          <col style="width: 70px">    <!-- Aspa -->
        </colgroup>
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Padre</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% _cats.forEach(row => { %>
            <tr class="clickable-row" onclick="location.href='/categorias/<%= row.id %>'">
              <td title="<%= row.nombre %>"><%= row.nombre %></td>
              <td title="<%= row.padre_nombre || '' %>"><%= row.padre_nombre || '—' %></td>
              <td class="text-end no-ellipsis" onclick="event.stopPropagation()">
                <form method="POST" action="/categorias/<%= row.id %>/eliminar" style="display:inline; background-color: transparent;">
                  <a href="#"
                     class="aspa-roja"
                     title="Eliminar"
                     aria-label="Eliminar"
                     onclick="event.stopPropagation(); if (confirm('¿Eliminar la categoría &quot;<%= row.nombre %>&quot;?')) this.closest('form').submit(); return false;">×</a>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<div class="volver-bloque-izquierda">
  <a href="/configuracion" class="enlace-final">← Volver a configuración</a>
</div>

<style>
  #cats-list-wrap .panel-narrow{ max-width: 1000px; margin: 0 auto; }

  .table-no-scroll{ width:100%; border-collapse:collapse; table-layout: fixed; }
  .table-no-scroll th, .table-no-scroll td{
    border:1px solid #e9ecef; vertical-align:middle;
    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
  }
  .table-compact th, .table-compact td{ padding:6px 8px; font-size:.95rem; }
  .table-compact thead th{ font-weight:700; }

  /* Evitar "..." en la columna del aspa */
  .no-ellipsis{ overflow: visible !important; text-overflow: clip !important; }

  .aspa-roja{ color:#dc2626; font-weight:700; font-size:18px; line-height:1; text-decoration:none; padding:0 .25rem; cursor:pointer; }
  .aspa-roja:hover{ color:#b91c1c; }
</style>

