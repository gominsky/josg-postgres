<% hero = false %>

<div class="container my-4">
  <div class="panel-card">
    <div class="form-head">
      <h1 class="h1-titulo"><%= title %></h1>
    </div>
    <form method="POST" action="<%= EDIT ? ('/cuentas/' + cuenta.id) : '/cuentas/nuevo' %>" style="background-color: transparent";>
      <!-- Nombre -->
      <div class="mb-3">
        <label class="form-label">Nombre de la cuenta</label>
        <input class="form-control" name="nombre" required autofocus
               placeholder="Ej. 400 Proveedores / 572 Bancos"
               value="<%= cuenta?.nombre || '' %>">
        <div class="help-text">Usa el nombre tal y como quieres verlo en listados y sugerencias.</div>
      </div>

      <!-- Estado (solo en edición) -->
      <% if (EDIT) { %>
        <div class="mb-3">
  <label class="form-label">Estado</label>
  <div class="checkline">
    <input
      type="checkbox"
      id="activo"
      name="activo"
      class="chk-orange"
      <%= (cuenta?.activo !== false) ? 'checked' : '' %> >
    <label for="activo" class="chk-orange-label" style="margin:0;cursor:pointer;">
  Activa (desmarca para dejarla inactiva)
</label>
  </div>
</div>

      <% } %>

      <div class="actions">
        <a class="btn-primary-negro" href="/cuentas">Cancelar</a>
        <button class="btn-primary-negro" type="submit">Guardar</button>
      </div>
    </form>
  </div>

  <div class="volver-bloque-izquierda" style="margin-top:12px;">
    <a href="/contabilidad" class="enlace-final">← Volver a contabilidad</a>
  </div>
</div>
