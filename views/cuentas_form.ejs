<% hero=false; %>
<div class="container my-4">
  <div class="panel-card" style="background:#fff;border:1px solid rgba(0,0,0,.08);border-radius:18px;padding:16px;max-width:720px;">
    <h1 class="h1-titulo"><%= title %></h1>
    <form method="POST" action="<%= EDIT?('/cuentas/'+cuenta.id):'/cuentas/nuevo' %>">
      <div class="mb-3">
        <label class="form-label">Nombre</label>
        <input class="form-control" name="nombre" required value="<%= cuenta?.nombre||'' %>">
      </div>
      <% if (EDIT) { %>
      <div class="mb-3">
        <label class="form-label">Activo</label>
        <input type="checkbox" name="activo" <%= (cuenta?.activo!==false)?'checked':'' %> >
      </div>
      <% } %>
      <div class="d-flex gap-2">
        <a class="btn btn-outline" href="/cuentas">Cancelar</a>
        <button class="btn-main">Guardar</button>
      </div>
    </form>
  </div>
</div>
