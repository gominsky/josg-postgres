<% const isEdicion = Boolean(item && item.id); %>
<% title = isEdicion ? 'Editar tipo de ausencia' : 'Nuevo tipo de ausencia'; %>
<% hero = false; %>

<div class="header-compact">
  <h1 class="h1-titulo"><%= title %></h1>
  <a href="/ausencias" class="enlace-final">← Volver</a>
</div>

<form method="POST"
      action="<%= isEdicion ? '/ausencias/editar/' + item.id : '/ausencias' %>"
      class="formulario-alumno contenedor-borde">
  <div class="grupo-campos">
    <h2>Datos</h2>
    <div class="form-grid-2">
      <label>Tipo:
        <input type="text" name="tipo" required value="<%= item?.tipo || '' %>">
      </label>
    </div>
  </div>
  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/ausencias" class="enlace-final-naranja">← Volver</a>
    <button type="submit" class="btn-main-blanco"><%= isEdicion ? 'Actualizar' : 'Crear' %></button>
  </div>
</form>

<% if (isEdicion) { %>
  <form method="POST" action="/ausencias/eliminar/<%= item.id %>"
        onsubmit="return confirm('¿Eliminar este tipo de ausencia?');"
        class="text-center mt-3">
    <button type="submit" class="btn-main-blanco btn-rojo btn-sm">Eliminar</button>
  </form>
<% } %>
