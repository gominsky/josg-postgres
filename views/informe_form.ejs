<% title = 'Crear Informe' %>
<% hero = false %>

<div class="container my-4">
  <div class="row g-4">

    <!-- Filtros del informe -->
    <div class="col-md-5">
      <div class="formulario-centrado p-3 rounded">
        <form action="/informes/ficha/filtrar" method="POST" id="form-filtrar">
          <h2 class="h5 mb-3 text-dark text-center fw-bold">Filtros</h2>
          <div class="mb-2">
            <label class="form-label form-label-sm fw-bold">Nombre del informe</label>
            <input type="text" name="nombre_informe" class="form-control form-control-sm" required value="<%= nombreInforme || '' %>">
          </div>

          <div class="mb-3">
            <label for="grupo_id" class="form-label fw-bold">Grupo</label>
            <select class="form-select" name="grupo_id" id="grupo_id" required>
              <option value="todos" <%= grupoSeleccionado === 'todos' ? 'selected' : '' %>>Todos</option>
              <option value="ninguno" <%= grupoSeleccionado === 'ninguno' ? 'selected' : '' %>>Ninguno</option>
              <% grupos.forEach(grupo => { %>
                <option value="<%= grupo.id %>" <%= grupoSeleccionado == grupo.id ? 'selected' : '' %>><%= grupo.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3" id="bloque-instrumento">
            <label for="instrumento_id" class="form-label fw-bold">Instrumento</label>
            <select class="form-select" name="instrumento_id" id="instrumento-select" required>
              <option value="todos" <%= instrumentoSeleccionado === 'todos' ? 'selected' : '' %>>Todos</option>
              <% instrumentos.forEach(inst => { %>
                <option value="<%= inst.id %>" <%= instrumentoSeleccionado == inst.id ? 'selected' : '' %>><%= inst.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="mb-2">
            <label class="form-label form-label-sm fw-bold">Fecha</label>
            <input type="date" name="fecha" class="form-control form-control-sm" id="fecha-input" required value="<%= fechaHoy %>">
            <label class="form-label form-label-sm fw-bold">Fecha fin</label>
            <input type="date" name="fecha_fin" class="form-control form-control-sm" id="fecha-fin-input" value="<%= typeof fecha_fin !== 'undefined' ? fecha_fin : fechaHoy %>">
          </div>

          <div class="d-flex justify-content-center gap-2 mb-3">
            <button type="submit" class="btn btn-dark btn-sm">Aplicar filtros</button>
            <button formaction="/informes/horas" formmethod="GET" class="btn-main-blanco fw-bold px-3 py-1">Porcentaje de horas</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Formulario de resultados -->
    <div class="col-md-7">
      <% if (grupoSeleccionado === 'ninguno') { %>
        <div class="mensaje-ok text-center">Informe sin alumnos, añade campos.</div>
      <% } else if (alumnos && alumnos.length) { %>
        <div class="mensaje-ok text-center">Alumnos filtrados, añade campos.</div>
      <% } %>

      <% if (grupoSeleccionado === 'ninguno' || (alumnos && alumnos.length)) { %>
        <form id="form-informe" method="POST" action="/informes/ficha/guardar-json" class="formulario-centrado">
          <input type="hidden" name="nombre_informe" value="<%= nombreInforme %>">
          <input type="hidden" name="grupo_id" value="<%= grupoSeleccionado %>">
          <input type="hidden" name="instrumento_id" value="<%= instrumentoSeleccionado %>">
          <input type="hidden" name="profesor_id" value="<%= profesorSeleccionado %>">
          <input type="hidden" name="fecha" value="<%= fechaHoy %>">
          <input type="hidden" name="fecha_fin" value="<%= typeof fecha_fin !== 'undefined' ? fecha_fin : fechaHoy %>">
          <input type="hidden" name="resultados" id="resultados-json">
          <input type="hidden" name="campos_json" id="campos-json">

          <h2 class="h5 mb-3 text-dark text-center">Elegir campos para el informe</h2>
          <!-- Botón añadir campo con preventDefault para evitar submit -->
          <div class="text-center mb-3">
            <button type="button" class="btn btn-dark btn-sm" onclick="event.preventDefault(); addCampo()">+ Añadir campo</button>
          </div>

          <table class="table table-bordered table-sm" id="tabla-campos">
            <thead class="table-light">
              <tr>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Obligatorio</th>
                <th>Acción</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>

          <div id="alumnos-container" class="table-responsive mb-3"></div>

          <div class="text-center">
            <button type="submit" class="btn btn-dark btn-sm">Guardar informe</button>
          </div>
        </form>

        <script>
          const campos = [];
          const alumnos = <%- JSON.stringify(alumnos) %>;

          function renderTablaAlumnos(camposFinal) {
            const cont = document.getElementById('alumnos-container');
            if (!alumnos.length || !camposFinal.length) return cont.innerHTML = '';
            let html = `<table class="table table-sm table-bordered"><thead><tr><th>Alumno</th>`;
            camposFinal.forEach((c, i) => html += `<th>${c.nombre || 'Campo ' + (i+1)}</th>`);
            html += `</tr></thead><tbody>`;
            alumnos.forEach(al => {
              html += `<tr><td>${al.apellidos}, ${al.nombre}</td>`;
              camposFinal.forEach((campo, idx) => {
                const nm = `r_${al.id}_${idx}`;
                let inp = campo.tipo === 'texto'
                  ? `<input type="text" class="form-control form-control-sm" name="${nm}">`
                  : campo.tipo === 'numero'
                    ? `<input type="number" class="form-control form-control-sm" name="${nm}" step="0.01">`
                    : `<input type="checkbox" class="form-check-input" name="${nm}">`;
                html += `<td>${inp}</td>`;
              });
              html += `</tr>`;
            });
            html += `</tbody></table>`;
            cont.innerHTML = html;
          }

          function addCampo() {
            const tbody = document.querySelector('#tabla-campos tbody');
            const idx = campos.length;
            campos.push({ nombre: '', tipo: 'texto', obligatorio: false });

            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td><input type="text" class="form-control form-control-sm" data-idx="${idx}" data-prop="nombre" oninput="updateCampo(${idx}, 'nombre', this.value)"></td>
              <td>
                <select class="form-select form-select-sm" data-idx="${idx}" data-prop="tipo" onchange="updateCampo(${idx}, 'tipo', this.value)">
                  <option value="texto">Texto</option>
                  <option value="numero">Número</option>
                  <option value="booleano">Sí/No</option>
                </select>
              </td>
              <td class="text-center"><input type="checkbox" class="form-check-input" data-idx="${idx}" data-prop="obligatorio" onchange="updateCampo(${idx}, 'obligatorio', this.checked)"></td>
              <td><button type="button" class="btn btn-sm text-danger" onclick="removeCampo(${idx})">×</button></td>
            `;
            tbody.appendChild(tr);
            renderTablaAlumnos(campos);
          }

          function updateCampo(idx, prop, val) {
            campos[idx][prop] = prop === 'obligatorio' ? (val ? 1 : 0) : val;
            renderTablaAlumnos(campos);
          }

          function removeCampo(idx) {
            campos.splice(idx, 1);
            document.querySelectorAll('#tabla-campos tr')[idx+1].remove();
            renderTablaAlumnos(campos);
          }

          document.getElementById('form-informe').addEventListener('submit', function(e) {
            document.getElementById('campos-json').value = JSON.stringify(campos);
            const resultados = [];
            document.querySelectorAll('#alumnos-container input').forEach(el => {
              const [_, alId, campoIdx] = el.name.split('_');
              const val = el.type === 'checkbox' ? (el.checked ? '1':'0') : el.value;
              resultados.push({ alumno_id: parseInt(alId), campo_index: parseInt(campoIdx), valor: val });
            });
            document.getElementById('resultados-json').value = JSON.stringify(resultados);
          });
        </script>
      <% } else { %>
        <p class="mensaje-error">No alumnos activos.</p>
      <% } %>
    </div>
  </div>
</div>
<div class="volver-bloque-izquierda mt-4">
  <a href="/informes" class="enlace-final">← Volver</a>
</div>
