<% title = 'Crear Informe' %>
<% hero = false %>

<div class="container my-4">
  <div class="row g-4">

    <!-- ========== PASO 1: NOMBRE (y filtros ocultos recibidos) ========== -->
    <div class="col-md-5">
      <div class="formulario-centrado p-3 rounded">
        <form action="/informes/ficha/filtrar" method="POST" id="form-filtrar">
          <h2 class="h5 mb-3 text-dark text-center fw-bold">Crear informe/listado</h2>

          <!-- Campo: Nombre del informe / archivo -->
          <div class="mb-2">
            <label class="form-label form-label-sm fw-bold">Nombre</label>
            <input type="text"
                   name="nombre_informe"
                   class="form-control form-control-sm"
                   value="<%= nombreInforme || '' %>"
                   placeholder="Ej.: Listado Grupo X Instr. Y 2025-06-01">
          </div>

          <!-- Filtros ocultos heredados de Informes y certificados -->
          <input type="hidden" name="grupo_id"        value="<%= grupoSeleccionado %>">
          <input type="hidden" name="instrumento_id"  value="<%= instrumentoSeleccionado %>">
          <input type="hidden" name="fecha"           value="<%= fechaHoy %>">
          <input type="hidden" name="fecha_fin"       value="<%= typeof fecha_fin !== 'undefined' ? fecha_fin : fechaHoy %>">

          <!-- Resumen visual con NOMBRES (no IDs) y sin fecha_fin -->
          <%
            const resumenGrupo = (() => {
              const gs = (typeof grupoSeleccionado === 'undefined' ? 'todos' : grupoSeleccionado);
              if (gs === 'todos' || gs === '' || gs == null) return 'Todos';
              if (gs === 'ninguno') return 'Ninguno';
              const g = (grupos || []).find(x => String(x.id) === String(gs));
              return g ? g.nombre : String(gs);
            })();

            const resumenInst = (() => {
              if (grupoSeleccionado === 'ninguno') return 'Ninguno';  // 👈 regla pedida
              const isel = (typeof instrumentoSeleccionado === 'undefined' ? 'todos' : instrumentoSeleccionado);
              if (isel === 'todos' || isel === '' || isel == null) return 'Todos';
              const i = (instrumentos || []).find(x => String(x.id) === String(isel));
              return i ? i.nombre : String(isel);
            })();
          %>

          <div class="small text-muted mb-2">Filtros recibidos:</div>
          <div class="d-flex flex-wrap gap-2 mb-3">
            <span class="badge-soft">Grupo: <strong><%= resumenGrupo %></strong></span>
            <span class="badge-soft">Instrumento: <strong><%= resumenInst %></strong></span>
            <span class="badge-soft">Fecha: <strong><%= fechaHoy %></strong></span>
          </div>

          <div class="d-flex justify-content-center gap-2 mb-3">
            <button type="submit" class="btn btn-dark btn-sm">Guardar nombre</button>
          </div>
        </form>
      </div>
    </div>

    <!-- ========== PASO 2: CAMPOS + ALUMNOS ========== -->
    <div class="col-md-7" id="seccion-campos">
      <% if (grupoSeleccionado==='ninguno') { %>
        <div class="mensaje-ok text-center">Informe sin alumnos, añade campos.</div>
      <% } else if (alumnos && alumnos.length) { %>
        <div class="mensaje-ok text-center">Alumnos filtrados, añade campos para ver la tabla.</div>
      <% } %>

      <% if (grupoSeleccionado==='ninguno' || (alumnos && alumnos.length)) { %>
        <form id="form-informe" method="POST" action="/informes/ficha/guardar-json" class="formulario-centrado">
          <!-- hidden coherentes con backend -->
          <input type="hidden" name="nombre_informe" value="<%= nombreInforme %>">
          <input type="hidden" name="grupo_id" value="<%= grupoSeleccionado %>">
          <input type="hidden" name="instrumento_id" value="<%= instrumentoSeleccionado %>">
          <input type="hidden" name="profesor_id" value="<%= typeof profesorSeleccionado==='undefined' ? '' : profesorSeleccionado %>">
          <input type="hidden" name="fecha" value="<%= fechaHoy %>">
          <input type="hidden" name="campos_json" id="campos-json">
          <input type="hidden" name="resultados" id="resultados-json">
          <input type="hidden" name="mostrar_grupo" value="<%= showGroup? '1':'0' %>">
          <input type="hidden" name="mostrar_instrumento" value="<%= showInstrument? '1':'0' %>">

          <h2 class="h5 mb-3 text-dark text-center">Elegir campos para el informe</h2>
          <div class="text-center mb-3">
            <button type="button" class="btn btn-dark btn-sm" onclick="event.preventDefault(); addCampo()">+ Añadir campo</button>
          </div>

          <table class="table table-bordered table-sm" id="tabla-campos">
            <thead class="table-light">
              <tr>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Obligatorio</th>
                <th>Acción</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>

          <div id="alumnos-container" class="table-responsive mb-3"></div>

          <div class="text-center">
            <button type="submit" class="btn btn-dark btn-sm">Guardar informe</button>
          </div>
        </form>

        <script>
          // ===== Datos iniciales desde servidor =====
          const campos = <%- JSON.stringify((campos || []).map(c => ({
            nombre: c.nombre,
            tipo: c.tipo,
            obligatorio: c.obligatorio ? 1 : 0
          }))) %>;
          const alumnos = <%- JSON.stringify(alumnos || []) %>;
          const showGrp = <%= showGroup ? 'true' : 'false' %>;
          const showInst = <%= showInstrument ? 'true' : 'false' %>;

          // ===== Render de alumnos en función de los campos =====
          function renderTablaAlumnos(camposFinal) {
            const cont = document.getElementById('alumnos-container');
            if (!alumnos.length || !camposFinal.length) { cont.innerHTML = ''; return; }

            let html = '<table class="table table-sm table-bordered"><thead><tr>';
            html += '<th>Alumno</th>';
            if (showGrp)  html += '<th>Grupo</th>';
            if (showInst) html += '<th>Instrumento</th>';
            camposFinal.forEach((c,i) => html += '<th>' + (c.nombre || ('Campo ' + (i+1))) + '</th>');
            html += '</tr></thead><tbody>';

            alumnos.forEach(al => {
              html += '<tr>';
              html += '<td>' + al.apellidos + ', ' + al.nombre + '</td>';
              if (showGrp)  html += '<td>' + (al.grupos || '') + '</td>';
              if (showInst) html += '<td>' + (al.instrumentos || '') + '</td>';

              camposFinal.forEach((campo, idx) => {
                const nm = `r_${al.id}_${idx}`;
                let inp = '';
                if (campo.tipo === 'texto') {
                  inp = `<input type="text" class="form-control form-control-sm" name="${nm}">`;
                } else if (campo.tipo === 'numero') {
                  inp = `<input type="number" class="form-control form-control-sm" name="${nm}" step="0.01">`;
                } else { // booleano
                  inp = `<input type="checkbox" class="form-check-input" name="${nm}">`;
                }
                html += `<td>${inp}</td>`;
              });

              html += '</tr>';
            });

            html += '</tbody></table>';
            cont.innerHTML = html;
          }

          // ===== Gestión de la lista de campos =====
          function addCampo() {
            const tbody = document.querySelector('#tabla-campos tbody');
            const idx = campos.length;
            campos.push({ nombre:'', tipo:'texto', obligatorio:0 });

            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td><input type="text" class="form-control form-control-sm"
                         data-idx="${idx}" oninput="updateCampo(${idx},'nombre',this.value)"></td>
              <td>
                <select class="form-select form-select-sm" data-idx="${idx}"
                        onchange="updateCampo(${idx},'tipo',this.value)">
                  <option value="texto">Texto</option>
                  <option value="numero">Número</option>
                  <option value="booleano">Sí/No</option>
                </select>
              </td>
              <td class="text-center">
                <input type="checkbox" class="form-check-input"
                       onchange="updateCampo(${idx},'obligatorio',this.checked?1:0)">
              </td>
              <td><button type="button" class="btn btn-sm text-danger" onclick="removeCampo(${idx})">×</button></td>
            `;
            tbody.appendChild(tr);
            renderTablaAlumnos(campos);
          }

          function updateCampo(i, prop, val) {
            campos[i][prop] = (prop === 'obligatorio') ? (val ? 1 : 0) : val;
            renderTablaAlumnos(campos);
          }

          function removeCampo(i) {
            campos.splice(i, 1);
            const rows = document.querySelectorAll('#tabla-campos tbody tr');
            if (rows[i]) rows[i].remove();
            renderTablaAlumnos(campos);
          }

          // ===== Envío: empaquetar para tu backend =====
          // Tu backend espera en parsedResultados: r["campo_0"], r["campo_1"], ...
          document.getElementById('form-informe').addEventListener('submit', (e) => {
            // 1) Campos
            document.getElementById('campos-json').value = JSON.stringify(campos);

            // 2) Resultados agrupados por alumno, con keys campo_0..campo_n
            const porAlumno = new Map(); // id -> obj
            document.querySelectorAll('#alumnos-container input').forEach(el => {
              const m = el.name.match(/^r_(\d+)_(\d+)$/); // r_alId_idxCampo
              if (!m) return;
              const alId = Number(m[1]);
              const idxCampo = Number(m[2]);
              const valor = (el.type === 'checkbox') ? (el.checked ? '1' : '0') : el.value;

              if (!porAlumno.has(alId)) porAlumno.set(alId, { alumno_id: alId });
              porAlumno.get(alId)[`campo_${idxCampo}`] = valor;
            });

            const resultados = Array.from(porAlumno.values());
            document.getElementById('resultados-json').value = JSON.stringify(resultados);
          });

          // ===== Normalización & "Prueba de atril" =====
          function norm(s) {
            return (s || '')
              .toLowerCase()
              .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
              .replace(/[^\w\s]/g, ' ')
              .replace(/\s+/g, ' ')
              .trim();
          }
          function esPruebaAtril(nombre) {
            return norm(nombre).startsWith('prueba de atril');
          }

          function syncCamposUI() {
            const tbody = document.querySelector('#tabla-campos tbody');
            tbody.innerHTML = '';
            campos.forEach((c, idx) => {
              const tr = document.createElement('tr');
              tr.innerHTML = `
                <td><input type="text" class="form-control form-control-sm"
                           value="${c.nombre}"
                           oninput="updateCampo(${idx},'nombre',this.value)"></td>
                <td>
                  <select class="form-select form-select-sm"
                          onchange="updateCampo(${idx},'tipo',this.value)">
                    <option value="texto"    ${c.tipo==='texto'?'selected':''}>Texto</option>
                    <option value="numero"   ${c.tipo==='numero'?'selected':''}>Número</option>
                    <option value="booleano" ${c.tipo==='booleano'?'selected':''}>Sí/No</option>
                  </select>
                </td>
                <td class="text-center">
                  <input type="checkbox" class="form-check-input"
                         ${c.obligatorio ? 'checked' : ''}
                         onchange="updateCampo(${idx},'obligatorio',this.checked?1:0)">
                </td>
                <td><button type="button" class="btn btn-sm text-danger" onclick="removeCampo(${idx})">×</button></td>
              `;
              tbody.appendChild(tr);
            });
            renderTablaAlumnos(campos);
          }

          function ensureCamposPruebaAtril(nombre) {
            if (!esPruebaAtril(nombre)) return;
            const tiene = (t) => campos.some(c => norm(c.nombre) === norm(t));
            let cambiado = false;
            if (!tiene('Puntuación') && !tiene('Puntuacion')) {
              campos.push({ nombre: 'Puntuación', tipo: 'numero', obligatorio: 0 });
              cambiado = true;
            }
            if (!tiene('Asistencia')) {
              campos.push({ nombre: 'Asistencia', tipo: 'booleano', obligatorio: 0 });
              cambiado = true;
            }
            if (cambiado) syncCamposUI();
          }

          // Hook al input de nombre (del paso 1)
          const inputNombre = document.querySelector('input[name="nombre_informe"]');
          if (inputNombre) {
            inputNombre.addEventListener('input', () => ensureCamposPruebaAtril(inputNombre.value));
            ensureCamposPruebaAtril(inputNombre.value); // también al cargar
          }

          // Al cargar, pinta lo que haya en `campos`
          document.addEventListener('DOMContentLoaded', syncCamposUI);
        </script>
      <% } %>
    </div>
  </div>
</div>

<div class="volver-bloque-izquierda mt-4">
  <a href="/informes" class="enlace-final">← Volver</a>
</div>

<% /* Scroll automático al paso 2 si ya hay filtrado (alumnos o 'ninguno') */ %>
<% if (typeof filtrado !== 'undefined' && filtrado) { %>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('seccion-campos')?.scrollIntoView({ behavior:'smooth', block:'start' });
  });
</script>
<% } %>


