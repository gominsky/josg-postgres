<% title = 'Crear Informe' %>
<% hero = false %>

<div class="container my-4">
  <div class="row g-4">

    <!-- Filtros del informe -->
    <div class="col-md-5">
      <div class="formulario-centrado p3 rounded" style="background-color: transparent">
        <form action="/informes/ficha/filtrar" method="POST" style="background-color: rgba(12, 233, 93, 1)">
          <h2 class="h5 mb-3 text-dark text-center fw-bold">Filtros</h2>
          <div class="mb-2">
            <label class="form-label form-label-sm fw-bold">Nombre del informe</label>
            <input type="text" name="nombre_informe" class="form-control form-control-sm" required value="<%= nombreInforme || '' %>">
          </div>

          <div class="mb-3">
            <label for="grupo_id" class="form-label fw-bold">Grupo</label>
            <select class="form-select" name="grupo_id" id="grupo_id" required>
              <option value="todos" <%= grupoSeleccionado === 'todos' ? 'selected' : '' %>>Todos</option>
              <option value="ninguno" <%= grupoSeleccionado === 'ninguno' ? 'selected' : '' %>>Ninguno</option>
              <% grupos.forEach(grupo => { %>
                <option value="<%= grupo.id %>" <%= grupoSeleccionado == grupo.id ? 'selected' : '' %>><%= grupo.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3" id="bloque-instrumento">
            <label for="instrumento_id" class="form-label fw-bold">Instrumento</label>
            <select class="form-select" name="instrumento_id" id="instrumento-select" required>
              <option value="todos" <%= instrumentoSeleccionado === 'todos' ? 'selected' : '' %>>Todos</option>
              <% instrumentos.forEach(inst => { %>
                <option value="<%= inst.id %>" <%= instrumentoSeleccionado == inst.id ? 'selected' : '' %>><%= inst.nombre %></option>
              <% }) %>
            </select>
          </div>

          <div class="mb-2">
            <label class="form-label form-label-sm fw-bold">Fecha</label>
            <input type="date" name="fecha" class="form-control form-control-sm" id="fecha-input" required value="<%= fechaHoy %>">
          </div>

          <div class="text-center mt-3">
            <button type="submit" class="btn btn-dark btn-sm">Aplicar</button>
          </div>
        </form>

        <script>
          const grupoSelect = document.getElementById('grupo_id');
          const instrumentoBlock = document.getElementById('bloque-instrumento');
          const instrumentoSelect = document.getElementById('instrumento-select');
          const fechaInput = document.getElementById('fecha-input');

          function actualizarVisibilidadInstrumento() {
            const grupo = grupoSelect.value;
            if (grupo === 'ninguno') {
              instrumentoBlock.style.display = 'none';
              instrumentoSelect.removeAttribute('required');
              instrumentoSelect.value = 'ninguno';
              fechaInput?.removeAttribute('required');
            } else {
              instrumentoBlock.style.display = 'block';
              instrumentoSelect.setAttribute('required', 'required');
              fechaInput?.setAttribute('required', 'required');
            }
          }

          grupoSelect.addEventListener('change', actualizarVisibilidadInstrumento);
          window.addEventListener('DOMContentLoaded', actualizarVisibilidadInstrumento);
        </script>
      </div>
    </div>

    <!-- Formulario de resultados -->
    <div class="col-md-7">
      <% if (grupoSeleccionado === 'ninguno') { %>
        <div class="mensaje-ok text-center">
          Estás creando un informe personalizado sin alumnos. Añade los campos que desees.
        </div>
      <% } else if (alumnos && alumnos.length) { %>
        <div class="mensaje-ok text-center">
          Alumnos filtrados correctamente. Ahora puedes añadir los campos para tu informe.
        </div>
      <% } %>

      <% if (grupoSeleccionado === 'ninguno' || (alumnos && alumnos.length)) { %>
        <form id="form-informe" method="POST" action="/informes/ficha/guardar-json" class="formulario-centrado" style="background-color: rgba(12, 233, 93, 1)">
          <input type="hidden" name="nombre_informe" value="<%= nombreInforme %>">
          <input type="hidden" name="grupo_id" value="<%= grupoSeleccionado %>">
          <input type="hidden" name="instrumento_id" value="<%= instrumentoSeleccionado %>">
          <input type="hidden" name="profesor_id" value="<%= profesorSeleccionado %>">
          <input type="hidden" name="fecha" value="<%= fechaHoy %>">
          <input type="hidden" name="resultados" id="resultados-json">
          <input type="hidden" name="campos_json" id="campos-json">

          <h2 class="h5 mb-3 text-dark text-center">Elegir campos para el informe</h2>
          <button type="submit" class="btn btn-dark btn-sm" onclick="addCampo()">+ Añadir campo</button>


          <table class="table table-bordered table-sm" id="tabla-campos">
            <thead class="table-light">
              <tr>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Obligatorio</th>
                <th></th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>

          <div class="table-responsive" id="alumnos-container"></div>

          <div class="text-center mt-4">
            <button type="submit" class="btn btn-dark btn-sm">Guardar informe</button>
          </div>
        </form>

        <script>
          const campos = [];
          const alumnos = <%- JSON.stringify(alumnos) %>;

          function renderTablaAlumnos(camposFinal) {
            const cont = document.getElementById('alumnos-container');
            if (!alumnos.length || !camposFinal.length) return cont.innerHTML = '';

            let html = `<table class="table table-sm table-bordered align-middle text-center">
              <thead class="table-light"><tr><th>Alumno</th>`;

            camposFinal.forEach((c, idx) => {
              html += `<th>${c.nombre || 'Campo ' + (idx + 1)}</th>`;
            });

            html += '</tr></thead><tbody>';

            alumnos.forEach(alumno => {
              html += `<tr><td class="text-start">${alumno.apellidos}, ${alumno.nombre}</td>`;
              camposFinal.forEach((campo, idx) => {
                const name = `r_${alumno.id}_${idx}`;
                let input = '';

                if (campo.tipo === 'texto') {
                  input = `<input type="text" class="form-control form-control-sm" name="${name}">`;
                } else if (campo.tipo === 'numero') {
                  input = `<input type="number" class="form-control form-control-sm" name="${name}" step="0.01" min="0" max="10">`;
                } else if (campo.tipo === 'booleano') {
                  input = `<input type="checkbox" class="form-check-input" name="${name}">`;
                }

                html += `<td>${input}</td>`;
              });
              html += '</tr>';
            });

            html += '</tbody></table>';
            cont.innerHTML = html;
          }

          function addCampo(nombre = '', tipo = 'texto', obligatorio = false) {
            const idx = campos.length;
            campos.push({ nombre, tipo, obligatorio });

            const row = document.createElement('tr');
            row.innerHTML = `
              <td><input type="text" class="form-control form-control-sm" value="${nombre}" data-idx="${idx}" data-prop="nombre" oninput="updateCampoNombre(${idx}, this.value)"></td>
              <td>
                <select class="form-select form-select-sm" data-idx="${idx}" data-prop="tipo" onchange="updateCampoTipo(${idx}, this.value)">
                  <option value="texto"${tipo === 'texto' ? ' selected' : ''}>Texto</option>
                  <option value="numero"${tipo === 'numero' ? 'selected' : ''}>Número</option>
                  <option value="booleano"${tipo === 'booleano' ? 'selected' : ''}>Sí/No</option>
                </select>
              </td>
              <td class="text-center">
                <input type="checkbox" class="form-check-input" ${obligatorio ? 'checked' : ''} data-idx="${idx}" data-prop="obligatorio" onchange="updateCampoObligatorio(${idx}, this.checked)">
              </td>
              <td><button type="button" class="btn btn-sm text-danger fw-bold" style="font-size: 1rem;" onclick="removeCampo(this)">×</button></td>
            `;
            document.querySelector('#tabla-campos tbody').appendChild(row);
            renderTablaAlumnos(campos);
          }

          function updateCampoNombre(idx, value) {
            campos[idx].nombre = value;
            renderTablaAlumnos(campos);
          }
          function updateCampoTipo(idx, tipo) {
            campos[idx].tipo = tipo;
            renderTablaAlumnos(campos);
          }
          function updateCampoObligatorio(idx, obligatorio) {
            campos[idx].obligatorio = obligatorio ? 1 : 0;
          }
          function removeCampo(btn) {
            const row = btn.closest('tr');
            const idx = [...row.parentNode.children].indexOf(row);
            campos.splice(idx, 1);
            row.remove();
            renderTablaAlumnos(campos);
          }

          document.getElementById('form-informe').addEventListener('submit', function (e) {
            const camposFinal = [];
            const resultados = [];

            document.querySelectorAll('#tabla-campos tbody tr').forEach(row => {
              const nombre = row.querySelector('[data-prop="nombre"]').value.trim();
              const tipo = row.querySelector('[data-prop="tipo"]').value;
              const obligatorio = row.querySelector('[data-prop="obligatorio"]').checked ? 1 : 0;
              if (nombre) camposFinal.push({ nombre, tipo, obligatorio });
            });

            alumnos.forEach(alumno => {
              camposFinal.forEach((campo, campo_index) => {
                const name = `r_${alumno.id}_${campo_index}`;
                const el = document.querySelector(`[name="${name}"]`);
                if (el) {
                  const valor = el.type === 'checkbox' ? (el.checked ? '1' : '0') : el.value;
                  resultados.push({ alumno_id: alumno.id, campo_index, valor });
                }
              });
            });
            document.getElementById('campos-json').value = JSON.stringify(camposFinal);
            document.getElementById('resultados-json').value = JSON.stringify(resultados);
          });
        </script>
      <% } else if (grupoSeleccionado && instrumentoSeleccionado) { %>
        <p class="mensaje-error">No hay alumnos activos en este grupo con ese instrumento.</p>
      <% } %>
    </div>
  </div>
</div>
<div class="volver-bloque-izquierda mt-4">
  <a href="/informes" class="enlace-final">← Volver</a>
</div>