<% const isEdicion = Boolean(grupo && grupo.id); %>
<% title = isEdicion ? 'Editar grupo' : 'Nuevo grupo'; %>
<% hero = false; %>

<div class="header-compact">
  <h1 class="h1-titulo"><%= title %></h1>
  <a href="/grupos" class="enlace-final">← Volver</a>
</div>

<form method="POST"
      action="<%= isEdicion ? '/grupos/editar/' + grupo.id : '/grupos' %>"
      class="formulario-alumno contenedor-borde">

  <div class="grupo-campos">
    <h2>Datos del grupo</h2>
    <div class="form-grid-2">
      <label>Nombre:
        <input type="text" name="nombre" required value="<%= grupo?.nombre || '' %>">
      </label>
      <label>Descripción:
        <textarea name="descripcion" rows="3"><%= grupo?.descripcion || '' %></textarea>
      </label>
    </div>
  </div>

  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/grupos" class="enlace-final-naranja">← Volver</a>
    <button type="submit" class="btn-main-blanco">
      <%= isEdicion ? 'Actualizar' : 'Crear grupo' %>
    </button>
  </div>
</form>

<% if (isEdicion) { %>
  <form method="POST" action="/grupos/eliminar/<%= grupo.id %>"
        onsubmit="return confirm('¿Eliminar este grupo?');"
        class="text-center mt-3">
    <button type="submit" class="btn-main-blanco btn-rojo btn-sm">Eliminar grupo</button>
  </form>
<% } %>
