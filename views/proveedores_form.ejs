<% const isEdit = !!(proveedor && proveedor.id); %>
<% title = isEdit ? 'Editar proveedor' : 'Nuevo proveedor' %>
<% hero  = false %>

<h1 class="h1-titulo text-center mb-4"><%= title %></h1>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="custom-error" role="alert" style="max-width: 680px; margin: 0 auto 1rem;">
    <%= error %>
  </div>
<% } %>
<% const deshabilitar = (typeof error !== 'undefined' && error) ? 'disabled' : '' %>

<form id="form-proveedor"
      method="POST"
      action="<%= isEdit ? ('/proveedores/' + proveedor.id) : '/proveedores/nuevo' %>"
      class="formulario-alumno"
      style="border: 2px solid #FF9501; border-radius: .75rem; padding: 1rem; max-width: 680px; margin: 2rem auto;">

  <!-- Grupo: Datos del proveedor -->
  <div class="grupo-campos">
    <h2>Datos del proveedor</h2>
    <div class="form-grid-2">
      <label>Nombre*:
        <input name="nombre" class="form-input" required autofocus
               placeholder="Nombre fiscal o comercial"
               autocomplete="organization"
               value="<%= proveedor?.nombre || '' %>">
      </label>

      <label>CIF/NIF:
        <input name="cif" class="form-input"
               placeholder="Ej. B12345678"
               value="<%= proveedor?.cif || '' %>">
      </label>
    </div>
  </div>

  <!-- Grupo: Contacto -->
  <div class="grupo-campos">
    <h2>Contacto</h2>
    <div class="form-grid-2">
      <label>Email:
        <input type="email" name="email" class="form-input"
               autocomplete="email"
               placeholder="facturacion@proveedor.com"
               value="<%= proveedor?.email || '' %>">
      </label>

      <label>Teléfono:
        <input name="telefono" class="form-input"
               autocomplete="tel"
               placeholder="+34 600 000 000"
               value="<%= proveedor?.telefono || '' %>">
      </label>

      <label>Persona de contacto:
        <input name="contacto" class="form-input"
               placeholder="Nombre y apellidos"
               value="<%= proveedor?.contacto || '' %>">
      </label>

      <!-- hueco para mantener rejilla equilibrada -->
      <span></span>
    </div>
  </div>

  <!-- Grupo: Dirección -->
  <div class="grupo-campos">
    <h2>Dirección</h2>
    <div class="form-grid-2">
      <label style="grid-column:1/-1;">Dirección:
        <input name="direccion" class="form-input"
               placeholder="Calle, número, piso…"
               autocomplete="street-address"
               value="<%= proveedor?.direccion || '' %>">
      </label>

      <label>Municipio:
        <input name="municipio" class="form-input"
               autocomplete="address-level2"
               value="<%= proveedor?.municipio || '' %>">
      </label>

      <label>Provincia:
        <input name="provincia" class="form-input"
               autocomplete="address-level1"
               value="<%= proveedor?.provincia || '' %>">
      </label>

      <label>Código postal:
        <input name="codigo_postal" class="form-input"
               inputmode="numeric" pattern="[0-9]*" maxlength="10"
               autocomplete="postal-code"
               value="<%= proveedor?.codigo_postal || '' %>">
      </label>
    </div>
  </div>

  <!-- Grupo: Bancarios -->
  <div class="grupo-campos">
    <h2>Bancarios</h2>
    <div class="form-grid-2">
      <label style="grid-column:1/-1;">IBAN:
        <input name="iban" id="iban" class="form-input"
               placeholder="ES12 3456 7890 1234 5678 9012"
               value="<%= proveedor?.iban || '' %>">
      </label>
    </div>
  </div>

  <!-- Grupo: Notas -->
  <div class="grupo-campos">
    <h2>Notas</h2>
    <div class="form-grid-2">
      <label style="grid-column:1/-1;">Observaciones / internas:
        <textarea name="notas" rows="3" class="form-input"
                  placeholder="Condiciones de pago, persona de facturación, etc."><%= proveedor?.notas || '' %></textarea>
      </label>
    </div>
  </div>

  <!-- Estado (solo edición) -->
  <div class="grupo-campos">
    <h2>Estado</h2>
    <div class="form-grid-2">
      <label class="checkline" style="display:flex;align-items:center;gap:.6rem;">
        <span>Activar/desactivar proveedor</span>
        <input type="checkbox" id="activo" name="activo"
               <%= (typeof proveedor === 'undefined' || proveedor === null) ? 'checked' : ((proveedor.activo!==false) ? 'checked' : '') %> >
      </label>
    </div>
  </div>
 <!-- Acciones -->
  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/proveedores" class="enlace-final-naranja">← Volver</a>
    <div class="d-flex gap-2">
      <button type="submit" class="btn-main">Guardar</button>
    </div>
  </div>
</form>

<script>
  // Formateo suave del IBAN (agrupa en bloques de 4), igual que tenías
  (function(){
    const el = document.getElementById('iban');
    if (!el) return;
    const format = v => v.replace(/\s+/g,'').toUpperCase().replace(/(.{4})/g,'$1 ').trim();
    el.addEventListener('input', () => {
      const raw = el.value;
      el.value = format(raw);
    });
  })();
</script>

