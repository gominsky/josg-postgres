<% title = 'Mensajes' %>
<% hero = false %>

<!-- Header compacto -->
<div class="header-compact">
  <h1 class="h1-titulo">Mensajes</h1>
  <a href="/josgentumano/mensajes.html" class="btn-main-blanco">Ver bandeja móvil</a>
</div>

<div id="toast" class="toast-fixed" role="status" aria-live="polite"></div>

<div class="grid-msg">
  <!-- Compositor -->
  <form id="msg-form" class="panel" autocomplete="off">
    <div class="hdr">
      <h2 class="h1-titulo" style="margin:0;">Enviar mensaje</h2>
      <span class="pill" id="pill-count" title="Destinatarios estimados">— destinatarios</span>
    </div>

    <!-- Título + URL -->
    <div class="row row-2">
      <div>
        <label class="form-label" for="titulo">Título</label>
        <input id="titulo" name="titulo" class="form-control" maxlength="80" placeholder="p. ej., Recordatorio de ensayo" required>
        <div class="counter" id="c-titulo">0 / 80</div>
      </div>
      <div>
        <label class="form-label" for="url">Enlace (opcional)</label>
        <input id="url" name="url" class="form-control" placeholder="https://…">
        <div class="help">Se mostrará como botón “Abrir”.</div>
      </div>
    </div>

    <!-- Mensaje -->
    <div class="row">
      <div>
        <label class="form-label" for="cuerpo">Mensaje</label>
        <textarea id="cuerpo" name="cuerpo" maxlength="500" placeholder="Texto del aviso para los alumnos…" required></textarea>
        <div class="counter" id="c-cuerpo">0 / 500</div>
      </div>
    </div>

    <!-- Enlaces extra -->
    <div id="links-block" class="row">
      <div>
        <label class="form-label">Enlaces extra (opcionales)</label>
        <div id="links-wrap"></div>
        <button type="button" class="btn-main-blanco" id="add-link">Añadir enlace</button>
        <div class="help">Puedes añadir hasta 2 enlaces extra (además del campo “Enlace” de arriba).</div>
      </div>
    </div>

    <!-- Destinatarios -->
    <div class="row">
      <div>
        <p class="section-title">Destinatarios</p>
        <div class="chips" role="tablist" aria-label="Modo de selección">
          <span class="chip active" data-mode="todos" role="tab" aria-selected="true">Todos</span>
          <span class="chip" data-mode="grupos" role="tab" aria-selected="false">Por grupos</span>
          <span class="chip" data-mode="instrumento" role="tab" aria-selected="false">Por instrumento</span>
          <span class="chip" data-mode="grupo_instrumento" role="tab" aria-selected="false">Grupo + instrumento</span>
        </div>
        <div class="help">Elige “Todos”, o restringe por grupo, por instrumento, o por ambos a la vez.</div>
      </div>

      <!-- Selector de grupos -->
      <div id="blk-grupos" style="display:none;">
        <label class="form-label" for="g-buscar">Elige grupos</label>
        <div class="group-search">
          <input id="g-buscar" class="form-control" placeholder="Filtrar grupos por nombre…">
          <button class="btn-main-blanco" type="button" id="g-todos">Marcar todo</button>
          <button class="btn-main-blanco" type="button" id="g-ninguno">Quitar todo</button>
        </div>
        <div class="groups-list" id="groups">
          <% (grupos || []).forEach(g => { %>
            <label>
              <input type="checkbox" class="g-check" value="<%= g.id %>">
              <span><%= g.nombre %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <!-- Solo instrumentos -->
      <div id="blk-instrumento" style="display:none;">
        <label class="form-label" for="i-buscar">Elige instrumentos</label>
        <div class="group-search">
          <input id="i-buscar" class="form-control" placeholder="Filtrar instrumentos…">
          <button class="btn-main-blanco" type="button" id="i-todos">Marcar todo</button>
          <button class="btn-main-blanco" type="button" id="i-ninguno">Quitar todo</button>
        </div>
        <div class="groups-list" id="instruments">
          <% (instrumentos || []).forEach(i => { %>
            <label>
              <input type="checkbox" class="i-check" value="<%= i.id %>">
              <span><%= i.nombre %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <!-- Grupo + Instrumento -->
      <div id="blk-grupo-instrumento" style="display:none;">
        <div class="row row-2">
          <div>
            <label class="form-label" for="i2-buscar">Instrumentos</label>
            <div class="group-search">
              <input id="i2-buscar" class="form-control" placeholder="Filtrar instrumentos…">
              <button class="btn-main-blanco" type="button" id="i2-todos">Marcar todo</button>
              <button class="btn-main-blanco" type="button" id="i2-ninguno">Quitar todo</button>
            </div>
            <div class="groups-list" id="instruments2" style="max-height:200px;">
              <% (instrumentos || []).forEach(i => { %>
                <label>
                  <input type="checkbox" class="i2-check" value="<%= i.id %>">
                  <span><%= i.nombre %></span>
                </label>
              <% }) %>
            </div>
          </div>
          <div>
            <label class="form-label">Grupos</label>
            <div class="groups-list" id="groups2" style="max-height:200px;">
              <% (grupos || []).forEach(g => { %>
                <label>
                  <input type="checkbox" class="g2-check" value="<%= g.id %>">
                  <span><%= g.nombre %></span>
                </label>
              <% }) %>
            </div>
            <div class="help">Se enviará a alumnos cuyo instrumento esté en la lista y pertenezcan a los grupos marcados.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Acciones -->
    <div class="actions">
      <button type="submit" class="btn-main-blanco" id="btn-enviar">Enviar ahora</button>
      <button type="button" class="btn-main-blanco" id="btn-reset" style="opacity:.9;">Limpiar</button>
    </div>
  </form>

  <!-- Previsualización y últimos -->
  <aside class="panel preview">
    <p class="section-title">Vista previa</p>
    <div class="mock-card" aria-live="polite">
      <div class="mock-title" id="pv-title">Título del mensaje</div>
      <div class="mock-body" id="pv-body" style="color:#333;">El contenido aparecerá aquí mientras escribes.</div>
      <div class="mock-url" id="pv-url" style="display:none;"></div>
      <ul id="pv-links" style="margin-top:.35rem; padding-left:1rem;"></ul>
    </div>

    <p class="section-title" style="margin-top:14px;">Últimos mensajes</p>
    <div id="ultimos-wrap" class="panel" style="padding:12px;">
      <div id="ultimos-list" style="display:grid; gap:10px;"></div>
      <div id="ultimos-empty" class="help" style="display:none;">No hay mensajes aún.</div>
      <div id="ultimos-pager" style="margin-top:10px; display:flex; flex-wrap:wrap; gap:6px; justify-content:center;"></div>
    </div>
  </aside>
</div>

<!-- Footer -->
<div class="volver-bloque-izquierda">
  <a href="/" class="enlace-final">← Volver al inicio</a>
</div>

<style>
  :root{
    --accent-50:#fff6e8; --accent-100:#ffeed7; --accent-200:#ffe0b3; --accent-300:#ffd08a;
    --accent-400:#ffb554; --accent-500:#ff9500; --accent-700:#c26c00;
    --ok-50:#ecfdf5; --ok-200:#a7f3d0; --ok-600:#059669;
    --err-50:#fef2f2; --err-200:#fecaca; --err-700:#b91c1c;
    --text-main:#212529; --muted:#6c757d; --border:rgba(0,0,0,.08);
    --shadow:0 1px 2px rgba(0,0,0,.04); --shadow-lg:0 10px 25px rgba(0,0,0,.12);
  }
  .grid-msg{ display:grid; gap:18px; grid-template-columns:1fr; margin-top:10px; }
  @media (min-width: 992px){ .grid-msg{ grid-template-columns:1.15fr .85fr; } }
  .panel{ background:#fff; border:1px solid var(--border); border-radius:16px; box-shadow:var(--shadow); padding:16px 18px; }
  .hdr{ display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:6px; }
  .section-title{ font-weight:700; color:var(--text-main); margin:16px 0 8px; font-size:1rem; }
  .help{ font-size:.9rem; color:var(--muted); margin-top:6px; }
  .row{ display:grid; gap:12px; grid-template-columns:1fr; }
  @media (min-width:768px){ .row-2{ grid-template-columns:1fr 1fr; } }
  .form-label{ font-weight:600; color:var(--text-main); margin:12px 0 6px; }
  .form-control, .form-select, textarea{
    width:100%; border:1px solid var(--border); border-radius:12px; padding:.6rem .75rem; outline:0; background:#fff;
    font-size:.95rem;
  }
  .form-control:focus, .form-select:focus, textarea:focus{ border-color:var(--accent-300); box-shadow:0 0 0 3px var(--accent-50); }
  textarea{ min-height:140px; resize:vertical; }
  .counter{ font-size:.8rem; color:var(--muted); margin-top:4px; }
  .chips{ display:flex; gap:.5rem; flex-wrap:wrap; margin: 8px 0 10px; }
  .chip{ background:var(--accent-100); color:#5b2b00; border:1px solid var(--accent-200);
    border-radius:999px; padding:.35rem .7rem; font-size:.9rem; cursor:pointer; user-select:none; }
  .chip.active{ background:var(--accent-400); border-color:var(--accent-500); }
  #blk-grupos{ margin-top:10px; }
  .group-search{ display:flex; gap:.5rem; align-items:center; margin-bottom:6px; }
  .groups-list{
    max-height: 240px; overflow:auto; border:1px solid var(--border); border-radius:12px; padding:8px;
    display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:.35rem .75rem; background:#fff;
  }
  .groups-list label{ display:flex; align-items:center; gap:.45rem; padding:.25rem .35rem; border-radius:8px; cursor:pointer; }
  .groups-list label:hover{ background:#fafafa; }
  .groups-list input.g-check:checked + span,
  .groups-list input.g2-check:checked + span,
  .groups-list input.i-check:checked + span,
  .groups-list input.i2-check:checked + span{ font-weight:700; }
  #blk-instrumento, #blk-grupo-instrumento{ margin-top:10px; }
  .preview{ position:sticky; top:16px; }
  .mock-card{ display:flex; flex-direction:column; gap:.35rem; background:linear-gradient(180deg,#ffffff,#fdfcfa);
    border:1px solid var(--border); border-radius:16px; padding:14px; box-shadow:var(--shadow); }
  .mock-title{ font-weight:700; color:var(--text-main); font-size:1rem; }
  .mock-url{ font-size:.9rem; color:#0d6efd; word-break:break-all; }
  .actions{ display:flex; gap:.5rem; flex-wrap:wrap; margin-top:12px; align-items:center; }
  .toast-fixed{
    position: fixed; top: 16px; right: 16px; z-index: 2000; min-width: 260px;
    background: var(--ok-50); border:1px solid var(--ok-200); color: var(--ok-600);
    border-radius: 12px; box-shadow:var(--shadow-lg); padding:.65rem .8rem; display:none; font-size:.95rem;
  }
  .toast-fixed.error{ background: var(--err-50); border-color: var(--err-200); color: var(--err-700); }
  .toast-fixed.show{ display:block; animation: toastIn .18s ease-out; }
  @keyframes toastIn { from{ opacity:0; transform: translateY(-6px);} to{opacity:1; transform:none;} }
  .pill{ display:inline-block; font-weight:700; font-size:.78rem; padding:.18rem .5rem; border-radius:999px;
    background: var(--accent-100); border:1px solid var(--accent-300); color:#5b2b00; }

  /* Panel "Últimos mensajes" */
  .last-msg{
    display:grid; gap:6px; grid-template-columns: 1fr auto;
    align-items:start; border:1px solid var(--border);
    border-radius:12px; padding:10px; background:#fff;
  }
  .last-msg h4{ margin:0; font-size:.9rem; line-height:1.2; color:var(--text-main); }
  .last-msg p{ margin:0; font-size:.86rem; line-height:1.25; color:#333; font-weight:400; }
  .last-msg time{ font-size:.78rem; color:var(--muted); }
  .last-msg .actions{ display:flex; gap:.35rem; }
  .btn-linklike{
    background:transparent; border:1px solid var(--border); border-radius:10px; padding:.2rem .5rem;
    cursor:pointer; font-size:.82rem;
  }
  #ultimos-wrap .section-title { font-size:.95rem !important; }
  #ultimos-wrap .last-msg h4   { font-size:.88rem !important; }
  #ultimos-wrap .last-msg p    { font-size:.85rem !important; }
  #ultimos-wrap .last-msg time { font-size:.78rem !important; }
  #ultimos-wrap .btn-linklike  { font-size:.82rem !important; }

  .pager-btn{
    border:1px solid var(--border);
    background:#fff;
    padding:.25rem .6rem;
    border-radius:8px;
    cursor:pointer;
    font-size:.85rem;
  }
  .pager-btn[disabled]{ opacity:.5; cursor:default; }
  .pager-btn.active{
    font-weight:700;
    border-color: var(--accent-400);
    box-shadow: 0 0 0 3px var(--accent-50);
  }
    /* Forzar color legible en los nombres de grupos e instrumentos */
  .groups-list label,
  #groups label span,
  #groups2 label span,
  #instruments label span,
  #instruments2 label span {
    color: var(--text-main) !important; /* #212529 por defecto */
  }

  /* Mantener solo el "negrita al seleccionar" como ya tenías */
  .groups-list input.g-check:checked + span,
  .groups-list input.g2-check:checked + span,
  .groups-list input.i-check:checked + span,
  .groups-list input.i2-check:checked + span{
    font-weight:700;
  }

</style>

<script>
(function(){
  const $ = s => document.querySelector(s);
  const $$ = s => Array.from(document.querySelectorAll(s));

  const form = $('#msg-form'), btnEnviar = $('#btn-enviar'), btnReset = $('#btn-reset');
  const toast = $('#toast'), titulo = $('#titulo'), cuerpo = $('#cuerpo'), url = $('#url');
  const cTitulo = $('#c-titulo'), cCuerpo = $('#c-cuerpo'), pvTitle = $('#pv-title'), pvBody = $('#pv-body'), pvUrl = $('#pv-url');
  const pillCount = $('#pill-count');

  const blkGrupos = $('#blk-grupos'), blkInst = $('#blk-instrumento'), blkGI = $('#blk-grupo-instrumento');
  const gBuscar = $('#g-buscar'), gTodos = $('#g-todos'), gNinguno = $('#g-ninguno');
  const iBuscar = $('#i-buscar'), iTodos = $('#i-todos'), iNinguno = $('#i-ninguno');
  const i2Buscar = $('#i2-buscar'), i2Todos = $('#i2-todos'), i2Ninguno = $('#i2-ninguno');
  const linksWrap = document.getElementById('links-wrap');
  const btnAddLink = document.getElementById('add-link');

  // Estado
  const state = {
    mode: 'todos',
    groupsChecked: new Set(),
    groupsChecked2: new Set(),
    instrumentosChecked: new Set(),
    instrumentosChecked2: new Set()
  };

  // Contadores y preview
  function updateCounters(){
    cTitulo.textContent = `${titulo.value.length} / ${titulo.maxLength}`;
    cCuerpo.textContent = `${cuerpo.value.length} / ${cuerpo.maxLength}`;
  }
  function updatePreview(){
    pvTitle.textContent = titulo.value.trim() || 'Título del mensaje';
    pvBody.textContent  = cuerpo.value.trim() || 'El contenido aparecerá aquí mientras escribes.';
    const u = url.value.trim();
    if (u){ pvUrl.textContent = ensureProto(u); pvUrl.style.display='block'; } else { pvUrl.textContent=''; pvUrl.style.display='none'; }

    const pvLinks = document.getElementById('pv-links');
    if (pvLinks){
      pvLinks.innerHTML = '';
      const extras = Array.from(document.querySelectorAll('.link-input')).map(i => i.value.trim()).filter(Boolean);
      extras.forEach((u, idx) => {
        const li = document.createElement('li');
        const href = ensureProto(u);
        li.innerHTML = `<a href="${href}" target="_blank" rel="noopener">Enlace ${idx+1}</a>`;
        pvLinks.appendChild(li);
      });
    }
  }
  function ensureProto(u){ return /^[a-zA-Z][a-zA-Z0-9+.-]*:\/\//.test(u) ? u : 'https://' + u; }
  titulo.addEventListener('input', ()=>{ updateCounters(); updatePreview(); });
  cuerpo.addEventListener('input', ()=>{ updateCounters(); updatePreview(); });
  url.addEventListener('input', updatePreview);
  updateCounters(); updatePreview();

  // Enlaces extra
  function addLinkRow(value=''){
    const row = document.createElement('div');
    row.style.display='flex'; row.style.gap='.5rem'; row.style.margin='6px 0';
    row.innerHTML = `
      <input class="form-control link-input" placeholder="https://…" value="${value}">
      <button type="button" class="btn-main-blanco link-del" title="Quitar">Quitar</button>
    `;
    row.querySelector('.link-del').addEventListener('click', ()=> { row.remove(); updatePreview(); });
    row.querySelector('.link-input').addEventListener('input', updatePreview);
    linksWrap.appendChild(row);
  }
  if (btnAddLink) {
    btnAddLink.addEventListener('click', ()=>{
      const current = linksWrap.querySelectorAll('.link-input').length;
      if (current >= 2) return;
      addLinkRow('');
    });
  }

  // Modo (chips)
  function setMode(m){
    state.mode = m;
    $$('.chip').forEach(ch => ch.classList.toggle('active', ch.dataset.mode===m));
    blkGrupos.style.display = (m==='grupos') ? 'block' : 'none';
    blkInst.style.display   = (m==='instrumento') ? 'block' : 'none';
    blkGI.style.display     = (m==='grupo_instrumento') ? 'block' : 'none';
    updateDestCount();
  }
  $$('.chip').forEach(ch => ch.addEventListener('click', ()=> setMode(ch.dataset.mode)));
  setMode('todos');

  // Grupos (bloque principal)
  function syncGroupsFromDOM(){
    state.groupsChecked.clear();
    $$('.g-check:checked').forEach(el => state.groupsChecked.add(parseInt(el.value)));
    updateDestCount();
  }
  $$('.g-check').forEach(el => el.addEventListener('change', syncGroupsFromDOM));
  if (gTodos) gTodos.addEventListener('click', ()=> { $$('.g-check').forEach(el=>el.checked=true); syncGroupsFromDOM(); });
  if (gNinguno) gNinguno.addEventListener('click', ()=> { $$('.g-check').forEach(el=>el.checked=false); syncGroupsFromDOM(); });
  if (gBuscar) gBuscar.addEventListener('input', ()=>{
    const q = (gBuscar.value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
    $$('#groups label').forEach(l=>{
      const txt = l.textContent.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
      l.style.display = txt.includes(q) ? '' : 'none';
    });
  });

  // Grupos (segundo bloque en Grupo+Instrumento)
  function syncGroups2(){
    state.groupsChecked2.clear();
    $$('.g2-check:checked').forEach(el => state.groupsChecked2.add(parseInt(el.value)));
    updateDestCount();
  }
  $$('.g2-check').forEach(el => el.addEventListener('change', syncGroups2));

  // Instrumentos
  function syncInstruments(){
    state.instrumentosChecked.clear();
    $$('.i-check:checked').forEach(el => state.instrumentosChecked.add(parseInt(el.value)));
    updateDestCount();
  }
  $$('.i-check').forEach(el => el.addEventListener('change', syncInstruments));
  if (iTodos) iTodos.addEventListener('click', ()=> { $$('.i-check').forEach(el=>el.checked=true); syncInstruments(); });
  if (iNinguno) iNinguno.addEventListener('click', ()=> { $$('.i-check').forEach(el=>el.checked=false); syncInstruments(); });
  if (iBuscar) iBuscar.addEventListener('input', ()=>{
    const q = (iBuscar.value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
    $$('#instruments label').forEach(l=>{
      const txt = l.textContent.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
      l.style.display = txt.includes(q) ? '' : 'none';
    });
  });

  // Instrumentos (G+I)
  function syncInstruments2(){
    state.instrumentosChecked2.clear();
    $$('.i2-check:checked').forEach(el => state.instrumentosChecked2.add(parseInt(el.value)));
    updateDestCount();
  }
  $$('.i2-check').forEach(el => el.addEventListener('change', syncInstruments2));
  if (i2Todos) i2Todos.addEventListener('click', ()=> { $$('.i2-check').forEach(el=>el.checked=true); syncInstruments2(); });
  if (i2Ninguno) i2Ninguno.addEventListener('click', ()=> { $$('.i2-check').forEach(el=>el.checked=false); syncInstruments2(); });
  if (i2Buscar) i2Buscar.addEventListener('input', ()=>{
    const q = (i2Buscar.value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
    $$('#instruments2 label').forEach(l=>{
      const txt = l.textContent.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
      l.style.display = txt.includes(q) ? '' : 'none';
    });
  });

  // Contador destinatarios
  function updateDestCount(){
    let txt = '— destinatarios';
    if (state.mode==='grupos') {
      const g = state.groupsChecked.size; txt = g ? `${g} grupo(s)` : '— destinatarios';
    }
    if (state.mode==='instrumento') {
      const i = state.instrumentosChecked.size; txt = i ? `${i} instrumento(s)` : '— destinatarios';
    }
    if (state.mode==='grupo_instrumento') {
      const g = state.groupsChecked2.size, i = state.instrumentosChecked2.size;
      txt = (g && i) ? `${g} grupo(s) + ${i} instrumento(s)` : '— destinatarios';
    }
    pillCount.textContent = txt;
  }

  // Toast
  function showToast(msg, ok=true){
    toast.textContent = msg;
    toast.classList.remove('error'); if(!ok) toast.classList.add('error');
    toast.classList.add('show'); clearTimeout(showToast._t);
    showToast._t = setTimeout(()=> toast.classList.remove('show'), 4000);
  }

  // Envío AJAX
  form.addEventListener('submit', async (ev)=>{
    ev.preventDefault();

    const body = {
      titulo: titulo.value.trim(),
      cuerpo: cuerpo.value.trim(),
      url: url.value.trim() || null,
      broadcast: state.mode === 'todos',
      grupos: [],
      instrumentos: [],
      links: Array.from(document.querySelectorAll('.link-input')).map(i => i.value.trim()).filter(Boolean)
    };

    if (!body.titulo || !body.cuerpo){ showToast('Completa título y mensaje', false); return; }

    if (state.mode === 'grupos'){
      body.grupos = Array.from(state.groupsChecked.values());
      if (!body.grupos.length){ showToast('Selecciona al menos un grupo', false); return; }
    }
    if (state.mode === 'instrumento'){
      body.instrumentos = Array.from(state.instrumentosChecked.values());
      if (!body.instrumentos.length){ showToast('Elige al menos un instrumento', false); return; }
    }
    if (state.mode === 'grupo_instrumento'){
      body.instrumentos = Array.from(state.instrumentosChecked2.values());
      body.grupos = Array.from(state.groupsChecked2.values());
      if (!body.instrumentos.length || !body.grupos.length){
        showToast('Elige instrumentos y al menos un grupo', false); return;
      }
    }

    btnEnviar.disabled = true; const old = btnEnviar.textContent; btnEnviar.textContent = 'Enviando…';
    try{
      const r = await fetch('/mensajes', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const j = await r.json();
      if(!r.ok || !j.success) throw new Error(j.error || 'No se pudo enviar');

      showToast(`✅ Enviado (id ${j.mensaje_id}) a ${j.enviados} alumno(s).`, true);

      // refrescar panel (página 1)
      fetchPage(1);

      // limpiar campos
      cuerpo.value=''; url.value=''; titulo.value=''; linksWrap.innerHTML = '';
      updateCounters(); updatePreview();
    }catch(e){ showToast('❌ ' + (e.message || 'Error al enviar'), false); }
    finally{ btnEnviar.disabled=false; btnEnviar.textContent = old; }
  });

  // Limpiar
  btnReset.addEventListener('click', ()=>{
    form.reset(); setMode('todos');
    state.groupsChecked.clear(); state.groupsChecked2.clear();
    state.instrumentosChecked.clear(); state.instrumentosChecked2.clear();
    $$('.g-check,.g2-check,.i-check,.i2-check').forEach(el => el.checked=false);
    linksWrap.innerHTML = '';
    updateCounters(); updatePreview(); updateDestCount();
  });

})();
</script>

<script>
// ==== PANEL ÚLTIMOS: paginación tipo Google ====
const PAGE_SIZE = 5;

const ultList   = document.getElementById('ultimos-list');
const ultEmpty  = document.getElementById('ultimos-empty');
const pager     = document.getElementById('ultimos-pager');

let currentPage = 1;
let totalPages  = 1;
let isLoadingUlt = false;

async function fetchPage(page = 1){
  if (isLoadingUlt) return;
  isLoadingUlt = true;

  try{
    const qs = new URLSearchParams({ page: String(page), limit: String(PAGE_SIZE), _t: Date.now() });
    const r = await fetch('/mensajes/ultimos?' + qs.toString(), { headers:{ 'Accept':'application/json' } });
    const data = await r.json();

    if (!r.ok || !data?.success) throw new Error(data?.error || 'No se pudo cargar');

    currentPage = data.page;
    totalPages  = data.pages;
    renderList(data.items || []);
    renderPager(currentPage, totalPages);
  }catch(e){
    console.error('ultimos error', e);
    ultList.innerHTML = '';
    ultEmpty.style.display = 'block';
    if (pager) pager.innerHTML = '';
  }finally{
    isLoadingUlt = false;
  }
}

function renderList(items){
  ultList.innerHTML = '';

  if (!items.length){
    ultEmpty.style.display = 'block';
    return;
  }
  ultEmpty.style.display = 'none';

  for (const it of items){
    const id = Number(it.id);
    const card = document.createElement('div');
    card.className = 'last-msg';
    card.dataset.id = String(id);

    const fecha = new Date(it.created_at);
    const fechaTxt = isNaN(fecha.getTime()) ? '' : fecha.toLocaleString();

    card.innerHTML = `
      <div>
        <h4 title="ID ${id}">${escapeHtml(it.titulo || '(sin título)')}</h4>
        <p style="font-weight:400;">${escapeHtml((it.cuerpo || '').slice(0,140))}${(it.cuerpo && it.cuerpo.length>140)?'…':''}</p>
        <time>${fechaTxt}</time>
      </div>
      <div class="actions">
        <button class="btn-linklike btn-del" type="button" data-del="${id}" title="Eliminar">Eliminar</button>
      </div>
    `;
    ultList.appendChild(card);
  }

  // Bind eliminar
  ultList.querySelectorAll('.btn-del').forEach(btn=>{
    if (!btn._wired) { btn._wired = true; btn.addEventListener('click', onDeleteClick); }
  });
}

function renderPager(page, pages){
  if (!pager) return;
  pager.innerHTML = '';
  if (pages <= 1) return;

  const addBtn = (label, p, { disabled=false, active=false } = {})=>{
    const b = document.createElement('button');
    b.type = 'button';
    b.className = 'pager-btn' + (active ? ' active' : '');
    b.textContent = label;
    if (disabled) b.disabled = true;
    b.addEventListener('click', ()=>{
      if (disabled || p === currentPage) return;
      fetchPage(p);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    pager.appendChild(b);
  };

  // «Anterior»
  addBtn('‹', Math.max(1, page - 1), { disabled: page === 1 });

  // Ventana de números
  const windowSize = 2;
  let start = Math.max(1, page - windowSize);
  let end   = Math.min(pages, page + windowSize);

  if (start > 1){
    addBtn('1', 1, { active: page === 1 });
    if (start > 2) addEllipsis();
  }
  for (let p = start; p <= end; p++){
    addBtn(String(p), p, { active: p === page });
  }
  if (end < pages){
    if (end < pages - 1) addEllipsis();
    addBtn(String(pages), pages, { active: page === pages });
  }

  // «Siguiente»
  addBtn('›', Math.min(pages, page + 1), { disabled: page === pages });

  function addEllipsis(){
    const span = document.createElement('span');
    span.textContent = '…';
    span.style.cssText = 'padding:0 .25rem; color: var(--muted); align-self:center;';
    pager.appendChild(span);
  }
}

function escapeHtml(s){
  return String(s || '')
    .replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;')
    .replaceAll('"','&quot;').replaceAll("'",'&#39;');
}

// Eliminar con recarga de página
async function onDeleteClick(ev){
  const btn = ev.currentTarget;
  const id = btn?.dataset?.del;
  if (!id) return;
  if (!confirm('¿Eliminar este mensaje?')) return;

  try{
    const r = await fetch(`/mensajes/${id}`, { method: 'DELETE' });
    const j = await r.json().catch(()=> ({}));
    if (!r.ok || j?.success === false) throw new Error(j?.error || 'No se pudo eliminar');

    // recargar toda la página (como pediste)
    location.reload();
  }catch(e){
    console.error(e);
    alert('No se pudo eliminar el mensaje.');
  }
}

// Carga inicial
fetchPage(1);
</script>

