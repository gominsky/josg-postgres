<% title = 'Informes y certificados' %>
<% hero = false %>

<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card p-4 shadow-sm">
        <h2 class="h5 mb-3 text-center fw-bold">Filtros de Informe</h2>
        <form action="/informes/horas" method="GET" class="formulario-filtro">
          <div class="mb-3">
            <label for="grupo" class="form-label fw-bold">Grupo</label>
            <select id="grupo" name="grupo" class="form-select form-select-sm">
              <option value="" selected>Todos</option>
              <% grupos.forEach(g => { %>
                <option value="<%= g.id %>"><%= g.nombre %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label for="instrumento" class="form-label fw-bold">Instrumento</label>
            <select id="instrumento" name="instrumento" class="form-select form-select-sm">
              <option value="" selected>Todos</option>
              <% instrumentos.forEach(i => { %>
                <option value="<%= i.id %>"><%= i.nombre %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label for="fecha" class="form-label fw-bold">Fecha inicio</label>
            <input type="date" id="fecha" name="fecha" class="form-control form-control-sm" required>
          </div>
          <div class="mb-3">
            <label for="fecha_fin" class="form-label fw-bold">Fecha fin</label>
            <input type="date" id="fecha_fin" name="fecha_fin" class="form-control form-control-sm">
          </div>
          <div class="d-flex justify-content-between mt-4">
            <button type="submit" formaction="/informes/horas" formmethod="GET" class="btn-main-blanco px-4 py-2">% Horas</button>
          </div>
        </form>
      </div>
    </div>
  </div>
  <div class="volver-bloque-izquierda mt-4">
    <a href="/informes" class="enlace-final">← Volver a Informes</a>
  </div>
</div>
