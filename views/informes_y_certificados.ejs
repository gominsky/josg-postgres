<% title = 'Informes y certificados' %>
<% hero = false %>

<div id="ic-wrap" class="container my-4">

  <!-- ====== ESTILOS ====== -->

  <!-- ====== FORMULARIO + TARJETAS ====== -->
  <form id="filtros-form" action="/informes/horas" method="GET" class="filtros-card">
    <!-- Título dentro del contenedor -->
    <div class="filtros-header">
      <h1 class="h1-titulo"><%= title %></h1>
    </div>

    <!-- Fila 1: Grupo + Instrumento -->
    <div class="row g-3 align-items-end">
      <div class="col-12 col-md-6">
        <label for="grupo" class="form-label">Grupo</label>
        <select id="grupo" name="grupo" class="form-select form-select-sm">
          <option value="todos" selected>Todos</option>
          <option value="ninguno">Ninguno</option> <!-- 👈 para listados sin alumnos -->
          <% grupos.forEach(g => { %>
            <option value="<%= g.id %>"><%= g.nombre %></option>
          <% }) %>
        </select>
      </div>

      <div class="col-12 col-md-6">
        <label for="instrumento" class="form-label">Instrumento</label>
        <select id="instrumento" name="instrumento" class="form-select form-select-sm">
          <option value="" selected>Todos</option>
          <% instrumentos.forEach(i => { %>
            <option value="<%= i.id %>"><%= i.nombre %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <!-- Fila 1.5: Sección Violín (solo visible si instrumento = Violín) -->
    <div class="row g-3 align-items-center mt-0" id="violin-row" style="display:none;">
      <input type="hidden" id="sec_violin" name="sec_violin" value="">
      <div class="col-12">
        <label class="form-label">Sección violín</label>
        <div class="chips" id="violin-chips">
          <span class="chip" data-sec="">Todos</span>
          <span class="chip" data-sec="I">Violín I</span>
          <span class="chip" data-sec="II">Violín II</span>
        </div>
      </div>
    </div>

    <!-- Fila 2: Fechas (4 columnas) -->
    <div class="row g-3 align-items-end mt-0">
      <div class="col-12 col-sm-6 col-lg-3">
        <label for="fecha" class="form-label">Fecha inicio</label>
        <input type="date" id="fecha" name="fecha" class="form-control form-control-sm date-input">
      </div>
      <div class="col-12 col-sm-6 col-lg-3">
        <label for="fecha_fin" class="form-label">Fecha fin</label>
        <input type="date" id="fecha_fin" name="fecha_fin" class="form-control form-control-sm date-input">
      </div>
      <div class="col-12 col-lg-6">
        <label class="form-label">Rango rápido</label>
        <div class="chips">
          <span class="chip" data-range="30d">Últ. 30 días</span>
          <span class="chip" data-range="q">Últ. trimestre</span>
          <span class="chip" data-range="ytd">Año actual</span>
        </div>
      </div>
    </div>

    <!-- Fichas -->
    <div class="action-grid">
      <!-- Informes guardados (histórico) -->
      <a href="/informes/lista" class="action-card" aria-label="Ir al listado de informes guardados">
        <div class="icon-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
              viewBox="0 0 16 16" fill="currentColor">
            <path d="M2 4.5a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1-.5-.5zm0 4a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1-.5-.5zm0 4a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1 0 1z"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Informes guardados</p>
          <p class="action-desc">Consulta todos los informes y listados generados hasta la fecha.</p>
          <p class="req-line"><span class="badge-soft">Histórico completo</span></p>
        </div>
      </a>
          <!-- Clasificación actual (editar) -->
      <button type="button" id="cardAtrilActual" class="action-card">
        <div class="icon-badge" aria-hidden="true">
          <!-- icono “ordenar” -->
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
              viewBox="0 0 16 16" fill="currentColor">
            <path d="M3 2.5a.5.5 0 0 1 .5-.5H9a.5.5 0 0 1 0 1H3.5a.5.5 0 0 1-.5-.5zM3 6a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1H3.5A.5.5 0 0 1 3 6zm0 3.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1H3.5a.5.5 0 0 1-.5-.5zM3 13a.5.5 0 0 1 .5-.5H8a.5.5 0 0 1 0 1H3.5A.5.5 0 0 1 3 13z"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Pruebas de atril, situación actual (editar)</p>
          <p class="action-desc">Tabla editable por instrumento y alumno. Genera el plano usando esta clasificación.</p>
          <p class="req-line"><span class="badge-soft">Requiere: Grupo</span></p>
          <div style="margin-top:.4rem;" onclick="event.stopPropagation();">
            <select id="grupoAtril" class="form-select form-select-sm">
              <option value="">— selecciona un grupo —</option>
              <%
                const EXCLUIR_ATRIL = /reserva|invitado|viol[ií]n\s*(i{1,2})\s*$/i;
                const gruposAtril = (grupos||[]).filter(g => !EXCLUIR_ATRIL.test(g.nombre));
              %>
              <% gruposAtril.forEach(g => { %>
                <option value="<%= g.id %>"><%= g.nombre %></option>
              <% }) %>
            </select>
          </div>
        </div>
      </button>
      <!-- Listado / Tabla dinámica (lleva filtros) -->
      <a href="#" id="cardFicha" class="action-card">
        <div class="icon-badge" aria-hidden="true">
          <!-- icono "tabla" -->
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
              viewBox="0 0 16 16">
            <path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h11A1.5 1.5 0 0 1 15 2.5v11A1.5 1.5 0 0 1 13.5 15h-11A1.5 1.5 0 0 1 1 13.5v-11zM2 5h12V2.5a.5.5 0 0 0-.5-.5H2.5a.5.5 0 0 0-.5.5V5zm12 1H2v7.5a.5.5 0 0 0 .5.5H5V6h9zM6 14h3V6H6v8zm4 0h3V6h-3v8z"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Listado / Tabla dinámica</p>
          <p class="action-desc">Construye listados y tablas eligiendo registros y campos, con guardado rápido. Para generar listados sin alumnos únicamente seleccionar Ninguno en grupo</p>
          <p class="req-line"><span class="badge-soft">Requiere: Fecha, grupo e instrumento</span></p>
        </div>
      </a>

      <!-- Porcentaje de asistencia -->
      <button type="submit" class="action-card" formaction="/informes/horas" formmethod="GET" id="cardHoras">
        <div class="icon-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
               viewBox="0 0 16 16"><path d="M8 3.5a.5.5 0 0 1 .5.5v4.25l3 1.8a.5.5 0 0 1-.5.866l-3.5-2.1A.5.5 0 0 1 7.25 8V4a.5.5 0 0 1 .5-.5z"/><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m0-1A7 7 0 1 1 8 1a7 7 0 0 1 0 14"/></svg>
        </div>
        <div>
          <p class="action-title">Porcentaje de asistencia</p>
          <p class="action-desc">Genera el informe a partir de los filtros.</p>
          <p class="req-line">
            <span class="badge-soft">Requiere: Fechas y grupo</span>
          </p>
        </div>
      </button>

      <!-- Plano de informes de pruebas de atril (separar)
      <button type="button" id="cardPlano" class="action-card">
        <div class="icon-badge" aria-hidden="true"> -->
          <!-- mapa 
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
               viewBox="0 0 16 16"><path d="M15.817.113A.5.5 0 0 1 16 .5v13.99a.5.5 0 0 1-.683.472L10 12.566l-4.64 2.022a.5.5 0 0 1-.36 0L.183 13.887A.5.5 0 0 1 0 13.5V-.49a.5.5 0 0 1 .683-.472L6 1.434l4.64-2.022a.5.5 0 0 1 .36 0zM6 2.434l-4-1.74V13.566l4 1.74zM10 1.566l-4 1.74v11.74l4-1.74zM15 13.566V1.26l-4-1.74v12.306z"/></svg>
        </div>
        <div>
          <p class="action-title">Distribución (últimas pruebas de atril)</p>
          <p class="action-desc">Abre el PDF más reciente del grupo seleccionado.</p>
          <p class="req-line"><span class="badge-soft">Requiere: Grupo</span></p>
        </div>
      </button>-->
      <!-- Compartir plano (último) -->
      <div class="action-card" id="cardSharePlano" role="group" tabindex="0" aria-label="Generar enlace público del plano">
        <div class="icon-badge" aria-hidden="true">
          <!-- icono link -->
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
              viewBox="0 0 16 16" fill="currentColor">
            <path d="M6.354 5.5H4a3 3 0 0 0 0 6h3a3 3 0 0 0 2.674-1.664.5.5 0 1 1 .893.448A4 4 0 0 1 7 12.5H4a4 4 0 0 1 0-8h2.354a.5.5 0 0 1 0 1z"/>
            <path d="M12 3.5H9a3 3 0 0 0-2.674 1.664.5.5 0 1 1-.893-.448A4 4 0 0 1 9 2.5h3a4 4 0 0 1 0 8H9.646a.5.5 0 0 1 0-1H12a3 3 0 0 0 0-6z"/>
          </svg>
        </div>

  <div>
    <p class="action-title">Enlace público del plano de distribución</p>
    <p class="action-desc">Genera un link firmado al PDF del <em>último</em> plano del grupo seleccionado.</p>
    <p class="req-line"><span class="badge-soft">Requiere: grupo concreto</span></p>

    <div class="row g-2 align-items-end">
      <div class="col-md-5">
        <label class="form-label form-label-sm mb-1">Caducidad</label>
        <select class="form-select form-select-sm" id="sharePlanoExpire">
          <option value="">Sin caducidad</option>
          <option value="168">7 días</option>
          <option value="720" selected>30 días</option>
          <option value="2160">90 días</option>
        </select>
      </div>
      <div class="col-md-7 d-grid">
        <button type="button" class="btn btn-main-blanco btn-sm" id="sharePlanoBtn">
          Generar enlace
        </button>
      </div>
    </div>

    <!-- Resultado -->
    <div class="mt-2 share-mini d-none" id="sharePlanoMini">
      <div class="input-group input-group-sm">
        <input type="text" class="form-control share-url" id="sharePlanoUrl" readonly>
        <button type="button" class="btn btn-outline-secondary share-copy" id="sharePlanoCopy">Copiar</button>
      </div>
      <div class="mt-1 d-flex gap-2 align-items-center">
        <span class="badge-soft d-none" id="sharePlanoExpBadge"></span>
        <small class="text-muted d-none" id="sharePlanoHint">Se copia automáticamente al generar.</small>
      </div>
      <small class="text-danger d-none" id="sharePlanoErr"></small>
    </div>
  </div>
</div>

    </div>
  </form>

  <div class="volver-bloque-izquierda mt-4">
    <a href="/" class="enlace-final">← Volver al inicio</a>
  </div>
</div>

<script>
  (function () {
    const form       = document.getElementById('filtros-form');
    const elGrupo    = document.getElementById('grupo');
    const elInstr    = document.getElementById('instrumento');
    const elFecha    = document.getElementById('fecha');
    const elFechaFin = document.getElementById('fecha_fin');
    const cardPlano  = document.getElementById('cardPlano');

    // === Sección Violín ===
    const violinRow  = document.getElementById('violin-row');
    const secHidden  = document.getElementById('sec_violin');
    const violinChips= document.getElementById('violin-chips');

    const norm  = s => (s||'').toString().trim();
    const strip = s => norm(s).normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase();
    const isViolinText = t => strip(t).startsWith('violin'); // “violín” con/ sin tilde

    function toggleViolinChips(){
      const text = elInstr.options[elInstr.selectedIndex]?.text || '';
      const show = isViolinText(text);
      violinRow.style.display = show ? 'flex' : 'none';
      if (!show) {
        secHidden.value = '';
        violinChips?.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
      }
    }
    elInstr.addEventListener('change', toggleViolinChips);
    toggleViolinChips();

    violinChips?.addEventListener('click', (e)=>{
      const chip = e.target.closest('.chip'); if (!chip) return;
      violinChips.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
      chip.classList.add('active');
      secHidden.value = chip.dataset.sec || '';
      updateURL();
    });

    // ==== Chips: rangos rápidos ====
    const fmt = d => d.toISOString().slice(0,10);
    const setRange = (a, b) => { elFecha.value = fmt(a); elFechaFin.value = fmt(b); };
    const setActive = chip => {
      document.querySelectorAll('.chip[data-range]').forEach(c=>c.classList.remove('active'));
      chip?.classList.add('active');
    };

    document.querySelectorAll('.chip[data-range]').forEach(chip => {
      chip.addEventListener('click', () => {
        const now = new Date();
        const end = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        const kind = chip.dataset.range;

        if (kind === '30d') {
          const start = new Date(end); start.setDate(start.getDate() - 29);
          setRange(start, end);
        } else if (kind === 'q') {
          const m = end.getMonth(); const q = Math.floor(m/3);
          const prevQ = (q + 3) % 4; const y = q===0 ? end.getFullYear()-1 : end.getFullYear();
          const startM = prevQ * 3; const endM = startM + 2;
          const start = new Date(y, startM, 1);
          const finish = new Date(y, endM + 1, 0);
          setRange(start, finish);
        } else if (kind === 'ytd') {
          setRange(new Date(end.getFullYear(), 0, 1), end);
        }
        setActive(chip);
        updateURL();
      });
    });

    // ==== Plano (avisa si falta grupo o si es 'ninguno') ====
    cardPlano?.addEventListener('click', () => {
    const grupo = elGrupo?.value;
    if (!grupo || grupo === 'ninguno') { alert('Selecciona un grupo válido primero.'); return; }
    window.open(`/plano/clasif/${encodeURIComponent(grupo)}.pdf`, '_blank', 'noopener');
  });

    // ==== Enlace a Ficha: llevar también sec_violin ====
    cardFicha?.addEventListener('click', (e) => {
      e.preventDefault();
      const qs = new URLSearchParams();
      if (elGrupo?.value)    qs.set('grupo', elGrupo.value);
      if (elInstr?.value)    qs.set('instrumento', elInstr.value);
      if (elFecha?.value)    qs.set('fecha', elFecha.value);
      if (elFechaFin?.value) qs.set('fecha_fin', elFechaFin.value);
      if (secHidden?.value)  qs.set('sec_violin', secHidden.value);
      qs.set('_ts', Date.now());
      location.href = '/informes/ficha?' + qs.toString();
    });

    // ==== Porcentaje: sólo requiere Fecha (sec_violin via hidden ya viaja por GET) ====
    form?.addEventListener('submit', (e) => {
      const target = e.submitter;
      if (elFecha.value && !elFechaFin.value) elFechaFin.value = elFecha.value;
      if (target && target.getAttribute('formaction') === '/informes/horas') {
        if (!elFecha.value) {
          e.preventDefault();
          alert('Para % Horas de asistencia falta: Fecha inicio');
          return false;
        }
      }
      updateURL();
    });

    // ==== Persistir filtros en la URL (y restaurarlos) ====
    const campos = ['grupo','instrumento','fecha','fecha_fin','sec_violin'];
    function loadFromURL(){
      const p = new URLSearchParams(location.search);
      campos.forEach(id=>{
        const el = document.getElementById(id);
        if (el && p.has(id)) el.value = p.get(id);
      });
      // activar chip de sección si viene por URL
      const sec = document.getElementById('sec_violin')?.value || '';
      if (sec && violinChips){
        violinChips.querySelectorAll('.chip').forEach(c=>{
          c.classList.toggle('active', (c.dataset.sec||'')===sec);
        });
      }
      toggleViolinChips();
    }
    function updateURL(){
      const p = new URLSearchParams(location.search);
      campos.forEach(id=>{
        const el = document.getElementById(id);
        if (!el) return;
        if (el.value) p.set(id, el.value); else p.delete(id);
      });
      history.replaceState(null,'', `${location.pathname}?${p.toString()}`);
    }
    loadFromURL();
    ['grupo','instrumento','fecha','fecha_fin'].forEach(id=>{
      document.getElementById(id)?.addEventListener('change', updateURL);
    });
  })();
</script>
<script>
  (() => {
    const card    = document.getElementById('cardSharePlano');
    if (!card) return;
  
    const sel     = document.getElementById('grupo'); // selector ya existente
    const btn     = document.getElementById('sharePlanoBtn');
    const expSel  = document.getElementById('sharePlanoExpire');
    const mini    = document.getElementById('sharePlanoMini');
    const urlInp  = document.getElementById('sharePlanoUrl');
    const copyBt  = document.getElementById('sharePlanoCopy');
    const expBadg = document.getElementById('sharePlanoExpBadge');
    const hint    = document.getElementById('sharePlanoHint');
    const errBox  = document.getElementById('sharePlanoErr');
  
    async function generateLink() {
      errBox.classList.add('d-none');
      const grupo = sel && sel.value;
      if (!grupo || grupo === 'todos' || grupo === 'ninguno') {
        errBox.textContent = 'Selecciona un grupo concreto antes de generar el enlace.';
        errBox.classList.remove('d-none');
        return;
      }
      btn.disabled = true;
      const old = btn.textContent;
      btn.textContent = 'Generando…';
  
      try {
        const expireHours = expSel && expSel.value ? Number(expSel.value) : undefined;
        const r = await fetch('/api/share', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            kind: 'plano',
            params: { grupo, src: 'clasif' },
            ...(expireHours ? { expireHours } : {})
          })
        });
        const j = await r.json();
        if (!j.ok) throw new Error(j.msg || 'No se pudo crear el enlace');
  
        urlInp.value = j.url;
        mini.classList.remove('d-none');
        hint.classList.remove('d-none');
  
        // Mostrar caducidad de forma destacada
        if (j.expiresAt) {
          const d = new Date(j.expiresAt);
          expBadg.textContent = 'Caduca: ' + d.toLocaleString();
          expBadg.classList.remove('d-none');
        } else {
          expBadg.classList.add('d-none');
        }
  
        try { await navigator.clipboard.writeText(j.url); } catch {}
      } catch (e) {
        errBox.textContent = e.message || 'Error';
        errBox.classList.remove('d-none');
      } finally {
        btn.disabled = false;
        btn.textContent = old;
      }
    }
  
    // Accesible: click / Enter / Space
    btn.addEventListener('click', generateLink);
    card.addEventListener('keydown', (ev) => {
      if (ev.key === 'Enter' || ev.key === ' ') { ev.preventDefault(); generateLink(); }
    });
  
    copyBt.addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(urlInp.value); } catch {}
    });
  })();
  </script>
  <script>
    (function () {
      const btn = document.getElementById('cardAtrilActual');
      if (!btn) return;
      btn.addEventListener('click', (e) => {
        // Ignorar clicks dentro del select propio del card
        if (e.target.closest('select')) return;
        const grupoSel = document.getElementById('grupoAtril')?.value || '';
        if (!grupoSel) {
          return alert('Selecciona un grupo para editar su clasificación actual.');
        }
        window.location.href = `/atril/actual/editor?grupo_id=${encodeURIComponent(grupoSel)}`;
      });
    })();
  </script>
    