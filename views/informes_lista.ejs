<% title = 'Listado de Informes' %>
<% hero = false %>

<div class="container mt-4">
    <h1 class="h1-titulo"><%= title %></h1>
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
      <input
        id="busqueda-informes"
        type="text"
        placeholder="Buscar por nombre, grupo..."
        class="form-control"
        style="max-width: 300px;"
      >
    </div>

  <% if (informes.length === 0) { %>
    <p class="mt-4 text-center">No hay informes disponibles.</p>
  <% } else { %>
    <div class="table-responsive">
      <table class="tabla-estilizada" id="tabla-informes">
        <thead class="table-light text-center">
          <tr>
            <th class="sortable" data-type="text">Informe</th>
            <th class="sortable" data-type="date">Fecha</th>
            <th class="sortable" data-type="text">Grupo</th>
            <th class="sortable" data-type="text">Instrumento</th>
          </tr>
        </thead>
        <tbody>
          <% informes.forEach(i => { %>
            <tr class="fila-enlace clickable-row" onclick="location.href='/informes/detalle/<%= i.id %>'">
              <td><%= i.informe %></td>
              <td data-value="<%= i.fecha %>"><%= new Date(i.fecha).toLocaleDateString('es-ES') %></td>
              <td><%= i.grupo || '—' %></td>
              <td><%= i.instrumento || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <div class="volver-bloque-izquierda mt-4">
    <a href="/informes" class="enlace-final">← Volver a informes</a>
  </div>
</div>

<script>
  document.getElementById('busqueda-informes').addEventListener('input', function () {
    const filtro = this.value.toLowerCase().trim();
    document.querySelectorAll('#tabla-informes tbody tr').forEach(fila => {
      fila.style.display = fila.textContent.toLowerCase().includes(filtro) ? '' : 'none';
    });
  });
</script>
<script>
  (function () {
    const table = document.getElementById('tabla-informes');
    if (!table) return;

    const ths = table.querySelectorAll('thead th.sortable');
    ths.forEach((th, idx) => {
      th.setAttribute('aria-sort', 'none');

      th.addEventListener('click', () => {
        // limpiar estado en otros <th>
        ths.forEach(o => { if (o !== th) { o.classList.remove('sorted-asc','sorted-desc'); o.setAttribute('aria-sort','none'); } });

        // alternar asc/desc
        const asc = !th.classList.contains('sorted-asc');
        th.classList.toggle('sorted-asc',  asc);
        th.classList.toggle('sorted-desc', !asc);
        th.setAttribute('aria-sort', asc ? 'ascending' : 'descending');

        const tbody = table.querySelector('tbody');
        const rows  = Array.from(tbody.querySelectorAll('tr'));

        const type = th.dataset.type || 'text';
        const collator = new Intl.Collator('es', { numeric: true, sensitivity: 'base' });

        const key = (tr) => {
          const cell = tr.children[idx];
          const raw  = cell?.dataset?.value ?? cell?.textContent?.trim() ?? '';
          if (type === 'date') {
            // usamos ISO de data-value (YYYY-MM-DD) para ordenar estable
            return String(raw);
          }
          const n = Number(String(raw).replace(',', '.'));
          if (!Number.isNaN(n) && raw !== '') return n;
          return String(raw).toLowerCase();
        };

        rows.sort((a, b) => {
          const ka = key(a), kb = key(b);
          let cmp;
          if (typeof ka === 'number' && typeof kb === 'number') {
            cmp = ka - kb;
          } else if (type === 'date') {
            cmp = ka < kb ? -1 : ka > kb ? 1 : 0; // ISO lexicográfico
          } else {
            cmp = collator.compare(ka, kb);
          }
          return asc ? cmp : -cmp;
        });

        rows.forEach(r => tbody.appendChild(r));
      });
    });
  })();
</script>
