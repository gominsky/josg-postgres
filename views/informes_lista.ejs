<% title = 'Listado de Informes' %>
<% hero = false %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h1-titulo"><%= title %></h1>
    <div>
      <a href="/informes/certificados" class="btn-main me-2">+ Informes y Certificados</a>
      <a href="/informes/ficha" class="btn-main">+ Listado dinámico</a>
    </div>
  </div>

  <div class="d-flex justify-content-center mb-4">
    <form id="busqueda-form">
      <div class="campo-filtro">
        <label for="busqueda">Buscar</label>
        <input type="text" id="busqueda-informes" class="form-centrado-select" placeholder="Nombre, fecha...">
      </div>
    </form>
  </div>

  <% if (informes.length === 0) { %>
    <p class="mt-4 text-center">No hay informes disponibles.</p>
  <% } else { %>
    <div class="table-responsive">
      <table class="tabla-estilizada" id="tabla-informes">
        <thead class="table-light text-center">
          <tr>
            <th>Informe</th>
            <th>Fecha</th>
            <th>Grupo</th>
            <th>Instrumento</th>
          </tr>
        </thead>
        <tbody>
          <% informes.forEach(i => { %>
            <tr class="fila-enlace clickable-row" onclick="location.href='/informes/detalle/<%= i.id %>'">
              <td><%= i.informe %></td>
              <td><%= new Date(i.fecha).toLocaleDateString('es-ES') %></td>
              <td><%= i.grupo || '—' %></td>
              <td><%= i.instrumento || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

  <div class="volver-bloque-izquierda mt-4">
    <a href="/" class="enlace-final">← Volver al inicio</a>
  </div>
</div>

<script>
  document.getElementById('busqueda-informes').addEventListener('input', function () {
    const filtro = this.value.toLowerCase().trim();
    document.querySelectorAll('#tabla-informes tbody tr').forEach(fila => {
      fila.style.display = fila.textContent.toLowerCase().includes(filtro) ? '' : 'none';
    });
  });
</script>
