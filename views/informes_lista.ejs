<% title = 'Informes guardados' %>
<% hero = false %>

<div class="header-compact">
  <h1 class="h1-titulo">Informes guardados</h1>
  <a href="/informes" class="enlace-final">← Volver</a>
</div>

<div class="mx-auto mb-3" style="max-width:1200px; padding:0 1rem;">
  <input id="busqueda-informes" type="text"
         placeholder="Buscar por nombre, grupo, instrumento…"
         class="form-control form-control-sm"
         autocomplete="off">
</div>

<% if (informes.length === 0) { %>
  <p class="mt-4 text-center text-muted">No hay informes disponibles.</p>
<% } else { %>
  <div class="mx-auto" style="max-width:1200px; padding:0 1rem 2rem;">
    <div class="table-responsive">
      <table class="tabla-estilizada tabla-tight tabla-hover" id="tabla-informes">
        <thead>
          <tr>
            <th class="sortable" data-type="text" data-col="0">
              Informe <span class="sort-icon">↕</span>
            </th>
            <th class="sortable" data-type="date" data-col="1">
              Fecha <span class="sort-icon">↕</span>
            </th>
            <th class="sortable" data-type="text" data-col="2">
              Grupo <span class="sort-icon">↕</span>
            </th>
            <th class="sortable" data-type="text" data-col="3">
              Instrumento <span class="sort-icon">↕</span>
            </th>
          </tr>
        </thead>
        <tbody>
          <% informes.forEach(i => { %>
            <tr class="clickable-row fila-enlace"
                onclick="location.href='/informes/detalle/<%= i.id %>'">
              <td><%= i.informe %></td>
              <td data-value="<%= i.fecha %>">
                <%= new Date(i.fecha + 'T12:00:00').toLocaleDateString('es-ES') %>
              </td>
              <td><%= i.grupo || '—' %></td>
              <td><%= i.instrumento || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<script>
(() => {
  /* ── Buscador con normalización de acentos ── */
  const input = document.getElementById('busqueda-informes');
  const tbody = document.querySelector('#tabla-informes tbody');

  function norm(s) {
    return (s || '').toString().toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
  }

  input?.addEventListener('input', () => {
    const q = norm(input.value);
    tbody?.querySelectorAll('tr').forEach(tr => {
      tr.style.display = !q || norm(tr.textContent).includes(q) ? '' : 'none';
    });
  });

  /* ── Ordenación de columnas ── */
  const table = document.getElementById('tabla-informes');
  if (!table) return;

  let sortCol = -1, sortAsc = true;
  table.querySelectorAll('th.sortable').forEach(th => {
    th.style.cursor = 'pointer';
    th.addEventListener('click', () => {
      const col  = parseInt(th.dataset.col);
      const type = th.dataset.type || 'text';
      if (sortCol === col) sortAsc = !sortAsc;
      else { sortCol = col; sortAsc = true; }

      table.querySelectorAll('th .sort-icon').forEach(i => i.textContent = '↕');
      th.querySelector('.sort-icon').textContent = sortAsc ? '↑' : '↓';

      const rows = [...tbody.querySelectorAll('tr')];
      const collator = new Intl.Collator('es', { numeric: true, sensitivity: 'base' });

      rows.sort((a, b) => {
        const ca = a.children[col], cb = b.children[col];
        const va = ca?.dataset?.value ?? ca?.textContent?.trim() ?? '';
        const vb = cb?.dataset?.value ?? cb?.textContent?.trim() ?? '';
        let cmp;
        if (type === 'date') {
          cmp = va < vb ? -1 : va > vb ? 1 : 0;
        } else {
          const na = Number(String(va).replace(',', '.'));
          const nb = Number(String(vb).replace(',', '.'));
          cmp = (!isNaN(na) && !isNaN(nb)) ? na - nb : collator.compare(va, vb);
        }
        return sortAsc ? cmp : -cmp;
      });
      rows.forEach(r => tbody.appendChild(r));
    });
  });
})();
</script>
