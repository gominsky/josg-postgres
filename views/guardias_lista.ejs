<% title = 'Planilla de Guardias' %>
<% hero = false %>

<h1 class="text-center mb-4">Planilla de Guardias</h1>

<!-- Filtros + acciones alineados en una sola fila -->
<div class="d-flex flex-wrap align-items-end justify-content-center gap-3 mb-4">

  <!-- Formulario de filtros con acciones incluidas -->
  <form method="GET" action="/guardias" class="d-flex flex-wrap align-items-end gap-2">
    <div class="campo-filtro">
      <label for="desde" class="form-centrado-etiqueta">Desde</label>
      <input type="date" id="desde" name="desde" value="<%= desde %>" class="form-centrado-select" />
    </div>
    <div class="campo-filtro">
      <label for="hasta" class="form-centrado-etiqueta">Hasta</label>
      <input type="date" id="hasta" name="hasta" value="<%= hasta %>" class="form-centrado-select" />
    </div>
    <div class="campo-filtro">
      <label for="grupo" class="form-centrado-etiqueta">Grupo</label>
      <select id="grupo" name="grupo" class="form-centrado-select">
        <option value="">Todos</option>
        <% grupos.forEach(function(g) { %>
          <option value="<%= g.id %>" <%= grupo == g.id ? 'selected' : '' %>><%= g.nombre %></option>
        <% }) %>
      </select>
    </div>

    <!-- Botón Filtrar -->
    <button type="submit" class="btn-main-blanco px-4 py-2">Filtrar</button>

    <!-- Botón Asignar Guardias Múltiples -->
    <button formaction="/guardias/generar-multiples" formmethod="POST" class="btn-main-blanco fw-bold px-4 py-2">
      Asignar guardias múltiples
    </button>

    <!-- Botón Generar PDF -->
    <button formaction="/guardias/informe" formmethod="POST" class="btn-main-blanco fw-bold px-4 py-2">
      Generar PDF
    </button>
  </form>

</div>


  <% if (guardias.length > 0) { %>
    <div class="mx-auto" style="max-width: 1200px; padding: 0 1rem;">

    <div class="table-responsive mt-4">
      <table class="tabla-estilizada">
        <thead>
          <tr>
            <th>Fecha</th>
            <th>Evento</th>
            <th>Grupo</th>
            <th>Guardia 1</th>
            <th>Guardia 2</th>
            <th>Eliminar / sugerir guardia</th>
          </tr>
        </thead>
          <tbody>
  <% guardias.forEach(g => { %>
    <tr
      <% if (g.guardia_id) { %>
        style="cursor: pointer;" onclick="location.href='/guardias/editar/<%= g.guardia_id %>?desde=<%= desde %>&hasta=<%= hasta %>'"
      <% } %>
    >
      <td>
        <%= new Date(g.fecha_inicio).toLocaleString('es-ES', {
          day: '2-digit',
          month: '2-digit',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        }).replace(',', '') %>
      </td>
      <td><%= g.evento %></td>
      <td><%= g.grupo %></td>
      <td><%= g.guardia1 || '-' %></td>
      <td><%= g.guardia2 || '-' %></td>
      <td class="text-center" onclick="event.stopPropagation();">
  <% if (g.guardia_id) { %>
    <form method="POST" action="/guardias/eliminar/<%= g.guardia_id %>?desde=<%= encodeURIComponent(desde || '') %>&hasta=<%= encodeURIComponent(hasta || '') %>&grupo=<%= encodeURIComponent(grupo || '') %>" onsubmit="event.stopPropagation(); return confirm('¿Eliminar guardia?');" style="display:inline; background-color: transparent;">
      <button 
        type="submit" 
        class="btn btn-sm text-danger fw-bold" 
        style="font-size: 1rem; line-height: 1;" 
        onclick="event.stopPropagation();"
      >×</button>
    </form>
  <% } else { %>
   <form method="POST" action="/guardias/generar" style="margin: 0; display: inline; background-color: transparent;">
  <input type="hidden" name="evento_id" value="<%= g.evento_id %>">
  <input type="hidden" name="desde" value="<%= desde %>">
  <input type="hidden" name="hasta" value="<%= hasta %>">
  <button type="submit" class="btn-primary-negro btn-sm  px-2 py-1" style="font-size: 0.75rem; line-height: 1;">Asignar guardia</button>
  </form>

  <% } %>
</td>

    </tr>
  <% }) %>
</tbody>


      </table> 
      </div>
    </div>
  <% } else { %>
    <p class="mt-4" style="text-align: center;"">No hay eventos registrados.</p>
  <% } %>

  <div class="volver-bloque-izquierda mt-4">
    <a href="/eventos" class="enlace-final">← Eventos</a>
  </div>
</div>

<script>
  function filtrarFechas() {
    const desde = document.querySelector('input[name="desde"]').value;
    const hasta = document.querySelector('input[name="hasta"]').value;
    if (desde && hasta) {
      const params = new URLSearchParams({ desde, hasta });
      window.location.href = `/guardias?${params.toString()}`;
    }
  }
</script>



