<% title = 'Pagos a proveedor' %>
<% hero  = false %>

<div id="pag-list-wrap" class="container my-4">

  <div class="panel-card">
    <div class="list-header">
      <h1 class="h1-titulo" style="margin:0;">Pagos a proveedor</h1>
      <% const enc = encodeURIComponent; %>
      <% const baseQS = `proveedor=${enc(filtros.proveedor||'')}&desde=${enc(filtros.desde||'')}&hasta=${enc(filtros.hasta||'')}&q=${enc(filtros.q||'')}&ordenar=${enc(filtros.ordenar||'')}`; %>
      <div class="header-actions">
        <a class="btn btn-outline" href="/contabilidad/pagos/export.csv?<%= baseQS %>">⬇️ Exportar CSV</a>
        <a class="btn btn-outline" href="/contabilidad/pagos/nuevo">＋ Registrar pago</a>
      </div>
    </div>

    <!-- FILTROS (idénticos a los de facturas; si los tienes en un partial, inclúyelos aquí) -->

    <!-- CHIPS -->
    <div class="chips" style="margin-top:8px;">
      <span class="chip" data-range="30d">Últ. 30 días</span>
      <span class="chip" data-range="mes">Mes actual</span>
      <span class="chip" data-range="trim">Trimestre actual</span>
      <span class="chip" data-range="ytd">Año en curso</span>
      <a class="chip" href="/contabilidad/pagos">Quitar filtros</a>
    </div>

    <!-- RESUMEN -->
    <%
      let nPag = (pagos||[]).length, sumaImporte=0, sumaAplicado=0;
      (pagos||[]).forEach(p => { sumaImporte += Number(p.importe_total||0); sumaAplicado += Number(p.aplicado||0); });
    %>
    <div class="small" style="margin-top:8px; color:var(--muted);">
      <strong><%= nPag %></strong> pagos ·
      Importe: <strong class="num"><%= sumaImporte.toFixed(2) %> €</strong> ·
      Aplicado: <strong class="num"><%= sumaAplicado.toFixed(2) %> €</strong>
    </div>

    <!-- LISTA -->
    <% if ((pagos||[]).length === 0) { %>
      <p class="text-muted" style="margin-top:12px;">No hay resultados para esos filtros.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table-lite">
          <thead>
            <tr>
              <th>Fecha</th><th>Proveedor</th><th class="text-end">Importe</th><th class="text-end">Aplicado</th><th class="text-end">Pendiente</th><th>Estado</th><th>Referencia</th>
            </tr>
          </thead>
          <tbody>
            <%
              const fmtDate = (v) => (v && typeof v.toISOString === 'function')
                ? v.toISOString().slice(0,10)
                : String(v||'').slice(0,10);
            %>
            <% (pagos||[]).forEach(p => {
                 const aplicado = Number(p.aplicado||0);
                 const importe  = Number(p.importe_total||0);
                 const pend     = Math.max(importe - aplicado, 0);
            %>
              <tr class="clickable-row" onclick="location.href='/contabilidad/pagos/<%= p.id %>'">
                <td><%= fmtDate(p.fecha) %></td>
                <td><%= p.proveedor_nombre || '—' %></td>
                <td class="text-end num"><%= importe.toFixed(2) %> €</td>
                <td class="text-end num"><%= aplicado.toFixed(2) %> €</td>
                <td class="text-end num"><strong><%= pend.toFixed(2) %> €</strong></td>
                <td>
                  <% if (pend > 0.009) { %>
                    <span class="badge badge-warn">Parcial</span>
                  <% } else { %>
                    <span class="badge badge-ok">Aplicado</span>
                  <% } %>
                </td>
                <td><%= p.referencia || '' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <!-- PAGINACIÓN -->
<% 
  const p = (typeof paginacion !== 'undefined' && paginacion)
    ? paginacion 
    : { page: 1, per_page: 50, total_pages: 1 };
%>

<% if (p.total_pages > 1) { %>
  <div class="pager">
    <% if (p.page > 1) { %>
      <a href="/contabilidad/pagos?<%= baseQS %>&per_page=<%= p.per_page %>&page=1">« Primero</a>
      <a href="/contabilidad/pagos?<%= baseQS %>&per_page=<%= p.per_page %>&page=<%= p.page - 1 %>">‹ Anterior</a>
    <% } else { %>
      <span>« Primero</span><span>‹ Anterior</span>
    <% } %>

    <span class="current">Página <%= p.page %> / <%= p.total_pages %></span>

    <% if (p.page < p.total_pages) { %>
      <a href="/contabilidad/pagos?<%= baseQS %>&per_page=<%= p.per_page %>&page=<%= p.page + 1 %>">Siguiente ›</a>
      <a href="/contabilidad/pagos?<%= baseQS %>&per_page=<%= p.per_page %>&page=<%= p.total_pages %>">Última »</a>
    <% } else { %>
      <span>Siguiente ›</span><span>Última »</span>
    <% } %>
  </div>
<% } %>

    </div>
  </div>
</div>

<div class="volver-bloque-izquierda">
  <a href="/contabilidad" class="enlace-final">← Volver a contabilidad</a>
</div>

<script>
  (function(){
    // Busca un formulario de filtros (si existe) con id específico o genérico
    const f = document.querySelector('form#filtrosPagos') || document.getElementById('filtros');
    const elDesde = f?.elements?.['desde'];
    const elHasta = f?.elements?.['hasta'];
    function fmt(d){ return d.toISOString().slice(0,10); }
    function setRange(a,b){ if (elDesde) elDesde.value=fmt(a); if (elHasta) elHasta.value=fmt(b); f?.submit?.(); }
    document.querySelectorAll('.chip[data-range]').forEach(chip=>{
      chip.addEventListener('click', ()=>{
        const now=new Date(); const today=new Date(now.getFullYear(),now.getMonth(),now.getDate());
        if (chip.dataset.range==='30d'){ const s=new Date(today); s.setDate(s.getDate()-29); setRange(s,today); }
        if (chip.dataset.range==='mes'){ const s=new Date(today.getFullYear(),today.getMonth(),1); const e=new Date(today.getFullYear(),today.getMonth()+1,0); setRange(s,e); }
        if (chip.dataset.range==='trim'){ const m=today.getMonth(); const q=Math.floor(m/3); const s=new Date(today.getFullYear(),q*3,1); const e=new Date(today.getFullYear(),q*3+3,0); setRange(s,e); }
        if (chip.dataset.range==='ytd'){ const s=new Date(today.getFullYear(),0,1); setRange(s,today); }
      });
    });
  })();
</script>
