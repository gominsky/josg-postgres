<% const isEdicion = Boolean(tipo && tipo.id); %>
<% title = isEdicion ? 'Editar Tipo de Cuota' : 'Nuevo Tipo de Cuota'; %>
<% hero = false; %>

<h1 class="h1-titulo"><%= title %></h1>

<form
  id="form-tipo-cuota"
  method="POST"
  action="<%= isEdicion 
    ? '/tipos_cuotas/editar/' + tipo.id 
    : '/tipos_cuotas'
  %>"
  class="formulario-alumno"
  style="border: 2px solid #FF9501; border-radius: 0.75rem; padding: 1rem;"
>
  <div class="grupo-campos">
    <h2>Datos del Tipo de Cuota</h2>
    <div class="form-grid-2">
      <label>Tipo de cuota:
        <input 
          type="text" 
          name="tipo" 
          value="<%= tipo?.tipo || '' %>" 
          required
        >
      </label>
    </div>
  </div>

  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/tipos_cuotas" class="enlace-final-naranja">← Volver</a>
    <div class="d-flex align-items-center gap-2">
      <button type="submit" class="btn-main">
        <%= isEdicion ? 'Actualizar' : 'Registrar' %>
      </button>
      <% if (isEdicion) { %>
        <button
          type="submit"
          class="btn-rojo"
          form="form-tipo-cuota"
          formaction="/tipos_cuotas/<%= tipo.id %>?_method=DELETE"
          formmethod="POST"
          onclick="return confirm('¿Eliminar este tipo de cuota?');"
        >Eliminar</button>
      <% } %>
    </div>
  </div>
</form>
