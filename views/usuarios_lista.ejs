<% title = 'Usuarios' %>
<% hero = false %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h1-titulo mb-0">Gestión de Usuarios</h1>
    <a href="/usuarios/nuevo" class="btn-main fw-bold">+ Nuevo Usuario</a>
  </div>

  <% if (usuarios && usuarios.length > 0) { %>
    <table class="tabla-estilizada">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Apellidos</th> 
          <th>Email</th>
          <th>Rol</th>
        </tr>
      </thead>
      <tbody>
        <% usuarios.forEach(u => { %>
          <tr onclick="window.location='/usuarios/<%= u.id %>/editar'" style="cursor: pointer;">
            <td><%= u.nombre %></td>
            <td><%= u.apellidos %></td>
            <td><%= u.email %></td>
            <td><%= u.rol %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p>No hay usuarios registrados.</p>
  <% } %>
</div>

