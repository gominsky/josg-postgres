<% title = 'Usuarios'; hero = false %>

<div class="header-compact">
  <h1 class="h1-titulo">Usuarios</h1>
  <a href="/usuarios/nuevo" class="btn-main-blanco">+ Añadir usuario</a>
</div>

<% if (!usuarios || usuarios.length === 0) { %>
  <p class="text-muted mt-3 text-center">No hay usuarios registrados.</p>
<% } else { %>
  <div class="dashboard-grid">
    <% usuarios.forEach(u => { %>
      <a href="/usuarios/<%= u.id %>/editar" class="card activo card--josg" style="text-decoration:none;">
        <div class="alumno-nombre"><%= u.nombre %> <%= u.apellidos %></div>
        <div class="alumno-instrumento"><%= u.email %></div>
        <div class="alumno-grupo"><%= u.rol.charAt(0).toUpperCase() + u.rol.slice(1).replace('_', ' ') %></div>
      </a>
    <% }) %>
  </div>
<% } %>

<div class="volver-bloque-izquierda">
  <a href="/configuracion" class="enlace-final">← Volver a configuración</a>
</div>
