   <script>
(() => {
  const el = document.getElementById('evtDate');
  if (!el) return;

  const iso = (el.dataset.date || '').trim();      // p.ej. "2025-10-07"
  const hIni = (el.dataset.hini || '').slice(0,5); // "HH:MM"
  const hFin = (el.dataset.hfin || '').slice(0,5); // "HH:MM"

  let fechaTxt = '';
  if (iso) {
    // Permite "YYYY-MM-DD" o iso con tiempo
    const ymd = /^\d{4}-\d{2}-\d{2}$/.test(iso) ? iso + 'T00:00:00' : iso;
    const d = new Date(ymd);
    if (!isNaN(d.getTime())) {
      fechaTxt = d.toLocaleDateString('es-ES', {
        weekday: 'short', day: '2-digit', month: 'long', year: 'numeric'
      });
      // Capitaliza el primer carácter (opcional)
      fechaTxt = fechaTxt.charAt(0).toUpperCase() + fechaTxt.slice(1);
    }
  }

  // Construye "mar, 07 de octubre de 2025 — 18:00–20:00"
  const horas =
    (hIni && hFin) ? ` — ${hIni}–${hFin}` :
    (hIni ? ` — ${hIni}` : '');

  el.textContent = (fechaTxt || 'Fecha sin definir') + horas;
})();
</script>
<script>
(() => {
  const eventoId = <%= evento.id %>;

  // Rutas disponibles (sin add_all)
  window.ROUTES = window.ROUTES || {};
  window.ROUTES.extras = {
    list:   (id, tipo) => `/eventos/${id}/extras/${tipo}`,
    addSel: (id, tipo) => `/eventos/${id}/extras/${tipo}/add`,
    tags:   (id)       => `/eventos/${id}/extras/tags` // si algún día existe, se usará
  };
   // Leer horas del evento de #evtDate
  const evtDateEl = document.getElementById('evtDate');
 const H_INI = (evtDateEl?.dataset?.hini || '').slice(0,5) || null;
  const H_FIN = (evtDateEl?.dataset?.hfin || '').slice(0,5) || null;
  // Fallback y “memoria” local
  const FALLBACK = { invitados: new Set(), reservas: new Set() };
  const LS_INV = `evt${eventoId}:extras:inv`;
  const LS_RES = `evt${eventoId}:extras:res`;
  const addedInv = new Set(JSON.parse(localStorage.getItem(LS_INV) || '[]'));
  const addedRes = new Set(JSON.parse(localStorage.getItem(LS_RES) || '[]'));
  const saveAdded = () => {
    localStorage.setItem(LS_INV, JSON.stringify([...addedInv]));
    localStorage.setItem(LS_RES, JSON.stringify([...addedRes]));
  };

  // Carga tabla de un tipo (rellena fallback)
  async function load(tipo){
  const rows = await __fetchJSON(window.ROUTES.extras.list(eventoId, tipo));
  const tbody = document.querySelector(`#extrasWrap table[data-tipo="${tipo}"] tbody`);
  if (!tbody) return;

  tbody.textContent = '';

  for (const r of (rows || [])) {
    const tr = document.createElement('tr');
    tr.dataset.alumno = String(r.id);

    // ✓
    const tdChk = document.createElement('td');
    const chk = document.createElement('input');
    chk.type = 'checkbox';
    chk.className = 'sel';
    tdChk.appendChild(chk);

    // Nombre + instrumento (debajo)
    const tdNom = document.createElement('td');

    const lineaNombre = document.createElement('div');
    const strong = document.createElement('strong');
    strong.textContent = `${r.apellidos || ''}, ${r.nombre || ''}`.replace(/\s+,/g, ',');
    lineaNombre.appendChild(strong);

    const lineaInstr = document.createElement('div');
    lineaInstr.className = 'text-muted';
    const instrumentos = (r.instrumento || r.instrumentos || '').toString().trim();
    lineaInstr.textContent = instrumentos || '—';

    tdNom.append(lineaNombre, lineaInstr);

    tr.append(tdChk, tdNom);
    tbody.appendChild(tr);
  }

  // Fallbacks (mantén tu lógica)
  FALLBACK[tipo].clear();
  (rows || []).forEach(r => FALLBACK[tipo].add(Number(r.id)));
}


 async function addSelected(tipo){
   const tbody = document.querySelector(`#extrasWrap table[data-tipo="${tipo}"] tbody`);
   const ids = Array.from(tbody.querySelectorAll('.sel:checked'))
     .map(chk => Number(chk.closest('tr').dataset.alumno))
     .filter(Number.isInteger);
   if (!ids.length) return;

  // Lee horas del encabezado del evento
   const evt = document.getElementById('evtDate');
   const H_INI = (evt?.dataset?.hini || '').slice(0,5) || null; // "HH:MM"
   const H_FIN = (evt?.dataset?.hfin || '').slice(0,5) || null; // "HH:MM"

   const alumnos = ids.map(id => ({
     alumno_id: id,
     hora_inicio: H_INI,
     hora_fin: H_FIN
     // instrumento: (opcional; si no lo pones, el plano usa fallback y mostrará "Varios" si procede)
   }));

   // Endpoint correcto para extras (insert-only)
   await fetch(window.ROUTES.extras.addSel(eventoId, tipo), {
     method: 'POST',
     headers: { 'Content-Type':'application/json' },
     body: JSON.stringify({ alumnos })
   });

   ids.forEach(id => (tipo === 'invitados' ? addedInv : addedRes).add(id));
   saveAdded();
   window.location.reload();
 }

  // Delegación: “Ocultar” independiente + “Añadir seleccionados”
  document.getElementById('extrasWrap').addEventListener('click', (ev) => {
    const btn = ev.target.closest('[data-action], .panel-toggle');
    if (!btn) return;

    // ⛔ cancela cualquier “add-all” residual
    if (btn.dataset?.action === 'add-all') return;

    // Mostrar/ocultar propio panel
    if (btn.classList.contains('panel-toggle')) {
      const panel = btn.closest('.extras-panel');
      const collapsed = panel.classList.toggle('is-collapsed');
      btn.textContent = collapsed ? 'Mostrar' : 'Ocultar';
      btn.setAttribute('aria-expanded', String(!collapsed));
      return;
    }

    const tipo = btn.closest('.extras-panel')?.dataset?.tipo;
    if (!tipo) return;
    if (btn.dataset.action === 'add-sel') addSelected(tipo);
  });

  // Marcado INV/RES
  async function fetchTagsSafe(){
    try { return await __fetchJSON(window.ROUTES.extras.tags(eventoId)); }
    catch { // 404 → combina fallback + lo añadido en esta sesión
      return {
        invitados: [...new Set([...FALLBACK.invitados, ...addedInv])],
        reservas : [...new Set([...FALLBACK.reservas , ...addedRes])]
      };
    }
  }
  async function marcarAsignacionesConTags(){
    const tags = await fetchTagsSafe();
    const setInv = new Set(tags.invitados || []);
    const setRes = new Set(tags.reservas  || []);
    const body = document.getElementById('asigBody'); if (!body) return;

    body.querySelectorAll('tr[data-alumno]').forEach(tr => {
      const id = Number(tr.dataset.alumno);
      if (!Number.isInteger(id)) return;

      tr.classList.remove('is-invitado', 'is-reserva');
      tr.querySelectorAll('.tag-chip').forEach(n => n.remove());

      let chip = '';
      if (setInv.has(id)) { tr.classList.add('is-invitado'); chip = '<span class="tag-chip inv">INV</span>'; }
      else if (setRes.has(id)) { tr.classList.add('is-reserva'); chip = '<span class="tag-chip res">RES</span>'; }

      if (chip) {
         const strong = tr.querySelector('td:first-child strong');
        if (strong) strong.insertAdjacentHTML('afterend', ' ' + chip);
      }
    });
  }

  // Carga inicial y observer robusto
  (async () => {
    await load('invitados');
    await load('reservas');
    marcarAsignacionesConTags();
    __initAsignObserver(marcarAsignacionesConTags);
  })();
})();
</script>
