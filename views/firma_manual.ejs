<script>
  /* FIX: Extras (Invitados/Reservas) – añadir seleccionados con horas y sin colisiones */
  (() => {
    const wrap = document.getElementById('extrasWrap');
    if (!wrap) return;
  
    // Id del evento (ya lo tienes disponible en la vista)
    const eventoId = Number(<%= evento.id %>);
  
    // Lee horas del evento desde #evtDate (data-hini / data-hfin)
    const evtDate = document.getElementById('evtDate');
    const toHHMMSS = v => {
      const m = String(v || '').match(/^(\d{2}):(\d{2})/);
      return m ? `${m[1]}:${m[2]}:00` : null;
    };
    const H_INI = toHHMMSS(evtDate?.dataset?.hini);
    const H_FIN = toHHMMSS(evtDate?.dataset?.hfin);
  
    async function putAsignacion(alumnoId, body) {
      const r = await fetch(`/eventos/${eventoId}/asignaciones/${alumnoId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      if (!r.ok) throw new Error('PUT asignación falló');
    }
  
    async function addSel(tipo) {
      const tbody = wrap.querySelector(`table[data-tipo="${tipo}"] tbody`);
      if (!tbody) return;
      const ids = Array.from(tbody.querySelectorAll('input.sel:checked'))
        .map(ch => Number(ch.closest('tr')?.dataset?.alumno))
        .filter(Number.isInteger);
      if (!ids.length) return;
  
      const body = {};
      if (H_INI) body.hora_inicio = H_INI;
      if (H_FIN) body.hora_fin    = H_FIN;
  
      // Sube cada seleccionado con horas del evento
      for (const id of ids) await putAsignacion(id, body);
  
      // Al terminar, recarga para que desaparezcan de extras y aparezcan en la lista asignada
      location.reload();
    }
  
    // Captura primero y anula manejadores viejos que estaban duplicados/rotos
    wrap.addEventListener('click', (ev) => {
      const btn = ev.target.closest('[data-action="add-sel"]');
      if (!btn) return;
      ev.preventDefault();
      ev.stopImmediatePropagation(); // <-- clave: cancela los listeners antiguos
      const panel = btn.closest('.extras-panel');
      const tipo = panel?.dataset?.tipo; // 'invitados' | 'reservas'
      if (tipo) addSel(tipo);
    }, true);
  })();
  </script>
  <script>
    (() => {
      const btn   = document.getElementById('shareEventoBtn');
      const mini  = document.getElementById('shareEventoMini');
      const inp   = document.getElementById('shareEventoUrl');
      const copy  = document.getElementById('shareEventoCopy');
      const exp   = document.getElementById('shareEventoExp');
      const err   = document.getElementById('shareEventoErr');
    
      const eventoId = <%= Number(evento.id) %>; // ya lo tienes en la vista
    
      btn?.addEventListener('click', async (e) => {
        e.preventDefault();
        err.classList.add('d-none');
    
        try {
          btn.disabled = true;
          const prev = btn.textContent; btn.textContent = 'Generando…';
    
          const r = await fetch('/api/share', {
            method: 'POST',
            headers: { 'Content-Type':'application/json' },
            body: JSON.stringify({
              kind: 'plano',
              params: { grupo: eventoId, src: 'evento' }, // ← plano del EVENTO
              expireHours: 24 * 7                           // 7 días (ajusta a gusto)
            })
          });
          const j = await r.json().catch(() => ({}));
          if (!r.ok || !j.ok) throw new Error(j.msg || 'No se pudo crear el enlace');
    
          inp.value = j.url;
          mini.classList.remove('d-none');
          exp.textContent = j.expiresAt ? new Date(j.expiresAt).toLocaleString() : '—';
    
          copy.onclick = () => {
            navigator.clipboard.writeText(j.url).then(() => {
              const old = copy.textContent; copy.textContent = 'Copiado ✓';
              setTimeout(() => copy.textContent = old, 1000);
            });
          };
    
          btn.textContent = prev;
          btn.disabled = false;
        } catch (e) {
          err.textContent = e.message || 'Error creando el enlace';
          err.classList.remove('d-none');
          btn.disabled = false;
          btn.textContent = 'Generar enlace público';
        }
      });
    })();
    </script>    
    <script>
      (() => {
        const btn   = document.getElementById('shareEventoBtn');  // tu botón existente
        if (!btn) return;
      
        const eventoId = <%= Number(evento.id) %>;                // en firma_manual.ejs
      
        const $modalEl = document.getElementById('sharePlanoModal');
        const $url     = document.getElementById('sharePlanoUrl');
        const $exp     = document.getElementById('sharePlanoExp');
        const $copy    = document.getElementById('sharePlanoCopy');
        const $open    = document.getElementById('sharePlanoOpen');
      
        // instancia Bootstrap Modal
        let modal;
        function ensureModal() {
          if (!modal) modal = new bootstrap.Modal($modalEl, { backdrop: 'static' });
        }
      
        btn.addEventListener('click', async (e) => {
          e.preventDefault();
          btn.disabled = true;
          const prev = btn.textContent;
          btn.textContent = 'Generando…';
          try {
            const r = await fetch('/api/share', {
              method: 'POST',
              headers: { 'Content-Type':'application/json' },
              body: JSON.stringify({
                kind: 'plano',
                params: { grupo: eventoId, src: 'evento' },
                expireHours: 24 * 7
              })
            });
            const j = await r.json();
            if (!r.ok || !j.ok) throw new Error(j.msg || 'No se pudo crear el enlace');
      
            // Rellenar modal
            $url.value = j.url;
            $exp.textContent = j.expiresAt ? new Date(j.expiresAt).toLocaleString() : '—';
            $open.href = j.url;
      
            // Mostrar modal (sin mover cabecera)
            ensureModal();
            modal.show();
      
            // Copiar al portapapeles
            $copy.onclick = () => {
              navigator.clipboard.writeText(j.url).then(() => {
                const old = $copy.textContent; $copy.textContent = 'Copiado ✓';
                setTimeout(() => $copy.textContent = old, 1200);
              });
            };
      
          } catch (err) {
            alert(err.message || 'Error creando el enlace');
          } finally {
            btn.textContent = prev;
            btn.disabled = false;
          }
        });
      })();
      </script>
      