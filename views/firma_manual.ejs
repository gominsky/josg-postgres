<!-- ============ Utils compartidas ============ -->
<script>
(() => {
  window.__fetchJSON = async (url, opts) => {
    const r = await fetch(url, opts||{});
    if (!r.ok) throw new Error((await r.text()) || r.status);
    const ct = r.headers.get('content-type') || '';
    return ct.includes('application/json') ? r.json() : {};
  };
  window.__jsonOrText = async (res) => {
    const ct = res.headers.get('content-type') || '';
    return ct.includes('application/json') ? res.json() : { error: await res.text() };
  };
})();
</script>

<!-- ============ Rutas necesarias ============ -->
<script>
(() => {
  window.ROUTES = {
    asignaciones: {
      base:   (eventoId, alumnoId) => `/eventos/${eventoId}/asignaciones/${alumnoId}`,
      refresh:(eventoId) => `/eventos/${eventoId}/asignaciones/refresh`,
      bulk:   (eventoId) => `/eventos/${eventoId}/asignaciones/bulk`
    },
    instrumentos: {
      list: (eventoId) => `/eventos/${eventoId}/instrumentos`,
      del : (eventoId) => `/eventos/${eventoId}/instrumentos`
    },
    familias: {
      list: (eventoId) => `/eventos/${eventoId}/familias`,
      put : (eventoId) => `/eventos/${eventoId}/familias`,
      del : (eventoId) => `/eventos/${eventoId}/familias`
    }
  };
    const extras = {
    list:   (eventoId, tipo) => `/eventos/${eventoId}/extras/${tipo}`,              // GET
    addAll: (eventoId, tipo) => `/eventos/${eventoId}/extras/${tipo}/add_all`,      // POST
    addSel: (eventoId, tipo) => `/eventos/${eventoId}/extras/${tipo}/add`           // POST
  };
  window.ROUTES = window.ROUTES || {};
  window.ROUTES.extras = extras;
})();
</script>

<script>
(() => {
  const eventoId = <%= evento.id %>;
  const $wrap = document.getElementById('extrasWrap');

  const tipos = ['invitados','reservas'];
  const dataCache = { invitados: [], reservas: [] };

  async function load(tipo){
    const url = window.ROUTES.extras.list(eventoId, tipo);
    dataCache[tipo] = await __fetchJSON(url);
    render(tipo);
  }

  function render(tipo){
  const rows = dataCache[tipo] || [];
  const tbody = document.querySelector(`#extrasWrap table[data-tipo="${tipo}"] tbody`);
  if (!tbody) return;

  // Limpia el cuerpo
  tbody.textContent = '';

  if (!rows.length) return;

  for (const r of rows) {
    const tr = document.createElement('tr');
    tr.dataset.alumno = String(r.id);

    // Columna check
    const tdChk = document.createElement('td');
    const chk = document.createElement('input');
    chk.type = 'checkbox';
    chk.className = 'sel';
    tdChk.appendChild(chk);

    // Columna nombre (línea 1: nombre; línea 2: instrumento)
    const tdNom = document.createElement('td');

    const lineaNombre = document.createElement('div');
    const strong = document.createElement('strong');
    strong.textContent = `${r.apellidos || ''}, ${r.nombre || ''}`.replace(/\s+,/g, ',');
    lineaNombre.appendChild(strong);

    const lineaInstr = document.createElement('div');
    lineaInstr.className = 'text-muted small';
    const instrumentos = (r.instrumento || r.instrumentos || '').toString().trim();
    if (instrumentos) {
      lineaInstr.textContent = instrumentos;
    } else {
      // Si prefieres no mostrar nada, comenta las dos siguientes líneas:
      lineaInstr.textContent = '—';
      lineaInstr.style.opacity = '0.6';
    }

    tdNom.append(lineaNombre, lineaInstr);

    tr.append(tdChk, tdNom);
    tbody.appendChild(tr);
  }
}

  async function addAll(tipo){
    await __fetchJSON(window.ROUTES.extras.addAll(eventoId, tipo), { method:'POST' });
    window.location.reload();
  }

  // — Horas del evento → HH:MM:SS
  const evtDateEl = document.getElementById('evtDate');
  const toHHMMSS = v => {
    const t = String(v||'').slice(0,5);
    return /^\d{2}:\d{2}$/.test(t) ? (t + ':00') : null;
  };
  const H_INI = toHHMMSS(evtDateEl?.dataset?.hini);
  const H_FIN = toHHMMSS(evtDateEl?.dataset?.hfin);

  async function addSelected(tipo){
  const $wrap = document.getElementById('extrasWrap');
  const tbody = $wrap?.querySelector(`table[data-tipo="${tipo}"] tbody`);
  if (!tbody) return;

  const filas = Array.from(tbody.querySelectorAll('.sel:checked'))
    .map(ch => ch.closest('tr'))
    .filter(Boolean);
  if (!filas.length) return;

  // Horas del evento desde #evtDate (dataset con "hini"/"hfin")
  const evt = document.getElementById('evtDate');
  const toHHMMSS = v => {
    const m = String(v||'').match(/^(\d{2}):(\d{2})(?::(\d{2}))?$/);
    return m ? `${m[1]}:${m[2]}:${m[3] ?? '00'}` : null;
  };
  const H_INI = toHHMMSS(evt?.dataset?.hini);
  const H_FIN = toHHMMSS(evt?.dataset?.hfin);

  // Prepara lote (incluye instrumento si lo quieres persistir)
  const alumnos = filas.map(tr => {
    const alumno_id = Number(tr.dataset.alumno);
    const instText  = tr.querySelector('.text-muted, .text-muted.small')?.textContent?.trim() || '';
    const instrumento = (instText.split(',')[0] || '').trim() || null;
    return { alumno_id, hora_inicio: H_INI, hora_fin: H_FIN, instrumento };
  });

  const url = (window.ROUTES?.extras?.addSel?.(eventoId, tipo)) ?? `/eventos/${eventoId}/extras/${tipo}/add`;
  const r = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type':'application/json' },
    body: JSON.stringify({ alumnos })
  });
  if (!r.ok) {
    const msg = await r.text().catch(()=>r.statusText);
    throw new Error(`Fallo al añadir ${tipo}: ${r.status} ${msg}`);
  }

  // (opcional) memoriza en LS si usas addedInv/addedRes
  if (window.addedInv && window.addedRes && window.saveAdded) {
    alumnos.forEach(a => (tipo === 'invitados' ? addedInv : addedRes).add(a.alumno_id));
    saveAdded();
  }

  location.reload();
}

// Delegación de clicks (asegúrate de tener $wrap)
const $wrap = document.getElementById('extrasWrap');
$wrap.addEventListener('click', ev => {
  const btn = ev.target.closest('[data-action]');
  if (!btn) return;
  const tipo = btn.closest('[data-tipo]')?.dataset.tipo;
  if (!tipo) return;

  if (btn.dataset.action === 'add-all') addAll(tipo);
  if (btn.dataset.action === 'add-sel') addSelected(tipo);
});

  // Init
  (async () => {
    for (const t of tipos) await load(t);
  })();
})();
</script>

