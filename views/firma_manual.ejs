<% title = 'Configuración de evento' %>
<% hero = false %>
<!-- ================== TOOLBAR COMPACTA (2 FILAS) ================== -->
<div class="evt-toolbar">
  <!-- Fila 1: Plantillas -->
  <div class="evt-row evt-row-top">
    <div class="evt-left">
      <div class="tpl-group">
        <label for="tplSel" class="tpl-label">Plantilla</label>
        <select id="tplSel" class="form-select form-select-sm tpl-sel">
          <option value="">Selecciona una plantilla </option>
        </select>
      </div>
      <div class="btn-group gap-2">
        <button id="tplApply"  class="btn btn-ghost-sm">Vista previa</button>
        <button id="tplClear"  class="btn btn-ghost-sm">Quitar filtro</button>
        <button id="tplPersist" class="btn btn-solid-sm">Aplicar y guardar</button>
        <button id="tplDelete"  class="btn btn-outline-sm" disabled>Eliminar</button>
      </div>
      <span id="tplInfo" class="tpl-info small"></span>
    </div>
    <div class="evt-right"><!-- vacío a propósito --></div>
  </div>

  <!-- Fila 2: Configuración (switches + utilidades + guardar plantilla) -->
  <div class="evt-row evt-row-bottom">
    <div class="cfg-left">
      <span class="cfg-label">Configuración:</span>
      <label class="pill-switch">
        <input class="form-check-input" type="checkbox" id="swFam">
        <span>Familias</span>
      </label>
      <label class="pill-switch">
        <input class="form-check-input" type="checkbox" id="swInst">
        <span>Instrumento</span>
      </label>
      <label class="pill-switch">
        <input class="form-check-input" type="checkbox" id="swAlu" checked>
        <span>Individual</span>
      </label>

      <!-- Enlace Guardar plantilla (mismo sitio visual, pero en la fila de abajo) -->
      <div class="tpl-popwrap">
        <a id="linkSaveTpl" href="#" class="evt-link-add">＋ Guardar configuración actual como plantilla</a>
        <!-- Popover guardar plantilla -->
<form id="saveTplForm" class="evt-popover tpl-hidden form-compact" style="margin:0">
  <div class="popover-head">
    <strong>Guardar plantilla</strong>
    <button type="button" class="btn-icon" id="tplCloseX" aria-label="Cerrar">✕</button>
  </div>

  <label class="fc-label" for="tplName">Nombre</label>
  <input id="tplName" class="form-control fc-input" type="text"
         maxlength="60" placeholder="p.ej. Concierto — Ensayo general" required>

  <div class="inline-row">
    <label class="fc-label" for="tplDesc">Descripción <span class="muted">(opcional)</span></label>
    <span class="char-count" id="tplDescCount">0/120</span>
  </div>
  <textarea id="tplDesc" class="form-control fc-textarea" rows="2" maxlength="120"
            placeholder="Notas para reconocerla rápidamente…"></textarea>

  <div class="btns-row">
    <button class="btn btn-outline-xs" type="button" id="cancelSaveTpl">Cancelar</button>
    <button class="btn btn-solid-xs" type="submit" id="tplSubmit">Guardar</button>
  </div>

  <div class="msg-row">
    <span id="saveTplMsg" class="small msg muted"></span>
  </div>
</form>

      </div>
    </div>

    <div class="cfg-right">
      <button id="btnRefreshAsign" class="btn btn-ghost-sm">Restaurar alumnos</button>
      <a class="btn btn-outline-sm" href="/plano/evento/<%= evento.id %>.pdf" target="_blank" rel="noopener">Plano del evento (PDF)</a>
    </div>
  </div>
</div>
<style>
.tpl-sel {
  width: 50% !important;    /* antes 32%, ahora un poco más ancho */
  max-width: 500px;         /* permite crecer un poco más en pantallas grandes */
  min-width: 180px;         /* sigue siendo razonable en pantallas pequeñas */
  flex: 0 0 auto;
}
/* Margen lateral suave para que la tabla no toque bordes */
.container-fluid { padding-left: 12px; padding-right: 12px; }

/* ===== Toolbar ===== */
.evt-toolbar{
  position: relative;
  display: grid;
  gap: 0;                    /* filas pegadas entre sí */
  margin: 0 0 .6rem 0;       /* pegada al header */
}
.evt-row{
  display: flex; align-items: center; justify-content: space-between;
  gap: .75rem; flex-wrap: wrap;
  background: #fff; border: 1px solid #e6e6e6; border-radius: 14px;
  padding: .5rem .75rem; box-shadow: 0 1px 0 rgba(0,0,0,.02);
}
.evt-row-top{
  border-bottom-left-radius: 0; border-bottom-right-radius: 0; border-bottom: none;
  padding-top: .65rem; padding-bottom: .65rem;
}
.evt-row-bottom{
  border-top-left-radius: 0; border-top-right-radius: 0;
  padding-top: .5rem; padding-bottom: .5rem;
}
.evt-left, .evt-right, .cfg-left, .cfg-right {
  display: flex; align-items: center; gap: .6rem; flex-wrap: nowrap;
}

/* Plantillas: select + etiqueta */
.tpl-group { display: inline-flex; align-items: center; gap: .45rem; flex-wrap: nowrap; margin-right: .25rem; }
.tpl-label { font-weight: 600; color:#222; font-size: .95rem; }

/* Select un poco más grande y más pegado a los botones */
.tpl-sel {
  width: 32% !important;         /* un poco más grande */
  max-width: 340px;
  min-width: 160px;
  flex: 0 0 auto;                /* no se expande */
  margin-right: .25rem;          /* más cerca de los botones */
}

/* Info contador de filtro */
.tpl-info { color:#6b7280; }

/* Enlace “Guardar como plantilla” */
.tpl-popwrap { position: relative; }
.evt-link-add{
  font-weight: 600; font-size: .95rem; text-decoration: none; color: #111;
  padding: 6px 10px; border-radius: 10px; border: 1px dashed #e6e6e6;
}
.evt-link-add:hover{ background: #fafafa; }

/* Popover justo debajo del enlace (anclado al wrap) */
.evt-popover{
  position: absolute; top: calc(100% + 8px); left: 0; z-index: 20;
  display: flex; flex-direction: column; gap: 8px; width: min(440px, 85vw);
  background: #fff; border: 1px solid #e6e6e6; border-radius: 14px; padding: 12px;
  box-shadow: 0 12px 28px rgba(0,0,0,.08);
}
.evt-popover .row{ display: flex; gap: 8px; }
.evt-popover input.form-control{ height: 34px; font-size: 14px; }

/* Botones del popover más pequeños */
.btn-solid-xs{
  background:#222; color:#fff; border:1px solid #222;
  border-radius: 10px; padding:.25rem .55rem; font-weight: 700; font-size: 13px;
}
.btn-solid-xs:hover{ filter:brightness(.95); }
.btn-outline-xs{
  background: transparent; color:#222; border:1px solid #cfcfcf;
  border-radius: 10px; padding:.25rem .55rem; font-weight: 600; font-size: 13px;
}
.btn-outline-xs:hover{ background:#f5f5f5; }

/* ===== Botones neutrales de la barra ===== */
.btn-ghost-sm{
  background: transparent; color:#111; border:1px solid #e1e1e1;
  border-radius: 10px; padding:.35rem .75rem; font-weight: 600;
}
.btn-ghost-sm:hover{ background:#f8f8f8; }
.btn-outline-sm{
  background: transparent; color:#222; border:1px solid #cfcfcf;
  border-radius: 10px; padding:.35rem .75rem; font-weight: 600;
}
.btn-outline-sm:hover{ background:#f5f5f5; }
.btn-solid-sm{
  background:#222; color:#fff; border:1px solid #222;
  border-radius: 10px; padding:.35rem .75rem; font-weight: 700;
}
.btn-solid-sm:hover{ filter:brightness(.95); }

/* ===== Pill switches ===== */
.cfg-label{ font-weight:700; color:#222; margin-right:.25rem; }
.pill-switch{
  display:inline-flex; align-items:center; gap:.45rem;
  background:#fafafa; border:1px solid #e6e6e6; border-radius: 999px;
  padding: .22rem .55rem .22rem .4rem; cursor: pointer; user-select: none;
}
.pill-switch input{ margin:0; width:18px; height:18px; }
.pill-switch span{ font-weight:600; color:#333; font-size:.95rem; }

/* Utilidad */
.tpl-hidden{ display:none !important; }

/* Responsivo: en móviles dejamos que la fila envuelva */
@media (max-width: 640px){
  .evt-left, .cfg-left { flex-wrap: wrap; }
  .tpl-sel { width: 100% !important; max-width: 100%; }
}
/* ===== Popover compacto y elegante ===== */
.evt-popover.form-compact{
  position: absolute; top: 44px; /* se ajusta con tu barra */
  right: 10px; z-index: 30;
  display: grid; grid-template-columns: 1fr; gap: 8px;
  width: min(380px, 88vw); /* más estrecho */
  background: #fff; border: 1px solid #e9e9e9; border-radius: 12px;
  padding: 10px 12px;
  box-shadow: 0 12px 28px rgba(0,0,0,.08);
}

.popover-head{
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom: 2px;
}
.popover-head strong{ font-size: 14px; color:#111; }

.btn-icon{
  appearance:none; border:0; background:transparent; cursor:pointer;
  font-size: 16px; line-height: 1; padding: 2px 4px; color:#666;
  border-radius: 6px;
}
.btn-icon:hover{ background:#f3f3f3; }

/* Campos compactos */
.fc-label{ font-size: 12px; font-weight: 600; color:#333; margin-bottom: 2px; }
.muted{ color:#8a8a8a; font-weight: 500; }

.fc-input, .fc-textarea{
  height: 30px; font-size: 14px; padding: 4px 8px;
  border: 1px solid #dcdcdc; border-radius: 8px; background:#fff;
}
.fc-textarea{ height:auto; resize: vertical; min-height: 62px; }

/* Fila de descripción con contador */
.inline-row{
  display:flex; align-items: baseline; justify-content: space-between;
  margin-top: 4px;
}
.char-count{ font-size: 12px; color:#9a9a9a; }

/* Botones XS del popover (más pequeños que los generales) */
.btn-solid-xs, .btn-outline-xs{
  padding: .28rem .6rem; font-size: 13px; font-weight: 700; border-radius: 9px;
}
.btn-solid-xs{ background:#111; color:#fff; border:1px solid #111; }
.btn-solid-xs:hover{ filter:brightness(.96); }
.btn-outline-xs{ background:#fff; color:#222; border:1px solid #cfcfcf; }
.btn-outline-xs:hover{ background:#f6f6f6; }

/* Disposición botones y mensajes */
.btns-row{
  display:flex; gap: 8px; justify-content: flex-end; align-items:center; margin-top: 2px;
}
.msg-row{ min-height: 18px; }
.msg{ font-size: 12px; }
/* Select de plantilla: más ancho y menos alto */
.form-select.tpl-sel{
  min-width: 340px;         /* antes ~280-300; súbelo un poco */
  max-width: 42vw;          /* límite en pantallas grandes */
  height: 32px;             /* más bajo */
  padding: .2rem .65rem;    /* compacta verticalmente */
  font-size: .92rem;        /* un poco más pequeño para ganar altura */
  line-height: 1.2;         /* ayuda a bajar la altura total */
}

/* En algunos Bootstrap, la altura la controlan variables: reforzamos */
.form-select.tpl-sel{
  --bs-form-select-padding-y: .2rem;
  --bs-form-select-font-size: .92rem;
}

/* Acerca el select a los botones */
.evt-left{ gap: .5rem; }    /* si quieres aún más pegado, usa .4rem */

</style>
<script>
(() => {
  // ⛑️ Evita registrar dos veces si la vista reinyecta scripts
  if (window.__TPL_SAVE_UI_BOUND__) return;
  window.__TPL_SAVE_UI_BOUND__ = true;

  const $link = document.getElementById('linkSaveTpl');
  const $form = document.getElementById('saveTplForm');
  const $name = document.getElementById('tplName');
  const $desc = document.getElementById('tplDesc');
  const $count= document.getElementById('tplDescCount');   // opcional: si no existe, no pasa nada
  const $msg  = document.getElementById('saveTplMsg');
  const $btnX = document.getElementById('tplCloseX');      // opcional
  const $btnCancel = document.getElementById('cancelSaveTpl');
  const $btnSubmit = document.getElementById('tplSubmit'); // opcional
  const eventoId = <%= evento.id %>;

  function openForm(){
    $form.classList.remove('tpl-hidden');
    requestAnimationFrame(()=> $name?.focus());
  }
  function resetForm(){
    $msg.textContent = '';
    if ($name) $name.value = '';
    if ($desc) $desc.value = '';
    if ($count) $count.textContent = '0/120';
  }
  function closeForm(){
    $form.classList.add('tpl-hidden');
    resetForm();
  }

  // Abrir / cerrar
  $link?.addEventListener('click', (e) => {
    e.preventDefault();
    ($form.classList.contains('tpl-hidden') ? openForm() : closeForm());
  });
  $btnCancel?.addEventListener('click', (e)=>{ e.preventDefault(); closeForm(); });
  $btnX?.addEventListener('click', (e)=>{ e.preventDefault(); closeForm(); });

  // Cerrar con ESC
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape' && !$form.classList.contains('tpl-hidden')) closeForm();
  });

  // Cerrar haciendo click fuera
  document.addEventListener('click', (ev) => {
    if ($form.classList.contains('tpl-hidden')) return;
    const inside = ev.target.closest('#saveTplForm') || ev.target.closest('#linkSaveTpl');
    if (!inside) closeForm();
  });

  // Contador descripción (si existe)
  $desc?.addEventListener('input', ()=> { if ($count) $count.textContent = `${$desc.value.length}/120`; });

  // 🛡️ Mutex global para evitar doble envío
  async function doSave(nombre, descripcion){
    if (window.__TPL_SAVE_IN_FLIGHT__) return;  // ya se está guardando
    window.__TPL_SAVE_IN_FLIGHT__ = true;
    $btnSubmit?.setAttribute('disabled','disabled');

    try{
      const r = await fetch(`/plantillas/from-event/${eventoId}`, {
        method:'POST',
        headers:{ 'Content-Type':'application/json' },
        body: JSON.stringify({ nombre, descripcion })
      });
      const ct = r.headers.get('content-type')||'';
      const data = ct.includes('application/json') ? await r.json() : {};
      if (!r.ok || data?.ok === false) throw new Error(data?.error || `HTTP ${r.status}`);

      $msg.textContent = '✓ Guardada';

      // refresca el select y selecciona la nueva si devuelves id
      if (window.__reloadTplSel) {
        window.__reloadTplSel({ selectNewId: data?.id }).catch(console.error);
      }
      setTimeout(closeForm, 400);
    } catch (e) {
      console.error(e);
      $msg.textContent = 'Error guardando';
    } finally {
      window.__TPL_SAVE_IN_FLIGHT__ = false;
      $btnSubmit?.removeAttribute('disabled');
    }
  }

  // Envío del form (único)
  $form?.addEventListener('submit', (ev) => {
    ev.preventDefault();
    ev.stopPropagation();
    ev.stopImmediatePropagation(); // por si quedó algún handler viejo
    const nombre = ($name?.value||'').trim();
    const descripcion = ($desc?.value||'').trim() || null;
    if (!nombre) { $name?.focus(); return; }
    $msg.textContent = 'Guardando…';
    doSave(nombre, descripcion);
  });
})();
</script>


  <!-- ========= BLOQUE FAMILIAS ========= -->
  <div id="famWrap" style="display:none">
    <h5 class="mb-2">Agrupación por familias</h5>
    <div class="table-responsive">
      <table class="table table-striped tabla-estilizada">
        <thead>
          <tr>
            <th>Familia</th>
            <th class="text-center">Inicio</th>
            <th class="text-center">Fin</th>
            <th>Actividad</th>
            <th>Notas</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="famBody">
          <tr><td colspan="6" class="text-muted">(Se cargará al activar el switch)</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ========= BLOQUE INSTRUMENTOS ========= -->
  <div id="instWrap" style="display:none">
    <h5 class="mb-2">Agrupación por instrumentos</h5>
    <div class="table-responsive">
      <table class="table table-striped tabla-estilizada">
        <thead>
          <tr>
            <th>Instrumento</th>
            <th class="text-center">Inicio</th>
            <th class="text-center">Fin</th>
            <th>Actividad</th>
            <th>Notas</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="instBody">
          <tr><td colspan="6" class="text-muted">(Se cargará al activar el switch)</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ========= BLOQUE INDIVIDUAL ========= -->
  <div id="alumWrap">
    <h5 class="mb-2">Asignaciones individuales</h5>
    <div class="table-responsive">
      <table class="table table-striped tabla-estilizada">
        <thead>
          <tr>
            <th class="th-sort" data-key="apellidos">Músico</th>
            <th class="th-sort" data-key="instrumento">Instrumento</th>
            <th class="text-center th-sort" data-key="firmado">Firmado</th>
            <th class="text-center th-sort" data-key="inicio">Inicio</th>
            <th class="text-center th-sort" data-key="fin">Fin</th>
            <th class="th-sort" data-key="ausencia">Ausencia</th>
            <th class="text-center">Min. perdidos</th>
            <th class="th-sort" data-key="actividad">Actividad</th>
            <th class="th-sort" data-key="notas">Notas</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="asigBody">
          <% (alumnos||[]).forEach(row => { %>
           <tr
              data-alumno="<%= row.id %>"
              data-apellidos="<%= (row.apellidos || '') + ' ' + (row.nombre || '') %>"
              data-instrumento="<%= row.instrumento || row.instrumento_mostrado || ((row.instrumentos||'').split(',')[0]||'') %>"
              data-instrumentos="<%= row.instrumentos || '' %>"
              data-instr-empty="<%= (!row.instrumento || String(row.instrumento).trim()==='') ? '1' : '0' %>"
              data-inicio="<%= (row.hora_inicio || '') %>"
              data-fin="<%= (row.hora_fin || '') %>"
              data-ausencia-id="<%= row.ausencia_tipo_id || '' %>"
              data-ausencia="<%= row.ausencia_tipo || '' %>"
              data-actividad-id="<%= row.actividad_complementaria_id || '' %>"
              data-actividad="<%= row.actividad_complementaria || '' %>"
              data-notas="<%= row.notas || '' %>"
              data-familia="<%= row.familia_mostrada || '' %>"
              data-minutos="<%= row.minutos_perdidos || '' %>"
            >
            <td>
              <strong><%= (row.apellidos||'') %>, <%= (row.nombre||'') %></strong>
              <div class="text-muted small">
                <%= (row.instrumentos || '') %>
              </div>
            </td>
            <td>
              <div class="td-instrumento" contenteditable="true">
                <%= row.instrumento || row.instrumento_mostrado || (row.instrumentos||'').split(',')[0] || '' %>
              </div>
            </td>            
              <td class="text-center">
                <input class="form-check-input chk-firmado" type="checkbox" value="<%= row.id %>"
                  <%= firmados.includes(row.id) ? 'checked' : '' %>>
              </td>
              <td><input type="time" class="form-control form-control-sm inp-ini"
                value="<%= (row.hora_inicio || '').slice(0,5) %>"></td>
              <td><input type="time" class="form-control form-control-sm inp-fin"
                value="<%= (row.hora_fin || '').slice(0,5) %>"></td>
              <td><select class="form-select form-select-sm sel-aus"></select></td>
              <td class="text-center">
                <% if (row.minutos_perdidos && row.minutos_perdidos > 0) { %>
                  <span class="badge-delay">+<%= row.minutos_perdidos %> min</span>
                <% } else { %>
                  —
                <% } %>
              </td>
              
              <td><select class="form-select form-select-sm sel-act"></select></td>
              <td><input type="text" class="form-control form-control-sm inp-notas"
                value="<%= row.notas || '' %>"></td>
              <td><button type="button" class="btn btn-outline-danger btn-sm btn-del">&times;</button></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="volver-bloque-izquierda mt-4">
      <a href="/eventos" class="enlace-final">← Volver al calendario</a>
    </div>
  </div>
</div>

