<% title = 'Configuración de evento' %>
<% hero = false %>

<div class="container-fluid mt-4" style="max-width: 1400px;">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h1-titulo mb-0">Configuración de evento</h1>
    <div class="d-flex gap-2">
      <button id="btnRefreshAsign" class="btn-main-blanco fw-bold px-3 py-2">Repoblar desde grupo</button>
      <a href="/eventos" class="btn-main-blanco fw-bold px-3 py-2">Eventos</a>
    </div>
  </div>

  <div class="text-center mb-3">
    <h5>Evento: <%= evento.titulo %> (<%= evento.grupo_nombre %>)</h5>
    <p>
      <strong>Fecha:</strong> <%= iniTxt %>,
      <strong>Hora:</strong> <%= hIni %> - <%= hFin %>
    </p>
  </div>

  <!-- Tabla única: firmas + edición -->
  <div>
    <table class="table table-sm align-middle tabla-estilizada">
      <thead>
        <tr>
          <th class="th-sort" data-sort="apellidos">Nombre completo</th>
          <th class="th-sort" data-sort="instrumento">Instrumento</th>
          <th class="th-sort" data-sort="firmado">Firmado</th>
          <th class="th-sort" data-sort="inicio">Inicio</th>
          <th class="th-sort" data-sort="fin">Fin</th>
          <th class="th-sort" data-sort="ausencia">Ausencia</th>
          <th class="th-sort" data-sort="actividad">Actividad compl.</th>
          <th class="th-sort" data-sort="notas">Notas</th>
          <th style="width:160px">Acciones</th>
        </tr>
      </thead>

      <tbody id="asigBody">
        <% alumnos.forEach(row => { %>
          <tr class="<%= row.ausencia_tipo_id ? 'row-ausente' : '' %> <%= row.actividad_complementaria_id ? 'row-actividad' : '' %>"
              data-alumno="<%= row.id %>"
              data-apellidos="<%= (row.apellidos || '') + ', ' + (row.nombre || '') %>"
              data-instrumento="<%= row.instrumento_mostrado || '' %>"
              data-firmado="<%= firmados.includes(row.id) ? '1' : '0' %>"
              data-inicio="<%= (row.hora_inicio || '').slice(0,5) %>"
              data-fin="<%= (row.hora_fin || '').slice(0,5) %>"
              data-ausencia="<%= row.ausencia_tipo || '' %>"
              data-actividad="<%= row.actividad_complementaria || '' %>"
              data-ausencia-id="<%= row.ausencia_tipo_id || '' %>"
              data-actividad-id="<%= row.actividad_complementaria_id || '' %>"
              data-notas="<%= row.notas || '' %>">
            <td class="text-start"><%= row.apellidos %>, <%= row.nombre %></td>
            <td><%= row.instrumento_mostrado || (row.instrumentos || '') %></td>

            <td class="text-center">
              <input
                class="form-check-input chk-firmado"
                type="checkbox"
                value="<%= row.id %>"
                <%= firmados.includes(row.id) ? 'checked' : '' %>
                style="transform:scale(1.6); accent-color: orange;"
              >
            </td>
            <td><input type="time" class="form-control form-control-sm inp-ini" value="<%= (row.hora_inicio || '').slice(0,5) %>"></td>
            <td><input type="time" class="form-control form-control-sm inp-fin" value="<%= (row.hora_fin || '').slice(0,5) %>"></td>
            <td><select class="form-select form-select-sm sel-aus"></select></td>
            <td><select class="form-select form-select-sm sel-act"></select></td>
            <td><input type="text" class="form-control form-control-sm inp-notas" value="<%= row.notas || '' %>"></td>
            <td class="text-end">
              <button type="button" class="btn btn-outline-danger btn-sm btn-del" aria-label="Eliminar">&times;</button>
            </td>
          </tr>
        <% }) %>
      </tbody>

      <tfoot>
        <tr>
          <td colspan="9" class="text-end align-middle">
            <button id="btnGuardarLote" class="btn-main-blanco" disabled>
              Guardar <span id="cntCambios">(0)</span>
            </button>
          </td>
        </tr>
      </tfoot>
    </table>
  </div>

  <div class="volver-bloque-izquierda mt-4">
    <a href="/eventos" class="enlace-final">← Volver al calendario</a>
  </div>
</div>

<style>
  .tabla-estilizada td, .tabla-estilizada th { padding: 10px 12px; vertical-align: middle; }
  .tabla-estilizada input.form-control, .tabla-estilizada select.form-select {
    height: 36px; padding: 4px 10px; font-size: .95rem;
  }
  .row-ausente   { background: #fff7df; }
  .row-actividad { box-shadow: inset 3px 0 0 #0d6efd; }
  .row-dirty     { background: rgba(255,149,1,.08); }
  .th-sort { cursor: pointer; user-select: none; }
  .th-sort::after { content: ' ⇅'; font-size: .8em; opacity: .5; }
  .th-sort.asc::after  { content: ' ↑'; opacity: .9; }
  .th-sort.desc::after { content: ' ↓'; opacity: .9; }
</style>

<script>
(() => {
  const eventoId   = <%= evento.id %>;
  const $tbody     = document.getElementById('asigBody');
  const $btnRefresh= document.getElementById('btnRefreshAsign');
  const $btnGuardar= document.getElementById('btnGuardarLote');
  const $cnt       = document.getElementById('cntCambios');

  // -------------------------------
  // Utilidades
  // -------------------------------
  const jsonOrText = async (res) => {
    const ct = res.headers.get('content-type') || '';
    if (ct.includes('application/json')) return res.json();
    return { error: await res.text() };
  };

  const setBusy = (btn, busy, txtBusy) => {
    if (!btn) return;
    btn.disabled = !!busy;
    if (busy) {
      btn.dataset._txt = btn.textContent;
      if (txtBusy) btn.textContent = txtBusy;
    } else {
      if (btn.dataset._txt) btn.textContent = btn.dataset._txt;
      delete btn.dataset._txt;
    }
  };

  const setDirty = (tr, dirty) => {
    tr.dataset.dirty = dirty ? '1' : '0';
    tr.classList.toggle('row-dirty', !!dirty);
    updateCounter();
  };

  const updateCounter = () => {
    const n = $tbody.querySelectorAll('tr[data-dirty="1"]').length;
    if ($cnt) $cnt.textContent = `(${n})`;
    if ($btnGuardar) $btnGuardar.disabled = n === 0;
  };

  const buildRowPayload = (tr) => {
    const alumnoId   = Number(tr.dataset.alumno);
    const firmado    = tr.querySelector('.chk-firmado')?.checked || false;
    const ausenciaId = tr.querySelector('.sel-aus')?.value || '';
    const actividadId= tr.querySelector('.sel-act')?.value || '';
    const notas      = tr.querySelector('.inp-notas')?.value?.trim() || '';
    const hIni       = tr.querySelector('.inp-ini')?.value?.slice(0,5) || '';
    const hFin       = tr.querySelector('.inp-fin')?.value?.slice(0,5) || '';

    return {
      alumno_id: alumnoId,
      firmado: !!firmado,
      ausencia_tipo_id: ausenciaId ? Number(ausenciaId) : null,
      actividad_complementaria_id: actividadId ? Number(actividadId) : null,
      notas: notas || null,
      hora_inicio: hIni || null,
      hora_fin: hFin || null
    };
  };

  // -------------------------------
  // Catálogos: Ausencias / Actividades
  // -------------------------------
  const fetchJSON = async (url) => {
    const res = await fetch(url);
    if (!res.ok) throw new Error('HTTP ' + res.status);
    return res.json();
  };

  const buildOptions = ($select, items, selectedId) => {
    const optEmpty = document.createElement('option');
    optEmpty.value = ''; optEmpty.textContent = '—';
    $select.appendChild(optEmpty);
    items.forEach(it => {
      const opt = document.createElement('option');
      opt.value = String(it.id);
      opt.textContent = it.tipo;
      if (selectedId && String(selectedId) === String(it.id)) opt.selected = true;
      $select.appendChild(opt);
    });
  };

  const populateAllSelects = async () => {
    try {
      const [ausencias, actividades] = await Promise.all([
        fetchJSON('/ausencias/api'),
        fetchJSON('/actividades/api')
      ]);
      $tbody.querySelectorAll('tr').forEach(tr => {
        const selAus = tr.querySelector('.sel-aus');
        const selAct = tr.querySelector('.sel-act');
        if (selAus) buildOptions(selAus, ausencias, tr.dataset.ausenciaId || '');
        if (selAct) buildOptions(selAct, actividades, tr.dataset.actividadId || '');
      });
    } catch (err) {
      console.error('Error cargando catálogos:', err);
      $tbody.querySelectorAll('.sel-aus, .sel-act').forEach(s => {
        if (!s.querySelector('option')) {
          const opt = document.createElement('option');
          opt.value = ''; opt.textContent = '—'; s.appendChild(opt);
        }
      });
    }
  };

  // -------------------------------
  // Eventos UI
  // -------------------------------
  // Marcar cambios por cualquier edición
  $tbody.addEventListener('change', (ev) => {
    const el = ev.target;
    const tr = el.closest('tr');
    if (!tr) return;

    if (el.classList.contains('sel-aus')) {
      tr.dataset.ausenciaId = el.value || '';
      tr.dataset.ausencia   = el.options[el.selectedIndex]?.textContent || '';
    } else if (el.classList.contains('sel-act')) {
      tr.dataset.actividadId = el.value || '';
      tr.dataset.actividad   = el.options[el.selectedIndex]?.textContent || '';
    } else if (el.classList.contains('chk-firmado')) {
      tr.dataset.firmado = el.checked ? '1' : '0';
    } else if (el.classList.contains('inp-ini')) {
      tr.dataset.inicio = el.value?.slice(0,5) || '';
    } else if (el.classList.contains('inp-fin')) {
      tr.dataset.fin = el.value?.slice(0,5) || '';
    } else if (el.classList.contains('inp-notas')) {
      tr.dataset.notas = el.value || '';
    }

    setDirty(tr, true);
  });

  // Ordenación por cabecera (simple)
  document.querySelectorAll('th.th-sort').forEach(th => {
    th.addEventListener('click', () => {
      const key = th.dataset.sort;
      if (!key) return;
      const rows = Array.from($tbody.querySelectorAll('tr'));
      const asc = !th.classList.contains('asc');
      document.querySelectorAll('th.th-sort').forEach(h => h.classList.remove('asc','desc'));
      th.classList.add(asc ? 'asc' : 'desc');

      const val = (tr, key) => {
        let v = tr.dataset[key] ?? '';
        if (key === 'firmado') v = Number(v);
        else if (key === 'inicio' || key === 'fin') v = (v || '').replace(':','');
        else v = (v || '').toString().toLowerCase();
        return v;
      };
      rows.sort((a,b) => {
        const va = val(a,key), vb = val(b,key);
        if (va < vb) return asc ? -1 : 1;
        if (va > vb) return asc ?  1 : -1;
        return 0;
      });
      rows.forEach(r => $tbody.appendChild(r));
    });
  });

  // Eliminar asignación (por fila)
  $tbody.addEventListener('click', async (ev) => {
    const btnDel = ev.target.closest('.btn-del');
    if (!btnDel) return;
    const tr = btnDel.closest('tr');
    const alumnoId = tr?.dataset.alumno;
    if (!alumnoId) return;

    if (!confirm('¿Quitar a este alumno del evento?')) return;
    try {
      setBusy(btnDel, true, 'Eliminando…');
      const res = await fetch(`/eventos/${eventoId}/asignaciones/${alumnoId}`, { method:'DELETE' });
      const data = await jsonOrText(res);
      if (!res.ok) throw new Error(data?.error || `HTTP ${res.status}`);
      tr.remove();
      updateCounter();
    } catch (err) {
      console.error('Error eliminando asignación:', err);
      alert('Error eliminando asignación');
      setBusy(btnDel, false);
    }
  });

  // Repoblar desde grupo
  if ($btnRefresh) {
    $btnRefresh.addEventListener('click', async () => {
      if (!confirm('Añadirá los alumnos del grupo vigentes ese día (no borra). ¿Continuar?')) return;
      try {
        setBusy($btnRefresh, true, 'Repoblando…');
        const res = await fetch(`/eventos/${eventoId}/asignaciones/refresh`, { method:'POST' });
        const data = await jsonOrText(res);
        if (!res.ok) throw new Error(data?.error || `HTTP ${res.status}`);
        location.reload();
      } catch (err) {
        console.error('Error refrescando asignaciones:', err);
        alert('Error refrescando asignaciones');
        setBusy($btnRefresh, false);
      }
    });
  }

  // Guardar en lote
  const guardarLote = async () => {
    const dirtyRows = Array.from($tbody.querySelectorAll('tr[data-dirty="1"]'));
    if (!dirtyRows.length) return;

    const cambios = dirtyRows.map(tr => buildRowPayload(tr));
    const oldTxt = $btnGuardar.textContent;
    setBusy($btnGuardar, true, 'Guardando…');

    try {
      const res = await fetch(`/eventos/${eventoId}/firma_manual/batch`, {
        method:'PUT',
        headers:{ 'Content-Type':'application/json' },
        body: JSON.stringify({ cambios })
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      // si el backend no manda JSON, no lo exigimos
      try { await res.json(); } catch(_) {}

      dirtyRows.forEach(tr => setDirty(tr, false));
      $btnGuardar.textContent = '✔ Guardado';
      setTimeout(() => setBusy($btnGuardar, false, oldTxt), 900);
    } catch (err) {
      console.error('Error guardando lote:', err);
      alert('No se pudieron guardar los cambios');
      setBusy($btnGuardar, false, oldTxt);
      updateCounter();
    }
  };

  $btnGuardar?.addEventListener('click', (e) => {
    e.preventDefault();
    guardarLote();
  });

  // Init
  populateAllSelects();
  updateCounter();
})();
</script>
