<% title = 'Baremos'; hero = false %>

<div class="header-compact">
  <h1 class="h1-titulo">Baremos</h1>
  <a href="/baremos/nuevo" class="btn-main-blanco">+ Añadir baremo</a>
</div>

<% if (!baremos || baremos.length === 0) { %>
  <p class="text-muted mt-3 text-center">No hay baremos registrados.</p>
<% } else { %>
  <div class="dashboard-grid">
    <% baremos.forEach(b => { %>
      <a href="/baremos/editar/<%= b.id %>" class="card activo card--oeg" style="text-decoration:none;">
        <div class="alumno-nombre"><%= b.tipo %></div>
        <div class="alumno-instrumento"><%= b.porcentaje %>%</div>
      </a>
    <% }) %>
  </div>
<% } %>

<div class="volver-bloque-izquierda">
  <a href="/configuracion" class="enlace-final">← Volver a configuración</a>
</div>
