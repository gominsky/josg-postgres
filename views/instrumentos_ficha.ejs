<% const isEdicion = Boolean(instrumento && instrumento.id); %>
<% title = isEdicion ? 'Editar Instrumento' : 'Nuevo Instrumento'; %>
<% hero = false; %>

<h1 class="h1-titulo"><%= title %></h1>

<form 
  id="form-instrumento" 
  method="POST" 
  action="<%= isEdicion ? '/instrumentos/editar/' + instrumento.id : '/instrumentos' %>" 
  class="formulario-alumno" 
  style="border: 2px solid #FF9501; border-radius: 0.75rem; padding: 1rem;"
>
  <div class="grupo-campos">
    <h2>Datos del Instrumento</h2>
    <div class="form-grid-2">
      <label>Nombre:
        <input type="text" name="nombre" id="nombre" value="<%= instrumento?.nombre || '' %>" required>
      </label>
      <label>Familia:
        <select name="familia" required>
          <% familias.forEach(fam => { %>
            <option
              value="<%= fam %>"
              <%= instrumento && instrumento.familia === fam ? 'selected' : '' %>
            ><%= fam %></option>
          <% }) %>
        </select>
       </label>
    </div>
  </div>

  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/instrumentos" class="enlace-final">← Volver</a>
    <div class="d-flex align-items-center gap-2">
      <button type="submit" class="btn-main-blanco"><%= isEdicion ? 'Actualizar' : 'Registrar' %></button>
      <% if (isEdicion) { %>
        <button
          type="submit"
          class="btn-main-blanco"
          formaction="/instrumentos/<%= instrumento.id %>?_method=DELETE"
          formmethod="POST"
          onclick="return confirm('¿Eliminar este instrumento?');"
        >Eliminar</button>
      <% } %>
    </div>
  </div>
</form>


