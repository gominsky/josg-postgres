<% title = 'Listado de Instrumentos' %>
<% hero = false %>

<div>
  <h1 class="h1-titulo">Listado de Instrumentos</h1>
  <div style="text-align: center; margin-top: 1rem;">
    <a href="/instrumentos/nuevo" class="btn-main" style="max-width: 220px;">+ Añadir instrumento</a>
  </div>

  <% if (instrumentos.length === 0) { %>
    <p class="enlace-final" style="text-align: center; margin-top: 2rem;">No hay instrumentos registrados.</p>
  <% } else { %>
    <div class="dashboard-grid" style="margin-top: 2rem;">
      <% instrumentos.forEach(i => { %>
        <a href="/instrumentos/<%= i.id %>/editar" class="card-marron" style="text-decoration: none;">
          <div style="font-weight: 600; font-size: 1rem;"><%= i.nombre %></div>
          <div style="font-size: 0.85rem; color: #f5f1f1;"><%= i.familia %></div>
        </a>
      <% }) %>
    </div>
  <% } %>

  <div class="volver-bloque-izquierda">
  <a href="/configuracion" class="enlace-final">← Volver a configuración</a>
</div>
</div>