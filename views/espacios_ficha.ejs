<% const isEdit = Boolean(espacio && espacio.id); %>
<% title = isEdit ? 'Editar Espacio' : 'Nuevo Espacio'; %>
<% hero = false; %>

<h1 class="h1-titulo"><%= title %></h1>

<form id="form-espacio"
      method="POST"
      action="<%= isEdit ? '/espacios/editar/' + espacio.id : '/espacios' %>"
      class="formulario-alumno"
      style="border:2px solid #FF9501;border-radius:.75rem;padding:1rem;">

  <!-- Datos principales -->
  <div class="grupo-campos">
    <h2>Datos del espacio</h2>
    <div class="form-grid-2">
      <label>Nombre
        <input type="text" name="nombre" required value="<%= espacio?.nombre || '' %>">
      </label>
      <label>Propietario
        <input type="text" name="propietario" required value="<%= espacio?.propietario || '' %>">
      </label>
    </div>
    <div class="form-grid-2">
      <label>Dirección
        <input type="text" name="direccion" required value="<%= espacio?.direccion || '' %>">
      </label>
      <label>Ubicación (enlace de Google Maps)
        <input type="url" name="ubicacion" placeholder="https://maps.google.com/…" value="<%= espacio?.ubicacion || '' %>">
        <% if (isEdit && espacio?.ubicacion) { %>
          <a href="<%= espacio.ubicacion %>" target="_blank" rel="noopener noreferrer">Ver en Google Maps</a>
        <% } %>
      </label>
    </div>
  </div>

  <!-- Contacto -->
  <div class="grupo-campos">
    <h2>Contacto</h2>
    <div class="form-grid-3">
      <label>Teléfono
        <input type="text" name="telefono" value="<%= espacio?.telefono || '' %>">
      </label>
      <label>Email
        <input type="email" class="input-alto" name="email" value="<%= espacio?.email || '' %>">
      </label>
      <label>Sitio web
        <input type="text" name="sitio_web" value="<%= espacio?.sitio_web || '' %>">
      </label>
    </div>
  </div>

  <!-- Clasificación -->
  <div class="grupo-campos">
    <h2>Clasificación</h2>
    <div class="form-grid-2">
      <label>Tipo de espacio
        <select name="tipo_espacio" class="input-alto">
          <option value="">Seleccione</option>
          <option value="Auditorio"  <%= espacio?.tipo_espacio==='Auditorio' ? 'selected' : '' %>>Auditorio</option>
          <option value="Teatro"     <%= espacio?.tipo_espacio==='Teatro' ? 'selected' : '' %>>Teatro</option>
          <option value="Aire libre" <%= espacio?.tipo_espacio==='Aire libre' ? 'selected' : '' %>>Aire libre</option>
          <option value="Otro" <%= espacio?.tipo_espacio==='Otro' ? 'selected' : '' %>>Otro</option>
        </select>
      </label>
      <label>Aforo
        <input type="number" name="aforo" min="0" value="<%= espacio?.aforo ?? '' %>">
      </label>
    </div>
  </div>

  <!-- Recursos y observaciones -->
  <div class="grupo-campos">
    <h2>Recursos y observaciones</h2>
    <div class="form-grid-1">
      <label>Recursos disponibles
        <textarea name="recursos_disponibles" rows="3"><%= espacio?.recursos_disponibles || '' %></textarea>
      </label>
      <label>Observaciones
        <textarea name="observaciones" rows="3"><%= espacio?.observaciones || '' %></textarea>
      </label>
    </div>
  </div>

  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/espacios" class="enlace-final">← Volver</a>
    <div class="d-flex align-items-center gap-2">
      <button type="submit" class="btn-main-blanco"><%= isEdit ? 'Actualizar' : 'Registrar' %></button>
      <% if (isEdit) { %>
        <button
          type="submit"
          class="btn-main-blanco"
          form="form-espacio"
          formaction="/espacios/eliminar/<%= espacio.id %>"
          formmethod="POST"
          onclick="return confirm('¿Eliminar este espacio?');"
        >Eliminar</button>
      <% } %>
    </div>
  </div>
</form>

<style>
  .form-grid-1 { display:grid; grid-template-columns: 1fr; gap:18px; }
  .form-grid-2 { display:grid; grid-template-columns: 1fr 1fr; gap:18px; }
  .form-grid-3 { display:grid; grid-template-columns: 1fr 1fr 1fr; gap:18px; }
  .grupo-campos { border:1px solid #eee; border-radius:10px; padding:18px 18px 12px; margin:20px 0; }
  .grupo-campos h2 { font-size:1.05rem; margin:0 0 12px; }
  label { display:flex; flex-direction:column; gap:8px; font-weight:600; }
  input[type="text"], input[type="number"], input[type="color"],
  input[type="email"], textarea, select {
    border-radius:8px;
    border:1px solid rgba(0,0,0,.2);
    padding:10px 12px;
  }
  /* Extra altura para email y select */
  .input-alto {
    height: 46px;
    line-height: 46px;
  }
  .formulario-alumno label { color:#000 !important; font-weight:600; }
  .formulario-alumno input,
  .formulario-alumno textarea,
  .formulario-alumno select {
    color:#000; background:#fff;
  }
</style>

