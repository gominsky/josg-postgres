<% title = 'Centro de ayuda'; hero = false %>

<div class="header-compact">
  <h1 class="h1-titulo">Centro de ayuda</h1>
  <input id="help-q" type="search" placeholder="Buscar tema…"
         autocomplete="off" class="help-search">
</div>

<div class="action-grid" id="help-grid">

  <a href="/firmas/ayuda" class="action-card"
     data-text="firmas asistencia qr escaneo camara geolocalizacion ubicacion app">
    <div>
      <p class="action-title">JOSG en tu mano</p>
      <p class="action-desc">Registro de asistencia mediante QR desde el móvil, con geolocalización opcional.</p>
      <p class="req-line">
        <span class="badge-soft">QR</span>
        <span class="badge-soft">Asistencia</span>
        <span class="badge-soft">App</span>
      </p>
    </div>
  </a>

  <a href="/alumnos/ayuda" class="action-card"
     data-text="musicos alumnos grupos instrumentos cuotas pagos foto baja eliminar">
    <div>
      <p class="action-title">Músicos</p>
      <p class="action-desc">Alta y edición de músicos, asignación a grupos e instrumentos, cuotas y bajas.</p>
      <p class="req-line">
        <span class="badge-soft">Listado</span>
        <span class="badge-soft">Ficha</span>
        <span class="badge-soft">Finanzas</span>
      </p>
    </div>
  </a>

  <a href="/eventos/ayuda" class="action-card"
     data-text="eventos calendario listado qr firmas asistencia plantillas planos invitados reservas">
    <div>
      <p class="action-title">Eventos</p>
      <p class="action-desc">Calendario, firma manual, plantillas de convocatoria, planos e invitados.</p>
      <p class="req-line">
        <span class="badge-soft">Calendario</span>
        <span class="badge-soft">Plantillas</span>
        <span class="badge-soft">Planos</span>
      </p>
    </div>
  </a>

  <a href="/informes/ayuda" class="action-card"
     data-text="informes listados atril horas certificados pdf exportar constructor">
    <div>
      <p class="action-title">Informes</p>
      <p class="action-desc">Listados dinámicos, pruebas de atril, porcentaje de asistencia y exportación PDF.</p>
      <p class="req-line">
        <span class="badge-soft">Listados</span>
        <span class="badge-soft">Atril</span>
        <span class="badge-soft">PDF</span>
      </p>
    </div>
  </a>

  <a href="/partituras/ayuda" class="action-card"
     data-text="partituras obras autor titulo grupos instrumentos pdf zip audio video app">
    <div>
      <p class="action-title">Partituras</p>
      <p class="action-desc">Repositorio de partituras y acceso desde la app de músicos.</p>
      <p class="req-line">
        <span class="badge-soft">Repositorio</span>
        <span class="badge-soft">PDF / ZIP</span>
        <span class="badge-soft">App</span>
      </p>
    </div>
  </a>

  <a href="/mensajes/ayuda" class="action-card"
     data-text="mensajes avisos adjuntos push notificaciones bandeja leido">
    <div>
      <p class="action-title">Mensajes</p>
      <p class="action-desc">Bandeja de entrada, composición de mensajes, adjuntos y notificaciones push.</p>
      <p class="req-line">
        <span class="badge-soft">Bandeja</span>
        <span class="badge-soft">Adjuntos</span>
        <span class="badge-soft">Push</span>
      </p>
    </div>
  </a>

  <a href="/guardias/ayuda" class="action-card"
     data-text="guardias control acceso seguridad vigilancia entrada salida">
    <div>
      <p class="action-title">Guardias</p>
      <p class="action-desc">Control de acceso y registro de entradas y salidas en eventos.</p>
      <p class="req-line">
        <span class="badge-soft">Acceso</span>
        <span class="badge-soft">Registro</span>
      </p>
    </div>
  </a>

  <a href="/configuracion/ayuda/configuracion" class="action-card"
     data-text="configuracion usuarios docentes grupos instrumentos espacios ausencias actividades backup ajustes">
    <div>
      <p class="action-title">Configuración</p>
      <p class="action-desc">Usuarios, grupos, instrumentos, espacios, ausencias, actividades y ajustes generales.</p>
      <p class="req-line">
        <span class="badge-soft">Usuarios</span>
        <span class="badge-soft">Grupos</span>
        <span class="badge-soft">Ajustes</span>
      </p>
    </div>
  </a>

</div>

<div class="volver-bloque-izquierda mt-3">
  <a href="/" class="enlace-final">← Volver al inicio</a>
</div>

<script>
(() => {
  const q = document.getElementById('help-q');
  q?.addEventListener('input', () => {
    const s = q.value.toLowerCase().trim();
    document.querySelectorAll('#help-grid .action-card').forEach(c => {
      const t = c.textContent.toLowerCase() + ' ' + (c.dataset.text || '');
      c.style.display = !s || t.includes(s) ? '' : 'none';
    });
  });
})();
</script>
