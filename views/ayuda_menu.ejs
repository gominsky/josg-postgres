<% title = 'Centro de ayuda' %>
<% hero  = false %>

<div id="help-wrap" class="container my-4">
  <style>
    :root{
      --ink:#111827; --muted:#6b7280; --border:#e5e7eb; --card:#fff;
      --shadow:0 1px 2px rgba(0,0,0,.05);
    }
    #help-wrap.container{ padding:12px; }
    @media (min-width: 1200px){ #help-wrap.container{ max-width: 1160px; } }

    .head{
      display:flex; align-items:center; justify-content:space-between;
      gap:12px; flex-wrap:wrap; margin-bottom:12px;
    }
    .head h1{ margin:0; font-weight:800; color:var(--ink); font-size:clamp(1.35rem,1rem + 1.2vw,2rem); }
    .search{
      flex:1 1 320px; display:flex; justify-content:flex-end;
    }
    .search input{
      width:100%; max-width:420px; padding:.6rem .8rem; font-size:1rem;
      border:1px solid var(--border); border-radius:10px; box-shadow:var(--shadow);
    }

    .grid{
      display:grid; gap:16px; margin-top:8px;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    }
    .card{
      display:flex; gap:12px; align-items:flex-start; text-decoration:none;
      background:var(--card); color:var(--ink); border:1px solid var(--border);
      border-radius:14px; padding:14px; box-shadow:var(--shadow);
      transition: transform .12s ease, box-shadow .12s ease;
    }
    .card:hover{ transform:translateY(-2px); box-shadow:0 10px 20px rgba(0,0,0,.08); }
    .ic{
      width:42px; height:42px; border-radius:10px; display:flex; align-items:center; justify-content:center;
      background:#f3f4f6; border:1px solid #e5e7eb;
    }
    .ic svg{ width:22px; height:22px; fill:#111827; opacity:.9; }
    .body{ min-width:0; }
    .ttl{ font-weight:800; font-size:1.05rem; margin:0 0 .15rem; }
    .mut{ color:var(--muted); margin:0; font-size:.95rem; }
    .tags{ display:flex; gap:.35rem; flex-wrap:wrap; margin-top:.4rem; }
    .tag{ display:inline-block; border:1px solid var(--border); border-radius:999px; padding:.14rem .5rem; background:#f9fafb; font-size:.82rem; color:#374151; }

    .volver{ margin-top:14px; }
    .volver a{ text-decoration:none; color:#374151; }
  </style>

  <div class="head">
    <h1>Centro de ayuda</h1>
    <div class="search">
      <input id="help-q" type="search" placeholder="Buscar… (músicos, eventos, guardias…)" autocomplete="off">
    </div>
  </div>

  <div class="grid" id="help-grid">
    <!-- Músicos -->
    <a href="/alumnos/ayuda" class="card"
       data-text="musicos alumnos grupos instrumentos cuotas pagos foto baja eliminar">
      <div class="ic"><svg><use href="#i-user"/></svg></div>
      <div class="body">
        <p class="ttl">Músicos</p>
        <p class="mut">Alta/edición, grupos e instrumentos, foto, cuotas y pagos, bajas.</p>
        <div class="tags">
          <span class="tag">Listado y filtros</span><span class="tag">Ficha</span><span class="tag">Finanzas</span>
        </div>
      </div>
    </a>

    <!-- Eventos -->
    <a href="/eventos/ayuda" class="card"
       data-text="eventos calendario listado qr firmas asistencia guardias">
      <div class="ic"><svg><use href="#i-calendar"/></svg></div>
      <div class="body">
        <p class="ttl">Eventos</p>
        <p class="mut">Calendario, listado por rango, QR, firmas y control de asistencia.</p>
        <div class="tags">
          <span class="tag">Calendario</span><span class="tag">Firmas</span><span class="tag">QR</span>
        </div>
      </div>
    </a>

    <!-- Guardias -->
    <a href="/guardias/ayuda" class="card"
       data-text="guardias turnos cuadrantes asignaciones">
      <div class="ic"><svg><use href="#i-shield"/></svg></div>
      <div class="body">
        <p class="ttl">Guardias</p>
        <p class="mut">Cuadrantes, asignaciones y seguimiento de guardias.</p>
        <div class="tags">
          <span class="tag">Cuadrantes</span><span class="tag">Asignaciones</span>
        </div>
      </div>
    </a>

    <!-- Contabilidad -->
    <a href="/contabilidad/ayuda" class="card"
       data-text="contabilidad gastos facturas proveedores pagos adjuntos exportaciones">
      <div class="ic"><svg><use href="#i-coins"/></svg></div>
      <div class="body">
        <p class="ttl">Contabilidad (Gastos)</p>
        <p class="mut">Facturas, proveedores, pagos y adjuntos. Exportación y estados.</p>
        <div class="tags">
          <span class="tag">Facturas</span><span class="tag">Pagos</span><span class="tag">Proveedores</span>
        </div>
      </div>
    </a>

    <!-- Cuotas -->
    <a href="/cuotas/ayuda" class="card"
       data-text="cuotas generacion pagos recibos tipos periodos">
      <div class="ic"><svg><use href="#i-receipt"/></svg></div>
      <div class="body">
        <p class="ttl">Cuotas</p>
        <p class="mut">Generación por rango, registro de pagos y tipos de cuota.</p>
        <div class="tags">
          <span class="tag">Generación</span><span class="tag">Pagos</span><span class="tag">Tipos</span>
        </div>
      </div>
    </a>
  <!-- Informes -->
<a href="/informes/ayuda" class="card"
data-text="informes listados atril horas certificados pdf exportar constructor">
<div class="ic" aria-hidden="true">
 <!-- SVG inline -->
 <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
      viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
   <rect x="4" y="3" width="16" height="18" rx="2"></rect>
   <line x1="8" y1="8"  x2="16" y2="8"></line>
   <line x1="8" y1="12" x2="16" y2="12"></line>
   <line x1="8" y1="16" x2="13" y2="16"></line>
 </svg>
</div>
<div class="body">
 <p class="ttl">Informes</p>
 <p class="mut">Listados, pruebas de atril, horas y exportación.</p>
 <div class="tags">
   <span class="tag">Listados</span><span class="tag">Atril</span><span class="tag">PDF</span>
 </div>
</div>
</a>


</div>

<div class="panel-header" style="margin-top:10px;">
    <a href="/configuracion" class="enlace-final">← Volver a Configuración</a>
  </div>
</div>

<!-- Iconos -->
<svg width="0" height="0" style="position:absolute;visibility:hidden">
  <symbol id="i-user" viewBox="0 0 24 24"><path d="M12 12a5 5 0 1 0-5-5 5 5 0 0 0 5 5Z"/><path d="M3 22a9 9 0 0 1 18 0"/></symbol>
  <symbol id="i-calendar" viewBox="0 0 24 24"><path d="M3 5h18v16H3z"/><path d="M8 3v4M16 3v4M3 9h18"/></symbol>
  <symbol id="i-shield" viewBox="0 0 24 24"><path d="M12 2 4 5v6c0 5 3.5 9 8 11 4.5-2 8-6 8-11V5Z"/></symbol>
  <symbol id="i-coins" viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="7" ry="3"/><path d="M5 5v6c0 1.7 3.1 3 7 3s7-1.3 7-3V5M5 11v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6"/></symbol>
  <symbol id="i-receipt" viewBox="0 0 24 24"><path d="M6 2h12v20l-3-2-3 2-3-2-3 2z"/><path d="M8 7h8M8 11h8M8 15h8"/></symbol>
</svg>

<script>
(() => {
  const q = document.getElementById('help-q');
  const cards = Array.from(document.querySelectorAll('#help-grid .card'));
  function filtrar(){
    const s = (q.value || '').toLowerCase().trim();
    cards.forEach(c => {
      const t = c.innerText.toLowerCase() + ' ' + (c.getAttribute('data-text')||'');
      c.style.display = !s || t.includes(s) ? '' : 'none';
    });
  }
  q && q.addEventListener('input', filtrar);
})();
</script>
