  </symbol>
  <symbol id="i-score" viewBox="0 0 24 24">
    <path d="M9 4v12.5a3.5 3.5 0 1 1-2-3.1V4h2Z"/>
    <path d="M17 6v9.5a3.5 3.5 0 1 1-2-3.1V6h2Z"/>
