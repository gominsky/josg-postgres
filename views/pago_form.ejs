<% title = 'Registrar Pago'; %>
<% hero = false; %>

<h1 class="h1-titulo text-center mb-4"><%= title %></h1>

<form id="form-pago" method="POST" action="/pagos" class="formulario-alumno" style="border: 2px solid #FF9501; border-radius: 0.75rem; padding: 1rem; max-width: 500px; margin: 2rem auto;">
  <input type="hidden" name="alumno_id" value="<%= alumno.id %>">

  <div class="grupo-campos">
    <h2>Datos de Pago</h2>
    <div class="form-grid-2">
      <label>Importe:
        <input type="number" name="importe" step="0.01" class="form-input" required>
      </label>

      <label>Fecha de pago:
        <input type="date" name="fecha_pago" class="form-input" required value="<%= new Date().toISOString().split('T')[0] %>">
      </label>

      <label>Medio de pago:
        <select name="medio_pago" class="form-input">
          <option value="efectivo">Efectivo</option>
          <option value="transferencia">Transferencia</option>
          <option value="tarjeta">Tarjeta</option>
          <option value="otro">Otro</option>
        </select>
      </label>

      <label>Referencia:
        <input type="text" name="referencia" class="form-input">
      </label>

      <label>Observaciones:
        <textarea name="observaciones" class="form-input" rows="2"></textarea>
      </label>
    </div>
  </div>

  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/pagos/<%= alumno.id %>" class="enlace-final-naranja">← Volver</a>
    <button type="submit" class="btn-main">Registrar pago</button>
  </div>
</form>

