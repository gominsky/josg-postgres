<% const esEdicion = typeof usuario !== 'undefined' && usuario !== null; %>
<% title = esEdicion ? 'Editar Usuario' : 'Crear Usuario' %>
<% hero = false %>

<h1 class="h1-titulo"><%= title %></h1>

<!-- Ficha de campos -->
<div class="dashboard-grid">
  <form id="form-usuario"
    method="POST"
    action="<%= esEdicion ? '/usuarios/' + usuario.id + '/editar' : '/usuarios/nuevo' %>"
    class="card-variacion2"
    style="width: 430px; height: auto; box-sizing: border-box; overflow: auto;">

    <div>
      <label for="nombre"><div style="font-weight: 600; font-size: 1rem;">Nombre</div></label>
      <div><input type="text" name="nombre" required value="<%= esEdicion ? usuario.nombre : '' %>"/></div>
    </div>

    <div>
      <label for="email"><div style="font-weight: 600; font-size: 1rem;">Correo electrónico</div></label>
      <div><input type="email" name="email" required value="<%= esEdicion ? usuario.email : '' %>"/></div>
    </div>

    <div>
      <label for="password"><div style="font-weight: 600; font-size: 1rem;">Contraseña</div></label>
      <div><input type="password" name="password" <%= esEdicion ? '' : 'required' %> /></div>
      <% if (esEdicion) { %>
        <div class="form-text">Dejar en blanco para mantener la contraseña actual</div>
      <% } %>
    </div>
      <div style="margin-top: 1rem;">
        <label for="rol"><div style="font-weight: 600; font-size: 1rem;">Rol</div></label>
        <select name="rol" required>
          <option value="admin" <%= esEdicion && usuario.rol === 'admin' ? 'selected' : '' %>>Administrador</option>
          <option value="docente" <%= esEdicion && usuario.rol === 'docente' ? 'selected' : '' %>>Docente</option>
        </select> 
    </div>
  </form>
</div>

<!-- Ficha de Guardar y Eliminar -->
<div class="dashboard-grid">
  <a href="#" onclick="document.getElementById('form-usuario').submit(); return false;" class="card-variacion2">
    <div style="font-weight: 600; font-size: 1rem;">Guardar</div>
  </a>

  <% if (esEdicion) { %>
    <a href="#" onclick="if(confirm('¿Eliminar este usuario?')) document.getElementById('delete-form').submit(); return false;" class="card-eliminar">
      <div style="font-weight: 600; font-size: 1rem;">Eliminar</div>
    </a>
    <form id="delete-form" method="POST" action="/usuarios/<%= usuario.id %>/eliminar" class="hidde" style="background-color: transparent;"></form>
  <% } %>
</div>

<!-- Enlace Volver -->
<div class="volver-bloque-izquierda">
  <a href="/usuarios" class="enlace-final">← Volver a lista de usuarios</a>
</div>
