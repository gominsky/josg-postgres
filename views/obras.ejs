<% title = 'Zona de obras' %>
<header class="hero-header page-obras">
  <div class="container page-wrap">
    <div class="obras-wrap">
      <div class="obras-icon" aria-hidden="true">🎻</div>
      <h1 class="obras-title">Estamos afinando la orquesta</h1>
      <p class="obras-sub">Volvemos enseguida. Gracias por tu paciencia.</p>

      <div class="obras-actions">
        <a href="/" class="btn-main">Volver al inicio</a>
      </div>

      <p class="obras-note">Código: 503 · Servicio temporalmente no disponible</p>
    </div>
  </div>
</header>

<style>
/* ====== “Zona de obras” (scoped) ====== */
.page-obras{
  /* fondo tipo escenario con “cortinas” suaves y base inferior */
  background:
    linear-gradient(0deg, transparent 0 78%, rgba(200,71,44,.9) 78% 92%, transparent 92%),
    linear-gradient(102deg, rgba(255,138,0,.25) 0 18%, transparent 18%),
    linear-gradient(-102deg, rgba(255,176,32,.25) 0 18%, transparent 18%),
    #000;
  background-repeat:no-repeat;
  background-size:100% 100%, 50% 120%, 50% 120%;
  background-position:center bottom, left top, right top;
}

.page-obras .obras-wrap{
  max-width: 680px;
  margin: 0 auto;
  text-align: center;
  color: #FF9501;
  padding: 1.2rem;
  background: rgba(0,0,0,.35);
  border-radius: 12px;
}

.page-obras .obras-icon{
  font-size: clamp(2.6rem, 2rem + 2vw, 4rem);
  filter: drop-shadow(0 4px 0 rgba(0,0,0,.35));
  margin-bottom: .25rem;
}

.page-obras .obras-title{
  margin:.25rem 0 .35rem;
  font-size: clamp(1.4rem, 1.1rem + 1.2vw, 2rem);
  font-weight: 800;
  color: #FF9501;
}

.page-obras .obras-sub{
  margin:.1rem 0 1rem;
  color:#fff;
  opacity:.9;
  font-size: .98rem;
}

.page-obras .obras-actions{
  display:flex; gap:.6rem; justify-content:center; flex-wrap:wrap;
}
.page-obras .btn-main, .page-obras .btn-main-blanco{
  margin-top:0;                 /* tus botones traen margin-top, aquí lo quitamos */
  padding:.45rem .9rem;
  font-size:.9rem;
  border-radius:10px;
}

.page-obras .obras-note{
  margin:.9rem 0 0;
  color:#fff; opacity:.75; font-size:.85rem;
}

/* móvil: evita salto de fondo fijo */
@media (max-width:768px){
  .page-obras{ background-attachment: scroll !important; }
}
</style>
