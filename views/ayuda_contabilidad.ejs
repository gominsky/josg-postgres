    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
      <h1 class="h1">Ayuda · Contabilidad (Gastos)</h1>
      <div class="cta">
        <a href="/contabilidad/facturas">Ir a Facturas →</a>
        <a href="/proveedores">Ir a Proveedores →</a>
        <a href="/cuentas">Ir a Cuentas →</a>
      </div>
    </div>

    <!-- Índice -->
    <nav class="toc" aria-label="Índice">
      <a href="#flujo">Flujo rápido</a>
