<div class="help-wrap" data-help-theme="blue">
  <div class="panel">
    <div class="help-article-head">
      <h1 class="h1">Ayuda · Contabilidad</h1>
      <div class="cta">
        <a href="/contabilidad/facturas">Facturas →</a>
        <a href="/proveedores">Proveedores →</a>
        <a href="/cuentas">Cuentas →</a>
      </div>
    </div>

    <nav class="toc" aria-label="Índice">
      <a href="#flujo">Flujo rápido</a>
      <a href="#listado">Listado y filtros</a>
      <a href="#factura">Nueva / Editar factura</a>
