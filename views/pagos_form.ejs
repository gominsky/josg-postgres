<% title = 'Registrar pago'; hero = false; %>
<div class="container my-4">
<!-- === Paso 1: elegir proveedor (sobrio) === -->
<div class="panel-card" style="margin-bottom:1rem;">
  <h1 class="h1-center">Registrar pago</h1>
  <form method="GET" action="/contabilidad/pagos/nuevo" class="topgrid" style="background-color: transparent";>
    <div>
      <label class="form-label">Proveedor</label>
      <select name="proveedor" class="form-select" required>
        <option value="">— Selecciona —</option>
        <% (proveedores||[]).forEach(p => { %>
          <option value="<%= p.id %>" <%= (proveedorSel==p.id)?'selected':'' %>><%= p.nombre %></option>
        <% }) %>
      </select>
    </div>
    <div style="display:flex; align-items:end; justify-content:flex-end;">
      <button class="btn-main">Cargar facturas</button>
    </div>
  </form>
</div>

  <% if (proveedorSel) { %>
    <!-- === Paso 2: datos del pago + distribución === -->
    <form method="POST" action="/contabilidad/pagos/guardar" id="form-pago" class="panel-card">
      <input type="hidden" name="proveedor_id" value="<%= proveedorSel %>">

      <!-- Datos del pago -->
      <div class="grupo-campos">
        <h2>Datos del pago</h2>
        <div class="form-grid-4">
          <label>
            <span class="form-label">Fecha</span>
            <input type="date" name="fecha" required class="form-control" value="<%= hoy %>">
          </label>
          <label>
            <span class="form-label">Importe total (€)</span>
            <input type="number" name="importe_total" step="0.01" min="0.01" class="form-control" required>
          </label>
          <label>
            <span class="form-label">Método</span>
            <select name="metodo" class="form-select" required>
              <option value="transferencia">Transferencia</option>
              <option value="tarjeta">Tarjeta</option>
              <option value="efectivo">Efectivo</option>
              <option value="domiciliacion">Domiciliación</option>
              <option value="otro" selected>Otro</option>
            </select>
          </label>
          <label>
            <span class="form-label">Referencia</span>
            <input type="text" name="referencia" class="form-control" placeholder="Nº operación / banco">
          </label>
          <label style="grid-column:1/-1;">
            <span class="form-label">Notas</span>
            <textarea name="notas" rows="2" class="form-control"></textarea>
          </label>
        </div>
      </div>

      <!-- Distribución -->
      <div class="grupo-campos">
        <h2>Distribución entre facturas</h2>
        <div class="small-muted inline-note">
          Facturas con saldo para el proveedor. Introduce importes a aplicar (puedes usar “Saldo”).
        </div>

        <% const d2 = v => (v && typeof v.toISOString==='function') ? v.toISOString().slice(0,10) : String(v||'').slice(0,10); %>

        <div class="table-responsive" style="margin-top:.5rem;">
          <table class="table">
            <thead>
              <tr>
                <th>#</th><th>Emisión</th><th>Vencimiento</th>
                <th class="text-end">Total</th>
                <th class="text-end">Pagado</th>
                <th class="text-end">Saldo</th>
                <th class="text-end" style="width:160px;">Aplicar</th>
              </tr>
            </thead>
            <tbody>
              <% (facturasPend||[]).forEach(f => { %>
                <tr>
                  <td><a href="/contabilidad/facturas/<%= f.id %>" target="_blank" rel="noopener"><%= f.numero || f.id %></a></td>
                  <td><%= d2(f.fecha_emision) %></td>
                  <td><%= d2(f.fecha_vencimiento) %></td>
                  <td class="text-end num"><%= Number(f.total||0).toFixed(2) %> €</td>
                  <td class="text-end num"><%= Number(f.pagado||0).toFixed(2) %> €</td>
                  <td class="text-end num"><strong><%= Number(f.saldo||0).toFixed(2) %> €</strong></td>
                  <td class="text-end">
                    <div style="display:flex; gap:6px; justify-content:flex-end;">
                      <input type="number" step="0.01" min="0" class="form-control"
                             style="max-width:110px;text-align:right;"
                             name="aplicaciones[<%= f.id %>]"
                             data-saldo="<%= Number(f.saldo||0).toFixed(2) %>"
                             placeholder="0,00">
                      <button class="btn-outline btn-sm" data-fill-saldo type="button">Saldo</button>
                    </div>
                  </td>
                </tr>
              <% }) %>
              <% if (!(facturasPend && facturasPend.length)) { %>
                <tr><td colspan="7" class="small-muted">No hay facturas con saldo para este proveedor.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Acciones -->
      <div class="acciones-finales">
        <div class="small-muted" style="margin-right:auto; margin-left:1rem;">
          Suma aplicada: <span id="sum-aplicada">0,00</span> €
        </div>
        <button class="btn-primary-negro">Guardar pago</button>
      </div>
    </form>
  <% } %>
  <div class="volver-bloque-izquierda" style="margin-top:12px;">
    <a href="/contabilidad" class="enlace-final">← Volver a contabilidad</a>
  </div>
</div>

<script>
(function(){
  const form = document.getElementById('form-pago');
  if (!form) return;

  const totEl   = form.elements['importe_total'];
  const sumSpan = document.getElementById('sum-aplicada');

  function toNum(v){ const n = parseFloat(String(v).replace(',','.')); return isNaN(n)?0:n; }
  function fix2(n){ return (Math.round(n*100)/100).toFixed(2); }
  form.addEventListener('submit', () => {
    // limpia antiguos (si recargas sin cerrar)
    form.querySelectorAll('input[name="aplicaciones_ids[]"], input[name="aplicaciones_importe[]"]').forEach(e => e.remove());

    const toNum = v => { const n = Number(String(v||'').replace(',', '.')); return Number.isFinite(n) ? n : 0; };

    form.querySelectorAll('input[name^="aplicaciones["]').forEach(inp => {
      const m = inp.name.match(/^aplicaciones\[(\d+)\]$/);
      if (!m) return;
      const facturaId = Number(m[1]);
      const importe   = toNum(inp.value || 0);
      if (!facturaId || importe <= 0) return;

      const hidId  = document.createElement('input');
      hidId.type   = 'hidden';
      hidId.name   = 'aplicaciones_ids[]';
      hidId.value  = String(facturaId);
      form.appendChild(hidId);

      const hidImp = document.createElement('input');
      hidImp.type  = 'hidden';
      hidImp.name  = 'aplicaciones_importe[]';
      hidImp.value = String(importe.toFixed(2));
      form.appendChild(hidImp);
    });
  });
  function recalc(){
    let sum = 0;
    form.querySelectorAll('input[name^="aplicaciones["]').forEach(inp => { sum += toNum(inp.value || 0); });
    sumSpan.textContent = fix2(sum);
  }

  form.querySelectorAll('[data-fill-saldo]').forEach(btn => {
    btn.addEventListener('click', () => {
      const input = btn.parentElement.querySelector('input[name^="aplicaciones["]');
      const saldo = toNum(input.getAttribute('data-saldo') || '0');
      input.value = fix2(saldo);
      recalc();
    });
  });

  form.addEventListener('input', (e) => {
    const t = e.target;
    if (t.name && t.name.startsWith('aplicaciones[')) {
      const saldo = toNum(t.getAttribute('data-saldo') || '0');
      let v = toNum(t.value || 0);
      if (v > saldo) v = saldo;
      if (v < 0) v = 0;
      t.value = fix2(v);
      recalc();
    }
  });

  form.addEventListener('submit', (e) => {
    const total = toNum(totEl.value || 0);
    let sum = 0;
    form.querySelectorAll('input[name^="aplicaciones["]').forEach(inp => { sum += toNum(inp.value || 0); });

    if (sum - total > 0.009) {
      e.preventDefault();
      alert('La suma aplicada excede el importe del pago.');
      return false;
    }
    form.querySelectorAll('input[name^="aplicaciones["]').forEach(inp => { inp.value = fix2(toNum(inp.value || 0)); });
    totEl.value = fix2(total);
  });
})();
</script>

