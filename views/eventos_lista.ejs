<%
// ======================================================
//  Vista Eventos: CALENDARIO (por defecto) o LISTA + FORM
//  • Si "eventos" es null/undefined => Calendario
//  • Si "eventos" es Array          => Form arriba + Lista debajo
// ======================================================
title = 'Agenda de Eventos';
hero  = false;

const enLista = Array.isArray(eventos);

const opts = { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit', timeZone:'Europe/Madrid' };
const isValidDate = (d) => d instanceof Date && !isNaN(d.getTime());
const toISO = (v) => {
  if (!v) return '';
  if (v instanceof Date) {
    const y=v.getFullYear(), m=String(v.getMonth()+1).padStart(2,'0'), d=String(v.getDate()).padStart(2,'0');
    return `${y}-${m}-${d}`;
  }
  const s = String(v);
  if (/^\d{4}-\d{2}-\d{2}/.test(s)) return s.slice(0,10);
  if (s.includes('T')) return s.split('T')[0];
  return '';
};
const composeDT = (fecha, hora, fallbackHora='00:00') => {
  const f = toISO(fecha); if (!f) return null;
  const h = (hora && hora.length >= 4) ? hora.slice(0,5) : fallbackHora;
  const d = new Date(`${f}T${h}:00`);
  return isValidDate(d) ? d : null;
};
%>

<!-- Barra superior -->
<div class="d-flex align-items-center mb-3">
  <div class="ms-auto me-5 d-flex toolbar-right">
    <div class="d-flex flex-column align-items-end gap-2">
      <!-- Switch Calendario ⇄ Lista -->
      <div class="switch-wrap" title="Alternar vista">
        <div class="form-check form-switch m-0 d-flex align-items-center gap-2">
          <input class="form-check-input big-switch" type="checkbox" id="vistaSwitch" <%= enLista ? 'checked' : '' %>>
          <label class="form-check-label fw-semibold" for="vistaSwitch"><%= enLista ? 'Lista' : 'Calendario' %></label>
        </div>
      </div>

      <!-- Botón Eventos masivos -->
      <button type="button" class="btn-main-blanco fw-bold px-3 py-2"
              data-bs-toggle="modal" data-bs-target="#eventoMasivoModal">
        Eventos masivos
      </button>
    </div>
  </div>
</div>

<% if (!enLista) { %>
  <!-- ============== CALENDARIO ============== -->
  <div id="calendar" class="bg-white p-4 rounded shadow" style="margin-top: 2rem;"></div>

<% } else { %>
  <!-- ============== FORMULARIO DE FILTROS ============== -->
  <div id="ev-wrap" class="container my-3">
    <form id="eventosFiltrosForm" action="/eventos" method="GET" class="filtros-card">
      <div class="filtros-header">
        <h1 class="h1-titulo">Listado de eventos</h1>
      </div>

      <div class="row g-2 align-items-end">
        <div class="col-12 col-sm-6 col-lg-3">
          <label for="fecha" class="form-label">Fecha inicio</label>
          <input type="date" id="fecha" name="desde" class="form-control form-control-sm date-input">
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
          <label for="fecha_fin" class="form-label">Fecha fin</label>
          <input type="date" id="fecha_fin" name="hasta" class="form-control form-control-sm date-input">
        </div>
        <div class="col-12 col-lg-6">
          <label class="form-label">Rango rápido</label>
          <div class="chips" id="chipsRango">
            <span class="chip" data-range="mon">Últ. mes</span>
            <span class="chip" data-range="q">Últ. trimestre</span>
            <span class="chip" data-range="y">Últ. año</span>
          </div>
        </div>
      </div>

      <div class="row g-2 align-items-end inline-row">
        <div class="col-12 col-md-8 col-lg-6">
          <label for="grupo" class="form-label">Grupo</label>
          <div class="d-flex align-items-center">
            <select id="grupo" name="grupo" class="form-select form-select-sm flex-grow-1">
              <option value="todos">Todos</option>
              <% (grupos||[]).forEach(g => { %>
                <option value="<%= g.id %>"><%= g.nombre %></option>
              <% }) %>
            </select>
            <button type="submit" class="btn-accent">Filtrar</button>
          </div>
        </div>
      </div>
    </form>
  </div>

  <!-- ============== LISTA ============== -->
  <div class="container mt-4 contenedor-borde">
    <div class="text-center">
      <table class="tabla-estilizada">
        <thead>
          <tr>
            <th>Título</th>
            <th>Descripción</th>
            <th>Grupo</th>
            <th>Inicio</th>
            <th>Fin</th>
          </tr>
        </thead>
        <tbody>
          <% eventos.forEach(ev => {
               const ini = composeDT(ev.fecha_inicio, ev.hora_inicio, '00:00');
               const fin = composeDT(ev.fecha_fin, ev.hora_fin, '23:59');
          %>
            <tr class="evento-row fila-enlace" data-id="<%= ev.id %>">
              <td><strong><%= ev.titulo %></strong></td>
              <td><%= ev.descripcion || '—' %></td>
              <td><%= ev.grupo_nombre || '—' %></td>
              <td>
                <%= (ini && isValidDate(ini))
                    ? ini.toLocaleString('es-ES', opts)
                    : (ev.fecha_inicio
                        ? (new Date(toISO(ev.fecha_inicio) ? `${toISO(ev.fecha_inicio)}T00:00:00` : ev.fecha_inicio))
                            .toLocaleDateString('es-ES', { day:'2-digit', month:'2-digit', year:'numeric', timeZone:'Europe/Madrid' })
                        : '—') %>
              </td>
              <td>
                <%= (fin && isValidDate(fin))
                    ? fin.toLocaleString('es-ES', opts)
                    : (ev.fecha_fin
                        ? (new Date(toISO(ev.fecha_fin) ? `${toISO(ev.fecha_fin)}T00:00:00` : ev.fecha_fin))
                            .toLocaleDateString('es-ES', { day:'2-digit', month:'2-digit', year:'numeric', timeZone:'Europe/Madrid' })
                        : '—') %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="volver-bloque-izquierda">
    <a href="/eventos" class="enlace-final">← Volver al calendario</a>
  </div>
<% } %>

<!-- JS: filtros, chips y switch de vista -->
<script>
(function(){
  const $ = (s, r=document) => r.querySelector(s);

  const vistaSwitch = $('#vistaSwitch');
  if (vistaSwitch) {
    vistaSwitch.addEventListener('change', () => {
      if (vistaSwitch.checked) {
        let qs = null;
        try {
          const saved = JSON.parse(localStorage.getItem('ev_filtros') || 'null');
          if (saved?.desde && saved?.hasta) {
            qs = new URLSearchParams({ desde: saved.desde, hasta: saved.hasta, grupo: saved.grupo || 'todos' });
          }
        } catch {}
        if (!qs) {
          const now = new Date();
          const y = now.getFullYear(), m = now.getMonth();
          const toISO = d => d.toISOString().slice(0,10);
          qs = new URLSearchParams({ desde: toISO(new Date(y,m,1)), hasta: toISO(new Date(y,m+1,0)), grupo: 'todos' });
        }
        location.href = `/eventos?${qs.toString()}`;
      } else {
        location.href = '/eventos';
      }
    });
  }

  const fDesde = document.getElementById('fecha');
  const fHasta = document.getElementById('fecha_fin');
  const fGrupo = document.getElementById('grupo');
  const chips  = document.getElementById('chipsRango');

  if (fDesde && fHasta) {
    const toISO = d => d.toISOString().slice(0,10);

    function setRange(kind) {
      const now = new Date();
      const y = now.getFullYear(), m = now.getMonth();
      let start, end;
      if (kind === 'mon')      { start = new Date(y,m,1);                     end = new Date(y,m+1,0); }
      else if (kind === 'q')   { const q = Math.floor(m/3)*3; start = new Date(y,q,1); end = new Date(y,q+3,0); }
      else if (kind === 'y')   { start = new Date(y,0,1);                     end = new Date(y,12,0); }
      else                     { start = new Date(y,m,1);                     end = new Date(y,m+1,0); }
      fDesde.value = toISO(start);
      fHasta.value = toISO(end);
    }

    function setChipActive(kind) {
      chips?.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
      if (!kind) return;
      chips?.querySelector(`[data-range="${kind}"]`)?.classList.add('active');
    }

    (function preloadFromURL() {
      const p = new URLSearchParams(location.search);
      if (p.get('desde') || p.get('hasta')) {
        if (p.get('desde')) fDesde.value = p.get('desde');
        if (p.get('hasta')) fHasta.value = p.get('hasta');
        const g = p.get('grupo') || 'todos';
        if (fGrupo && [...fGrupo.options].some(o => String(o.value) === String(g))) fGrupo.value = g;
      } else {
        setRange('mon'); setChipActive('mon');
      }
    })();

    chips?.addEventListener('click', (e) => {
      const el = e.target.closest('.chip'); if (!el) return;
      setChipActive(el.dataset.range);
      setRange(el.dataset.range);
    });

    const form = document.getElementById('eventosFiltrosForm');
    form?.addEventListener('submit', () => {
      const desde = form.querySelector('[name="desde"]')?.value || '';
      const hasta = form.querySelector('[name="hasta"]')?.value || '';
      const grupo = form.querySelector('[name="grupo"]')?.value || 'todos';
      localStorage.setItem('ev_filtros', JSON.stringify({ desde, hasta, grupo }));
    });
  }
})();
</script>

<!-- Dependencias externas -->
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/locales-all.global.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>

<!-- Modal eventos masivos -->
<div class="modal fade modal-sheet" id="eventoMasivoModal" tabindex="-1" aria-labelledby="eventoMasivoTitulo" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <form id="eventoMasivoForm" class="modal-content">
      <div class="sheet-head">
        <h5 class="modal-title mb-0" id="eventoMasivoTitulo">Crear eventos masivos</h5>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>

      <div class="modal-body p-3">
        <div class="mb-2">
          <label class="form-label">Título</label>
          <input type="text" name="titulo" class="form-control form-control-sm" required>
        </div>
        <div class="mb-2">
          <label class="form-label">Espacio</label>
          <select name="espacio_id" class="form-select form-select-sm">
            <option value="">— Sin espacio —</option>
            <% (espacios || []).forEach(es => { %>
              <option value="<%= es.id %>"><%= es.nombre %></option>
            <% }) %>
          </select>
        </div>
        <div class="mb-2">
          <label class="form-label">Descripción</label>
          <textarea name="descripcion" class="form-control form-control-sm" rows="2"></textarea>
        </div>
        <div class="mb-2">
          <label class="form-label">Grupo</label>
          <select name="grupo_id" class="form-select form-select-sm" required>
            <% if (grupos && grupos.length > 0) { %>
              <option value="" disabled selected>Selecciona un grupo…</option>
              <% grupos.forEach(a => { %>
                <option value="<%= a.id %>"><%= a.nombre %></option>
              <% }) %>
            <% } else { %>
              <option disabled selected>No hay grupos disponibles</option>
            <% } %>
          </select>
        </div>
        <div class="row g-2">
          <div class="col-sm-6">
            <label class="form-label">Hora inicio</label>
            <input type="time" name="hora_inicio" class="form-control form-control-sm" value="09:00" required>
          </div>
          <div class="col-sm-6">
            <label class="form-label">Hora fin</label>
            <input type="time" name="hora_fin" class="form-control form-control-sm" value="10:00" required>
          </div>
        </div>
        <div class="form-check form-switch mt-2">
          <input type="checkbox" name="activo" id="activoMasivo" class="form-check-input">
          <label for="activoMasivo" class="form-check-label ms-2">Activar QR</label>
        </div>
        <hr class="my-2">
        <div class="mb-2">
          <label class="form-label">Días</label>
          <input id="multiDaysPicker" class="form-control form-control-sm" placeholder="Elige varios días…" readonly>
          <div id="multiDaysPickerHost" class="border rounded mt-2 p-2"></div>
          <div class="form-text">Selecciona los días del evento.</div>
        </div>
      </div>

      <div class="modal-footer py-2 px-3">
        <button type="submit" class="btn-main-blanco fw-bold px-3 py-1">Crear</button>
        <button type="button" class="btn-main-blanco fw-bold px-3 py-1" data-bs-dismiss="modal">Cancelar</button>
      </div>
    </form>
  </div>
</div>

<!-- Parcial con modal CRUD individual -->
<%- include('eventos_modal_scripts') %>

<!-- Lógica eventos masivos -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  const masivoBtn   = document.querySelector('[data-bs-target="#eventoMasivoModal"]');
  const masivoModal = document.getElementById('eventoMasivoModal');
  const masivoForm  = document.getElementById('eventoMasivoForm');

  if (!masivoModal || !masivoForm) return;

  if (masivoModal.parentNode !== document.body) document.body.appendChild(masivoModal);

  if (masivoBtn) {
    masivoBtn.addEventListener('click', () => {
      try { bootstrap.Modal.getOrCreateInstance(masivoModal).show(); } catch {}
    });
  }

  function ensureFlatpickr() {
    if (!window.flatpickr || masivoModal._fp) return masivoModal._fp || null;
    const host  = masivoModal.querySelector('#multiDaysPickerHost');
    const input = masivoModal.querySelector('#multiDaysPicker');
    if (!host || !input) return null;

    if (flatpickr.l10ns?.es) flatpickr.localize(flatpickr.l10ns.es);

    const fp = flatpickr(host, {
      inline: true, mode: 'multiple', dateFormat: 'Y-m-d',
      showMonths: 2, clickOpens: false, defaultDate: []
    });

    fp.set('onChange', (dates, _s, inst) => {
      const iso = dates.map(d => inst.formatDate(d, 'Y-m-d')).sort();
      input.value = iso.join(', ');
      inst._selectedIso = iso;
    });

    masivoModal._fp = fp;
    return fp;
  }

  masivoModal.addEventListener('shown.bs.modal', () => {
    const fp = ensureFlatpickr(); if (!fp) return;
    const fDesde = document.getElementById('fecha');
    if (fDesde?.value) { try { fp.jumpToDate(fDesde.value, true); } catch {} }
  });

  masivoModal.addEventListener('hidden.bs.modal', () => {
    const input = masivoModal.querySelector('#multiDaysPicker');
    if (masivoModal._fp) masivoModal._fp.clear();
    if (input) input.value = '';
  });

  masivoForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd   = new FormData(masivoForm);
    const body = Object.fromEntries(fd.entries());
    body.activo = masivoForm.querySelector('[name="activo"]').checked ? '1' : '0';

    const fp     = masivoModal._fp;
    const fechas = (fp && fp._selectedIso) ? fp._selectedIso : [];
    if (!fechas.length) { alert('Selecciona al menos un día'); return; }
    body.fechas = fechas;

    try {
      const res = await fetch('/eventos/masivo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      if (!res.ok) throw new Error(await res.text().catch(() => 'Error al crear eventos'));
      bootstrap.Modal.getOrCreateInstance(masivoModal).hide();
      location.reload();
    } catch (err) {
      console.error(err);
      alert('Hubo un problema creando los eventos.');
    }
  });
});
</script>
