<%
// ======================================================
//  Vista Eventos: CALENDARIO (por defecto) o LISTA + FORM
//  • Si "eventos" es null/undefined => Calendario
//  • Si "eventos" es Array          => Form arriba + Lista debajo
// ======================================================
title = 'Agenda de Eventos';
hero  = false;

// (en modo lista, el backend actual pasa { eventos, grupos })
const enLista = Array.isArray(eventos);

// Helpers (como en la vista original)
const opts = { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit', timeZone:'Europe/Madrid' };
const isValidDate = (d) => d instanceof Date && !isNaN(d.getTime());
const toISO = (v) => {
  if (!v) return '';
  if (v instanceof Date) {
    const y=v.getFullYear(), m=String(v.getMonth()+1).padStart(2,'0'), d=String(v.getDate()).padStart(2,'0');
    return `${y}-${m}-${d}`;
  }
  const s = String(v);
  if (/^\d{4}-\d{2}-\d{2}/.test(s)) return s.slice(0,10);
  if (s.includes('T')) return s.split('T')[0];
  return '';
};
const composeDT = (fecha, hora, fallbackHora='00:00') => {
  const f = toISO(fecha); if (!f) return null;
  const h = (hora && hora.length >= 4) ? hora.slice(0,5) : fallbackHora;
  const d = new Date(`${f}T${h}:00`);
  return isValidDate(d) ? d : null;
};
%>

<style>
/* ===== Ajustes globales suaves para la vista ===== */
.toolbar-right { padding-right: .25rem; }
.switch-wrap { position: relative; top: 2px; } /* baja un pelín el switch para alinearlo con botones */
.form-check.form-switch .form-check-input.big-switch{ transform: scale(1.2); }
.switch-wrap.ms-4 { margin-left: 1.25rem !important; }

/* ===== Estilo del formulario (compacto, neutro) ===== */
/* Paleta sobria y contraste alto */
:root{
    --fg:#111; --muted:#6b7280; --border:#e5e7eb; --accent:#111; --accent-ghost:#f3f4f6;
    --ring:0 0 0 3px rgba(17,17,17,.08);
  }

  #eventosFiltrosForm.filtros-card{
    border:1px solid var(--border); border-radius:16px; background:#fff;
    padding:12px 14px; box-shadow:0 1px 2px rgba(0,0,0,.04);
  }

  /* Cabecera más apretada */
  #eventosFiltrosForm .filtros-header{ margin-bottom:6px; }
  #eventosFiltrosForm .h1-titulo{
    font-size:1.1rem; font-weight:800; letter-spacing:.2px; color:var(--fg); margin:0;
  }

  /* Labels micro, en mayúsculas, pegadas al control */
  #eventosFiltrosForm .form-label{
    margin-bottom:.15rem; font-size:.72rem; font-weight:800;
    text-transform:uppercase; letter-spacing:.06em; color:var(--muted);
  }

  /* Campos compactos */
  #eventosFiltrosForm .form-control-sm,
  #eventosFiltrosForm .form-select-sm{
    min-height:34px; padding:.3rem .5rem; font-size:.9rem; border-radius:10px;
    border:1.5px solid var(--border);
  }
  #eventosFiltrosForm .form-control-sm:focus,
  #eventosFiltrosForm .form-select-sm:focus{
    outline:none; border-color:var(--accent); box-shadow:var(--ring);
  }

  /* Fechas: ancho consistente en desktop */
  @media (min-width: 992px){
    #eventosFiltrosForm .date-input{ width:10.25rem!important; }
  }

  /* Chips tipo segmented control */
  #chipsRango{ display:flex; flex-wrap:wrap; gap:.35rem; }
  #chipsRango .chip{
    display:inline-flex; align-items:center; gap:.35rem;
    padding:.28rem .6rem; font-size:.82rem; font-weight:700;
    border:1.5px solid var(--border); border-radius:999px;
    background:var(--accent-ghost); color:#1f2937; user-select:none; cursor:pointer;
    transition:transform .05s ease, border-color .15s ease, background .15s ease, color .15s ease;
  }
  #chipsRango .chip:hover{ transform:translateY(-1px); border-color:#c7cad0; }
  #chipsRango .chip.active{ background:var(--accent); color:#fff; border-color:var(--accent); }

  /* Fila grupo + botón en línea, muy compacta */
  #eventosFiltrosForm .inline-row{ margin-top:.25rem; }
  #eventosFiltrosForm .inline-row .d-flex{ gap:.5rem; }
  #eventosFiltrosForm label[for="grupo"]{ margin-bottom:.1rem!important; }

  /* Botón con presencia, pero pequeño */
  .btn-accent{
    background:var(--accent); color:#fff; border:1px solid var(--accent); border-radius:12px;
    padding:.45rem .8rem; line-height:1; font-weight:800; letter-spacing:.2px;
    transition:transform .05s ease, box-shadow .15s ease, opacity .15s ease;
  }
  .btn-accent:hover{ box-shadow:0 6px 18px rgba(0,0,0,.12); transform:translateY(-1px); }
  .btn-accent:active{ transform:translateY(0); }

  /* Respiración general entre filas, pero compacta */
  #eventosFiltrosForm .row.g-2{ --bs-gutter-x:.6rem; --bs-gutter-y:.4rem; }

  /* Ajustes finos en móviles: todo en dos filas muy cortas */
  @media (max-width: 575.98px){
    #eventosFiltrosForm .h1-titulo{ font-size:1rem; }
  }

/* ===== Modal masivo: capas seguras y tamaño ===== */
.modal { z-index: 1055; }
.modal-backdrop { z-index: 1050; }
#eventoMasivoModal .modal-dialog { max-width: 600px; }
@media (min-height: 680px) { #eventoMasivoModal .modal-body { max-height: none; } }
@media (max-height: 679px) { #eventoMasivoModal .modal-body { max-height: 65vh; overflow: auto; } }

/* Cabecera negra como el resto */
.sheet-head { display:flex; align-items:center; gap:12px; padding:12px 14px; background:#111; color:#fff; }

/* Flatpickr más compacto */
#multiDaysPickerHost { max-width:100%; overflow:hidden; }
#eventoMasivoModal .flatpickr-calendar { transform: scale(.9); transform-origin: top left; }
#eventoMasivoModal .flatpickr-day { width:32px; height:28px; line-height:28px; font-size:12px; }
#eventoMasivoModal .flatpickr-months .flatpickr-month, #eventoMasivoModal .flatpickr-weekdays { font-size:12px; }
/* Selección naranja */
#eventoMasivoModal .flatpickr-day.selected,
#eventoMasivoModal .flatpickr-day.start,
#eventoMasivoModal .flatpickr-day.end { background:#ff7a18!important; border-color:#ff7a18!important; color:#fff!important; }
#eventoMasivoModal .flatpickr-day.selected:hover,
#eventoMasivoModal .flatpickr-day.start:hover,
#eventoMasivoModal .flatpickr-day.end:hover { background:#e56700!important; border-color:#e56700!important; }
#eventoMasivoModal .flatpickr-day.inRange { background: rgba(255,122,24,.15)!important; border-color:#ff7a18!important; }
</style>

<!-- Barra superior -->
<div class="d-flex align-items-center mb-3">
  <div class="ms-auto me-5 d-flex toolbar-right">
    <!-- Pila: switch arriba, botón abajo -->
    <div class="d-flex flex-column align-items-end gap-2">
      <!-- Switch Calendario ⇄ Lista -->
      <div class="switch-wrap" title="Alternar vista">
        <div class="form-check form-switch m-0 d-flex align-items-center gap-2">
          <input class="form-check-input big-switch" type="checkbox" id="vistaSwitch" <%= enLista ? 'checked' : '' %>>
          <label class="form-check-label fw-semibold" for="vistaSwitch"><%= enLista ? 'Lista' : 'Calendario' %></label>
        </div>
      </div>

      <!-- Botón Eventos masivos (debajo del switch) -->
      <button type="button" class="btn-main-blanco fw-bold px-3 py-2"
              data-bs-toggle="modal" data-bs-target="#eventoMasivoModal">
        Eventos masivos
      </button>
    </div>
  </div>
</div>


<% if (!enLista) { %>
  <!-- ============== CALENDARIO (sin formulario visible) ============== -->
  <div id="calendar" class="bg-white p-4 rounded shadow" style="margin-top: 2rem;"></div>

<% } else { %>
  <!-- ============== FORMULARIO (compacto y neutro) ============== -->
  <div id="ev-wrap" class="container my-3">
    <form id="eventosFiltrosForm" action="/eventos" method="GET" class="filtros-card">
      <div class="filtros-header">
        <h1 class="h1-titulo">Listado de eventos</h1>
      </div>
    
      <!-- Fila 1: Fechas + Chips -->
      <div class="row g-2 align-items-end">
        <div class="col-12 col-sm-6 col-lg-3">
          <label for="fecha" class="form-label">Fecha inicio</label>
          <input type="date" id="fecha" name="desde" class="form-control form-control-sm date-input">
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
          <label for="fecha_fin" class="form-label">Fecha fin</label>
          <input type="date" id="fecha_fin" name="hasta" class="form-control form-control-sm date-input">
        </div>
        <div class="col-12 col-lg-6">
          <label class="form-label">Rango rápido</label>
          <div class="chips" id="chipsRango">
            <span class="chip" data-range="mon">Últ. mes</span>
            <span class="chip" data-range="q">Últ. trimestre</span>
            <span class="chip" data-range="y">Últ. año</span>
          </div>
        </div>
      </div>
    
      <!-- Fila 2: Grupo + botón en la misma línea -->
      <div class="row g-2 align-items-end inline-row">
        <div class="col-12 col-md-8 col-lg-6">
          <label for="grupo" class="form-label">Grupo</label>
          <div class="d-flex align-items-center">
            <select id="grupo" name="grupo" class="form-select form-select-sm flex-grow-1">
              <option value="todos">Todos</option>
              <% (grupos||[]).forEach(g => { %>
                <option value="<%= g.id %>"><%= g.nombre %></option>
              <% }) %>
            </select>
            <button type="submit" class="btn-accent">Filtrar</button>
          </div>
        </div>
      </div>
    </form>
  </div>

  <!-- ============== LISTA (tabla original, sin cambios de formato) ============== -->
  <div class="container mt-4 contenedor-borde">
    <div class="text-center">
      <!-- Tabla EXACTA de la vista original -->
      <table class="tabla-estilizada">
        <thead>
          <tr>
            <th>Título</th>
            <th>Descripción</th>
            <th>Grupo</th>
            <th>Inicio</th>
            <th>Fin</th>
          </tr>
        </thead>
        <tbody>
          <% eventos.forEach(ev => {
               const ini = composeDT(ev.fecha_inicio, ev.hora_inicio, '00:00');
               const fin = composeDT(ev.fecha_fin, ev.hora_fin, '23:59');
          %>
            <tr class="evento-row fila-enlace" data-id="<%= ev.id %>">
              <td><strong><%= ev.titulo %></strong></td>
              <td><%= ev.descripcion || '—' %></td>
              <td><%= ev.grupo_nombre || '—' %></td>
              <td>
                <%= (ini && isValidDate(ini))
                    ? ini.toLocaleString('es-ES', opts)
                    : (ev.fecha_inicio
                        ? (new Date(toISO(ev.fecha_inicio) ? `${toISO(ev.fecha_inicio)}T00:00:00` : ev.fecha_inicio))
                            .toLocaleDateString('es-ES', { day:'2-digit', month:'2-digit', year:'numeric', timeZone:'Europe/Madrid' })
                        : '—') %>
              </td>
              <td>
                <%= (fin && isValidDate(fin))
                    ? fin.toLocaleString('es-ES', opts)
                    : (ev.fecha_fin
                        ? (new Date(toISO(ev.fecha_fin) ? `${toISO(ev.fecha_fin)}T00:00:00` : ev.fecha_fin))
                            .toLocaleDateString('es-ES', { day:'2-digit', month:'2-digit', year:'numeric', timeZone:'Europe/Madrid' })
                        : '—') %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="volver-bloque-izquierda">
    <a href="/eventos" class="enlace-final">← Volver al calendario</a>
  </div>
<% } %>

<!-- ===== JS: filtros (chips + presets) y switch de vista ===== -->
<script>
(function(){
  const $ = (s, r=document) => r.querySelector(s);

  // Switch Calendario ⇄ Lista
  const vistaSwitch = $('#vistaSwitch');
  if (vistaSwitch){
    vistaSwitch.addEventListener('change', () => {
      if (vistaSwitch.checked){
        // Ir a LISTA: usa filtros guardados o, si no hay, mes actual entero + grupo=todos
        let qs = null;
        try {
          const saved = JSON.parse(localStorage.getItem('ev_filtros') || 'null');
          if (saved?.desde && saved?.hasta){
            qs = new URLSearchParams({ desde: saved.desde, hasta: saved.hasta, grupo: saved.grupo || 'todos' });
          }
        } catch {}
        if (!qs){
          const now = new Date();
          const y = now.getFullYear(), m = now.getMonth();
          const start = new Date(y, m, 1);
          const end   = new Date(y, m + 1, 0);
          const toISO = d => d.toISOString().slice(0,10);
          qs = new URLSearchParams({ desde: toISO(start), hasta: toISO(end), grupo: 'todos' });
        }
        location.href = `/eventos?${qs.toString()}`;
      } else {
        location.href = '/eventos';
      }
    });
  }

  // Presets del formulario (solo en LISTA)
  const fDesde = document.getElementById('fecha');     // name="desde"
  const fHasta = document.getElementById('fecha_fin'); // name="hasta"
  const fGrupo = document.getElementById('grupo');
  const chips  = document.getElementById('chipsRango');

  if (fDesde && fHasta){
    const toISO = d => d.toISOString().slice(0,10);

    function setRange(kind){
      const now = new Date();
      const y = now.getFullYear();
      const m = now.getMonth();
      let start, end;

      if (kind === 'mon'){                  // Mes actual entero
        start = new Date(y, m, 1);
        end   = new Date(y, m + 1, 0);
      } else if (kind === 'q'){             // Trimestre en curso entero
        const qStartM = Math.floor(m / 3) * 3;
        start = new Date(y, qStartM, 1);
        end   = new Date(y, qStartM + 3, 0);
      } else if (kind === 'y'){             // Año actual entero
        start = new Date(y, 0, 1);
        end   = new Date(y, 12, 0);
      } else {                              // fallback: mes actual
        start = new Date(y, m, 1);
        end   = new Date(y, m + 1, 0);
      }
      fDesde.value = toISO(start);
      fHasta.value = toISO(end);
    }

    function setChipActive(kind){
      chips?.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
      if (!kind) return;
      chips?.querySelector(`[data-range="${kind}"]`)?.classList.add('active');
    }

    (function preloadFromURL(){
      const p = new URLSearchParams(location.search);
      const hadRange = p.get('desde') || p.get('hasta');
      if (hadRange){
        if (p.get('desde')) fDesde.value = p.get('desde');
        if (p.get('hasta')) fHasta.value = p.get('hasta');
        const g = p.get('grupo') || 'todos';
        if (fGrupo && [...fGrupo.options].some(o=>String(o.value)===String(g))) fGrupo.value = g;
      } else { setRange('mon'); setChipActive('mon'); }
    })();

    chips?.addEventListener('click', (e)=>{
      const el = e.target.closest('.chip'); if(!el) return;
      setChipActive(el.dataset.range);
      setRange(el.dataset.range);
    });

    // Guardar filtros al enviar (recordar al volver con el switch)
    const form = document.getElementById('eventosFiltrosForm');
    form?.addEventListener('submit', () => {
      const desde = form.querySelector('[name="desde"]')?.value || '';
      const hasta = form.querySelector('[name="hasta"]')?.value || '';
      const grupo = form.querySelector('[name="grupo"]')?.value || 'todos';
      localStorage.setItem('ev_filtros', JSON.stringify({ desde, hasta, grupo }));
    });
  }
})();
</script>

<!-- ===== Cargas necesarias ANTES del parcial (orden importante) ===== -->
<!-- FullCalendar para que el calendario se pinte en la vista correspondiente -->
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/locales-all.global.min.js"></script>
