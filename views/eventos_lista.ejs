<% title = 'Agenda de Eventos' %>
<% hero = false %>
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h1-titulo mb-0">Listado de eventos</h1>
    <a href="/guardias" class="btn-main-blanco fw-bold px-3 py-2">Guardias</a>
  </div>
</div>

<%
// Helpers de plantilla
const opts = { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' };
const toISO = (v) => (v ? String(v).split('T')[0] : '');
const composeDT = (fecha, hora, fallbackHora='00:00') => {
  const f = toISO(fecha);
  if (!f) return null;
  const h = (hora && hora.length >= 4) ? hora.slice(0,5) : fallbackHora;
  // Evitar fecha inválida si la parte ya viene con hora
  if (String(fecha).includes('T') && !hora) return new Date(fecha); 
  return new Date(`${f}T${h}:00`);
};
%>

<% if (eventos && eventos.length >= 0) { %>
  <% if (eventos.length > 0) { %>
    <div class="container mt-4">
      <div class="text-center">
        <table class="tabla-estilizada">
          <thead>
            <tr>
              <th>Título</th>
              <th>Descripción</th>
              <th>Grupo</th>
              <th>Inicio</th>
              <th>Fin</th>
            </tr>
          </thead>
          <tbody>
            <% eventos.forEach(ev => { 
                 const ini = composeDT(ev.fecha_inicio, ev.hora_inicio, '00:00');
                 const fin = composeDT(ev.fecha_fin, ev.hora_fin, '23:59');
            %>
              <tr class="evento-row fila-enlace" data-id="<%= ev.id %>">
                <td><strong><%= ev.titulo %></strong></td>
                <td><%= ev.descripcion || '—' %></td>
                <td><%= ev.grupo_nombre || '—' %></td>
                <td><%= ini ? ini.toLocaleString('es-ES', opts) : (ev.fecha_inicio || '—') %></td>
                <td><%= fin ? fin.toLocaleString('es-ES', opts) : (ev.fecha_fin || '—') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>

        <h5 class="text-center mb-3">Lista personalizada:</h5>
        <form method="GET" action="/eventos" class="formulario-lista-customizada mt-4 p-3 rounded d-flex flex-wrap align-items-end gap-2 justify-content-center">
          <div>
            <label for="desde2" class="form-label mb-1">Desde</label>
            <input type="date" name="desde" id="desde2" class="form-control form-control-sm" required>
          </div>
          <div>
            <label for="hasta2" class="form-label mb-1">Hasta</label>
            <input type="date" name="hasta" id="hasta2" class="form-control form-control-sm" required>
          </div>
          <div class="d-flex align-items-end">
            <button type="submit" class="btn-main-blanco btn-sm">Ver listado</button>
          </div>
        </form>
      </div>
    </div>
  <% } else { %>
    <p class="text-center texto-base">No hay eventos registrados entre las fechas del calendario</p>
    <div>
      <h5 class="text-center mb-3">Lista personalizada:</h5>
      <form method="GET" action="/eventos" class="formulario-lista-customizada mt-4 p-3 rounded d-flex flex-wrap align-items-end gap-2">
        <div>
          <label for="desde2" class="form-label mb-1">Desde</label>
          <input type="date" name="desde" id="desde2" class="form-control form-control-sm" required>
        </div>
        <div>
          <label for="hasta2" class="form-label mb-1">Hasta</label>
          <input type="date" name="hasta" id="hasta2" class="form-control form-control-sm" required>
        </div>
        <div class="d-flex align-items-end">
          <button type="submit" class="btn-main-blanco btn-sm">Ver listado</button>
        </div>
      </form>
    </div>
  <% } %>
  <div class="volver-bloque-izquierda">
    <a href="/eventos" class="enlace-final">← Volver al calendario</a>
  </div>
<% } else { %>
  <div id="calendar" class="bg-white p-4 rounded shadow" style="margin-top: 2rem;"></div>
<% } %>

<%- include('eventos_modal_scripts') %>
