<!-- ===== Modal para creación MASIVA ===== -->
<div class="modal fade modal-sheet" id="eventoMasivoModal" tabindex="-1" aria-labelledby="eventoMasivoTitulo" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <form id="eventoMasivoForm" class="modal-content">
      <!-- Cabecera -->
      <div class="sheet-head">
        <h5 class="modal-title mb-0" id="eventoMasivoTitulo">Crear eventos masivos</h5>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>

      <div class="modal-body p-3">
        <div class="mb-2">
          <label class="form-label">Título</label>
          <input type="text" name="titulo" class="form-control form-control-sm" required>
        </div>

        <div class="mb-2">
          <label class="form-label">Descripción</label>
          <textarea name="descripcion" class="form-control form-control-sm" rows="2"></textarea>
        </div>

        <div class="mb-2">
          <label class="form-label">Grupo</label>
          <select name="grupo_id" class="form-select form-select-sm" required>
            <% if (grupos && grupos.length > 0) { %>
              <option value="" disabled selected>Selecciona un grupo…</option>
              <% grupos.forEach(a => { %>
                <option value="<%= a.id %>"><%= a.nombre %></option>
              <% }) %>
            <% } else { %>
              <option disabled selected>No hay grupos disponibles</option>
            <% } %>
          </select>
        </div>

        <div class="row g-2">
          <div class="col-sm-6">
            <label class="form-label">Hora inicio</label>
            <input type="time" name="hora_inicio" class="form-control form-control-sm" value="09:00" required>
          </div>
          <div class="col-sm-6">
            <label class="form-label">Hora fin</label>
            <input type="time" name="hora_fin" class="form-control form-control-sm" value="10:00" required>
          </div>
        </div>

        <div class="form-check form-switch mt-2">
          <input type="checkbox" name="activo" id="activoMasivo" class="form-check-input">
          <label for="activoMasivo" class="form-check-label ms-2">Activar QR</label>
        </div>

        <hr class="my-2">

        <div class="mb-2">
          <label class="form-label">Días</label>
          <input id="multiDaysPicker" class="form-control form-control-sm" placeholder="Elige varios días…" readonly>
          <div id="multiDaysPickerHost" class="border rounded mt-2 p-2"></div>
          <div class="form-text">Selecciona los días del evento.</div>
        </div>
      </div>

      <div class="modal-footer py-2 px-3">
        <button type="submit" class="btn-main-blanco fw-bold px-3 py-1">Crear</button>
        <button type="button" class="btn-main-blanco fw-bold px-3 py-1" data-bs-dismiss="modal">Cancelar</button>
      </div>
    </form>
  </div>
</div>

