<% title = 'Actividades complementarias'; hero = false %>

<div class="header-compact">
  <h1 class="h1-titulo">Actividades complementarias</h1>
  <a href="/actividades/nuevo" class="btn-main-blanco">+ Añadir</a>
</div>

<% if (!items || items.length === 0) { %>
  <p class="text-muted mt-3 text-center">No hay actividades registradas.</p>
<% } else { %>
  <div class="dashboard-grid">
    <% items.forEach(i => { %>
      <a href="/actividades/editar/<%= i.id %>" class="card activo card--josg" style="text-decoration:none;">
        <div class="alumno-nombre"><%= i.tipo %></div>
        <% if (i.descripcion) { %>
          <div class="alumno-instrumento"><%= i.descripcion %></div>
        <% } %>
      </a>
    <% }) %>
  </div>
<% } %>

<div class="volver-bloque-izquierda">
  <a href="/configuracion" class="enlace-final">← Volver a configuración</a>
</div>
