<% title = 'Asignar cuotas a grupos'; %>
<% hero = false; %>

<h1 class="h1-titulo text-center mb-4"><%= title %></h1>

<form id="form-asignar-cuotas" class="formulario-alumno mb-5" action="/cuotas/asignar" method="POST" class="formulario-alumno" style="border: 2px solid #FF9501; border-radius: 0.75rem; padding: 1rem; max-width: 600px; margin:0 auto;">
  <div class="grupo-campos">
    <h2>Grupos</h2>
    <div class="d-flex flex-wrap gap-3">
      <% if (grupos.length > 0) { %>
        <% grupos.forEach(g => { %>
          <label class="d-flex align-items-center">
            <input class="form-check-input me-1" type="checkbox" name="grupo_ids" value="<%= g.id %>">
            <span class="text-dark"><%= g.nombre %></span>
          </label>
        <% }) %>
      <% } else { %>
        <p>No hay grupos disponibles.</p>
      <% } %>
    </div>
  </div>

  <div class="grupo-campos">
    <h2>Tipo de Cuota</h2>
    <div class="form-grid-2">
      <label>Cuota:
        <select name="cuota_id" class="form-input" required>
          <% cuotas.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.nombre %> - <%= c.precio %> €</option>
          <% }) %>
        </select>
      </label>
    </div>
  </div>

  <div class="grupo-campos">
    <h2>Periodo</h2>
    <div class="form-grid-2">
      <label>Desde:
        <input type="date" name="fecha_inicio" class="form-input" required>
      </label>
      <label>Hasta:
        <input type="date" name="fecha_fin" class="form-input" required>
      </label>
    </div>
  </div>

  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/cuotas" class="enlace-final-naranja">← Volver</a>
    <button type="submit" class="btn-main">Asignar cuotas</button>
  </div>
</form>
