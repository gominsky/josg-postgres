<% title = 'Informe: % Horas de asistencia' %>
<% hero = false %>
<%
  function fmtFecha(f) {
    if (!f) return '';
    // T12:00:00 evita desfase por zona horaria
    const d = new Date(f + 'T12:00:00');
    if (isNaN(d)) return f;
    return d.toLocaleDateString('es-ES', { day:'2-digit', month:'2-digit', year:'numeric' });
  }
  const fechaFmt    = fmtFecha(fecha);
  const fechaFinFmt = fecha_fin ? fmtFecha(fecha_fin) : null;
%>

<div class="header-compact">
  <h1 class="h1-titulo">
    % Horas de asistencia
    <span style="font-size:.8em; font-weight:500; opacity:.7;">
      (<%= fechaFmt %><% if (fechaFinFmt) { %> – <%= fechaFinFmt %><% } %>)
    </span>
  </h1>
  <% if (resultados && resultados.length > 0) { %>
  <form action="/informes/horas/guardar" method="POST" style="display:contents;">
    <input type="hidden" name="fecha"       value="<%= fecha %>">
    <input type="hidden" name="fecha_fin"   value="<%= fecha_fin %>">
    <input type="hidden" name="grupo"       value="<%= grupo %>">
    <input type="hidden" name="instrumento" value="<%= instrumento %>">
    <%
      const datosGuardar = resultados.map(r => ({
        alumno_id: r.id, horas: r.horas, porcentaje: r.porcentaje
      }));
    %>
    <input type="hidden" name="resultados" value='<%- JSON.stringify(datosGuardar) %>'>
    <button type="submit" class="btn-main-blanco">Guardar informe</button>
  </form>
  <% } %>
</div>

<!-- Tabla -->
<div class="mx-auto" style="max-width:900px; padding:0 1rem 2rem;">
  <% if (!resultados || resultados.length === 0) { %>
    <p class="text-center text-muted mt-4">No hay datos para los filtros seleccionados.</p>
  <% } else { %>
    <div class="table-responsive">
      <table class="tabla-estilizada tabla-tight tabla-hover" id="tabla-horas">
        <thead>
          <tr>
            <th class="sortable" data-col="0">Alumno <span class="sort-icon">↕</span></th>
            <th class="sortable text-center" data-col="1">Horas asistidas <span class="sort-icon">↕</span></th>
            <th class="sortable text-center" data-col="2">Total horas <span class="sort-icon">↕</span></th>
            <th class="sortable text-center" data-col="3">% Asistencia <span class="sort-icon">↕</span></th>
          </tr>
        </thead>
        <tbody>
          <% resultados.forEach(r => { %>
            <tr>
              <td><%= r.alumno %></td>
              <td class="text-center" data-value="<%= r.horas %>"><%= r.horas %> h</td>
              <td class="text-center" data-value="<%= r.total_horas %>"><%= r.total_horas %> h</td>
              <td class="text-center" data-value="<%= r.porcentaje %>"><%= r.porcentaje %> %</td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<div class="volver-bloque-izquierda">
  <a href="/informes" class="enlace-final">← Volver a Informes</a>
</div>

<script>
(() => {
  const table = document.getElementById('tabla-horas');
  if (!table) return;
  const tbody = table.querySelector('tbody');
  let sortCol = -1, sortAsc = true;

  table.querySelectorAll('th.sortable').forEach(th => {
    th.style.cursor = 'pointer';
    th.addEventListener('click', () => {
      const col = parseInt(th.dataset.col);
      if (sortCol === col) sortAsc = !sortAsc;
      else { sortCol = col; sortAsc = true; }
      table.querySelectorAll('th .sort-icon').forEach(i => i.textContent = '↕');
      th.querySelector('.sort-icon').textContent = sortAsc ? '↑' : '↓';

      const rows = [...tbody.querySelectorAll('tr')];
      rows.sort((a, b) => {
        const ca = a.children[col], cb = b.children[col];
        const va = ca?.dataset?.value ?? ca?.textContent?.trim() ?? '';
        const vb = cb?.dataset?.value ?? cb?.textContent?.trim() ?? '';
        const na = parseFloat(va), nb = parseFloat(vb);
        const cmp = (!isNaN(na) && !isNaN(nb))
          ? na - nb
          : String(va).localeCompare(String(vb), 'es');
        return sortAsc ? cmp : -cmp;
      });
      rows.forEach(r => tbody.appendChild(r));
    });
  });
})();
</script>
