<%
  title = 'Listado de músicos';
  hero  = false;
  const VISTA = (typeof vista !== 'undefined' && vista === 'lista') ? 'lista' : 'tarjetas';
%>

<div class="header-compact">
  <h1 class="h1-titulo">Músicos</h1>

  <div class="header-actions">
    <a href="/alumnos/nuevo" class="btn-main-blanco">+ Añadir músico</a>

    <label class="vista-switch" title="Cambiar vista">
      <input type="checkbox" id="vistaSwitch" class="vista-switch__input"
             <%= VISTA === 'lista' ? 'checked' : '' %>
             role="switch"
             aria-label="<%= VISTA === 'lista' ? 'Cambiar a vista tarjetas' : 'Cambiar a vista lista' %>">
      <span class="vista-switch__track" aria-hidden="true"></span>
      <span class="vista-switch__label" id="vistaSwitchLabel">
        <%= VISTA === 'lista' ? 'Lista' : 'Tarjetas' %>
      </span>
    </label>
  </div>
</div>

<form method="GET" id="filtro-form" class="formulario-centrado filtro-card--shape">
  <div class="campo-filtro">
    <label for="estado">Estado</label>
    <select id="estado" name="estado" class="form-centrado-select">
      <% const _estado = (typeof estadoSeleccionado !== 'undefined' ? String(estadoSeleccionado) : 'todos'); %>
      <option value="todos" <%= _estado === 'todos' ? 'selected' : '' %>>Todos</option>
      <option value="1"     <%= _estado === '1'     ? 'selected' : '' %>>Activos</option>
      <option value="0"     <%= _estado === '0'     ? 'selected' : '' %>>No activos</option>
    </select>
  </div>

  <div class="campo-filtro">
    <label for="grupo_id">Grupo</label>
    <select id="grupo_id" name="grupo_id" class="form-centrado-select">
      <% const _grupo = (typeof grupoId !== 'undefined' ? String(grupoId) : 'todos'); %>
      <option value="todos" <%= _grupo === 'todos' ? 'selected' : '' %>>Todos</option>
      <% (grupos || []).forEach(g => { %>
        <option value="<%= g.id %>" <%= _grupo === String(g.id) ? 'selected' : '' %>><%= g.nombre %></option>
      <% }) %>
    </select>
  </div>

  <div class="campo-filtro">
    <label for="busqueda-alumnos">Buscar</label>
    <input id="busqueda-alumnos" name="busqueda" type="text"
           class="form-centrado-select"
           placeholder="Nombre, apellidos, instrumentos..."
           value="<%= typeof busqueda !== 'undefined' ? busqueda : '' %>">
  </div>

  <input type="hidden" name="vista" value="<%= VISTA %>">
</form>

<% if (alumnos.length > 0) { %>

  <% if (VISTA === 'tarjetas') { %>
    <div class="dashboard-grid" id="grid-alumnos">
      <% alumnos.forEach(alumno => { %>
        <a href="/alumnos/<%= alumno.id %>"
           class="card <%= alumno.activo === false ? 'pasivo' : 'activo' %>"
           data-fulltext="<%= (alumno.nombre + ' ' + alumno.apellidos + ' ' + (alumno.instrumentos || '') + ' ' + (alumno.grupos || '')).toLowerCase() %>">
          <div class="alumno-nombre" title="<%= alumno.nombre %> <%= alumno.apellidos %>">
            <%= alumno.nombre %> <%= alumno.apellidos %>
          </div>
          <% if (alumno.instrumentos) { %>
            <div class="alumno-instrumento"><%= alumno.instrumentos %></div>
          <% } %>
          <% if (alumno.grupos) { %>
            <div class="alumno-grupo"><%= alumno.grupos %></div>
          <% } %>
        </a>
      <% }) %>
    </div>

  <% } else { %>
    <div class="table-responsive tabla-compacta-wrap">
      <table class="tabla-estilizada tabla-compacta">
        <thead>
          <tr>
            <th class="th-sortable" data-col="0" scope="col" tabindex="0" aria-sort="none">Nombre</th>
            <th class="th-sortable" data-col="1" scope="col" tabindex="0" aria-sort="none">Instrumentos</th>
            <th class="th-sortable" data-col="2" scope="col" tabindex="0" aria-sort="none">Grupos</th>
            <th class="th-sortable" data-col="3" scope="col" tabindex="0" aria-sort="none">Estado</th>
          </tr>
        </thead>
        <tbody id="tabla-alumnos-body">
          <% alumnos.forEach(a => {
            const nombre    = (a.nombre   || '').trim();
            const apellidos = (a.apellidos || '').trim();
            const fullName  = `${nombre} ${apellidos}`.trim();
            const sortName  = (apellidos || nombre).toLowerCase() + ' ' + nombre.toLowerCase();
            const inst      = (a.instrumentos || '—');
            const grps      = (a.grupos || '—');
            const activoNum = a.activo ? 1 : 0;
          %>
            <tr class="fila-enlace" data-href="/alumnos/<%= a.id %>">
              <td data-sort="<%= sortName %>"><strong><%= fullName %></strong></td>
              <td data-sort="<%= inst.toLowerCase() %>"><%= inst %></td>
              <td data-sort="<%= grps.toLowerCase() %>"><%= grps %></td>
              <td data-sort="<%= activoNum %>"><span class="estado-badge estado-badge--<%= a.activo ? 'ok' : 'ko' %>"><%= a.activo ? 'Activo' : 'No activo' %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

<% } else { %>
  <p class="lista-vacia">No se encontraron músicos.</p>
<% } %>

<div class="volver-bloque-izquierda">
  <% if ((busqueda && busqueda.trim() !== '') || (estadoSeleccionado && estadoSeleccionado !== 'todos') || (grupoId && grupoId !== 'todos')) { %>
    <a href="/alumnos" class="enlace-final">← Volver</a>
  <% } else { %>
    <a href="/" class="enlace-final">← Volver al inicio</a>
  <% } %>
</div>

<script>
(function () {
  /* ── Filtros: enviar al cambiar select ── */
  ['estado', 'grupo_id'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('change', function () {
      document.getElementById('filtro-form').submit();
    });
  });

  /* ── Búsqueda en tiempo real (vista tarjetas) ── */
  var busq = document.getElementById('busqueda-alumnos');
  if (busq) {
    busq.addEventListener('input', function () {
      var filtro = this.value.toLowerCase().trim();
      document.querySelectorAll('#grid-alumnos .card').forEach(function (t) {
        var base = t.getAttribute('data-fulltext') || t.textContent.toLowerCase();
        t.style.display = base.includes(filtro) ? '' : 'none';
      });
    });
  }

  /* ── Toggle vista lista / tarjetas ── */
  var sw    = document.getElementById('vistaSwitch');
  var label = document.getElementById('vistaSwitchLabel');
  if (sw) {
    sw.addEventListener('change', function () {
      var nuevaVista = sw.checked ? 'lista' : 'tarjetas';
      if (label) label.textContent = sw.checked ? 'Lista' : 'Tarjetas';
      var url = new URL(location.href);
      url.searchParams.set('vista', nuevaVista);
      location.href = url.toString();
    });
  }

  /* ── Filas de tabla clicables (sin onclick inline) ── */
  document.querySelectorAll('.fila-enlace[data-href]').forEach(function (tr) {
    tr.style.cursor = 'pointer';
    tr.addEventListener('click', function (e) {
      if (!e.target.closest('a')) location.href = tr.dataset.href;
    });
  });

  /* ── Ordenación de tabla ── */
  (function () {
    var tbody = document.getElementById('tabla-alumnos-body');
    if (!tbody) return;
    var ths = Array.from(document.querySelectorAll('.th-sortable'));
    var sortState = { col: null, dir: 'none' };

    function cmp(a, b, numeric) {
      if (numeric) { return (Number(a) || 0) - (Number(b) || 0); }
      return a.localeCompare(b, 'es', { sensitivity: 'base' });
    }

    function sortBy(colIdx) {
      var rows    = Array.from(tbody.querySelectorAll('tr'));
      var isEstado = colIdx === 3;
      var nextDir  =
        (sortState.col !== colIdx) ? 'asc' :
        (sortState.dir === 'asc'  ? 'desc' :
        (sortState.dir === 'desc' ? 'none' : 'asc'));

      ths.forEach(function (th) { th.setAttribute('aria-sort', 'none'); });
      if (nextDir === 'none') { location.replace(location.href); return; }

      var th = ths.find(function (t) { return Number(t.dataset.col) === colIdx; });
      if (th) th.setAttribute('aria-sort', nextDir === 'asc' ? 'ascending' : 'descending');

      rows.sort(function (r1, r2) {
        var t1 = (r1.children[colIdx] && r1.children[colIdx].getAttribute('data-sort')) || (r1.children[colIdx] && r1.children[colIdx].textContent) || '';
        var t2 = (r2.children[colIdx] && r2.children[colIdx].getAttribute('data-sort')) || (r2.children[colIdx] && r2.children[colIdx].textContent) || '';
        var res = cmp(String(t1), String(t2), isEstado);
        return nextDir === 'asc' ? res : -res;
      });

      var frag = document.createDocumentFragment();
      rows.forEach(function (r) { frag.appendChild(r); });
      tbody.innerHTML = '';
      tbody.appendChild(frag);
      sortState = { col: colIdx, dir: nextDir };
    }

    ths.forEach(function (th) {
      var col = Number(th.dataset.col);
      th.addEventListener('click', function () { sortBy(col); });
      th.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); sortBy(col); }
      });
    });
  })();
})();
</script>
