<%
  title = 'Listado de músicos';
  hero  = false;
  const VISTA = (typeof vista !== 'undefined' && vista === 'lista') ? 'lista' : 'tarjetas';
%>

<div class="header-compact">
  <h1 class="h1-titulo">Músicos</h1>

  <div class="header-actions">
    <a href="/alumnos/nuevo" class="btn-main-blanco">+ Añadir músico</a>

    <div class="form-check form-switch m-0" title="Cambiar vista">
      <input class="form-check-input" type="checkbox" id="vistaSwitch" <%= VISTA==='lista' ? 'checked' : '' %>>
      <label class="form-check-label" for="vistaSwitch">
        <%= VISTA==='lista' ? 'Lista' : 'Tarjetas' %>
      </label>
    </div>
  </div>
</div>

<form method="GET" id="filtro-form" class="formulario-centrado filtro-card--shape">
  <div class="campo-filtro">
    <label for="estado">Estado</label>
    <select id="estado" name="estado" class="form-centrado-select"
            onchange="document.getElementById('filtro-form').submit()">
      <% const _estado = (typeof estadoSeleccionado !== 'undefined' ? String(estadoSeleccionado) : 'todos'); %>
      <option value="todos" <%= _estado === 'todos' ? 'selected' : '' %>>Todos</option>
      <option value="1"     <%= _estado === '1'     ? 'selected' : '' %>>Activos</option>
      <option value="0"     <%= _estado === '0'     ? 'selected' : '' %>>No activos</option>
    </select>
  </div>

  <div class="campo-filtro">
    <label for="grupo_id">Grupo</label>
    <select id="grupo_id" name="grupo_id" class="form-centrado-select1"
            onchange="document.getElementById('filtro-form').submit()">
      <% const _grupo = (typeof grupoId !== 'undefined' ? String(grupoId) : 'todos'); %>
      <option value="todos" <%= _grupo === 'todos' ? 'selected' : '' %>>Todos</option>
      <% (grupos || []).forEach(g => { %>
        <option value="<%= g.id %>" <%= _grupo === String(g.id) ? 'selected' : '' %>><%= g.nombre %></option>
      <% }) %>
    </select>
  </div>

  <div class="campo-filtro">
    <label for="busqueda-alumnos">Buscar</label>
    <input id="busqueda-alumnos" name="busqueda" type="text"
           class="form-centrado-select"
           placeholder="Nombre, apellidos, instrumentos..."
           value="<%= typeof busqueda !== 'undefined' ? busqueda : '' %>">
  </div>

  <input type="hidden" name="vista" value="<%= VISTA %>">
</form>

<% if (alumnos.length > 0) { %>
  <% if (VISTA === 'tarjetas') { %>
    <div class="dashboard-grid" id="grid-alumnos">
      <% alumnos.forEach(alumno => { %>
        <a href="/alumnos/<%= alumno.id %>"
           class="card <%= alumno.activo === false ? 'pasivo' : 'activo' %>"
           data-fulltext="<%= (alumno.nombre + ' ' + alumno.apellidos + ' ' + (alumno.instrumentos||'')).toLowerCase() %>">
          <div class="alumno-nombre" title="<%= alumno.nombre %> <%= alumno.apellidos %>">
            <%= alumno.nombre %> <%= alumno.apellidos %>
          </div>
          <% if (alumno.instrumentos) { %>
            <div class="muted" style="font-size:.85rem;margin-top:.2rem;"><%= alumno.instrumentos %></div>
          <% } %>
        </a>
      <% }) %>
    </div>

  <% } else { %>
    <div class="table-responsive tabla-compacta-wrap">
      <table class="tabla-estilizada tabla-compacta">
        <thead>
          <tr>
            <th class="th-sortable" data-col="0" scope="col" tabindex="0" aria-sort="none">Nombre</th>
            <th class="th-sortable" data-col="1" scope="col" tabindex="0" aria-sort="none">Instrumentos</th>
            <th class="th-sortable" data-col="2" scope="col" tabindex="0" aria-sort="none">Grupos</th>
            <th class="th-sortable" data-col="3" scope="col" tabindex="0" aria-sort="none">Estado</th>
          </tr>
        </thead>
        <tbody id="tabla-alumnos-body">
          <% alumnos.forEach(a => {
            const nombre    = (a.nombre   || '').trim();
            const apellidos = (a.apellidos || '').trim();
            const fullName  = `${nombre} ${apellidos}`.trim();
            const sortName  = (apellidos || nombre).toLowerCase() + ' ' + nombre.toLowerCase();
            const inst      = (a.instrumentos || '—');
            const grps      = (a.grupos || '—');
            const activoNum = a.activo ? 1 : 0;
          %>
            <tr class="fila-enlace" onclick="location.href='/alumnos/<%= a.id %>'" style="cursor:pointer;">
              <td data-sort="<%= sortName %>"><strong><%= fullName %></strong></td>
              <td data-sort="<%= inst.toLowerCase() %>"><%= inst %></td>
              <td data-sort="<%= grps.toLowerCase() %>"><%= grps %></td>
              <td data-sort="<%= activoNum %>">
                <span class="badge bg-<%= a.activo ? 'success' : 'danger' %>">
                  <%= a.activo ? 'Activo' : 'No activo' %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
<% } %>

<div class="volver-bloque-izquierda">
  <% if ((busqueda && busqueda.trim() !== '') || (estadoSeleccionado && estadoSeleccionado !== 'todos') || (grupoId && grupoId !== 'todos')) { %>
    <a href="/alumnos" class="enlace-final">← Volver</a>
  <% } else { %>
    <a href="/" class="enlace-final">← Volver al inicio</a>
  <% } %>
</div>

<script>
  document.getElementById('busqueda-alumnos')?.addEventListener('input', function () {
    const filtro = this.value.toLowerCase().trim();
    document.querySelectorAll('#grid-alumnos .card')?.forEach(t => {
      const base = t.getAttribute('data-fulltext') || t.textContent.toLowerCase();
      t.style.display = base.includes(filtro) ? '' : 'none';
    });
  });

  (function(){
    const sw = document.getElementById('vistaSwitch');
    if (!sw) return;
    sw.addEventListener('change', () => {
      const url = new URL(location.href);
      url.searchParams.set('vista', sw.checked ? 'lista' : 'tarjetas');
      location.href = url.toString();
    });
  })();

  (function(){
    const tbody = document.getElementById('tabla-alumnos-body');
    if (!tbody) return;
    const ths = Array.from(document.querySelectorAll('.th-sortable'));
    let sortState = { col: null, dir: 'none' };

    function cmp(a, b, numeric = false) {
      if (numeric) { const na = Number(a)||0, nb = Number(b)||0; return na - nb; }
      return a.localeCompare(b, 'es', { sensitivity: 'base' });
    }

    function sortBy(colIdx) {
      const rows    = Array.from(tbody.querySelectorAll('tr'));
      const isEstado = colIdx === 3;
      const nextDir =
        (sortState.col !== colIdx) ? 'asc' :
        (sortState.dir === 'asc' ? 'desc' : (sortState.dir === 'desc' ? 'none' : 'asc'));

      ths.forEach(th => th.setAttribute('aria-sort', 'none'));
      if (nextDir === 'none') { location.replace(location.href); return; }

      const th = ths.find(t => Number(t.dataset.col) === colIdx);
      if (th) th.setAttribute('aria-sort', nextDir === 'asc' ? 'ascending' : 'descending');

      rows.sort((r1, r2) => {
        const t1 = r1.children[colIdx]?.getAttribute('data-sort') || r1.children[colIdx]?.textContent || '';
        const t2 = r2.children[colIdx]?.getAttribute('data-sort') || r2.children[colIdx]?.textContent || '';
        const res = cmp(String(t1), String(t2), isEstado);
        return nextDir === 'asc' ? res : -res;
      });

      const frag = document.createDocumentFragment();
      rows.forEach(r => frag.appendChild(r));
      tbody.innerHTML = '';
      tbody.appendChild(frag);
      sortState = { col: colIdx, dir: nextDir };
    }

    ths.forEach(th => {
      const col = Number(th.dataset.col);
      th.addEventListener('click', () => sortBy(col));
      th.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); sortBy(col); }
      });
    });
  })();
</script>
