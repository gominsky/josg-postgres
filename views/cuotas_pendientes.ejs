<% title = 'Cuotas Pendientes' %>
<% hero = false %>

<div class="container-fluid px-4 my-4">
  <h1 class="text-center mb-4">Cuotas Pendientes</h1>

  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <input
      id="buscador"
      type="text"
      placeholder="Buscar alumno..."
      class="form-control"
      style="max-width: 300px;"
    >
  </div>

  <div class="table-responsive">
    <table class="tabla-estilizada" id="tabla-cuotas">
      <thead>
        <tr>
          <th>Alumno</th>
          <th>Cuota</th>
          <th>Vencimiento</th>
          <th>Retraso (días)</th>
          <th class="text-center">Estado</th>
          <th class="text-center">Acción</th>
        </tr>
      </thead>
      <tbody>
        <% cuotasPendientes.forEach(c => { %>
          <tr>
            <td class="alumno"><%= c.alumno %></td>
            <td><%= c.cuota %></td>
            <td><%= formatDate(c.fecha_vencimiento) %></td>
            <td><%= Math.floor(c.dias_retraso) %></td>
            <td class="text-center">
              <span class="badge bg-danger">Pendiente</span>
            </td>
            <td class="text-center">
              <a href="/pagos/nuevo/<%= c.alumno_id %>" class="btn btn-sm enlace-final-naranja" style="font-size: 0.8rem;">Registrar pago</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
  const input = document.getElementById('buscador');
  const filas = document.querySelectorAll('#tabla-cuotas tbody tr');

  input.addEventListener('input', () => {
    const filtro = input.value.toLowerCase();
    filas.forEach(fila => {
      const alumno = fila.querySelector('.alumno').textContent.toLowerCase();
      fila.style.display = alumno.includes(filtro) ? '' : 'none';
    });
  });
</script>
