<% title = 'Inicio - JOSG MANAGER' %>
<% hero  = true %>

<style>
  /* ===== Reset básico y layout ===== */
  *,*::before,*::after{ box-sizing: border-box; }
  html, body{ height:100%; margin:0; }
  body{
    min-height:100vh; display:flex; flex-direction:column;
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Syne", sans-serif;
    color:#111; background:#fff;
  }
  footer{ margin-top:auto; }

  /* ===== Vars Saul Bass + offsets ===== */
  :root{
    --sb-black:#111827;
    --sb-orange:#ff8a00;
    --sb-yellow:#ffb020;
    --sb-cream:#fff3dc;
    --sb-blue:#1f3a8a;
    --sb-rust:#c8472c;

    --lift:-16px;          /* eleva el bloque principal */
    --footer-h:110px;
    --top-offset:50px;

    /* Fondo */
    --bg-lift:60px;      /* ⬅️ súbelo/bájalo (100–220px) */
  }

  /* Accesibilidad: focus visible y enlace de salto */
  .skip-link{
    position:absolute; left:-9999px; top:auto; width:1px; height:1px; overflow:hidden;
  }
  .skip-link:focus{ left:16px; top:12px; width:auto; height:auto; padding:.5rem .75rem; background:#fff; border:2px solid var(--sb-black); border-radius:10px; z-index:9999; }
  :where(a,button,input,select,textarea,.tile-sb,.sb-exit):focus-visible{
    outline:3px solid var(--sb-yellow); outline-offset:2px;
  }

  /* ===== Hero sin fondos ni padding extra ===== */
  .hero-header{
    background: transparent !important;
    background-image: none !important;
    padding: 0 !important;
    height: auto !important;
    min-height: calc(100vh - var(--footer-h)) !important;
    display: block !important;
    align-items: initial !important;
    justify-content: initial !important;
    padding-top: var(--top-offset) !important;
    padding-bottom: 0 !important;

    /* Si usas el background en hero-header (en vez de body), aplica esto: */
    background-attachment: fixed;
    background-repeat: no-repeat;
    background-position: center calc(100% + var(--bg-lift)) !important;
  }

  /* Contenedor centrado y elevado */
  .container{
    max-width: 1100px;
    width: min(1100px, 100%);
    margin-left:auto; margin-right:auto;
    padding-left:16px; padding-right:16px;
  }
  .page-wrap{
    margin-top: var(--lift) !important;   /* sube el conjunto */
    padding-bottom: 48px;                 /* aire para el footer */
  }

  /* Colocar panel (solo cuando existe overlay logueado) */
  .hero-header .panel-usuario-overlay{
    position: absolute !important;
    top: var(--top-offset) !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    margin-top: 0 !important;
  }

  /* ===== Franja superior (rótulo) ===== */
  .sb-topline{
    display:flex; align-items:center; justify-content:center;
    font-weight:900; letter-spacing:.6px; text-transform:uppercase;
    color:#fff; background:#000;
    padding:6px 10px;
    clip-path: polygon(1.5% 0, 98.5% 0, 100% 85%, 2% 100%);
    transform: rotate(-0.4deg);
    margin:4px 0 10px;
  }

  /* ===== Banner usuario (vista logada) ===== */
  .sb-banner{
    position:relative;
    display:flex; align-items:center; justify-content:space-between; gap:12px;
    padding:10px 12px;
    border:2px solid var(--sb-black);
    background:var(--sb-orange);
    color:var(--sb-black);
    clip-path:polygon(2% 6%, 98% 0, 100% 85%, 4% 100%);
    box-shadow:none;
    transform:rotate(-0.4deg);
    margin:0 0 6px;
  }
  .sb-banner::after{
    content:""; position:absolute; inset:auto 10% -6px 4%;
    height:6px; background:var(--sb-black); transform:rotate(-0.3deg);
  }
  .sb-logo{
    height:44px; object-fit:contain;
    background:var(--sb-cream);
    padding:6px 10px; border:2px solid var(--sb-black);
    box-shadow:none; transform:rotate(-2deg);
  }
  .sb-greet{ display:flex; align-items:center; gap:10px; }
  .sb-avatar{
    width:40px; height:40px; border-radius:999px;
    border:2px solid var(--sb-black);
    background:var(--sb-black); color:#fff;
    box-shadow:none; transform:rotate(1deg);
    font-weight:900; display:flex; align-items:center; justify-content:center;
  }
  .sb-greet-text .hello{ margin:0; font-size:1rem; line-height:1.1; color:#000; }
  .sb-greet-text .role { margin:.15rem 0 0; color:#1f2937; font-size:.9rem; opacity:.9; }
  .sb-exit{
    display:inline-flex; align-items:center; gap:8px;
    padding:.5rem .8rem; border:2px solid var(--sb-black);
    background:#fff; color:var(--sb-black);
    border-radius:10px; text-decoration:none;
    box-shadow:none; transform:rotate(.6deg);
  }
  .sb-exit:hover{ filter:brightness(1.02); transform:translateY(-1px) rotate(.4deg); }

  @media (max-width:640px){
    .sb-banner{ flex-direction:column; align-items:stretch; gap:10px; clip-path: polygon(2% 3%, 98% 0, 100% 93%, 4% 100%); }
    .sb-logo{ height:42px; align-self:flex-start; }
    .sb-exit{ align-self:flex-end; }
  }

  /* ===== Grid de tarjetas (vista logada) ===== */
  .sb-grid{
    display:grid; gap:16px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    grid-auto-rows:108px;
    margin-top:8px; margin-bottom:40px;
  }
  .tile-sb{
    position:relative; display:flex; align-items:center; justify-content:center; text-align:center;
    padding:16px; text-decoration:none; font-weight:900; text-transform:uppercase; letter-spacing:.5px;
    color:var(--sb-black); background:var(--sb-cream);
    border:2px solid var(--sb-black); box-shadow:none;
    clip-path:polygon(3% 2%, 97% 0, 99% 92%, 5% 100%);
    transform:rotate(var(--rot, -0.6deg));
    transition:transform .15s ease, filter .15s ease;
  }
  .sb-grid .tile-sb:nth-child(2n){ --rot:.4deg; }
  .sb-grid .tile-sb:nth-child(3n){ --rot:-.9deg; }
  .sb-grid .tile-sb:nth-child(5n){ --rot:.8deg; }
  .tile-sb:hover{ transform:translateY(-2px) rotate(calc(var(--rot) * .6)); filter:brightness(1.02); }
  .tile-sb.is-orange{ background:var(--sb-orange); color:#111; }
  .tile-sb.is-yellow{ background:var(--sb-yellow); color:#111; }
  .tile-sb.is-cream { background:var(--sb-cream);  color:#111; }
  .tile-sb.is-black { background:var(--sb-black);  color:#fff; }
  .tile-sb.is-blue  { background:var(--sb-blue);   color:#fff; }
  .tile-sb.is-rust  { background:var(--sb-rust);   color:#fff; }
  .tile-sb.h1{ grid-row:span 1; } .tile-sb.h2{ grid-row:span 2; }
  .tile-sb.w1{ grid-column:span 1; } .tile-sb.w2{ grid-column:span 2; }
  @media (max-width:799px){ .tile-sb.w2{ grid-column:span 1; } }
  .tile-sb span{ display:block; line-height:1.1; font-size:clamp(1.05rem, .9rem + 1.2vw, 1.6rem); letter-spacing:.6px; }

  /* ===== Fondo global (si lo pones en body) ===== */
  body{
    background: url("/imagenes/fondo_negro.png") center calc(100% + var(--bg-lift)) / cover no-repeat fixed #fffff0;
    background-attachment: fixed;
    background-repeat: no-repeat;
    background-position: center calc(100% + var(--bg-lift)) !important;
  }
  /* Mejora móvil: el fixed en iOS/Android puede ser brusco */
  @media (max-width: 768px){
    body{ background-attachment: scroll; }
  }

  /* =========================================================
     LOGIN-ONLY (NO afecta a la página ya logada)
     ========================================================= */

  /* Contenedor del login: estrecho y centrado */
  .hero-header .sb-login{
    --login-w: 200px;     /* ⇦ ajusta 200/180/160 */
    --label-bg: var(--sb-cream);
    --label-fg: var(--sb-black);

    display:block;
    width: var(--login-w);
    margin: 0 auto;       /* centrado */
    background: transparent !important;
    border: 0 !important;
    clip-path: none !important;
    padding: 0 !important;
  }

  /* Cabecera del login */
  .hero-header .sb-login .sb-login-head{
    display:flex; align-items:center; gap:10px; margin-bottom:8px !important;
    justify-content:flex-start !important;
    flex-wrap:wrap;
    width: var(--login-w);
  }
  .hero-header .sb-login .sb-login-title-wrap{ display:inline-block; }
  .hero-header .sb-login .sb-login-title-pill{
    display:inline-block; font-weight:900; text-transform:uppercase; letter-spacing:.5px;
    font-size:.8rem; line-height:1; padding:4px 8px;
    border:2px solid var(--sb-black);
    clip-path: polygon(4% 5%, 96% 0, 98% 94%, 6% 100%); /* píldora estrecha */
    transform: rotate(-.5deg);
  }

  /* Sistema de recortes */
  .hero-header .sb-login .sb-cut{
    position:relative; display:block;
    border:2px solid var(--sb-black);
    padding:10px 12px; margin:6px 0;
    transform:rotate(-.5deg);
    width: var(--login-w); /* todos alinean con el ancho del login */
  }
  .hero-header .sb-login .sb-cut::before{
    content:""; position:absolute; inset:0; z-index:-1; background:var(--sb-black);
    transform:translate(6px,6px) rotate(-.2deg);
  }

  /* Formas (coinciden con banner/tiles) */
  .hero-header .sb-login .shape-banner{ clip-path: polygon(2% 6%, 98% 0, 100% 85%, 4% 100%); }
  .hero-header .sb-login .shape-tile  { clip-path: polygon(3% 2%, 97% 0, 99% 92%, 5% 100%); }
  .hero-header .sb-login .shape-tight { clip-path: polygon(4% 5%, 96% 0, 98% 94%, 6% 100%); }

  /* Tonos (elige por bloque) */
  .hero-header .sb-login .tone-cream  { background:var(--sb-cream);  color:var(--sb-black); }
  .hero-header .sb-login .tone-yellow { background:var(--sb-yellow); color:var(--sb-black); }
  .hero-header .sb-login .tone-orange { background:var(--sb-orange); color:#111; }
  .hero-header .sb-login .tone-blue   { background:var(--sb-blue);   color:#fff; }
  .hero-header .sb-login .tone-rust   { background:var(--sb-rust);   color:#fff; }
  .hero-header .sb-login .tone-black  { background:var(--sb-black);  color:#fff; }
  .hero-header .sb-login .tone-ivory  { background:#fff8e8;          color:var(--sb-black); }

  /* Form en columna */
  .hero-header .sb-login .login-form{
    display:flex !important; flex-direction:column !important; gap:8px !important;
    align-items:flex-start !important;
  }

  /* Campos: etiqueta + input (compactos) */
  .hero-header .sb-login .sb-cut.is-field label{
    display:inline-block; margin-bottom:6px;
    font-size:.68rem; font-weight:800; line-height:1;
    padding:2px 6px; border:2px solid var(--sb-black); border-radius:8px;
    background:var(--label-bg); color:var(--label-fg);
    transform:rotate(-.3deg);
  }
  .hero-header .sb-login .sb-cut.is-field input.form-control-sm{
    width:100%; font-size:.78rem !important; padding:.32rem .48rem !important;
    border:2px solid var(--sb-black) !important; border-radius:8px !important;
    background:#fff !important; color:#111 !important;
  }

  /* Botón */
  .hero-header .sb-login .sb-cut.is-button .btn-main-naranja{
    width:100% !important; font-size:.75rem !important; padding:.36rem .7rem !important;
    border:2px solid var(--sb-black) !important; border-radius:10px !important;
    background:var(--sb-black) !important; color:#fff !important;
    transform:skewX(-10deg) rotate(-.4deg);
  }

  /* Aviso de error accesible */
  .hero-header .sb-login .alert-login-error{
    width: var(--login-w) !important;
    border:2px solid var(--sb-black) !important; border-radius:10px !important;
    padding:.45rem .6rem !important; transform:rotate(-.4deg);
    background:var(--label-bg) !important; color:var(--label-fg) !important;
  }

  /* Logo peque en su recorte */
  .hero-header .sb-login .sb-cut.is-logo{ display:inline-flex; align-items:center; gap:8px; padding:6px 8px; }
  .hero-header .sb-login .sb-cut.is-logo .sb-login-logo{
    height:30px !important; width:auto; border:2px solid var(--sb-black);
    transform:rotate(-2deg);
  }

  /* =========================================================
     Botón ENTRAR agresivo (solo login)
     ========================================================= */

  /* base agresiva */
  .hero-header .sb-login .sb-cut.is-button .btn-main-naranja{
    position: relative;
    display: block;
    width: 100% !important;

    /* colores configurables por recorte (ver variantes más abajo) */
    background: var(--btn-bg, var(--sb-black)) !important;
    color: var(--btn-fg, #fff) !important;

    border: 3px solid var(--sb-black) !important;
    border-radius: 10px !important;

    font-weight: 900 !important;
    text-transform: uppercase;
    letter-spacing: .7px;

    /* más grande/“agresivo” que el compacto anterior */
    font-size: .82rem !important;
    padding: .58rem 1rem !important;

    /* gesto Bass */
    transform: skewX(-12deg) rotate(-.8deg);
    transition: transform .14s ease, filter .14s ease;
    box-shadow: none;
  }

  /* flecha “➔” con el mismo sesgo */
  .hero-header .sb-login .sb-cut.is-button .btn-main-naranja::after{
    content: "➔";
    display: inline-block;
    margin-left: .6rem;
    font-weight: 900;
    transform: skewX(12deg) rotate(.8deg);
  }

  /* sub-sombra recortada (capa negra desfasada) */
  .hero-header .sb-login .sb-cut.is-button .btn-main-naranja::before{
    content: "";
    position: absolute; inset: 0;
    background: var(--sb-black);
    clip-path: polygon(4% 5%, 96% 0, 98% 94%, 6% 100%);
    transform: translate(5px,5px) rotate(-.2deg);
    z-index: -1;
    border-radius: 10px;
  }

  /* hover/active con “golpe” */
  .hero-header .sb-login .sb-cut.is-button .btn-main-naranja:hover{
    filter: brightness(1.03);
    transform: translateY(-2px) skewX(-12deg) rotate(-.6deg);
  }
  .hero-header .sb-login .sb-cut.is-button .btn-main-naranja:active{
    transform: translateY(0) skewX(-12deg) rotate(-.6deg);
  }

  /* =========================================================
     Variantes de color del BOTÓN (opcional, por recorte)
     Aplica la clase tone-* al DIV .sb-cut.is-button para cambiar el botón.
     ========================================================= */
  .hero-header .sb-login .sb-cut.is-button.tone-yellow .btn-main-naranja{
    --btn-bg: var(--sb-yellow);  --btn-fg: var(--sb-black);
  }
  .hero-header .sb-login .sb-cut.is-button.tone-cream  .btn-main-naranja{
    --btn-bg: var(--sb-cream);   --btn-fg: var(--sb-black);
  }
  .hero-header .sb-login .sb-cut.is-button.tone-orange .btn-main-naranja{
    --btn-bg: var(--sb-orange);  --btn-fg: #111;
  }
  .hero-header .sb-login .sb-cut.is-button.tone-blue   .btn-main-naranja{
    --btn-bg: var(--sb-blue);
  }

  /* Toggle mostrar contraseña */
  .show-pass{
    display:inline-flex; align-items:center; gap:.4rem; cursor:pointer;
    font-size:.72rem; user-select:none; margin-top:2px;
  }


/* ======================
   OPCIONES DE FONDOS (Saul Bass, acción lateral e inferior)
   Usa clases en <body>: theme-curtains | theme-spotlights | theme-staff | theme-strips
   Te dejo un conmutador flotante para ir probando.
   ====================== */

/* Conmutador flotante (puedes borrar si no lo necesitas) */
.bg-switcher{ display:none !important; /* switcher desactivado */  position:fixed; right:12px; bottom:12px; z-index:9999; display:flex; gap:8px; align-items:center; padding:6px 10px; background:var(--sb-cream); color:var(--sb-black); border:2px solid var(--sb-black); border-radius:12px; transform:rotate(-.4deg); font-weight:900; font-size:12px; }
.bg-switcher button{ border:2px solid var(--sb-black); background:#fff; color:var(--sb-black); padding:2px 6px; border-radius:8px; cursor:pointer; font-weight:900; }

/* 1) Cortinas laterales + franja inferior */
body.theme-curtains{
  background-color: var(--sb-black) !important;
  background-image:
    linear-gradient(90deg, var(--curtain-left, var(--sb-blue)) 0 14%, transparent 14%),
    linear-gradient(270deg, var(--sb-yellow) 0 14%, transparent 14%),
    linear-gradient(0deg, transparent 0 74%, var(--sb-rust) 74% 88%, transparent 88%);
  background-repeat: no-repeat, no-repeat, no-repeat;
  background-position: left top, right top, center bottom;
  background-size: 16% 100%, 16% 100%, 100% 28%;
  background-attachment: fixed, fixed, fixed;
}

/* 2) Focos desde esquinas inferiores + franja inferior */
body.theme-spotlights{
  background-color: var(--sb-black) !important;
  background-image:
    radial-gradient(160% 65% at 0% 100%, rgba(255,138,0,.28) 0 42%, transparent 55%),
    radial-gradient(160% 65% at 100% 100%, rgba(31,58,138,.26) 0 42%, transparent 55%),
    linear-gradient(0deg, transparent 0 76%, var(--sb-rust) 76% 88%, transparent 88%);
  background-repeat: no-repeat, no-repeat, no-repeat;
  background-position: center bottom, center bottom, center bottom;
  background-size: 100% 100%, 100% 100%, 100% 100%;
  background-attachment: fixed, fixed, fixed;
}

/* 3) Pentagrama en el tercio inferior + toques laterales muy sutiles */
body.theme-staff{
  background-color: var(--sb-black) !important;
  background-image:
    repeating-linear-gradient(0deg, transparent 0 6px, rgba(255,255,255,.10) 6px 8px),
    linear-gradient(90deg, rgba(255,138,0,.06) 0 14%, transparent 14% 86%, rgba(255,176,32,.06) 86% 100%),
    linear-gradient(0deg, transparent 0 76%, var(--sb-rust) 76% 88%, transparent 88%);
  background-repeat: no-repeat, no-repeat, no-repeat;
  background-size: 100% 28vh, 100% 100%, 100% 100%;
  background-position: center bottom, center center, center bottom;
  background-attachment: fixed, fixed, fixed;
}

/* 4) Franjas diagonales estilo papel recortado */
body.theme-strips{
  background-color: var(--sb-black) !important;
  background-image:
    linear-gradient(100deg, var(--sb-orange) 0 10%, transparent 10%),
    linear-gradient(-100deg, var(--sb-yellow) 0 10%, transparent 10%),
    linear-gradient(0deg, transparent 0 78%, var(--sb-cream) 78% 82%, var(--sb-rust) 82% 92%, transparent 92%);
  background-repeat: no-repeat, no-repeat, no-repeat;
  background-size: 55% 130%, 55% 130%, 100% 100%;
  background-position: left center, right center, center bottom;
  background-attachment: fixed, fixed, fixed;
}

/* Móvil: evita tirones con backgrounds fijos */
@media (max-width:768px){
  body[class^="theme-"]{ background-attachment: scroll !important; }
}

/* ======================
   BASS BOLD — Diseños más arriesgados
   ====================== */

/* 5) Baton diagonal + cuñas laterales + franja inferior */
body.theme-bass-baton{
  background-color: var(--sb-black) !important;
  background-image:
    conic-gradient(at 0% 100%, var(--sb-orange) 0 70deg, transparent 70deg),
    conic-gradient(at 100% 100%, var(--sb-yellow) 0 70deg, transparent 70deg),
    linear-gradient(-28deg, transparent 0 58%, #fff 58% 61%, transparent 61% 100%),
    linear-gradient(0deg, transparent 0 78%, var(--sb-rust) 78% 92%, transparent 92%);
  background-repeat:no-repeat,no-repeat,no-repeat,no-repeat;
  background-size: 40% 100%, 40% 100%, 100% 100%, 100% 100%;
  background-position: left bottom, right bottom, center bottom, center bottom;
  background-attachment: fixed,fixed,fixed,fixed;
}

/* 6) Metronome inferior + barra base */
body.theme-bass-metronome{
  background-color: var(--sb-black) !important;
  background-image:
    conic-gradient(at 50% 100%, transparent 0 200deg, var(--sb-orange) 200deg 340deg, transparent 340deg 360deg),
    linear-gradient(0deg, transparent 0 76%, var(--sb-rust) 76% 92%, transparent 92%);
  background-repeat:no-repeat,no-repeat;
  background-size: 100% 100%, 100% 100%;
  background-position:center bottom, center bottom;
  background-attachment: fixed,fixed;
}

/* 7) Partitura rasgada (franja crema con líneas) */
body.theme-bass-tornscore{
  background-color: var(--sb-black) !important;
  background-image:
    repeating-linear-gradient(0deg, rgba(255,255,255,.12) 0 6px, rgba(255,255,255,0) 6px 10px),
    linear-gradient(0deg, transparent 0 74%, var(--sb-cream) 74% 88%, transparent 88%),
    conic-gradient(from 180deg at 50% 75%, transparent 0 10deg, var(--sb-black) 10deg 12deg, transparent 12deg 22deg, var(--sb-black) 22deg 24deg, transparent 24deg 34deg, var(--sb-black) 34deg 36deg, transparent 36deg 46deg, var(--sb-black) 46deg 48deg, transparent 48deg 360deg),
    linear-gradient(0deg, transparent 0 86%, var(--sb-rust) 86% 94%, transparent 94%);
  background-repeat:no-repeat,no-repeat,no-repeat,no-repeat;
  background-size: 100% 28vh, 100% 100%, 100% 100%, 100% 100%;
  background-position: center bottom, center bottom, center bottom, center bottom;
  background-attachment: fixed,fixed,fixed,fixed;
}

/* 8) Cuerdas laterales + puente inferior */
body.theme-bass-strings{
  background-color: var(--sb-black) !important;
  background-image:
    repeating-linear-gradient(90deg, rgba(255,255,255,.10) 0 3px, transparent 3px 18px),
    repeating-linear-gradient(90deg, rgba(255,255,255,.10) 0 3px, transparent 3px 18px),
    conic-gradient(at 50% 100%, transparent 0 200deg, var(--sb-yellow) 200deg 340deg, transparent 340deg 360deg),
    linear-gradient(0deg, transparent 0 82%, var(--sb-rust) 82% 95%, transparent 95%);
  background-repeat:no-repeat,no-repeat,no-repeat,no-repeat;
  background-size: 18% 100%, 18% 100%, 100% 100%, 100% 100%;
  background-position: left top, right top, center bottom, center bottom;
  background-attachment: fixed,fixed,fixed,fixed;
}

/* 9) Proscenio agresivo (marco de escenario) */
body.theme-bass-proscenium{
  background-color: var(--sb-black) !important;
  background-image:
    linear-gradient(102deg, var(--sb-orange) 0 18%, transparent 18%),
    linear-gradient(-102deg, var(--sb-yellow) 0 18%, transparent 18%),
    linear-gradient(0deg, transparent 0 78%, var(--sb-cream) 78% 82%, var(--sb-rust) 82% 94%, transparent 94%);
  background-repeat:no-repeat,no-repeat,no-repeat;
  background-size: 50% 120%, 50% 120%, 100% 100%;
  background-position: left top, right top, center bottom;
  background-attachment: fixed,fixed,fixed;
}

/* 10) Collage recortes (dinámico, center vacío) */
body.theme-bass-collage{
  background-color: var(--sb-black) !important;
  background-image:
    linear-gradient(75deg, var(--sb-orange) 0 10%, transparent 10%),
    linear-gradient(-75deg, var(--sb-yellow) 0 12%, transparent 12%),
    linear-gradient(40deg, var(--sb-cream) 0 8%, transparent 8%),
    linear-gradient(-40deg, var(--sb-rust) 0 10%, transparent 10%),
    radial-gradient(60% 30% at 50% 100%, rgba(255,255,255,.06) 0 80%, transparent 80%),
    linear-gradient(0deg, transparent 0 80%, var(--sb-rust) 80% 92%, transparent 92%);
  background-repeat:no-repeat,no-repeat,no-repeat,no-repeat,no-repeat,no-repeat;
  background-size: 46% 120%, 46% 120%, 40% 110%, 40% 110%, 100% 100%, 100% 100%;
  background-position: left -6%, right -6%, left 40%, right 35%, center bottom, center bottom;
  background-attachment: fixed,fixed,fixed,fixed,fixed,fixed;
}




/* ======================
   MOTIVOS (combinados con fondos) — estilo cartel Saul Bass
   ====================== */

/***** A) PROSCENIO + PUENTE DE VIOLÍN *****/
body.theme-proscenium-bridge{
  background-color: var(--sb-black) !important;
  background-image:
    linear-gradient(102deg, var(--sb-orange) 0 18%, transparent 18%),
    linear-gradient(-102deg, var(--sb-yellow) 0 18%, transparent 18%),
    linear-gradient(0deg, transparent 0 78%, var(--sb-cream) 78% 82%, var(--sb-rust) 82% 94%, transparent 94%);
  background-repeat:no-repeat,no-repeat,no-repeat;
  background-size: 50% 120%, 50% 120%, 100% 100%;
  background-position: left top, right top, center bottom;
  background-attachment: fixed,fixed,fixed;
}
/* Puente estilizado (papel recortado) */
body.theme-proscenium-bridge::before{
  content:""; position:fixed; left:50%; bottom:0; transform:translate(-50%,6px);
  width:min(820px, 86vw); height:min(34vh, 320px);
  background: var(--sb-cream);
  /* silueta dentada con clip-path (top recortado) */
  clip-path: polygon(
     3% 0, 14% 8%, 22% 0, 36% 10%, 48% 0, 62% 10%, 74% 0, 84% 8%, 97% 0,
     100% 30%, 100% 100%, 0 100%, 0 30%
  );
  box-shadow:none;
  z-index:0; pointer-events:none;
}
/* "ojos" del puente (agujeros) */
body.theme-proscenium-bridge::after{
  content:""; position:fixed; left:50%; bottom:calc(10vh); transform:translateX(-50%);
  width:min(760px, 78vw); height:100px; pointer-events:none; z-index:0;
  background:
    radial-gradient(circle at 28% 50%, var(--sb-black) 0 16px, transparent 17px),
    radial-gradient(circle at 72% 50%, var(--sb-black) 0 16px, transparent 17px),
    radial-gradient(50% 58% at 50% 88%, var(--sb-black) 0 60%, transparent 62%);
  background-repeat:no-repeat;
}

/***** B) METRÓNOMO + BASE *****/
body.theme-metronome-icon{
  background-color: var(--sb-black) !important;
  background-image:
    conic-gradient(at 50% 100%, transparent 0 200deg, var(--sb-orange) 200deg 340deg, transparent 340deg 360deg),
    linear-gradient(0deg, transparent 0 76%, var(--sb-rust) 76% 92%, transparent 92%);
  background-repeat:no-repeat,no-repeat;
  background-size: 100% 100%, 100% 100%;
  background-position:center bottom, center bottom;
  background-attachment: fixed,fixed;
}
/* cuerpo del metrónomo */
body.theme-metronome-icon::before{
  content:""; position:fixed; left:50%; bottom:0; transform:translate(-50%,8px);
  width:min(360px, 48vw); height:min(36vh, 260px);
  background: var(--sb-cream);
  clip-path: polygon(50% 3%, 12% 100%, 88% 100%);
  filter: drop-shadow(10px 10px 0 var(--sb-black));
  pointer-events:none; z-index:0;
}
/* ventana + péndulo */
body.theme-metronome-icon::after{
  content:""; position:fixed; left:50%; bottom:0; transform:translate(-50%,8px);
  width:min(360px, 48vw); height:min(36vh, 260px); pointer-events:none; z-index:0;
  background:
    /* ventana oscura */
    linear-gradient(var(--sb-black), var(--sb-black)) no-repeat 50% 58% / 12% 28%,
    /* varilla naranja */
    linear-gradient(115deg, transparent calc(50% - 2px), var(--sb-orange) calc(50% - 2px) calc(50% + 2px), transparent calc(50% + 2px)),
    /* pesa del péndulo */
    radial-gradient(circle at 62% 76%, var(--sb-orange) 0 10px, transparent 11px);
  -webkit-clip-path: polygon(50% 3%, 12% 100%, 88% 100%);
          clip-path: polygon(50% 3%, 12% 100%, 88% 100%);
}

/***** C) ARCO (BOW) LATERAL + COLLAGE *****/
body.theme-collage-bow{
  background-color: var(--sb-black) !important;
  background-image:
    linear-gradient(75deg, var(--sb-orange) 0 10%, transparent 10%),
    linear-gradient(-75deg, var(--sb-yellow) 0 12%, transparent 12%),
    linear-gradient(40deg, var(--sb-cream) 0 8%, transparent 8%),
    linear-gradient(-40deg, var(--sb-rust) 0 10%, transparent 10%),
    radial-gradient(60% 30% at 50% 100%, rgba(255,255,255,.06) 0 80%, transparent 80%),
    linear-gradient(0deg, transparent 0 80%, var(--sb-rust) 80% 92%, transparent 92%);
  background-repeat:no-repeat,no-repeat,no-repeat,no-repeat,no-repeat,no-repeat;
  background-size: 46% 120%, 46% 120%, 40% 110%, 40% 110%, 100% 100%, 100% 100%;
  background-position: left -6%, right -6%, left 40%, right 35%, center bottom, center bottom;
  background-attachment: fixed,fixed,fixed,fixed,fixed,fixed;
}
/* arco inclinado en el lateral derecho */
body.theme-collage-bow::before{
  content:""; position:fixed; right:2vw; top:4vh; width:2.2vw; min-width:10px; height:92vh;
  background: var(--sb-yellow); transform:skewX(-10deg) rotate(-6deg);
  box-shadow: 6px 6px 0 var(--sb-black);
  pointer-events:none; z-index:0;
}
body.theme-collage-bow::after{
  content:""; position:fixed; right:1.2vw; top:6vh; width:0; height:0; border-left:10px solid transparent; border-right:10px solid transparent; border-top:22px solid var(--sb-yellow); transform:rotate(-6deg);
  filter: drop-shadow(6px 6px 0 var(--sb-black)); pointer-events:none; z-index:0;
}

/* Móvil: reduce tamaños de los motivos */
@media (max-width:768px){
  body.theme-proscenium-bridge::before{ width:92vw; height:22vh; }
  body.theme-proscenium-bridge::after{ width:86vw; bottom:12vh; }
  body.theme-metronome-icon::before, body.theme-metronome-icon::after{ width:84vw; height:38vh; }
  body.theme-collage-bow::before{ width:3.2vw; min-width:8px; }
}


/* ======== NUEVOS TEMAS ORQUESTALES (f-holes, trompa, timbales) ======== */

/* D) f-holes de violín a ambos laterales (sugeridos) */
body.theme-orchestra-fholes{
  background-color: var(--sb-black) !important;
  background-image:
    /* toques laterales de color */
    linear-gradient(90deg, rgba(255,138,0,.06) 0 12%, transparent 12% 88%, rgba(255,176,32,.06) 88% 100%),
    /* franja inferior */
    linear-gradient(0deg, transparent 0 82%, var(--sb-rust) 82% 95%, transparent 95%),
    /* extremos superiores de f-hole (izq/der) */
    radial-gradient(40% 20% at 7% 28%, var(--sb-cream) 0 98%, transparent 100%),
    radial-gradient(40% 20% at 93% 28%, var(--sb-cream) 0 98%, transparent 100%),
    /* extremos inferiores de f-hole (izq/der) */
    radial-gradient(40% 20% at 7% 72%, var(--sb-cream) 0 98%, transparent 100%),
    radial-gradient(40% 20% at 93% 72%, var(--sb-cream) 0 98%, transparent 100%);
  background-repeat:no-repeat;
  background-size:100% 100%, 100% 100%, 12% 26%, 12% 26%, 12% 26%, 12% 26%;
  background-position:center center, center bottom, left 20%, right 20%, left 60%, right 60%;
}
/* tallos en S (muy sutiles) */
body.theme-orchestra-fholes::before,
body.theme-orchestra-fholes::after{
  content:""; position:fixed; top:12vh; bottom:12vh; width:10px; background: var(--sb-cream);
  filter: drop-shadow(6px 6px 0 var(--sb-black)); pointer-events:none; z-index:0;
}
body.theme-orchestra-fholes::before{ left:8%; transform:skewX(-12deg) rotate(-6deg); }
body.theme-orchestra-fholes::after{ right:8%; transform:skewX(12deg) rotate(6deg); }

/* E) Espiral de trompa + base */
body.theme-orchestra-horn{
  background-color: var(--sb-black) !important;
  background-image:
    /* espiral */
    repeating-conic-gradient(from 0deg at 14% 86%, rgba(255,176,32,.26) 0 6deg, rgba(255,138,0,.26) 6deg 12deg, transparent 12deg 18deg),
    radial-gradient(circle at 14% 86%, transparent 0 22vh, var(--sb-black) 22vh 100%),
    /* leve flare de campana */
    radial-gradient(60% 30% at 10% 100%, rgba(255,255,255,.06) 0 80%, transparent 80%),
    /* base */
    linear-gradient(0deg, transparent 0 82%, var(--sb-rust) 82% 95%, transparent 95%);
  background-repeat:no-repeat,no-repeat,no-repeat,no-repeat;
  background-size:100% 100%, 100% 100%, 100% 100%, 100% 100%;
  background-position:center bottom, center bottom, center bottom, center bottom;
}

/* F) Timbales en base (doble) */
body.theme-orchestra-timpani{
  background-color: var(--sb-black) !important;
  background-image:
    /* tambores */
    radial-gradient(60% 60% at 32% 100%, var(--sb-cream) 0 48%, transparent 50%),
    radial-gradient(60% 60% at 68% 100%, var(--sb-cream) 0 48%, transparent 50%),
    /* aros */
    radial-gradient(65% 65% at 32% 100%, var(--sb-rust) 0 52%, transparent 53%),
    radial-gradient(65% 65% at 68% 100%, var(--sb-rust) 0 52%, transparent 53%),
    /* patas */
    linear-gradient(var(--sb-cream), var(--sb-cream)),
    linear-gradient(var(--sb-cream), var(--sb-cream)),
    linear-gradient(var(--sb-cream), var(--sb-cream)),
    linear-gradient(var(--sb-cream), var(--sb-cream)),
    /* base roja */
    linear-gradient(0deg, transparent 0 82%, var(--sb-rust) 82% 95%, transparent 95%);
  background-repeat:no-repeat;
  background-size:
    36% 40%, 36% 40%,
    38% 42%, 38% 42%,
    4px 16vh, 4px 16vh, 4px 12vh, 4px 12vh,
    100% 100%;
  background-position:
    26% 100%, 74% 100%,
    26% 102%, 74% 102%,
    28% 75%, 24% 75%, 72% 78%, 76% 78%,
    center bottom;
}


/* ===== Login re-diseñado para seguir el estilo de panel/tiles ===== */
.sb-auth{ max-width: 720px; margin: 16px auto 32px; }
.sb-auth .sb-banner{ margin-bottom: 10px; }
.sb-auth-form{ display:grid; gap:12px; }
/* usamos las mismas "tiles" para campos */
.tile-sb .field-label{ display:inline-block; margin-bottom:6px; font-size:.72rem; font-weight:900; letter-spacing:.4px; border:2px solid var(--sb-black); border-radius:8px; padding:3px 8px; background:#fff8e8; color:var(--sb-black); transform:rotate(-.3deg); }
.tile-sb .field-input{ width:100%; font-size:.9rem; padding:.5rem .65rem; border:2px solid var(--sb-black); border-radius:10px; background:#fff; color:#111; }
.sb-auth-actions{ display:flex; align-items:center; justify-content:space-between; gap:12px; }
.btn-auth{ display:inline-flex; align-items:center; justify-content:center; gap:8px; padding:.55rem .95rem; border:2px solid var(--sb-black); border-radius:10px; background:var(--sb-black); color:#fff; font-weight:900; letter-spacing:.6px; text-transform:uppercase; transform:skewX(-10deg) rotate(-.4deg); }
.btn-auth:hover{ filter:brightness(1.03); transform:translateY(-2px) skewX(-10deg) rotate(-.4deg); }
.link-aux{ font-size:.68rem; font-weight:600; letter-spacing:.2px; color:inherit; text-decoration:underline; opacity:.95; }

@media (min-width:800px){ .sb-auth-form{ grid-template-columns:1fr; } }
</style>

<header class="hero-header">
  <a class="skip-link" href="#menu-principal">Saltar al contenido principal</a>

  <% if (!usuario) { %>
  <div class="container page-wrap">
    <div class="sb-topline">JOSG MANAGER - JOVEN ORQUESTA CIUDAD DE GRANADA</div>

    <section class="sb-auth" aria-labelledby="auth-title">
      <!-- Banner de acceso, igual estilo que el logado -->
      <div class="sb-banner">
        <img src="/imagenes/logoJOSG.png" alt="JOSG" class="sb-logo" loading="lazy">
        <div class="sb-greet-text">
          <p id="auth-title" class="hello" style="margin-bottom:.2rem;">Acceso</p>
          <p class="role">Introduce tus credenciales</p>
        </div>
      </div>

      <% if (error) { %>
        <div class="tile-sb is-yellow h1 w2" role="alert" aria-live="polite"><span><%= error %></span></div>
      <% } %>

      <form method="POST" action="/login" class="sb-auth-form" autocomplete="on" novalidate style="background-color: transparent;">
        <div class="tile-sb is-cream h1 w2">
          <label class="field-label" for="email">Usuario</label>
          <input id="email" type="email" name="email" class="field-input" placeholder="usuario@dominio.com" autocomplete="username" required>
        </div>

        <div class="tile-sb is-cream h1 w2">
          <label class="field-label" for="password">Contraseña</label>
          <input id="password" type="password" name="password" class="field-input" autocomplete="current-password" required>
          <label class="show-pass" style="margin-top:6px;">
            <input type="checkbox" id="toggle-pass" aria-controls="password" aria-label="Mostrar contraseña"> Mostrar contraseña
          </label>
        </div>

        <div class="tile-sb is-yellow h1 w2 sb-auth-actions">
          <button type="submit" class="btn-auth">Entrar</button>
          <a href="/recuperar" class="link-aux">¿Olvidaste la contraseña?</a>
        </div>
      </form>
    </section>
  </div>
<% } else { %>
    <div class="panel-usuario-overlay">
      <div class="container page-wrap">

        <div class="sb-topline">JOSG MANAGER - JOVEN ORQUESTA CIUDAD DE GRANADA</div>

        <!-- Banner -->
        <div class="sb-banner">
          <img src="/imagenes/logoJOSG.png" alt="JOSG" class="sb-logo" loading="lazy">

          <div class="sb-greet">
            <div class="sb-avatar">
              <%= (usuario.nombre || '?').trim().slice(0,1).toUpperCase() %>
            </div>
            <div class="sb-greet-text">
              <p class="hello">Hola, <strong style="color:#000;"><%= usuario.nombre %></strong></p>
              <p class="role"><%= usuario.rol %></p>
            </div>
          </div>

          <a href="/logout" class="sb-exit" title="Cerrar sesión" aria-label="Cerrar sesión">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" fill="none" stroke="currentColor" stroke-width="2"/>
              <path d="M16 17l5-5-5-5" fill="none" stroke="currentColor" stroke-width="2"/>
              <path d="M21 12H9" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
            Salir
          </a>
        </div>

        <!-- Grid -->
        <div id="menu-principal" class="sb-grid">
          <% if (usuario.rol === 'admin' || usuario.rol === 'docente') { %>
            <a href="/alumnos"       class="tile-sb is-yellow h2 w1"><span>Músicos</span></a>
            <a href="/profesores"    class="tile-sb is-cream  h1 w1"><span>Docentes</span></a>
            <a href="/eventos"       class="tile-sb is-rust   h1 w2"><span>Eventos / guardias</span></a>
            <a href="/informes"      class="tile-sb is-black  h1 w1"><span>Informes</span></a>
            <a href="/contabilidad"  class="tile-sb is-orange h2 w2"><span>Contabilidad</span></a>
            <a href="/configuracion" class="tile-sb is-yellow h1 w1"><span>Configuración</span></a>
          <% } else { %>
            <a href="/eventos" class="tile-sb is-blue h2 w2"><span>Eventos</span></a>
          <% } %>
        </div>

      </div>
    </div>
  <% } %>
</header>

<script>
  // Toggle mostrar contraseña (accesible)
  (function(){
    var t = document.getElementById('toggle-pass');
    var p = document.getElementById('password');
    if(t && p){
      t.addEventListener('change', function(){
        var showing = t.checked;
        p.type = showing ? 'text' : 'password';
        t.setAttribute('aria-pressed', showing ? 'true' : 'false');
      });
    }
  })();
</script>
<script>
  // Fijar tema: Trompa (espiral)
  document.addEventListener('DOMContentLoaded', function(){
    document.body.classList.add('theme-orchestra-horn');
  });
</script>
