<% title = 'Partituras'; hero = false; %>
<%
  function abs(u){
    if (!u) return '';
    const s = String(u).trim();
    if (!s) return '';
    if (s.startsWith('/')) return s;
    if (/^[a-zA-Z][\w+.-]*:\/\//.test(s)) return s;
    return 'https://' + s; // completa protocolo si falta
  }
%>
<div class="container-fluid mt-4" style="max-width: 1400px;">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h1-titulo mb-0">Repositorio de partituras</h1>

    <div class="d-flex align-items-center gap-2">
      <form class="d-flex" method="GET" action="/partituras">
        <input id="filtroQ"
       name="q"
       value="<%= (typeof q !== 'undefined' ? q : '') %>"
       class="form-control me-2"
       placeholder="Buscar por título, autor, grupo, género…"
       autocomplete="off">
      </form>
      <button class="btn-main-blanco fw-bold px-3 py-2" id="btnNueva" type="button">Nueva partitura</button>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-striped tabla-estilizada" id="tablaPartituras">
      <thead>
        <tr>
          <th role="button" data-sort="titulo"        aria-sort="none">Título</th>
          <th role="button" data-sort="autor"         aria-sort="none">Autor</th>
          <th role="button" data-sort="grupo_nombre"  aria-sort="none">Grupo</th>
          <th role="button" data-sort="duracion"      aria-sort="none">Duración</th>
          <th role="button" data-sort="genero"        aria-sort="none">Género</th>
          <th role="button" data-sort="activo"        aria-sort="none" class="text-center">Activa</th>
          <th>Partitura</th>
          <th>Audio/Vídeo</th>
        </tr>
      </thead>
      <tbody>
        <% (partituras || []).forEach(p => { %>
          <tr class="partitura-row fila-enlace" style="cursor:pointer"
              data-id="<%= p.id %>"
              data-titulo="<%- (p.titulo || '').toLowerCase() %>"
              data-autor="<%- (p.autor || '').toLowerCase() %>"
              data-grupo_nombre="<%- (p.grupo_nombre || '').toLowerCase() %>"
              data-duracion="<%- (p.duracion || '').toLowerCase() %>"
              data-genero="<%- (p.genero || '').toLowerCase() %>"
              data-activo="<%= p.activo ? '1' : '0' %>">
            <td><strong><%= p.titulo %></strong></td>
            <td><%= p.autor || '—' %></td>
            <td><%= p.grupo_nombre || '—' %></td>
            <td><%= p.duracion || '—' %></td>
            <td><%= p.genero || '—' %></td>
            <td class="text-center">
              <span class="badge <%= p.activo ? 'bg-success' : 'bg-secondary' %>">
                <%= p.activo ? 'Sí' : 'No' %>
              </span>
            </td>
            <td>
                <% if (p.enlace_partitura) { %>
               <a href="<%= abs(p.enlace_partitura) %>" target="_blank" rel="noopener">Descargar</a>
                <% } else { %>—<% } %>
            </td>
            <td>
              <% if (p.enlace_audio) { %>
                <a href="<%= p.enlace_audio %>" target="_blank" rel="noopener">Abrir</a>
              <% } else { %>—<% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<style>
  /* Estilo tipo firma_manual */
  .tabla-estilizada td, .tabla-estilizada th { padding: 10px 12px; vertical-align: middle; }
  .h1-titulo, .container-fluid strong { color:#000 !important; }

  /* Modal: borde negro en el formulario */
  #partituraModal .modal-content { background: transparent; box-shadow: none; }
  #partituraForm {
    background:#fff; border: 2px solid #000; border-radius: 12px; padding: 12px;
  }
  .sheet-head {
    display:flex; align-items:center; gap:12px;
    padding:12px 14px; background:#111; color:#fff;
    border-top-left-radius: 12px; border-top-right-radius: 12px;
  }

  /* Selector múltiple alto para instrumentos */
  #selInstrumentos { min-height: 220px; }

  /* Sort headers */
  th[data-sort] { user-select:none; position: relative; padding-right: 18px; }
  th[data-sort]::after{
    content: '↕'; font-size: 0.8rem; opacity: .4;
    position: absolute; right: 6px; top: 50%; transform: translateY(-50%);
  }
  th[aria-sort="ascending"]::after  { content: '↑'; opacity: .9; }
  th[aria-sort="descending"]::after { content: '↓'; opacity: .9; }

  /* ➕ Borde negro para el formulario de búsqueda (se aplica por JS con .borde-negro) */
  .borde-negro {
    border: 1px solid #000 !important;
    border-radius: .5rem;
    padding: .5rem;
  }
  /* Solo columnas 7 y 8 (Partitura y Audio/Vídeo) */
#tablaPartituras tbody tr > td:nth-child(7) a,
#tablaPartituras tbody tr > td:nth-child(8) a,
#tablaPartituras tbody tr > td:nth-child(7) a:visited,
#tablaPartituras tbody tr > td:nth-child(8) a:visited{
  color:#ea6b38 !important;
  font-weight:600;
  text-decoration:none;
  border-bottom:1px solid rgba(234,107,56,.35);
}

#tablaPartituras tbody tr > td:nth-child(7) a:hover,
#tablaPartituras tbody tr > td:nth-child(8) a:hover,
#tablaPartituras tbody tr > td:nth-child(7) a:focus,
#tablaPartituras tbody tr > td:nth-child(8) a:focus{
  color:#c85a2f !important;
  text-decoration:underline;
  border-bottom-color:transparent;
}
</style>

<!-- ===== Modal (sin footer) ===== -->
<div class="modal fade modal-sheet" id="partituraModal" tabindex="-1" aria-labelledby="partituraModalTitulo" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <form id="partituraForm" class="modal-content" enctype="multipart/form-data">
      <input type="hidden" name="id">

      <!-- Cabecera -->
      <div class="sheet-head">
        <h5 class="modal-title mb-0" id="partituraModalTitulo">Nueva partitura</h5>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>

      <!-- Cuerpo -->
      <div class="modal-body" style="padding: 12px 14px;">
        <div class="mb-2">
          <label class="form-label">Título</label>
          <input type="text" name="titulo" class="form-control" required>
        </div>

        <div class="row g-2">
          <div class="col-sm-6">
            <label class="form-label">Autor</label>
            <input type="text" name="autor" class="form-control">
          </div>
          <div class="col-sm-6">
            <label class="form-label">Arreglista</label>
            <input type="text" name="arreglista" class="form-control">
          </div>
        </div>

        <div class="row g-2 mt-0">
          <div class="col-sm-6">
            <label class="form-label">Grupo</label>
            <select name="grupo_id" class="form-select">
              <option value="">—</option>
              <% (grupos || []).forEach(g => { %>
                <option value="<%= g.id %>"><%= g.nombre %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-sm-3">
            <label class="form-label">Duración</label>
            <input type="text" name="duracion" class="form-control" placeholder="03:45 / 3-4 min">
          </div>
          <div class="col-sm-3">
            <label class="form-label">Género</label>
            <input type="text" name="genero" class="form-control">
          </div>
        </div>

        <div class="form-check form-switch my-2">
          <input type="checkbox" name="activo" id="activo" class="form-check-input">
          <label for="activo" class="form-check-label ms-2">Activa (pública)</label>
        </div>

        <div class="mb-2">
          <label class="form-label">Archivo de partitura (PDF/ZIP)</label>
          <input type="file" name="archivo_partitura" class="form-control" accept=".pdf,.zip,.PDF,.ZIP">
          <div class="form-text">Si no subes fichero, puedes indicar un enlace directamente.</div>
                  <!-- Mostrar archivo actual si existe -->
        <div id="archivoActualWrap" class="d-flex align-items-center gap-2 mt-2" hidden>
          <span class="badge bg-secondary">Archivo actual</span>
          <a id="archivoActualLink" href="#" target="_blank" rel="noopener" class="small text-decoration-underline"></a>
          <button type="button" id="quitarArchivoBtn" class="btn btn-link btn-sm text-danger p-0 ms-1" data-action="quitar-archivo">Quitar</button>
        </div>
        <!-- Flag opcional para pedir al servidor borrar el archivo -->
        <input type="hidden" name="eliminar_archivo_partitura" value="0">
        </div>

        <div class="row g-2">
          <div class="col-sm-6">
            <label class="form-label">Enlace partitura (URL)</label>
            <input type="url" name="enlace_partitura" class="form-control" placeholder="https://…">
          </div>
          <div class="col-sm-6">
            <label class="form-label">Enlace audio/vídeo (URL)</label>
            <input type="url" name="enlace_audio" class="form-control" placeholder="https://…">
          </div>
        </div>

        <div class="row g-2 mt-0">
          <div class="col-sm-6">
            <label class="form-label">Instrumentos (múltiple)</label>
            <select name="instrumentos" id="selInstrumentos" class="form-select" multiple size="10">
              <% (instrumentos || []).forEach(i => { %>
                <option value="<%= i.id %>"><%= i.nombre %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-sm-6">
            <label class="form-label">Descripción</label>
            <textarea name="descripcion" class="form-control" rows="10" placeholder="Notas, indicaciones…"></textarea>
          </div>
        </div>

        <div class="mt-3">
          <button type="submit" class="btn btn-dark">Guardar</button>
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="button" id="btnEliminar" class="btn btn-outline-danger d-none float-end">Eliminar</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
  const modalEl     = document.getElementById('partituraModal');
  const modal       = bootstrap.Modal.getOrCreateInstance(modalEl);
  const form        = document.getElementById('partituraForm');
  const selInst     = document.getElementById('selInstrumentos');
  const btnNueva    = document.getElementById('btnNueva');
  const btnEliminar = document.getElementById('btnEliminar');

  // Borde negro al form de búsqueda
  const searchForm = document.getElementById('filtroQ')?.form;
  if (searchForm) searchForm.classList.add('borde-negro');
  // === Filtro en vivo para la lista de partituras (según se escribe) ===
const inputQ = document.getElementById('filtroQ');
const tbody  = document.querySelector('#tablaPartituras tbody');

function normalize(s){
  return (s||'').toString().toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g,'') // quita acentos
    .trim();
}

function rowText(r){
  return [
    r.dataset.titulo,
    r.dataset.autor,
    r.dataset.grupo_nombre,
    r.dataset.duracion,
    r.dataset.genero
  ].map(normalize).join(' ');
}

function ensureNoResultsRow(){
  let noRow = document.getElementById('noResultsRow');
  if (!noRow) {
    noRow = document.createElement('tr');
    noRow.id = 'noResultsRow';
    const td = document.createElement('td');
    td.colSpan = 8; // coincide con tus 8 columnas
    td.className = 'text-center text-muted';
    td.textContent = 'Sin resultados';
    noRow.appendChild(td);
    tbody.appendChild(noRow);
  }
  return noRow;
}

let lastQ = '';
function applyFilter(q){
  const nq = normalize(q);
  if (nq === lastQ) return;
  lastQ = nq;

  const tokens = nq.split(/\s+/).filter(Boolean);
  let visibles = 0;

  tbody.querySelectorAll('tr.partitura-row').forEach(r => {
    const haystack = rowText(r);
    const ok = tokens.every(t => haystack.includes(t));
    r.style.display = ok ? '' : 'none';
    if (ok) visibles++;
  });

  const noRow = ensureNoResultsRow();
  noRow.style.display = visibles === 0 ? '' : 'none';

  const url = new URL(location.href);
  if (nq) url.searchParams.set('q', q); else url.searchParams.delete('q');
  history.replaceState(null, '', url);
}

if (inputQ) {
  inputQ.addEventListener('input', () => applyFilter(inputQ.value));
  inputQ.form?.addEventListener('submit', (e) => {
    e.preventDefault();
    applyFilter(inputQ.value);
  });
  // Filtro inicial por si viene ?q=... o hay valor en el input
  applyFilter(inputQ.value || '');
}

  // Normaliza rutas a URL absoluta (evita error en <input type="url">)
  function toAbsoluteUrl(v) {
    if (!v) return '';
    const s = String(v).trim();
    if (/^https?:\/\//i.test(s)) return s;
    if (s.startsWith('/')) return location.origin + s;
    return location.origin + '/' + s;
  }
  // === Helper: marcar <option> seleccionadas en un <select multiple> ===
function setSelectValues(selectElem, arr) {
  if (!selectElem || !Array.isArray(arr)) return;
  const values = arr.map(String);
  Array.from(selectElem.options).forEach(opt => {
    opt.selected = values.includes(opt.value);
  });
}

// === Listener delegado para el botón "Quitar" del archivo actual ===
// (añádelo una única vez, fuera de fillForm/clearForm)
document.addEventListener('click', (ev) => {
  const btn = ev.target.closest('[data-action="quitar-archivo"]');
  if (!btn) return;

  ev.preventDefault();

  const wrap = document.getElementById('archivoActualWrap');
  const link = document.getElementById('archivoActualLink');
  const flag = form.querySelector('input[name="eliminar_archivo_partitura"]');
  const file = form.querySelector('input[name="archivo_partitura"]');

  if (wrap) wrap.hidden = true;
  if (link) { link.removeAttribute('href'); link.textContent = ''; }
  if (flag) flag.value = '1';
  if (file) file.value = '';
});

// === Rellena el formulario al editar ===
function fillForm(p){
  form.querySelector('input[name="id"]').value = p.id || '';
  form.titulo.value             = p.titulo || '';
  form.autor.value              = p.autor || '';
  form.arreglista.value         = p.arreglista || '';
  if (form.grupo_id) form.grupo_id.value = p.grupo_id || '';
  form.duracion.value           = p.duracion || '';
  form.genero.value             = p.genero || '';
  form.enlace_partitura.value   = toAbsoluteUrl(p.enlace_partitura || '');
  // Si usas un único campo para audio/vídeo, ajústalo aquí (ej. form.enlace_audio o form.enlace_video)
  if (form.enlace_audio) form.enlace_audio.value = toAbsoluteUrl(p.enlace_audio || p.enlace_video || p.enlace || '');
  form.descripcion.value        = p.descripcion || '';
  if (form.activo) form.activo.checked = !!p.activo;

  // Select múltiple de instrumentos (si existe)
  if (typeof selInst !== 'undefined' && selInst) {
    setSelectValues(selInst, (p.instrumentos || []).map(String));
  }

  // UI editar
  if (typeof btnEliminar !== 'undefined' && btnEliminar) btnEliminar.classList.remove('d-none');
  const t = document.getElementById('partituraModalTitulo');
  if (t) t.textContent = 'Editar partitura';

  // === Mostrar "Archivo actual" si existe ===
  const wrap = document.getElementById('archivoActualWrap');
  const link = document.getElementById('archivoActualLink');
  const hiddenFlag = form.querySelector('input[name="eliminar_archivo_partitura"]');

  const ruta   = (p.ruta_partitura || p.ruta || p.archivo_partitura || '').toString().trim();
  const enlace = (p.enlace_partitura || '').toString().trim();

  let urlActual = '';
  if (ruta && ruta.startsWith('/')) {
    urlActual = location.origin + ruta;
  } else if (enlace) {
    urlActual = toAbsoluteUrl(enlace);
  }

  if (urlActual) {
    if (link) {
      link.href = urlActual;
      link.textContent = urlActual.split('/').pop();
    }
    if (wrap) wrap.hidden = false;
    if (hiddenFlag) hiddenFlag.value = '0';
  } else {
    if (wrap) wrap.hidden = true;
    if (hiddenFlag) hiddenFlag.value = '0';
  }

  // Limpia input[file] al entrar en edición (evita confusiones)
  const file = form.querySelector('input[name="archivo_partitura"]');
  if (file) file.value = '';
}

// === Limpia el formulario al crear nueva partitura ===
function clearForm(){
  form.reset();
  form.querySelector('input[name="id"]').value = '';
  if (typeof selInst !== 'undefined' && selInst) {
    Array.from(selInst.options).forEach(o => (o.selected = false));
  }
  if (typeof btnEliminar !== 'undefined' && btnEliminar) btnEliminar.classList.add('d-none');
  const t = document.getElementById('partituraModalTitulo');
  if (t) t.textContent = 'Nueva partitura';

  const wrap = document.getElementById('archivoActualWrap');
  const hiddenFlag = form.querySelector('input[name="eliminar_archivo_partitura"]');
  if (wrap) wrap.hidden = true;
  if (hiddenFlag) hiddenFlag.value = '0';

  const file = form.querySelector('input[name="archivo_partitura"]');
  if (file) file.value = '';
}

  // Nueva
  if (btnNueva) {
    btnNueva.addEventListener('click', e => {
      e.preventDefault();
      clearForm();
      modal.show();
    });
  }

  // Click en filas -> editar
  document.querySelectorAll('.partitura-row').forEach(row => {
    row.style.cursor = 'pointer';
    row.addEventListener('click', async ev => {
      if (ev.target.closest('a,button')) return;
      const id = row.dataset.id;
      if (!id) return;

      try {
        const r = await fetch(`/partituras/${id}`, {
          headers: { 'Accept': 'application/json' },
          credentials: 'same-origin'
        });
        const body = await r.text();
        if (!r.ok) throw new Error(`${r.status} ${r.statusText}\n${body}`);
        const p = JSON.parse(body);
        clearForm();
        fillForm(p);
        modal.show();
      } catch (e) {
        console.error(e);
        alert(`No se pudo cargar la partitura.\n\n${e.message}`);
      }
    });
  });

  // Guardar (POST nuevo, PUT edición)
  form.addEventListener('submit', async e => {
    e.preventDefault();

    // Asegura URLs absolutas
    form.enlace_partitura.value = toAbsoluteUrl(form.enlace_partitura.value);
    form.enlace_audio.value     = toAbsoluteUrl(form.enlace_audio.value);

    const id = form.querySelector('input[name="id"]').value.trim();
    const fd = new FormData(form);

    if (selInst) {
      const sel = Array.from(selInst.selectedOptions).map(o => o.value);
      fd.delete('instrumentos');
      sel.forEach(v => fd.append('instrumentos', v));
    }
    if (form.activo) fd.set('activo', form.activo.checked ? '1' : '0');

    const url = id ? `/partituras/${id}` : '/partituras';
    const method = id ? 'PUT' : 'POST';

    try {
      const r = await fetch(url, {
        method,
        body: fd,
        credentials: 'same-origin'
      });
      const txt = await r.text();
      if (!r.ok) throw new Error(`${method} ${url} -> ${r.status} ${r.statusText}\n${txt}`);
      modal.hide();
      location.reload();
    } catch (err) {
      console.error(err);
      alert(`Error al guardar la partitura.\n\n${err.message}`);
    }
  });

  // Eliminar
  btnEliminar.addEventListener('click', async () => {
    const id = form.querySelector('input[name="id"]').value.trim();
    if (!id) return;
    if (!confirm('¿Eliminar esta partitura?')) return;

    try {
      const r = await fetch(`/partituras/${id}`, {
        method: 'DELETE',
        credentials: 'same-origin'
      });
      const txt = await r.text();
      if (!r.ok) throw new Error(`DELETE /partituras/${id} -> ${r.status} ${r.statusText}\n${txt}`);
      modal.hide();
      location.reload();
    } catch (err) {
      console.error(err);
      alert(`No se pudo eliminar.\n\n${err.message}`);
    }
  });
});

</script>
