<% title = 'Contabilidad'; hero = false; %>
<div id="ctb-wrap" class="container my-4">
  <style>
    :root{
      --accent-50:#fff6e8; --accent-100:#ffeed7; --accent-200:#ffe0b3; --accent-300:#ffd08a;
      --accent-400:#ffb554; --accent-500:#ff9500; --accent-600:#e07f00; --accent-700:#c26c00;
      --text-main:#212529; --muted:#6c757d; --border:rgba(0,0,0,.08);
      --shadow:0 1px 2px rgba(0,0,0,.04); --shadow-lg:0 6px 18px rgba(0,0,0,.08);
    }
    @media (min-width: 992px){ #ctb-wrap.container{ max-width:1320px; } }

    .panel-card{
      background:#fff; color:var(--text-main); border:1px solid var(--border);
      border-radius:18px; box-shadow:var(--shadow); padding:16px 18px 18px;
    }
    .panel-header{
      display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:10px;
    }
    .panel-header .h1-titulo{
      margin:0; font-size:clamp(1.4rem,1.1rem + 1.2vw,2rem); font-weight:700;
    }

    /* Rejilla a 3 columnas (responsive) */
    .action-grid{ display:grid; gap:16px; margin-top:12px; grid-template-columns: 1fr; }
    @media (min-width: 768px){ .action-grid{ grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1200px){ .action-grid{ grid-template-columns: repeat(3, 1fr); } }

    .action-card{
      width:100%; display:flex; align-items:center; gap:14px; text-align:left;
      background:linear-gradient(180deg,#ffffff,#fdfcfa);
      border:1px solid var(--border); border-radius:16px; padding:14px 16px;
      box-shadow:var(--shadow);
      transition:transform .15s ease, box-shadow .15s ease, border-color .15s ease, background .15s ease;
      color:inherit; text-decoration:none; min-height:92px; /* altura coherente */
    }
    .action-card:hover,.action-card:focus{
      transform:translateY(-2px); box-shadow:var(--shadow-lg); border-color:var(--accent-200); background:#fff;
      text-decoration:none;
    }
    .icon-badge{
      width:44px; height:44px; border-radius:999px; flex-shrink:0;
      display:flex; align-items:center; justify-content:center;
      background:var(--accent-100); border:1px solid var(--accent-200); color:var(--accent-700);
    }
    .action-title{ font-weight:700; margin:0; color:var(--text-main); }
    .action-desc{ margin:.15rem 0 0; color:var(--muted); font-size:.92rem; }
  </style>

  <div class="panel-card">
    <div class="panel-header">
      <h1 class="h1-titulo"><%= title %></h1>
    </div>

    <div class="action-grid">
      <!-- Listado de facturas -->
      <a href="/contabilidad/facturas" class="action-card" aria-label="Listado de facturas">
        <div class="icon-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
               viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16l3-2 3 2 3-2 3 2V8z"/>
            <path d="M14 2v6h6"/>
            <path d="M8 13h8M8 9h4"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Listado de facturas</p>
          <p class="action-desc">Consulta, filtra y gestiona facturas de proveedores.</p>
        </div>
      </a>

      <!-- Nueva factura -->
      <a href="/contabilidad/facturas/nueva" class="action-card" aria-label="Nueva factura">
        <div class="icon-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
               viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16l3-2 3 2 3-2 3 2V8z"/>
            <path d="M14 2v6h6"/>
            <path d="M12 12v6M9 15h6"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Nueva factura</p>
          <p class="action-desc">Crear una factura de proveedor.</p>
        </div>
      </a>

      <!-- Listado de proveedores -->
      <a href="/proveedores" class="action-card" aria-label="Listado de proveedores">
        <div class="icon-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
               viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 3h4a2 2 0 0 1 2 2v2H8V5a2 2 0 0 1 2-2z"/>
            <rect x="3" y="7" width="18" height="13" rx="2"/>
            <path d="M3 12h18"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Listado de proveedores</p>
          <p class="action-desc">Gestiona el directorio de proveedores.</p>
        </div>
      </a>

      <!-- Nuevo proveedor -->
      <a href="/proveedores/nuevo" class="action-card" aria-label="Nuevo proveedor">
        <div class="icon-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
               viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="3"/>
            <path d="M4 20c0-3.3 3.6-6 8-6s8 2.7 8 6"/>
            <path d="M19 10v6M16 13h6"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Nuevo proveedor</p>
          <p class="action-desc">Dar de alta un proveedor rápidamente.</p>
        </div>
      </a>

      <!-- Listado de pagos -->
      <a href="/contabilidad/pagos" class="action-card" aria-label="Listado de pagos">
        <div class="icon-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
               viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="5" width="20" height="14" rx="2"/>
            <line x1="2" y1="10" x2="22" y2="10"/>
            <line x1="6" y1="15" x2="10" y2="15"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Listado de pagos</p>
          <p class="action-desc">Consulta y filtra pagos por proveedor, fecha y estado.</p>
        </div>
      </a>

      <!-- Registrar pago -->
      <a href="/contabilidad/pagos/nuevo" class="action-card" aria-label="Registrar pago">
        <div class="icon-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
               viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="5" width="20" height="14" rx="2"/>
            <line x1="2" y1="10" x2="22" y2="10"/>
            <path d="M16 14v6M13 17h6"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Registrar pago</p>
          <p class="action-desc">Crea un pago y aplícalo a una o varias facturas.</p>
        </div>
      </a>
      <!-- Cuotas -->
      <a href="/cuotas" class="action-card" aria-label="Configurar cuotas">
        <div class="icon-badge" aria-hidden="true" title="Cuotas">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
               width="22" height="22" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" role="img">
            <path d="M7 3h10a2 2 0 0 1 2 2v12l-2-1-2 1-2-1-2 1-2-1-2 1V5a2 2 0 0 1 2-2z"/>
            <path d="M9 8h6M9 11h3"/>
            <path d="M17 10.5h-4M17 13.5h-4m0-3a3 3 0 0 1 3-3m-3 6a3 3 0 0 0 3 3"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Cuotas</p>
          <p class="action-desc">Definir importes, periodos y recibos.</p>
        </div>
      </a>

      <!-- Ayuda -->
      <a href="/contabilidad/ayuda" class="action-card" aria-label="Ayuda de contabilidad">
        <div class="icon-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22"
               viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M9.09 9a3 3 0 1 1 5.82 1c0 2-3 2-3 4"/>
            <line x1="12" y1="17" x2="12" y2="17"/>
          </svg>
        </div>
        <div>
          <p class="action-title">Ayuda</p>
          <p class="action-desc">Cómo registrar facturas, pagos y proveedores.</p>
        </div>
      </a>
    </div>
  </div>

  <div class="panel-header">
    <a href="/" class="enlace-final">← Volver al inicio</a>
  </div>
</div>

