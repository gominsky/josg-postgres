<% title = 'Contabilidad'; hero = false; %>

<style>
  /* Solo estilos internos del contenido. NO tocamos .sb-grid */
  .tile-rich .tile-inner{
    display:flex; flex-direction:column; gap:10px;
    width:100%; padding:22px 22px; color:inherit;
  }
  .tile-rich .tile-title{
    margin:0; font-weight:800; line-height:1.15;
    font-size: clamp(1.1rem, 1rem + 0.9vw, 1.6rem);
  }
  .tile-rich .tile-desc{
    margin:0; opacity:.96;
    font-size: clamp(.96rem, .9rem + .4vw, 1.1rem);
  }
  /* Contraste del texto como en index (por si la hoja global no lo aplica aquí) */
  .sb-grid .tile-sb.is-black,
  .sb-grid .tile-sb.is-blue,
  .sb-grid .tile-sb.is-orange,
  .sb-grid .tile-sb.is-rust { color:#fff; }
  .sb-grid .tile-sb.is-cream,
  .sb-grid .tile-sb.is-yellow { color:#111; }
  .tile-rich, .tile-rich * { color: inherit; }

  .container.page-wrap .sb-grid {
    margin-top: 16px;          /* un poco de aire extra */
  }
  @media (min-width:1200px){
    .container.page-wrap .sb-grid { margin-top: 22px; }
  }
</style>

<div class="ctb-head d-flex align-items-center justify-content-between" style="max-width:1200px;margin:20px auto 12px;padding:0 12px;">
  <h1 style="margin:0;font-weight:700;font-size:clamp(1.4rem,1.1rem + 1.2vw,2rem);color:#000;">Contabilidad</h1>
  <a href="/" class="ctb-back" aria-label="Volver al inicio" style="color:#000;text-decoration:none;">← Volver</a>
</div>

<div class="container page-wrap">
  <div class="sb-grid">
    <!-- Usa las mismas clases del index: h1/h2 (alto), w1/w2/w3 (ancho), is-* (color) -->

    <a href="/contabilidad/facturas" class="tile-sb is-orange h2 w2 tile-rich">
      <div class="tile-inner">
        <p class="tile-title">Listado de facturas</p>
        <p class="tile-desc">Consulta, filtra y gestiona facturas de proveedores.</p>
      </div>
    </a>

    <a href="/contabilidad/facturas/nueva" class="tile-sb is-cream h2 w2 tile-rich">
      <div class="tile-inner">
        <p class="tile-title">Nueva factura</p>
        <p class="tile-desc">Crear una factura de proveedor.</p>
      </div>
    </a>

    <a href="/proveedores" class="tile-sb is-yellow h1 w2 tile-rich">
      <div class="tile-inner">
        <p class="tile-title">Listado de proveedores</p>
        <p class="tile-desc">Gestiona el directorio de proveedores.</p>
      </div>
    </a>

    <a href="/proveedores/nuevo" class="tile-sb is-blue h1 w2 tile-rich">
      <div class="tile-inner">
        <p class="tile-title">Nuevo proveedor</p>
        <p class="tile-desc">Dar de alta un proveedor rápidamente.</p>
      </div>
    </a>

    <a href="/contabilidad/pagos" class="tile-sb is-rust h2 w2 tile-rich">
      <div class="tile-inner">
        <p class="tile-title">Listado de pagos</p>
        <p class="tile-desc">Consulta y filtra pagos por proveedor, fecha y estado.</p>
      </div>
    </a>

    <a href="/contabilidad/pagos/nuevo" class="tile-sb is-cream h2 w2 tile-rich">
      <div class="tile-inner">
        <p class="tile-title">Registrar pago</p>
        <p class="tile-desc">Crea un pago y aplícalo a una o varias facturas.</p>
      </div>
    </a>

    <a href="/cuotas" class="tile-sb is-yellow h1 w2 tile-rich">
      <div class="tile-inner">
        <p class="tile-title">Cuotas</p>
        <p class="tile-desc">Definir importes, periodos y recibos.</p>
      </div>
    </a>

    <a href="/contabilidad/ayuda" class="tile-sb is-black h1 w2 tile-rich">
      <div class="tile-inner">
        <p class="tile-title">Ayuda</p>
        <p class="tile-desc">Cómo registrar facturas, pagos y proveedores.</p>
      </div>
    </a>
  </div>
</div>
