<% title = 'Contabilidad'; hero = false; %>

<div class="ctb-head d-flex align-items-center justify-content-between" style="max-width:1200px;margin:20px auto 12px;padding:0 12px;">
  <h1 style="margin:0;font-weight:700;font-size:clamp(1.4rem,1.1rem + 1.2vw,2rem);color:#000;">Contabilidad</h1>
  <div class="d-flex align-items-center gap-2">
    <button id="btnLibre" class="btn btn-sm btn-outline-dark">Modo libre</button>
    <button id="btnReset" class="btn btn-sm btn-outline-secondary">Restablecer</button>
    <a href="/" class="ctb-back" aria-label="Volver al inicio" style="color:#000;text-decoration:none;">← Volver</a>
  </div>
</div>

<div class="container page-wrap">
  <div id="canvas-wrap" class="canvas-wrap" data-menu="contabilidad">
    <div id="menu-config" class="sb-grid">
      <a data-id="cuotas"               href="/cuotas"                      class="tile-sb is-yellow h2 w2"><span>Cuotas</span></a>
      <a data-id="facturas"             href="/contabilidad/facturas"       class="tile-sb is-orange h1 w2"><span>Facturas</span></a>
      <a data-id="factura-nueva"        href="/contabilidad/facturas/nueva" class="tile-sb is-cream  h1 w2"><span>Nueva factura</span></a>
      <a data-id="proveedores"          href="/proveedores"                 class="tile-sb is-black  h1 w2"><span>Proveedores</span></a>
      <a data-id="proveedor-nuevo"      href="/proveedores/nuevo"           class="tile-sb is-blue   h1 w2"><span>Nuevo proveedor</span></a>
      <a data-id="pagos"                href="/contabilidad/pagos"          class="tile-sb is-rust   h1 w2"><span>Pagos</span></a>
      <a data-id="pago-nuevo"           href="/contabilidad/pagos/nuevo"    class="tile-sb is-orange h2 w2"><span>Registrar pago</span></a>
      <a data-id="ayuda"                href="/contabilidad/ayuda"          class="tile-sb is-cream  h1 w2"><span>Ayuda</span></a>
    </div>
  </div>
</div>

<style>
  .container.page-wrap .sb-grid { margin-top: 22px; }

  .canvas-wrap{ position: relative; }
  .canvas-wrap.free, .canvas-wrap.free-view{
    height: 1200px; border: 1px dashed rgba(0,0,0,.08);
    border-radius: 12px; padding: 8px;
  }
  .canvas-wrap.free #menu-config, .canvas-wrap.free-view #menu-config{
    display: block !important; position: relative; height: 100%;
  }
  .canvas-wrap.free #menu-config .tile-sb, .canvas-wrap.free-view #menu-config .tile-sb{
    position: absolute !important; margin: 0 !important;
    min-width: 180px; min-height: 120px;
    box-shadow: 0 4px 18px rgba(0,0,0,.08); user-select: none; touch-action: none;
  }

  .sb-grid .tile-sb.is-black, .sb-grid .tile-sb.is-blue, .sb-grid .tile-sb.is-orange, .sb-grid .tile-sb.is-rust { color:#fff; }
  .sb-grid .tile-sb.is-cream, .sb-grid .tile-sb.is-yellow { color:#111; }

  .tile-tools{ display:none; }
  .canvas-wrap.free .tile-tools{
    position:absolute; top:6px; right:6px; display:flex; gap:6px; z-index:2;
  }
  .canvas-wrap.free .tile-tools button{
    border:1px solid rgba(0,0,0,.15); background:#fff; border-radius:6px;
    padding:4px 8px; font-size:12px; line-height:1; cursor:pointer;
    box-shadow:0 1px 2px rgba(0,0,0,.08);
  }
  .canvas-wrap.free .tile-tools button:hover{ background:#f5f5f5; }
  .dragging{ outline: 2px dashed rgba(0,0,0,.25); outline-offset: 0; }
</style>

<script src="https://cdn.jsdelivr.net/npm/interactjs/dist/interact.min.js"></script>
<script>
(()=>{
  const wrap = document.getElementById('canvas-wrap');
  const grid = document.getElementById('menu-config');
  const btn  = document.getElementById('btnLibre');
  const btnReset = document.getElementById('btnReset');
  if (!wrap || !grid || !btn) return;

  const menuSlug = wrap.dataset.menu || 'contabilidad';
  const API = `/api/layout/${encodeURIComponent(menuSlug)}`;
  const LS_KEY = 'layout:' + menuSlug;
  const COLORS = ['is-cream','is-yellow','is-blue','is-orange','is-rust','is-black'];

  // -------- helpers de estado en cliente --------
  const loadLocal = () => { try{ const r=localStorage.getItem(LS_KEY); return r?JSON.parse(r):null; } catch { return null; } };
  const saveLocal = (o) => { try{ localStorage.setItem(LS_KEY, JSON.stringify(o)); } catch {} };
  const clearLocal= () => { try{ localStorage.removeItem(LS_KEY); } catch {} };
  const def = () => ({ mode:'grid', items:{} });

  // -------- API servidor --------
  async function loadServer(){
    const r = await fetch(API, { credentials:'include' });
    if (!r.ok) throw new Error('load failed ' + r.status);
    return r.json(); // { order_ids, sizes, colors, positions }
  }
  async function saveServer(payload){
    const r = await fetch(API, {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      credentials:'include',
      body: JSON.stringify(payload)
    });
    const t = await r.text();
    if (!r.ok) throw new Error('save failed ' + r.status + ' ' + t);
    return t;
  }

  // -------- utilidades de layout --------
  function applyItemStyles(tile, it){
    if(!it) return;
    COLORS.forEach(c=>tile.classList.remove(c));
    if(it.color) tile.classList.add(it.color);
    if(typeof it.x==='number') tile.style.left  = it.x+'px';
    if(typeof it.y==='number') tile.style.top   = it.y+'px';
    if(typeof it.w==='number') tile.style.width = it.w+'px';
    if(typeof it.h==='number') tile.style.height= it.h+'px';
    if(typeof it.z==='number') tile.style.zIndex= String(it.z);
  }

  function snapshot(){
    const rw=wrap.getBoundingClientRect(), items={};
    for(const t of grid.querySelectorAll('.tile-sb')){
      const id=t.dataset.id; if(!id) continue;
      const r=t.getBoundingClientRect();
      items[id] = {
        x: Math.max(0, r.left - rw.left),
        y: Math.max(0, r.top  - rw.top),
        w: r.width, h: r.height,
        color: COLORS.find(c=>t.classList.contains(c))||null,
        z: 0
      };
    }
    return items;
  }

  function collect(){
    const items={};
    for(const t of grid.querySelectorAll('.tile-sb')){
      const id=t.dataset.id; if(!id) continue;
      const rect=t.getBoundingClientRect();
      items[id] = {
        x: parseFloat(t.style.left)||0,
        y: parseFloat(t.style.top)||0,
        w: parseFloat(t.style.width)||rect.width,
        h: parseFloat(t.style.height)||rect.height,
        color: COLORS.find(c=>t.classList.contains(c))||null,
        z: parseInt(t.style.zIndex||'0',10)
      };
    }
    return items;
  }

  // -------- guardado con debounce --------
  let saveTimer=null;
  function scheduleSave(state){
    clearTimeout(saveTimer);
    saveTimer = setTimeout(async ()=>{
      const order_ids = Array.from(grid.querySelectorAll('.tile-sb')).map(a => a.dataset.id);
      
      // sizes (en “unidades” si te interesa; si no, déjalo vacío)
      const sizes={}, colors={}, positions={};
      for(const [id,it] of Object.entries(state.items||{})){
        sizes[id] = { w: Math.max(1, Math.round((it.w||180)/180)),
                      h: Math.max(1, Math.round((it.h||120)/120)) };
        if(it.color) colors[id]=it.color;
        positions[id] = { x:Math.round(it.x||0), y:Math.round(it.y||0),
                          w:Math.round(it.w||180), h:Math.round(it.h||120),
                          z:it.z||0, color:it.color||null };
      }

      const payload = { order_ids, sizes, colors, positions };
      try {
        const resp = await saveServer(payload);
        console.log('[client] guardado OK', resp);
      } catch (e) {
        console.warn('[client] fallo guardando en servidor, guardo local', e);
        saveLocal(state);
      }
    }, 400);
  }

  // -------- herramientas UI --------
  function cycleColor(tile){
    const cur = COLORS.find(c => tile.classList.contains(c));
    const idx = cur ? COLORS.indexOf(cur) : -1;
    const next = COLORS[(idx+1) % COLORS.length];
    COLORS.forEach(c => tile.classList.remove(c));
    tile.classList.add(next);
  }
  function addTools(tile){
    if (tile.querySelector('.tile-tools')) return;
    const tools = document.createElement('div'); tools.className = 'tile-tools';
    const bColor = document.createElement('button'); bColor.type='button'; bColor.textContent='Color';
    const bFront = document.createElement('button'); bFront.type='button'; bFront.textContent='⇪ Frente';
    bColor.addEventListener('click', (e)=>{ e.preventDefault(); e.stopPropagation(); cycleColor(tile); persistTile(tile); });
    bFront.addEventListener('click', (e)=>{ e.preventDefault(); e.stopPropagation(); tile.style.zIndex=String(Date.now()); persistTile(tile); });
    tools.append(bColor,bFront); tile.appendChild(tools);
  }

  function enableInteract(){
    const c=wrap;
    interact('.canvas-wrap.free #menu-config .tile-sb')
      .draggable({
        listeners:{
          start:e=>e.target.classList.add('dragging'),
          move:e=>{
            const t=e.target;
            const x=(parseFloat(t.style.left)||0)+e.dx;
            const y=(parseFloat(t.style.top)||0)+e.dy;
            const rc=c.getBoundingClientRect(), rt=t.getBoundingClientRect();
            t.style.left=Math.max(0,Math.min(x,rc.width-rt.width))+'px';
            t.style.top =Math.max(0,Math.min(y,rc.height-rt.height))+'px';
          },
          end:e=>{e.target.classList.remove('dragging'); persistTile(e.target);}
        },
        modifiers:[interact.modifiers.restrictRect({restriction:c,endOnly:true})]
      })
      .resizable({
        edges:{left:true,right:true,top:true,bottom:true},
        listeners:{
          move:e=>{
            const t=e.target;
            const ox=parseFloat(t.style.left)||0, oy=parseFloat(t.style.top)||0;
            let w=Math.max(180,e.rect.width), h=Math.max(120,e.rect.height);
            t.style.width=w+'px'; t.style.height=h+'px';
            const nx=ox+e.deltaRect.left, ny=oy+e.deltaRect.top;
            const rc=c.getBoundingClientRect();
            t.style.left=Math.max(0,Math.min(nx,rc.width-w))+'px';
            t.style.top =Math.max(0,Math.min(ny,rc.height-h))+'px';
          },
          end:e=>persistTile(e.target)
        },
        modifiers:[interact.modifiers.restrictEdges({outer:c,endOnly:true})]
      });
  }

  function preventWhileFree(e){ if(wrap.classList.contains('free')){ e.preventDefault(); e.stopPropagation(); } }

  // -------- persistencia por ficha --------
  function persistTile(tile){
    const cur = loadLocal() || def();
    if(cur.mode!=='free' && cur.mode!=='free-view') cur.mode='free-view';
    const id = tile.dataset.id; if(!id) return;
    const rect = tile.getBoundingClientRect(), rw=wrap.getBoundingClientRect();
    cur.items[id] = {
      x: Math.max(0, rect.left-rw.left),
      y: Math.max(0, rect.top -rw.top),
      w: rect.width, h: rect.height,
      color: COLORS.find(c=>tile.classList.contains(c))||null,
      z: parseInt(tile.style.zIndex||'0',10)
    };
    saveLocal(cur);          // guardo por si acaso
    scheduleSave(cur);       // mando a servidor
  }

  // -------- modos --------
  async function enterView(){
    // Limpia toolbars si vinimos de libre
    grid.querySelectorAll('.tile-sb .tile-tools').forEach(t => t.remove());

    wrap.classList.add('free-view');

    // Preferimos servidor; si está vacío, usamos snapshot actual
    let srv=null;
    try { srv = await loadServer(); } catch { srv = null; }
    const pos = srv?.positions || {};
    const items = Object.keys(pos).length ? pos : snapshot(); // <-- evita apilar

    for(const a of grid.querySelectorAll('a.tile-sb')){
      a.style.position='absolute'; a.style.margin='0';
      applyItemStyles(a, items[a.dataset.id]);
    }

    // Si el servidor no tenía posiciones, súbelas ya (para futuras sesiones/dispositivos)
    if (!Object.keys(srv?.positions||{}).length) {
      const cur = loadLocal() || def();
      cur.mode='free-view'; cur.items = items;
      saveLocal(cur);
      scheduleSave(cur);
    }
  }

  function exitView(){
    wrap.classList.remove('free-view');
    for(const a of grid.querySelectorAll('a.tile-sb')){
      a.style.position='';
      a.style.left=a.style.top=a.style.width=a.style.height=a.style.zIndex='';
    }
  }

  async function enterFree(){
    // Asegura vista absoluta y parte de lo que VES ahora mismo
    if(!wrap.classList.contains('free-view')) await enterView();

    wrap.classList.add('free'); btn.textContent='Guardar';

    // Bloquea clicks y añade herramientas
    grid.querySelectorAll('a.tile-sb').forEach(a=>a.addEventListener('click',preventWhileFree));
    grid.querySelectorAll('.tile-sb').forEach(addTools);
    enableInteract();
  }

  function exitFree(saveLayout = true){
    if (saveLayout){
      const cur = loadLocal() || def();
      cur.mode  = 'free-view';
      cur.items = collect();
      saveLocal(cur);
      scheduleSave(cur);
    }
    wrap.classList.remove('free');
    btn.textContent = 'Modo libre';
    grid.querySelectorAll('.tile-sb .tile-tools').forEach(t => t.remove());
    grid.querySelectorAll('a.tile-sb').forEach(a => a.removeEventListener('click', preventWhileFree));
    if (window.interact) interact('.tile-sb').unset();
  }

  // Hotkey Guardar sin salir
  document.addEventListener('keydown',(e)=>{
    if(!wrap.classList.contains('free')) return;
    const isMac=/Mac/i.test(navigator.platform); const mod=isMac?e.metaKey:e.ctrlKey;
    if(mod && e.key.toLowerCase()==='s'){
      e.preventDefault();
      const cur = loadLocal() || def();
      cur.mode='free-view'; cur.items=collect();
      saveLocal(cur); scheduleSave(cur);
      btn.textContent='Guardado'; setTimeout(()=>btn.textContent='Guardar',700);
    }
  });

  // Estado inicial: si ya tenías vista guardada, arranca en “solo ver”
  (async()=>{
    try{
      const s = await loadServer();
      if (Object.keys(s.positions||{}).length) { await enterView(); btn.textContent='Modo libre'; return; }
    } catch {}
    const cur=loadLocal();
    if(cur?.mode==='free' || cur?.mode==='free-view'){ await enterView(); btn.textContent='Modo libre'; }
  })();

  // Botones
  btn.addEventListener('click', ()=>{ if(wrap.classList.contains('free')) exitFree(true); else enterFree(); });
  btnReset?.addEventListener('click', ()=>{ if(wrap.classList.contains('free')) exitFree(false); exitView(); clearLocal(); });
})();
</script>
