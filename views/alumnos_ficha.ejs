<% title = 'Ficha del músico' %>
<% hero = false %>
<link rel="stylesheet" href="/styles.css">
<style>
  /* --- Ajuste de color: menos naranja, texto base negro --- */
  .ficha-container { color: #111; }
  .ficha-container p,
  .ficha-container li,
  .ficha-container td,
  .ficha-container th,
  .ficha-container .muted,
  .fichanav a { color: #111; }

  /* Titulares con acento sutil naranja solo en el borde */
  .h1-titulo, .ficha-grupo h2 { color: #111; }
  .ficha-grupo h2 { border-left: 4px solid #ff6a00; padding-left: .5rem; }

  /* Enlaces finales: negro por defecto, naranja al pasar */
  .enlace-final-naranja { color: #111 !important; border-bottom: 2px solid #ff6a00; }
  .enlace-final-naranja:hover { color: #ff6a00 !important; }

  /* Chips de tags en tono suave */
  .tag { background: #fff3e6; color: #111; border: 1px solid #ffd1a8; }

  /* Navegación */
  .fichanav a:hover { color: #ff6a00; }
  /* Labels (strong) en naranja, valores en negro */
  .ficha-container strong { color: #ff6a00; font-weight: 600; }
  /* === Forzar valores en negro (sobrescribe estilos globales) === */
  .ficha-container,
  .ficha-container p,
  .ficha-container li,
  .ficha-container td,
  .ficha-container th,
  .ficha-container .info-grid,
  .ficha-container .info-grid div,
  .ficha-container .info-grid span,
  .ficha-container .info-grid a { color:#111 !important; }

  /* Labels en naranja, mantienen contraste */
  .ficha-container strong { color:#ff6a00 !important; font-weight:600; }

  /* Chips/tags: texto negro, acento suave */
  .ficha-container .tag { color:#111 !important; background:#fff3e6; border:1px solid #ffd1a8; }
</style>
<style>
  /* ——— Colores locales de la ficha ——— */
  /* Todo el texto de la ficha a negro (por si había naranja global) */
  .ficha-container,
  .ficha-container p,
  .ficha-container li,
  .ficha-container td,
  .ficha-container th,
  .ficha-container .info-grid,
  .ficha-container .info-grid > div,
  .ficha-container .info-grid span,
  .ficha-container .info-grid a {
    color: #111 !important;
  }

  /* Labels en negro y en negrita */
  .ficha-container strong {
    color: #111 !important;
    font-weight: 700;
  }

  /* Badges/chips existentes (estado, etc.) con texto blanco */
  .ficha-container .badge * { color:#fff !important; }
  .ficha-container .badge { color:#fff !important; }
  .bg-success { background:#28a745; }  /* verde */
  .bg-danger  { background:#dc3545; }  /* rojo  */
  /* Tutor un poco más grande y legible */
  .tutor-line {
    font-size: 1.1rem;
    margin-top: .25rem;
  }
   /* Forzar blanco en chips dentro de la grid de la ficha */
   .ficha-container .info-grid .badge,
  .ficha-container .info-grid .badge * {
    color: #fff !important;}
</style>

<script>
  const alumnoId = <%= alumno.id %>;
</script>

<!-- NAV compacto para saltar por secciones -->

<div class="ficha-container contenedor-borde">
  <header class="ficha-header" id="perfil">
    <h1 class="h1-titulo"><%= alumno.nombre %> <%= alumno.apellidos %></h1>
    <p class="tutor-line"><strong>Tutor:</strong> <%= alumno.tutor || '—' %></p>

  </header>

  <!-- ========== PERFIL (como un bloque de "Foto" del form) ========== -->
  <section class="grupo-campos ficha-grupo" aria-labelledby="perfil-title">
    <div class="info-flex">
      <% if (alumno.foto) { %>
        <img src="/uploads/<%= alumno.foto %>" alt="Foto del alumno" class="foto-perfil">
      <% } else { %>
        <div class="foto-perfil d-flex align-items-center justify-content-center bg-light text-muted" aria-label="Sin foto">
          <svg viewBox="0 0 96 96" width="56" height="56" aria-hidden="true" focusable="false" style="opacity:.6">
            <circle cx="48" cy="48" r="45" fill="none" stroke="currentColor" stroke-width="3"/>
            <path d="M48 50c9.39 0 17-7.61 17-17S57.39 16 48 16s-17 7.61-17 17 7.61 17 17 17Zm0 8c-14.36 0-30 7.5-30 20v6h60v-6c0-12.5-15.64-20-30-20Z" fill="currentColor"/>
          </svg>
        </div>        
      <% } %>

      <div class="info-grid">
        <div><strong>Estado:</strong>
          <span class="badge bg-<%= alumno.activo ? 'success' : 'danger' %>">
            <%= alumno.activo ? 'Activo' : 'Pasivo' %>
          </span>
        </div>
        <div><strong>Registro en ¡JOSG en tu mano!:</strong>
          <span class="badge <%= alumno.registrado ? 'bg-success' : 'bg-danger' %>">
            <%= alumno.registrado ? 'Sí' : 'No' %>
          </span>
        </div>        
      </div>
    </div>
  </section>

  <!-- ========== CONTACTO Y DIRECCIÓN ========== -->
  <section class="grupo-campos ficha-grupo" id="contacto" aria-labelledby="contacto-title">
    <h2 id="contacto-title">Contacto y dirección</h2>
    <div class="info-grid">
      <div><strong>Dirección:</strong> <%= alumno.direccion || '—' %></div>
      <div><strong>Código Postal:</strong> <%= alumno.codigo_postal ?? '—' %></div>
      <div><strong>Municipio:</strong> <%= alumno.municipio || '—' %></div>
      <div><strong>Provincia:</strong> <%= alumno.provincia || '—' %></div>
      <div><strong>Email:</strong> <%= alumno.email || '—' %></div>
      <div><strong>Teléfono:</strong> <%= alumno.telefono || '—' %></div>
    </div>
  </section>

  <!-- ========== IDENTIFICACIÓN Y FECHAS (similar a "Datos personales") ========== -->
  <section class="grupo-campos ficha-grupo" id="identificacion" aria-labelledby="ident-title">
    <h2 id="ident-title">Identificación y fechas</h2>
    <div class="info-grid">
      <div><strong>DNI:</strong> <%= alumno.DNI || alumno.dni || '—' %></div>
      <div><strong>Fecha de nacimiento:</strong> <%= typeof formatDate === 'function' ? formatDate(alumno.fecha_nacimiento) : (alumno.fecha_nacimiento || '—') %></div>
      <div><strong>Fecha de alta:</strong> <%= typeof formatDate === 'function' ? formatDate(alumno.fecha_matriculacion) : (alumno.fecha_matriculacion || '—') %></div>
      <div><strong>Fecha de baja:</strong> <%= typeof formatDate === 'function' ? formatDate(alumno.fecha_baja) : (alumno.fecha_baja || '—') %></div>
    </div>
  </section>

  <!-- ========== CENTRO EDUCATIVO ========== -->
  <section class="grupo-campos ficha-grupo" id="centro" aria-labelledby="centro-title">
    <h2 id="centro-title">Centro educativo</h2>
    <div class="info-grid">
      <div><strong>Centro:</strong> <%= alumno.centro || '—' %></div>
      <div><strong>Profesor del centro:</strong> <%= alumno.profesor_centro || '—' %></div>
    </div>
  </section>

  <!-- ========== INSTRUMENTOS ========== -->
  <% if (alumno.instrumentos && alumno.instrumentos.length > 0) { %>
    <section class="grupo-campos ficha-grupo" id="instrumentos" aria-labelledby="inst-title">
      <h2 id="inst-title">Instrumentos</h2>
      <div class="tags-wrap">
        <% alumno.instrumentos.split(',').forEach(inst => { %>
          <span class="tag"><%= inst.trim() %></span>
        <% }) %>
      </div>
    </section>
  <% } %>

  <!-- ========== GRUPOS ========== -->
  <% if (alumno.grupos && alumno.grupos.length > 0) { %>
    <section class="grupo-campos ficha-grupo" id="grupos" aria-labelledby="grupos-title">
      <h2 id="grupos-title">Grupos</h2>
      <div class="tags-wrap">
        <% alumno.grupos.split(',').forEach(gr => { %>
          <span class="tag"><%= gr.replace(/\s*\(.*?\)\s*/g, '').trim() %></span>
        <% }) %>
      </div>
    </section>
  <% } %>

  <!-- ========== FINANZAS (plegable) ========== -->
  <section class="grupo-campos ficha-grupo" id="finanzas" aria-labelledby="finanzas-title">
    <div class="flex-between">
      <h2 id="finanzas-title">Finanzas</h2>
      <button id="toggleResumenBtn" class="btn-main-verde">Mostrar resumen financiero</button>
    </div>

    <div id="resumenFinanciero" class="finanzas-section" style="display: none;">
      <div class="subsection">
        <h3>Resumen</h3>
        <ul>
          <li><strong>Total de cuotas generadas:</strong> <%= resumenDeuda.total_cuotas.toFixed(2) %> €</li>
          <li><strong>Total pagado:</strong> <%= resumenDeuda.total_pagado.toFixed(2) %> €</li>
          <li><strong>Total pendiente:</strong> <%= resumenDeuda.total_pendiente.toFixed(2) %> €</li>
        </ul>
      </div>

      <% if (cuotasAlumno && cuotasAlumno.length > 0) { %>
        <div class="subsection">
          <h3>Cuotas</h3>
          <table class="table table-sm">
            <thead>
              <tr>
                <th>Nombre</th>
                <th>Importe</th>
                <th>Vencimiento</th>
                <th>Estado</th>
                <th>Fecha de pago</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="cuotas-tbody">
              <% cuotasAlumno.slice(0, 5).forEach(c => { %>
                <tr>
                  <td><%= c.nombre_cuota %></td>
                  <td><%= c.precio %> €</td>
                  <td><%= formatDate(c.fecha_vencimiento) %></td>
                  <td>
                    <span class="badge bg-<%= c.pagado ? 'success' : 'warning' %>"><%= c.pagado ? 'Pagada' : 'Pendiente' %></span>
                  </td>
                  <td><%= c.fecha_pago ? formatDate(c.fecha_pago) : '—' %></td>
                  <td style="text-align:center; width:60px;">
                    <% if (!c.pagado) { %>
                      <form action="/cuotas/alumno/eliminar/<%= c.id %>?alumno_id=<%= alumno.id %>&tab=finanzas" method="POST" style="margin:0; padding:0; display:inline; background:transparent;" onsubmit="return confirm('¿Eliminar esta cuota?');">
                        <button title="Eliminar cuota" style="all:unset; cursor:pointer; font-size:1rem; color:#c00; line-height:1;">✕</button>
                      </form>
                    <% } else { %>—<% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <% if (cuotasAlumno.length > 5) { %>
            <div class="text-center mt-2">
              <button id="btn-ver-mas-cuotas" class="btn btn-sm btn-outline-secondary">Ver más cuotas</button>
            </div>
          <% } %>
        </div>
      <% } %>

      <% if (pagos && pagos.length > 0) { %>
        <div class="subsection">
          <h3>Pagos</h3>
          <table class="table table-hover clickable-rows">
            <thead>
              <tr>
                <th>Fecha</th>
                <th>Importe</th>
                <th>Medio</th>
                <th>Cuota</th>
                <th>Referencia</th>
                <th>PDF</th>
              </tr>
            </thead>
            <tbody id="pagos-tbody">
              <% pagos.slice(0, 5).forEach(p => { %>
                <tr data-id="<%= p.pago_id %>" style="cursor:pointer;">
                  <td><%= p.fecha_pago ? p.fecha_pago.split('-').reverse().join('/') : '' %></td>
                  <td><%= Number(p.importe_pago).toFixed(2) %> €</td>
                  <td><%= p.medio_pago %></td>
                  <td><%= p.cuota_nombre %></td>
                  <td><%= p.referencia || '—' %></td>
                  <td>
                    <a href="/pagos/<%= p.pago_id %>/recibo" target="_blank" class="btn btn-sm btn-outline-dark" onclick="event.stopPropagation()">PDF</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <% if (pagos.length > 5) { %>
            <div class="text-center mt-2">
              <button id="btn-ver-mas" class="btn btn-sm btn-outline-secondary">Ver más pagos</button>
            </div>
          <% } %>
        </div>
      <% } %>

      <div class="acciones-financieras">
        <a href="/pagos/nuevo/<%= alumno.id %>" class="enlace-final-naranja">Registrar nuevo pago</a>
        <form action="/pagos/generar-cuotas" method="POST" class="form-centrado-etiqueta">
          <input type="hidden" name="alumno_id" value="<%= alumno.id %>">
          <% if (cuotasDisponibles && cuotasDisponibles.length > 0) { %>
            <div class="form-row">
              <label style="color: white;">Tipo de cuota:
                <select name="cuota_id" required>
                  <% cuotasDisponibles.forEach(c => { %>
                    <option value="<%= c.id %>"><%= c.nombre %> - <%= c.precio %> €</option>
                  <% }) %>
                </select>
              </label>
              <label style="color: white;">Desde:
                <input type="date" name="fecha_inicio" required>
              </label>
              <label style="color: white;">Hasta:
                <input type="date" name="fecha_fin" required>
              </label>
            </div>
            <button type="submit" class="btn-main-blanco">Generar cuotas</button>
          <% } else { %>
            <p style="color: white">No hay tipos de cuota disponibles para asignar.</p>
          <% } %>
        </form>
      </div>
    </div>
  </section>

  <!-- ========== ACCIONES FINALES ==========- -->
  <div class="acciones-finales mt-4">
    <div class="volver-izquierda"><a href="/alumnos" class="enlace-final-naranja">← Volver</a></div>
    <div class="editar-centro"><a href="/alumnos/<%= alumno.id %>/editar" class="enlace-final-naranja ms-3">Editar</a></div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btnToggle = document.getElementById('toggleResumenBtn');
    const resumen = document.getElementById('resumenFinanciero');

    const urlParams = new URLSearchParams(window.location.search);
    const tab = urlParams.get('tab');
    if (tab === 'finanzas') {
      resumen.style.display = 'block';
      btnToggle.textContent = 'Ocultar resumen financiero';
    }

    btnToggle.addEventListener('click', () => {
      const abierto = resumen.style.display !== 'none';
      resumen.style.display = abierto ? 'none' : 'block';
      btnToggle.textContent = abierto ? 'Mostrar resumen financiero' : 'Ocultar resumen financiero';
    });

    // Ver más pagos
    let paginaPagos = 2;
    const btnVerMas = document.getElementById('btn-ver-mas');
    if (btnVerMas) {
      btnVerMas.addEventListener('click', async () => {
        try {
          const res = await fetch(`/pagos/api/${alumnoId}?page=${paginaPagos}`);
          const nuevosPagos = await res.json();
          if (!nuevosPagos.length) { btnVerMas.disabled = true; btnVerMas.innerText = 'No hay más pagos'; return; }

          const tbody = document.getElementById('pagos-tbody');
          nuevosPagos.forEach(p => {
            const tr = document.createElement('tr');
            tr.setAttribute('data-id', p.pago_id);
            tr.style.cursor = 'pointer';
            tr.innerHTML = `
              <td>${p.fecha_pago ? new Date(p.fecha_pago).toLocaleDateString('es-ES') : ''}</td>
              <td>${parseFloat(p.importe_pago).toFixed(2)} €</td>
              <td>${p.medio_pago}</td>
              <td>${p.cuota_nombre}</td>
              <td>${p.referencia || '—'}</td>
              <td><a href="/pagos/${p.pago_id}/recibo" target="_blank" class="btn btn-sm btn-outline-dark" onclick="event.stopPropagation()">PDF</a></td>`;
            tr.addEventListener('click', (e) => {
              if (e.target.closest('a')) return;
              window.location.href = `/pagos/${p.pago_id}/editar`;
            });
            tbody.appendChild(tr);
          });
          paginaPagos++;
        } catch (error) {
          console.error('❌ Error cargando más pagos:', error);
        }
      });
    }

    // Ver más cuotas
    let paginaCuotas = 2;
    const btnVerMasCuotas = document.getElementById('btn-ver-mas-cuotas');
    if (btnVerMasCuotas) {
      btnVerMasCuotas.addEventListener('click', async () => {
        try {
          const res = await fetch(`/cuotas/api/<%= alumno.id %>?page=${paginaCuotas}`);
          const nuevasCuotas = await res.json();
          if (!nuevasCuotas.length) { btnVerMasCuotas.disabled = true; btnVerMasCuotas.innerText = 'No hay más cuotas'; return; }

          const tbody = document.getElementById('cuotas-tbody');
          nuevasCuotas.forEach(c => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td>${c.nombre_cuota}</td>
              <td>${parseFloat(c.precio).toFixed(2)} €</td>
              <td>${new Date(c.fecha_vencimiento).toLocaleDateString('es-ES')}</td>
              <td><span class="badge bg-${c.pagado ? 'success' : 'warning'}">${c.pagado ? 'Pagada' : 'Pendiente'}</span></td>
              <td>${c.fecha_pago ? new Date(c.fecha_pago).toLocaleDateString('es-ES') : '—'}</td>
              <td style="text-align:center; width:60px;">${!c.pagado ? `
                <form action="/cuotas/alumno/eliminar/${c.id}?alumno_id=<%= alumno.id %>&tab=finanzas" method="POST" style="margin:0; padding:0; display:inline; background:transparent;" onsubmit="return confirm('¿Eliminar esta cuota?');">
                  <button title="Eliminar cuota" style="all:unset; cursor:pointer; font-size:1rem; color:#c00; line-height:1;">✕</button>
                </form>` : '—'}</td>`;
            tbody.appendChild(tr);
          });
          paginaCuotas++;
        } catch (error) {
          console.error('❌ Error cargando más cuotas:', error);
        }
      });
    }

    // Click row pagos -> editar
    document.querySelectorAll('#pagos-tbody tr').forEach(tr => {
      tr.addEventListener('click', (e) => {
        if (e.target.closest('a')) return;
        const pagoId = tr.dataset.id;
        if (pagoId) window.location.href = `/pagos/${pagoId}/editar`;
      });
    });
  });
</script>


