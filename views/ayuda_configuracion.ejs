</svg>

<script>
(() => {
  const q = document.getElementById('help-q');
  const cards = Array.from(document.querySelectorAll('#help-grid .card'));
  function filtrar(){
    const s = (q.value || '').toLowerCase().trim();
    cards.forEach(c => {
      const t = c.innerText.toLowerCase() + ' ' + (c.getAttribute('data-text')||'');
      c.style.display = !s || t.includes(s) ? '' : 'none';
    });
  }
  q && q.addEventListener('input', filtrar);
})();
</script>
