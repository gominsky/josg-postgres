<% title = 'Ayuda · Configuración' %>
<% hero  = false %>

<div class="help-wrap" data-help-theme="blue">
  <div class="panel">
    <div class="help-article-head">
      <h1 class="h1">Ayuda · Configuración</h1>
      <div class="cta">
        <a href="/configuracion">Configuración →</a>
      </div>
    </div>

    <p class="notice info">El menú de configuración funciona igual que el de inicio: activa el <strong>Modo libre</strong> para mover los accesos donde quieras, y <strong>Restablecer</strong> para volver al orden original.</p>

    <nav class="toc" aria-label="Índice">
      <a href="#usuarios">Usuarios</a>
      <a href="#docentes">Docentes</a>
      <a href="#grupos">Grupos</a>
      <a href="#instrumentos">Instrumentos</a>
      <a href="#espacios">Espacios</a>
      <a href="#ausencias">Ausencias</a>
      <a href="#actividades">Actividades compl.</a>
      <a href="#guardias">Guardias</a>
      <a href="#backup">Copia de seguridad</a>
    </nav>

    <section id="usuarios" class="section">
      <h2>Usuarios</h2>
      <div class="grid-2">
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Listado y roles</h3>
          <ul class="list">
            <li>Nombre, email y rol; acceso a editar/eliminar; botón <em>+ Añadir</em>.</li>
            <li><strong>Roles disponibles:</strong> <code>admin</code>, <code>docente</code> y <code>usuario</code>.</li>
            <li>Si editas y dejas <em>Contraseña</em> vacía, no se cambia la actual.</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Procedimiento rápido</h3>
          <ol class="list">
            <li>Ir a <em>Usuarios</em> y pulsar <strong>+ Añadir</strong>.</li>
            <li>Completar nombre, apellidos, email y <strong>rol</strong>.</li>
            <li>Elegir una contraseña segura y <strong>Registrar</strong>.</li>
          </ol>
        </div>
      </div>
    </section>

    <section id="docentes" class="section">
      <h2>Docentes</h2>
      <div class="grid-2">
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Ficha</h3>
          <ul class="list">
            <li>Foto, contacto (email/teléfono), dirección, instrumentos y grupos asignados como chips.</li>
            <li><strong>Estado:</strong> activo/no activo (no elimina).</li>
            <li>Un docente con usuario web puede acceder al <em>Portal Maestro</em>.</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Procedimiento rápido</h3>
          <ol class="list">
            <li>Crear el usuario con rol <strong>docente</strong> si no existe.</li>
            <li>Entrar en <strong>Docentes</strong> y completar contacto, instrumentos y grupos.</li>
          </ol>
        </div>
      </div>
    </section>

    <section id="grupos" class="section">
      <h2>Grupos</h2>
      <div class="grid-2">
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Ficha</h3>
          <ul class="list">
            <li><em>Nombre</em> (obligatorio) y <em>Descripción</em> (opcional).</li>
            <li>Acciones: Registrar/Actualizar y Eliminar (con confirmación).</li>
          </ul>
          <p class="notice info">Los grupos se usan en Alumnos, Eventos, Informes y Guardias.</p>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Procedimiento rápido</h3>
          <ol class="list">
            <li>Ir a <em>Grupos</em> → <strong>+ Añadir</strong>.</li>
            <li>Escribir un nombre claro y una descripción breve.</li>
          </ol>
        </div>
      </div>
    </section>

    <section id="instrumentos" class="section">
      <h2>Instrumentos</h2>
      <div class="grid-2">
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Catálogo</h3>
          <ul class="list">
            <li>Organizado por familias: cuerdas, viento madera, viento metal, percusión.</li>
            <li>Ficha: <em>Nombre</em> y <em>Familia</em> (selector).</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Uso</h3>
          <ul class="list">
            <li>Asigna instrumentos a los músicos desde su ficha.</li>
            <li>Se usan en filtros, planos e informes.</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="espacios" class="section">
      <h2>Espacios</h2>
      <div class="grid-2">
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Campos</h3>
          <ul class="list">
            <li>Nombre y propietario (obligatorios), dirección y enlace Google Maps.</li>
            <li>Tipo (Auditorio, Teatro, Aire libre, Otro) y aforo.</li>
            <li>Recursos y observaciones libres.</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Procedimiento rápido</h3>
          <ol class="list">
            <li>Ir a <em>Espacios</em> → <strong>+ Nuevo espacio</strong>.</li>
            <li>Completar <strong>Nombre</strong>, <strong>Propietario</strong> y <strong>Dirección</strong>.</li>
            <li>Pegar la URL de Google Maps si es posible.</li>
          </ol>
        </div>
      </div>
    </section>

    <section id="ausencias" class="section">
      <h2>Ausencias</h2>
      <div class="grid-2">
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Tipos</h3>
          <ul class="list">
            <li>Relación de tipos (Justificada, Injustificada, Parcial, Retraso) con botón <em>+ Añadir</em>.</li>
            <li>Ficha: campo único <em>Tipo</em> (obligatorio).</li>
          </ul>
          <p class="notice info">Se usan en Eventos (firmas/asistencia) y en Informes.</p>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Consejo</h3>
          <ul class="list">
            <li>Mantén un catálogo corto y claro para facilitar la estadística.</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="actividades" class="section">
      <h2>Actividades complementarias</h2>
      <div class="grid-2">
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Ficha</h3>
          <ul class="list">
            <li><em>Tipo</em> (obligatorio) y <em>Descripción</em> (opcional).</li>
            <li>Ejemplos: montaje, desmontaje, apoyo de producción…</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Uso</h3>
          <ul class="list">
            <li>Vincula estas actividades a eventos para medir dedicación adicional.</li>
            <li>También se usan en <strong>Guardias</strong> para asignar músicos de montaje/desmontaje.</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="guardias" class="section">
      <h2>Guardias</h2>
      <div class="grid-2">
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Planilla y asignación</h3>
          <ul class="list">
            <li>Filtros: <em>Grupo</em>, <em>Fecha inicio</em> y <em>Fecha fin</em>. Chips de rango rápido.</li>
            <li>Por fila: si no hay guardia → <em>Asignar</em>; si existe → <em>Eliminar</em>. Clic en fila → <em>Editar</em>.</li>
            <li>Asignación múltiple para rellenar rangos de fechas de golpe.</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Acciones principales</h3>
          <ul class="list">
            <li><strong>Ver listado</strong> con los filtros actuales.</li>
            <li><strong>Asignar múltiples</strong> — requiere fechas.</li>
            <li><strong>Guardia de actividad</strong> — montaje/desmontaje, nº músicos configurable.</li>
            <li><strong>Tabla de asistencias</strong> — referencias cruzadas músicos × eventos.</li>
            <li><strong>PDF</strong> e <strong>Enlace público</strong> con caducidad configurable.</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="backup" class="section">
      <h2>Copia de seguridad</h2>
      <ul class="list">
        <li>Realiza copias antes de operaciones masivas (importes, generación de cuotas, etc.).</li>
        <li>Verifica el fichero y, si puedes, prueba en un entorno de test antes de aplicar en producción.</li>
        <li>Guarda las copias en un lugar seguro con control de versiones.</li>
      </ul>
    </section>

  </div>
</div>
