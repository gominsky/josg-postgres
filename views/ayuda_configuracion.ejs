  <symbol id="i-instrument" viewBox="0 0 24 24"><path d="M20 2l-8 8"/><circle cx="9" cy="15" r="4"/><path d="M16 4l4 4"/></symbol>
  <symbol id="i-map" viewBox="0 0 24 24"><path d="M21 10c0 6-9 12-9 12S3 16 3 10a9 9 0 1 1 18 0Z"/><circle cx="12" cy="10" r="3"/></symbol>
  <symbol id="i-absent" viewBox="0 0 24 24"><path d="M12 2a7 7 0 0 1 7 7v2a7 7 0 0 1-14 0V9a7 7 0 0 1 7-7Z"/><path d="M9 14h6M10 9h4"/></symbol>
