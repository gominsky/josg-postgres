<% title = 'Listado de Profesores' %>
<% hero = false %>

<div class="header-compact">
  <h1 class="h1-titulo">Listado de docentes</h1>
  <a href="/profesores/nuevo" class="btn-main btn-add">+ Añadir docente</a>
</div>

<form method="GET" id="filtro-form" class="formulario-centrado">
  <div class="campo-filtro">
    <label for="estado">Estado</label>
    <select id="estado" name="estado" class="form-centrado-select" onchange="document.getElementById('filtro-form').submit()">
      <option value="">Todos</option>
      <option value="1" <%= estado === '1' ? 'selected' : '' %>>Activos</option>
      <option value="0" <%= estado === '0' ? 'selected' : '' %>>Pasivos</option>
    </select>
  </div>

  <div class="campo-filtro">
    <label for="busqueda">Buscar</label>
    <input id="busqueda-profesores" type="text" class="form-centrado-select" placeholder="Nombre, apellidos...">
  </div>
</form>

<% if (profesores.length > 0) { %>
  <div class="dashboard-grid" id="grid-profesores">
    <% profesores.forEach(p => { %>
      <a href="/profesores/<%= p.id %>" class="card <%= p.activo === false ? 'pasivo' : 'activo' %>">
        <div><%= p.nombre %> <%= p.apellidos %></div>
      </a>
    <% }) %>
  </div>
<% } %>

<div class="volver-bloque-izquierda">
  <% if (estado !== '' || (busqueda && busqueda.trim() !== '')) { %>
    <a href="/profesores" class="enlace-final">← Volver</a>
  <% } else { %>
    <a href="/" class="enlace-final">← Volver al inicio</a>
  <% } %>
</div>

<script>
  document.getElementById('busqueda-profesores').addEventListener('input', function () {
    const filtro = this.value.toLowerCase().trim();
    const tarjetas = document.querySelectorAll('#grid-profesores .card');
    tarjetas.forEach(t => {
      const texto = t.textContent.toLowerCase();
      t.style.display = texto.includes(filtro) ? '' : 'none';
    });
  });
</script>

