<%
  title = 'Listado de docentes';
  hero  = false;
  const VISTA = (typeof vista !== 'undefined' && vista === 'lista') ? 'lista' : 'tarjetas';
%>

<div class="header-compact">
  <h1 class="h1-titulo">Docentes</h1>
  <div class="header-actions">
    <a href="/profesores/nuevo" class="btn-main-blanco">+ Añadir docente</a>
    <label class="vista-switch" title="Cambiar vista">
      <input type="checkbox" id="vistaSwitch" class="vista-switch__input"
             <%= VISTA === 'lista' ? 'checked' : '' %>
             role="switch"
             aria-label="<%= VISTA === 'lista' ? 'Cambiar a vista tarjetas' : 'Cambiar a vista lista' %>">
      <span class="vista-switch__track" aria-hidden="true"></span>
      <span class="vista-switch__label" id="vistaSwitchLabel">
        <%= VISTA === 'lista' ? 'Lista' : 'Tarjetas' %>
      </span>
    </label>
  </div>
</div>

<form method="GET" id="filtro-form" class="formulario-centrado filtro-card--shape">
  <div class="campo-filtro">
    <label for="estado">Estado</label>
    <select id="estado" name="estado" class="form-centrado-select"
            onchange="document.getElementById('filtro-form').submit()">
      <% const _estado = (typeof estado !== 'undefined' ? String(estado) : ''); %>
      <option value=""  <%= _estado === ''  ? 'selected' : '' %>>Todos</option>
      <option value="1" <%= _estado === '1' ? 'selected' : '' %>>Activos</option>
      <option value="0" <%= _estado === '0' ? 'selected' : '' %>>No activos</option>
    </select>
  </div>

  <div class="campo-filtro">
    <label for="busqueda-profesores">Buscar</label>
    <input id="busqueda-profesores" name="busqueda" type="text"
           class="form-centrado-select"
           placeholder="Nombre, apellidos..."
           value="<%= typeof busqueda !== 'undefined' ? busqueda : '' %>">
  </div>

  <input type="hidden" name="vista" value="<%= VISTA %>">
</form>

<% if (profesores.length > 0) { %>

  <% if (VISTA === 'tarjetas') { %>
    <div class="dashboard-grid" id="grid-profesores">
      <% profesores.forEach(p => {
           const full = `${p.nombre || ''} ${p.apellidos || ''}`.trim();
           const grupoNorm = (p.grupos || '').toLowerCase().trim().split(',')[0].trim();
           const grupoClase =
             grupoNorm.includes('josg')   ? 'card--josg'   :
             grupoNorm.includes('oeg')    ? 'card--oeg'    : '';
      %>
        <a href="/profesores/<%= p.id %>"
           class="card <%= p.activo === false ? 'pasivo' : 'activo' %> <%= grupoClase %>"
           data-fulltext="<%= (full + ' ' + (p.instrumentos || '') + ' ' + (p.grupos || '')).toLowerCase() %>">
          <div class="alumno-nombre" title="<%= full %>"><%= full %></div>
          <% if (p.instrumentos) { %>
            <div class="alumno-instrumento"><%= p.instrumentos %></div>
          <% } %>
          <% if (p.grupos) { %>
            <div class="alumno-grupo"><%= p.grupos %></div>
          <% } %>
        </a>
      <% }) %>
    </div>

  <% } else { %>
    <div class="table-responsive tabla-compacta-wrap">
      <table class="table tabla-compacta">
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Instrumentos</th>
            <th>Grupos</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody>
          <% profesores.forEach(p => {
               const full = `${p.nombre || ''} ${p.apellidos || ''}`.trim();
          %>
            <tr class="<%= p.activo === false ? 'pasivo' : '' %>"
                data-fulltext="<%= (full + ' ' + (p.instrumentos || '')).toLowerCase() %>">
              <td><a href="/profesores/<%= p.id %>"><%= full %></a></td>
              <td><%= p.instrumentos || '—' %></td>
              <td><%= p.grupos || '—' %></td>
              <td>
                <span class="badge bg-<%= p.activo ? 'success' : 'secondary' %>">
                  <%= p.activo ? 'Activo' : 'No activo' %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>

<% } else { %>
  <p class="text-muted mt-3">No se encontraron docentes.</p>
<% } %>

<div class="volver-bloque-izquierda">
  <a href="/" class="enlace-final">← Volver al inicio</a>
</div>

<script>
(() => {
  // Filtro en tiempo real
  const input = document.getElementById('busqueda-profesores');
  if (input) {
    input.addEventListener('input', function() {
      const filtro = this.value.toLowerCase().trim();
      document.querySelectorAll('#grid-profesores .card, .tabla-compacta tbody tr').forEach(el => {
        const base = el.getAttribute('data-fulltext') || el.textContent.toLowerCase();
        el.style.display = base.includes(filtro) ? '' : 'none';
      });
    });
  }

  // Switch de vista — igual que alumnos
  var sw  = document.getElementById('vistaSwitch');
  var lbl = document.getElementById('vistaSwitchLabel');
  if (sw) {
    sw.addEventListener('change', function() {
      var nuevaVista = sw.checked ? 'lista' : 'tarjetas';
      if (lbl) lbl.textContent = sw.checked ? 'Lista' : 'Tarjetas';
      var url = new URL(location.href);
      url.searchParams.set('vista', nuevaVista);
      location.href = url.toString();
    });
  }
})();
</script>
