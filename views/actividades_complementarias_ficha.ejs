<% const isEdicion = Boolean(item && item.id); %>
<% title = isEdicion ? 'Editar actividad complementaria' : 'Nueva actividad complementaria'; %>
<% hero = false; %>

<h1 class="h1-titulo"><%= title %></h1>

<form id="form-actividad" method="POST" action="<%= isEdicion ? '/actividades/editar/' + item.id : '/actividades' %>" class="formulario-alumno" style="border: 2px solid #FF9501; border-radius: 0.75rem; padding: 1rem;">
  <div class="grupo-campos">
    <h2>Datos</h2>
    <div class="form-grid-2">
      <label>Tipo:
        <input type="text" name="tipo" id="tipo" value="<%= item?.tipo || '' %>" required>
      </label>
      <label>Descripción:
        <textarea name="descripcion" id="descripcion" rows="3"><%= item?.descripcion || '' %></textarea>
      </label>
    </div>
  </div>

  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/actividades" class="enlace-final">← Volver</a>
    <div class="d-flex align-items-center gap-2">
      <button type="submit" class="btn-main-blanco"><%= isEdicion ? 'Actualizar' : 'Registrar' %></button>
      <% if (isEdicion) { %>
        <button
          type="submit"
          class="btn-main-blanco"
          form="form-actividad"
          formaction="/actividades/eliminar/<%= item.id %>"
          formmethod="POST"
          onclick="return confirm('¿Eliminar esta actividad?');"
        >Eliminar</button>
      <% } %>
    </div>
  </div>
</form>