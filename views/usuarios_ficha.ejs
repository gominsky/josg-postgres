<% const isEdicion = Boolean(usuario && usuario.id); %>
<% title = isEdicion ? 'Editar Usuario' : 'Nuevo Usuario'; %>
<% hero = false; %>

<h1 class="h1-titulo"><%= title %></h1>

<form id="form-usuario" method="POST" action="<%= isEdicion ? '/usuarios/' + usuario.id + '/editar' : '/usuarios/nuevo' %>" class="formulario-alumno" style="border: 2px solid #FF9501; border-radius: 0.75rem; padding: 1rem;">

  <div class="grupo-campos">
    <h2>Datos Personales</h2>
    <div class="form-grid-2">
      <label>Nombre:
        <input type="text" name="nombre" id="nombre" value="<%= usuario?.nombre || '' %>" required>
      </label>
      <label>Apellidos:
        <input type="text" name="apellidos" id="apellidos" value="<%= usuario?.apellidos || '' %>" required>
      </label>
    </div>
  </div>

  <div class="grupo-campos">
    <h2>Credenciales</h2>
    <div class="form-grid-2">
      <label>Email:
        <input type="email" name="email" id="email" value="<%= usuario?.email || '' %>" required>
      </label>
      <label><%= isEdicion ? 'Contraseña (deja vacío para mantener)' : 'Contraseña' %>:
        <input type="password" name="password" id="password" <%= isEdicion ? '' : 'required' %>>
      </label>
      <label>Rol:
        <select name="rol" id="rol" required>
          <option value="usuario" <%= usuario?.rol === 'usuario' ? 'selected' : '' %>>Usuario</option>
          <option value="docente" <%= usuario?.rol === 'docente' ? 'selected' : '' %>>Docente</option>
          <option value="admin" <%= usuario?.rol === 'admin' ? 'selected' : '' %>>Admin</option>
        </select>
      </label>
    </div>
  </div>

  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
  <a href="/usuarios" class="enlace-final">← Volver</a>
  <div class="d-flex align-items-center gap-2">
    <button type="submit" class="btn-main-blanco"><%= isEdicion ? 'Actualizar' : 'Registrar' %></button>
    <% if (isEdicion) { %>
      <button
        type="submit"
        class="btn-main-blanco"
        formaction="/usuarios/<%= usuario.id %>/eliminar"
        formmethod="POST"
        onclick="return confirm('¿Eliminar este usuario?');"
      >Eliminar</button>
    <% } %>
  </div>
</div>
</form>

