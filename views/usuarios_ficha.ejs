<% /* Vista: usuarios_ficha.ejs */ %>
<% /* Determina si estamos en modo edición: se recibe 'esEdicion' o se infiere de usuario.id */ %>
<% const isEdicion = (typeof esEdicion !== 'undefined') ? esEdicion : Boolean(usuario && usuario.id); %>
<% const title = isEdicion ? 'Editar Usuario' : 'Nuevo Usuario'; %>

<h1 class="h1-titulo"><%= title %></h1>

  <form
    id="form-usuario"
    method="POST"
    action="<%= isEdicion
      ? '/usuarios/' + usuario.id + '/editar'
      : '/usuarios/nuevo' %>"
  >
    <div>
      <label for="nombre"><div >Nombre</div></label>
      <div><input type="text" id="nombre" name="nombre" value="<%= (usuario && usuario.nombre) || '' %>" required/></div>
    </div>

    <div>
      <label for="apellidos"><div >Apellidos</div></label>
      <div><input type="text" id="apellidos" name="apellidos" value="<%= (usuario && usuario.apellidos) || '' %>" required/></div>
    </div>

    <div>
      <label for="email"><div>Email</div></label>
      <div><input type="email" id="email" name="email" value="<%= (usuario && usuario.email) || '' %>" required/></div>
    </div>

    <div>
      <label for="password"><div><%= isEdicion ? 'Contraseña (déjalo vacío para mantener la actual)' : 'Contraseña' %></div></label>
      <div><input type="password" id="password" name="password" <%= isEdicion ? '' : 'required' %> /></div>
    </div>

    <div>
      <label for="rol"><div>Rol</div></label>
      <div>
        <select id="rol" name="rol" required>
          <option value="usuario" <%= (usuario && usuario.rol === 'usuario') ? 'selected' : '' %>>Usuario</option>
          <option value="docente" <%= (usuario && usuario.rol === 'docente') ? 'selected' : '' %>>Docente</option>
          <option value="admin"   <%= (usuario && usuario.rol === 'admin') ? 'selected' : '' %>>Admin</option>
        </select>
      </div>
    </div>
  </form>
</div>

<div>
  <!-- Guardar -->
  <a
    href="#"
    onclick="document.getElementById('form-usuario').submit(); return false;"
    class="card-variacion2"
  >
    <div>Guardar</div>
  </a>

  <% if (isEdicion) { %>
    <!-- Eliminar -->
    <form
      id="delete-form"
      method="POST"
      action="/usuarios/<%= usuario.id %>/eliminar"
    ></form>

    <a
      href="#"
      onclick="if(confirm('¿Eliminar este usuario?')) document.getElementById('delete-form').submit(); return false;"
      class="card-eliminar"
    >
      <div>Eliminar</div>
    </a>
  <% } %>
</div>

<div class="volver-bloque-izquierda">
  <a href="/usuarios" class="enlace-final">← Volver a lista de usuarios</a>
</div>
