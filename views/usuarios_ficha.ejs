<% const isEdicion = Boolean(usuario && usuario.id); %>
<% title = isEdicion ? 'Editar usuario' : 'Nuevo usuario'; %>
<% hero = false; %>

<div class="header-compact">
  <h1 class="h1-titulo"><%= title %></h1>
  <a href="/usuarios" class="enlace-final">← Volver</a>
</div>

<form method="POST"
      action="<%= isEdicion ? '/usuarios/' + usuario.id + '/editar' : '/usuarios/nuevo' %>"
      class="formulario-alumno contenedor-borde">

  <div class="grupo-campos">
    <h2>Datos personales</h2>
    <div class="form-grid-2">
      <label>Nombre:
        <input type="text" name="nombre" required value="<%= usuario?.nombre || '' %>">
      </label>
      <label>Apellidos:
        <input type="text" name="apellidos" required value="<%= usuario?.apellidos || '' %>">
      </label>
    </div>
  </div>

  <div class="grupo-campos">
    <h2>Credenciales</h2>
    <div class="form-grid-2">
      <label>Email:
        <input type="email" name="email" required value="<%= usuario?.email || '' %>">
      </label>
      <label><%= isEdicion ? 'Contraseña (vacío = mantener)' : 'Contraseña' %>:
        <input type="password" name="password" <%= isEdicion ? '' : 'required' %>>
      </label>
      <label>Rol:
        <select name="rol" required>
          <% [
            ['admin',        'Admin'],
            ['docente',      'Docente'],
            ['usuario',      'Usuario'],
            ['guardia_josg', 'Guardia JOSG'],
            ['guardia_oeg',  'Guardia OEG'],
          ].forEach(([val, lbl]) => { %>
            <option value="<%= val %>" <%= usuario?.rol === val ? 'selected' : '' %>><%= lbl %></option>
          <% }) %>
        </select>
      </label>
    </div>
  </div>

  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/usuarios" class="enlace-final-naranja">← Volver</a>
    <button type="submit" class="btn-main-blanco"><%= isEdicion ? 'Actualizar' : 'Registrar' %></button>
  </div>
</form>

<% if (isEdicion) { %>
  <form method="POST" action="/usuarios/<%= usuario.id %>/eliminar"
        onsubmit="return confirm('¿Eliminar este usuario?');"
        class="text-center mt-3">
    <button type="submit" class="btn-main-blanco btn-rojo btn-sm">Eliminar usuario</button>
  </form>
<% } %>
