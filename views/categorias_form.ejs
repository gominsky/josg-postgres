<% hero = false %>

<div class="container my-4">
  <div class="panel-card">
    <div class="form-head">
      <h1 class="h1-titulo"><%= title %></h1>
    </div>

    <form method="POST" action="<%= EDIT ? ('/categorias/' + cat.id) : '/categorias/nuevo' %>" style="background-color: transparent;">
      <!-- Nombre -->
      <div class="mb-3">
        <label class="form-label">Nombre de la categoría</label>
        <input class="form-control" name="nombre" required autofocus
               placeholder="Ej. Suministros / Alquileres / Otros servicios"
               value="<%= cat?.nombre || '' %>">
      </div>

      <!-- Categoría padre -->
      <div class="mb-3">
        <label class="form-label">Categoría padre (opcional)</label>
        <select name="padre_id" class="form-select">
          <option value="">— Sin padre —</option>
          <% (padres||[]).forEach(p => { %>
            <option value="<%= p.id %>" <%= (cat?.padre_id === p.id) ? 'selected' : '' %>><%= p.nombre %></option>
          <% }) %>
        </select>
      </div>

      <div class="actions">
        <button class="btn-primary-negro" type="submit">Guardar</button>
      </div>
    </form>
  </div>

  <div class="volver-bloque-izquierda" style="margin-top:12px;">
    <a href="/categorias" class="enlace-final">← Volver</a>
  </div>
</div>
