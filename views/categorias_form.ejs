<% hero = false %>

<div class="container my-4">
  <div class="panel-card">
    <div class="form-head">
      <h1 class="h1-titulo"><%= title %></h1>
    </div>

    <form method="POST" action="<%= EDIT ? ('/categorias/' + cat.id) : '/categorias/nuevo' %>" style="background-color: transparent;">
      <!-- Nombre -->
      <div class="mb-3">
        <label class="form-label">Nombre de la categoría</label>
        <input class="form-control" name="nombre" required autofocus
               placeholder="Ej. Suministros / Alquileres / Otros servicios"
               value="<%= cat?.nombre || '' %>">
      </div>
      <div class="mb-3">
        <label class="form-label">Categoría padre (opcional)</label>
        <select name="parent_id" class="form-select">
          <option value="">— Sin padre —</option>
          <% (padres||[]).forEach(p => { %>
            <option value="<%= p.id %>" <%= (cat?.parent_id === p.id) ? 'selected' : '' %>><%= p.nombre %></option>
          <% }) %>
        </select>
      </div>
      <!-- Estado (solo en edición), igual que en cuentas_form -->
      <% if (EDIT) { %>
        <div class="mb-3">
          <label class="form-label">Estado</label>
          <div class="checkline">
            <input
              type="checkbox"
              id="activo"
              name="activo"
              class="chk-orange"
              <%= (cat?.activo !== false) ? 'checked' : '' %> >
            <label for="activo" class="chk-orange-label" style="margin:0;cursor:pointer;">
              Activa (desmarca para dejarla inactiva)
            </label>
          </div>
        </div>
      <% } %>

      <div class="actions">
        <a class="btn-primary-negro" href="/categorias">Cancelar</a>
        <button class="btn-primary-negro" type="submit">Guardar</button>
      </div>
    </form>
  </div>

  <div class="volver-bloque-izquierda" style="margin-top:12px;">
    <a href="/contabilidad" class="enlace-final">← Volver a contabilidad</a>
  </div>
</div>
