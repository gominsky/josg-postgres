<% title = 'Espacios'; hero = false %>

<div class="header-compact">
  <h1 class="h1-titulo">Espacios</h1>
  <a href="/espacios/nuevo" class="btn-main-blanco">+ Nuevo espacio</a>
</div>

<% if (!espacios || espacios.length === 0) { %>
  <p class="text-muted mt-3 text-center">No hay espacios registrados.</p>
<% } else { %>
  <div class="dashboard-grid">
    <% espacios.forEach(e => { %>
      <a href="/espacios/editar/<%= e.id %>"
         class="card activo card--josg"
         style="text-decoration:none;">
        <div class="alumno-nombre"><%= e.nombre %></div>
        <% if (e.propietario) { %>
          <div class="alumno-instrumento"><%= e.propietario %></div>
        <% } %>
        <% if (e.aforo) { %>
          <div class="alumno-grupo">Aforo: <%= e.aforo %></div>
        <% } %>
      </a>
    <% }) %>
  </div>
<% } %>

<div class="volver-bloque-izquierda">
  <a href="/configuracion" class="enlace-final">← Volver a configuración</a>
</div>
