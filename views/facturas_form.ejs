<% /* views/facturas_form.ejs */ %>
<% hero = false %>

<div id="factura-wrap" class="container my-4">
  <!-- ====== FORMULARIO PRINCIPAL ====== -->
  <form method="POST" action="/contabilidad/facturas/guardar" class="panel-card" id="form-factura" novalidate>
    <% if (EDIT && factura?.id) { %>
      <input type="hidden" name="id" value="<%= factura.id %>">
    <% } %>

    <div class="form-head">
      <h1 class="h1-titulo"><%= title %></h1>
    </div>

    <% if (typeof ok !== 'undefined' && ok) { %>
      <div class="flash-ok">✓ Guardado correctamente</div>
    <% } %>

    <!-- ===== Proveedor + Nº + Fechas ===== -->
    <div class="grid-2">
      <!-- Columna izquierda -->
      <div>
        <!-- Proveedor existente -->
        <div class="mb-3">
          <label class="form-label">Proveedor</label>
          <select name="proveedor_id" id="proveedor_id" class="form-select">
            <option value="">— Selecciona —</option>
            <% (proveedores||[]).forEach(p => { %>
              <option value="<%= p.id %>" <%= factura?.proveedor_id === p.id ? 'selected' : '' %>><%= p.nombre %></option>
            <% }) %>
          </select>
          <div class="help-text">
            ¿No está en la lista?
            <a href="#" id="toggleNewProv" class="link-soft">Añadir proveedor rápido</a>
          </div>
        </div>

        <!-- Alta rápida de proveedor -->
        <div id="nuevoProveedorBox" class="box-muted mb-3" style="display:none;">
          <div class="mb-2">
            <label class="form-label">Nombre del proveedor (nuevo)</label>
            <input type="text" class="form-control" name="proveedor_nombre" placeholder="Ej. Luthier García">
          </div>
          <div class="mb-1">
            <label class="form-label">NIF / CIF</label>
            <input type="text" class="form-control" name="proveedor_cif" placeholder="B12345678">
          </div>
          <div class="help-text">Se creará al guardar si no has elegido un proveedor.</div>
        </div>

        <!-- Nº factura -->
        <div class="mb-3">
          <label class="form-label">Nº de factura</label>
          <input type="text" class="form-control" name="numero" required
                 value="<%= factura?.numero || '' %>" placeholder="Ej. 2025-034">
        </div>

        <!-- Fechas -->
        <div class="row g-3">
          <div class="col-12 col-sm-6">
            <label class="form-label">Fecha emisión</label>
            <input type="date" class="form-control" name="fecha_emision" required
                   value="<%= factura?.fecha_emision ? String(factura.fecha_emision).slice(0,10) : '' %>">
          </div>
          <div class="col-12 col-sm-6">
            <label class="form-label">Fecha vencimiento</label>
            <input type="date" class="form-control" name="fecha_vencimiento"
                   value="<%= factura?.fecha_vencimiento ? String(factura.fecha_vencimiento).slice(0,10) : '' %>">
          </div>
        </div>
      </div>

      <!-- Columna derecha -->
      <div>
        <!-- Categoría / Cuenta -->
        <div class="mb-3">
          <label class="form-label">Categoría de gasto</label>
          <select name="categoria_id" class="form-select">
            <option value="">— Sin categoría —</option>
            <% (categorias||[]).forEach(c => { %>
              <option value="<%= c.id %>" <%= factura?.categoria_id === c.id ? 'selected' : '' %>><%= c.nombre %></option>
            <% }) %>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Cuenta (sugerida)</label>
          <select name="cuenta_id" class="form-select">
            <option value="">— Sin cuenta —</option>
            <% (cuentas||[]).forEach(ct => { %>
              <option value="<%= ct.id %>" <%= factura?.cuenta_id === ct.id ? 'selected' : '' %>><%= ct.nombre %></option>
            <% }) %>
          </select>
        </div>

        <!-- Estado -->
        <div class="mb-3">
          <label class="form-label">Estado</label>
          <select name="estado" class="form-select">
            <% const EST = (factura?.estado || 'pendiente'); %>
            <option value="borrador"  <%= EST==='borrador'  ? 'selected' : '' %>>Borrador</option>
            <option value="pendiente" <%= EST==='pendiente' ? 'selected' : '' %>>Pendiente</option>
            <option value="parcial"   <%= EST==='parcial'   ? 'selected' : '' %>>Parcial</option>
            <option value="pagada"    <%= EST==='pagada'    ? 'selected' : '' %>>Pagada</option>
            <option value="anulada"   <%= EST==='anulada'   ? 'selected' : '' %>>Anulada</option>
          </select>
        </div>
      </div>
    </div>

    <!-- ===== Concepto ===== -->
    <div class="mb-3">
      <label class="form-label">Concepto</label>
      <textarea name="concepto" class="form-control" rows="2" placeholder="Descripción breve del concepto…"><%= factura?.concepto || '' %></textarea>
    </div>

    <!-- ===== Importes ===== -->
    <div class="box-muted mb-3">
      <div class="money-row">
        <div>
          <label class="form-label">Base imponible (€)</label>
          <input type="number" inputmode="decimal" step="0.01" min="0" class="form-control"
                 name="base_imponible" id="base_imponible"
                 value="<%= typeof factura?.base_imponible !== 'undefined' ? Number(factura.base_imponible).toFixed(2) : '' %>" placeholder="0,00">
        </div>
        <div>
          <label class="form-label">IVA (%)</label>
          <input type="number" inputmode="decimal" step="0.01" min="0" class="form-control"
                 name="iva_pct" id="iva_pct"
                 value="<%= typeof factura?.iva_pct !== 'undefined' ? Number(factura.iva_pct) : 21 %>">
        </div>
        <div>
          <label class="form-label">Total (€)</label>
          <input type="number" inputmode="decimal" step="0.01" min="0" class="form-control"
                 name="total" id="total"
                 value="<%= typeof factura?.total !== 'undefined' ? Number(factura.total).toFixed(2) : '' %>" readonly>
        </div>
      </div>
      <div class="help-text">El total se calcula automáticamente = Base × (1 + IVA/100).</div>
    </div>

    <!-- ===== Notas / Observaciones ===== -->
    <div class="grid-2">
      <div class="mb-3">
        <label class="form-label">Notas internas</label>
        <textarea name="notas" class="form-control" rows="3" placeholder="Notas para uso interno…"><%= factura?.notas || '' %></textarea>
      </div>
    </div>

    <!-- ===== ACCIONES ===== -->
    <div class="actions">
      <% if (EDIT && factura?.id) { %>
        <!-- Evita formularios anidados usando formaction -->
        <button class="btn-primary-negro"
                formnovalidate
                formaction="/contabilidad/facturas/<%= factura.id %>/eliminar"
                formmethod="POST"
                onclick="return confirm('¿Eliminar factura?');">
          Eliminar
        </button>
      <% } %>
      <button type="submit" class="btn-primary-negro">Guardar</button>
    </div>
  </form>

  <!-- ====== ADJUNTOS (solo si hay ID) ====== -->
  <% if (EDIT && factura?.id) { %>
    <div class="subpanel">
      <div class="section-head">
        <h3 class="section-title">Adjuntos</h3>
        <div class="muted">Formatos: PDF / imágenes · máx. 10 MB</div>
      </div>
  
      <form action="/contabilidad/facturas/<%= factura.id %>/adjuntos" method="POST" enctype="multipart/form-data" class="inline-form">
        <div class="wide" style="display:flex;gap:8px;align-items:center;">
          <input type="file" name="adjuntos" accept="application/pdf,image/*" multiple />
          <button class="btn-subtle">Subir</button>
        </div>
      </form>
  
      <div class="adjuntos-grid mt-2">
        <% (adjuntos||[]).forEach(a => { %>
          <div class="adjunto-item">
            <% if ((a.mime||'').startsWith('image/')) { %>
              <a href="/uploads/facturas/<%= a.filename %>" target="_blank" rel="noopener">
                <img src="/uploads/facturas/<%= a.filename %>" alt="<%= a.original_name %>">
              </a>
            <% } else { %>
              <a href="/uploads/facturas/<%= a.filename %>" target="_blank" rel="noopener">
                <%= a.original_name || a.filename %>
              </a>
            <% } %>
            <form method="POST" action="/contabilidad/facturas/<%= factura.id %>/adjuntos/<%= a.id %>/eliminar" onsubmit="return confirm('¿Eliminar adjunto?')" style="background-color: white;">
              <button class="btn-subtle">Eliminar</button>
            </form>
          </div>
        <% }) %>
        <% if (!(adjuntos&&adjuntos.length)) { %>
          <div class="muted">Aún no hay adjuntos.</div>
        <% } %>
      </div>
    </div>
  <% } %>  

  <!-- ====== PAGOS (solo si hay ID) ====== -->
  <% if (EDIT && factura?.id) { %>
    <div class="subpanel">
      <div class="section-head">
        <h3 class="section-title">Pagos</h3>
        <div class="muted">
          Pagado: <strong><%= Number(factura.pagado||0).toFixed(2) %> €</strong> ·
          Saldo: <strong><%= Number(factura.saldo||0).toFixed(2) %> €</strong> ·
          <a href="/contabilidad/pagos/nuevo?proveedor=<%= factura.proveedor_id %>">Aplicar pago a varias facturas »</a>
        </div>
      </div>
  
      <% const fmt = v => (v && typeof v.toISOString==='function') ? v.toISOString().slice(0,10) : String(v||'').slice(0,10); %>
  
      <div class="table-responsive">
        <table class="table">
          <thead><tr><th>Fecha</th><th>Importe</th><th>Método</th><th>Ref.</th></tr></thead>
          <tbody>
            <% (pagos||[]).forEach(p => { %>
              <tr>
                <td><%= fmt(p.fecha) %></td>
                <td><%= Number(p.importe_aplicado).toFixed(2) %> €</td>
                <td><%= p.metodo || '' %></td>
                <td><%= p.referencia || '' %></td>
              </tr>
            <% }) %>
            <% if (!(pagos&&pagos.length)) { %><tr><td colspan="4" class="muted">Sin pagos</td></tr><% } %>
          </tbody>
        </table>
      </div>
  
      <hr class="soft-hr">
  
      <h4 class="section-title" style="font-size:1rem;">Registrar pago</h4>
      <form method="POST" action="/contabilidad/facturas/<%= factura.id %>/pagos" class="inline-form" style="background-color: white;">
        <div>
          <label class="form-label">Importe</label>
          <input type="number" step="0.01" min="0" name="importe" required value="<%= factura.saldo || '' %>" class="form-control">
        </div>
        <div>
          <label class="form-label">Fecha</label>
          <input type="date" name="fecha" required value="<%= new Date().toISOString().slice(0,10) %>" class="form-control">
        </div>
        <div>
          <label class="form-label">Método</label>
          <input type="text" name="metodo" placeholder="Transferencia / Tarjeta / Efectivo" class="form-control">
        </div>
        <div>
          <label class="form-label">Referencia</label>
          <input type="text" name="referencia" placeholder="Nº operación / banco" class="form-control">
        </div>
        <div class="wide">
          <label class="form-label">Notas</label>
          <textarea name="notas" rows="2" class="form-control"></textarea>
        </div>
        <div class="wide" style="display:flex;justify-content:flex-end;">
          <button class="btn-subtle">Guardar pago</button>
        </div>
      </form>
    </div>
  <% } %>
  
<div class="volver-bloque-izquierda">
  <a href="/contabilidad" class="enlace-final">← Volver a contabilidad</a>
</div>
<!-- ====== SCRIPT ====== -->
<script>
(function(){
  // Toggle alta rápida proveedor
  const linkToggle = document.getElementById('toggleNewProv');
  const box        = document.getElementById('nuevoProveedorBox');
  const selProv    = document.getElementById('proveedor_id');

  function showNewProv(show){
    if (!box || !selProv) return;
    box.style.display = show ? 'block' : 'none';
    if (show){
      selProv.value = '';
      selProv.setAttribute('disabled','disabled');
    } else {
      selProv.removeAttribute('disabled');
    }
  }
  linkToggle?.addEventListener('click', (e) => {
    e.preventDefault();
    const visible = box.style.display !== 'none';
    showNewProv(!visible);
  });

  // Cálculo automático del total (base → IVA → total)
  const baseEl = document.getElementById('base_imponible');
  const ivaEl  = document.getElementById('iva_pct');
  const totEl  = document.getElementById('total');

  function toNum(v){ const n = parseFloat(String(v).replace(',','.')); return isNaN(n)?0:n; }
  function fix2(n){ return (Math.round(n * 100) / 100).toFixed(2); }

  function recalc(){
    const base = toNum(baseEl?.value || 0);
    const pct  = toNum(ivaEl?.value  || 0);
    const total = base * (1 + (pct/100));
    if (totEl) totEl.value = fix2(total);
  }
  baseEl?.addEventListener('input', recalc);
  ivaEl?.addEventListener('input', recalc);
  baseEl?.addEventListener('blur', () => { if (baseEl.value) baseEl.value = fix2(toNum(baseEl.value)); });
  totEl?.addEventListener('blur',  () => { if (totEl.value)  totEl.value  = fix2(toNum(totEl.value));  });

  // Recalcula al cargar si hay valores
  recalc();

  // Validación mínima antes de enviar (proveedor o alta rápida + número + fecha)
  const form = document.getElementById('form-factura');
  form?.addEventListener('submit', (e) => {
    const provId = selProv?.value || '';
    const nuevoNombre = form.querySelector('input[name="proveedor_nombre"]')?.value.trim() || '';
    const num    = form.querySelector('input[name="numero"]')?.value.trim() || '';
    const femi   = form.querySelector('input[name="fecha_emision"]')?.value || '';

    if (!provId && !nuevoNombre){
      e.preventDefault();
      alert('Selecciona un proveedor o rellena los datos del nuevo proveedor.');
      return false;
    }
    if (!num || !femi){
      e.preventDefault();
      alert('Faltan Nº de factura o Fecha de emisión.');
      return false;
    }
    // Normaliza base/total a 2 decimales
    if (baseEl && baseEl.value) baseEl.value = fix2(toNum(baseEl.value));
    if (totEl  && totEl.value)  totEl.value  = fix2(toNum(totEl.value));
  });
})();
</script>

