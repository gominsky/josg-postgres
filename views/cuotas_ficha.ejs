<% const isEdicion = Boolean(cuota && cuota.id); %>
<% title = isEdicion ? 'Editar Cuota' : 'Crear Cuota'; %>
<% hero = false; %>

<h1 class="h1-titulo"><%= title %></h1>

<form
  id="form-cuota"
  method="POST"
  action="<%= isEdicion
    ? '/cuotas/' + cuota.id + '?_method=PUT'
    : '/cuotas'
  %>"
  class="formulario-alumno"
  style="border: 2px solid #FF9501; border-radius: 0.75rem; padding: 1rem;"
>
  <div class="grupo-campos">
    <h2>Datos de la Cuota</h2>
    <div class="form-grid-2">
      <label>Nombre:
        <input
          type="text"
          name="nombre"
          value="<%= cuota?.nombre || '' %>"
          required
        >
      </label>
      <label>Precio (€):
        <input
          type="number"
          name="precio"
          step="0.01"
          value="<%= cuota?.precio ? parseFloat(cuota.precio) : '' %>"
          required
        >
      </label>
    </div>
    <div class="form-grid-2">
      <label>Descripción:
        <textarea name="descripcion" rows="3"><%= cuota?.descripcion || '' %></textarea>
      </label>
      <label>Tipo de cuota:
        <select name="tipo_id" required>
          <% tipos.forEach(tipo => { %>
            <option
              value="<%= tipo.id %>"
              <%= cuota?.tipo_id === tipo.id ? 'selected' : '' %>
            ><%= tipo.tipo %></option>
          <% }) %>
        </select>
      </label>
    </div>
  </div>

  <div class="acciones-finales d-flex justify-content-between align-items-center mt-4">
    <a href="/cuotas" class="enlace-final-naranja">← Volver</a>
    <div class="d-flex align-items-center gap-2">
      <button type="submit" class="btn-main-blanco">
        <%= isEdicion ? 'Actualizar' : 'Registrar' %>
      </button>
      <% if (isEdicion) { %>
        <button
          type="submit"
          class="btn-main-blanco"
          formaction="/cuotas/<%= cuota.id %>?_method=DELETE"
          formmethod="POST"
          onclick="return confirm('¿Eliminar esta cuota?');"
        >Eliminar</button>
      <% } %>
    </div>
  </div>
</form>