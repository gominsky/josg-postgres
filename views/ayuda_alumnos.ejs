<% title = 'Ayuda · Músicos' %>
<% hero  = false %>
<link rel="stylesheet" href="/styles/estilos_help.css">


<div class="help-wrap">
  

  <div class="panel">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
      <h1 class="h1">Ayuda · Músicos</h1>
      <div class="cta">
        <a href="/alumnos">Ir al listado →</a>
        <a href="/alumnos/nuevo">Nuevo músico →</a>
      </div>
    </div>

    <!-- Índice -->
    <nav class="toc" aria-label="Índice">
      <a href="#flujo">Flujo rápido</a>
      <a href="#listado">Listado y filtros</a>
      <a href="#nuevo">Nuevo / Editar</a>
      <a href="#ficha">Ficha del músico</a>
      <a href="#finanzas">Cuotas y pagos</a>
      <a href="#foto">Foto y ficheros</a>
      <a href="#bajas">Bajas y eliminación</a>
      <a href="#faq">FAQ</a>
    </nav>

    <!-- Flujo rápido -->
    <section id="flujo" class="section">
      <h2>Flujo rápido</h2>
      <ol class="list">
        <li>Abre <span class="kbd">Listado de músicos</span> y filtra por <em>Estado</em>, <em>Grupo</em> o usa <em>Buscar</em>.</li>
        <li>Pulsa <strong>+ Añadir músico</strong> para crear uno nuevo y asignarle <em>grupos</em> e <em>instrumentos</em>.</li>
        <li>Desde la <strong>ficha</strong> del músico puedes ver datos, instrumentos/grupos y su <em>resumen financiero</em>.</li>
        <li>Genera <em>cuotas</em> mensuales por rango y registra <em>pagos</em> con recibo PDF.</li>
      </ol>
    </section>

    <!-- Listado y filtros -->
    <section id="listado" class="section">
      <h2>Listado y filtros</h2>
      <ul class="list">
        <li>Filtros por <strong>Estado</strong> (todos/activos/pasivos), <strong>Grupo</strong> y <strong>Búsqueda</strong> (nombre, apellidos, instrumentos).</li>
        <li>Botón <strong>+ Añadir músico</strong> en la cabecera; cada tarjeta enlaza a la ficha.</li>
        <li>El backend soporta los filtros y devuelve instrumentos agregados por alumno.</li>
      </ul>
      <p class="notice info">La búsqueda del listado filtra en vivo sobre las tarjetas visibles.</p>
    </section>

    <!-- Nuevo / Editar -->
    <section id="nuevo" class="section">
      <h2>Nuevo / Editar músico</h2>
      <div class="grid-2">
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Campos principales</h3>
          <ul class="list">
            <li>Datos personales y de contacto (nombre, apellidos, fecha de nacimiento, dirección, etc.).</li>
            <li><strong>Asignación</strong>: selección múltiple de <em>Grupos</em> e <em>Instrumentos</em>.</li>
            <li><strong>Estado</strong>: Activo / No activo. Al desactivar se guardará fecha de baja.</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Foto e importes</h3>
          <ul class="list">
            <li>Sube una <strong>Foto</strong> (campo de archivo). Si ya hay, se muestra y se conserva si no subes otra.</li>
            <li>La imagen se guarda en <span class="kbd">/uploads</span> con nombre único mediante <em>multer</em>.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Ficha -->
    <section id="ficha" class="section">
      <h2>Ficha del músico</h2>
      <ul class="list">
        <li>Datos de contacto y situación (alta/baja, activo). Muestra foto si está disponible.</li>
        <li><strong>Instrumentos</strong> y <strong>Grupos</strong> como etiquetas.</li>
        <li>Botones rápidos: <em>Volver</em> y <em>Editar</em>.</li>
      </ul>
    </section>

    <!-- Finanzas -->
    <section id="finanzas" class="section">
      <h2>Cuotas y pagos</h2>
      <div class="grid-2">
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Resumen financiero</h3>
          <ul class="list">
            <li>Totales: generadas, pagado y pendiente; botón para mostrar/ocultar el bloque.</li>
            <li>Tablas con las <em>últimas 5 cuotas</em> y <em>últimos 5 pagos</em> con botones “Ver más”.</li>
            <li>Cada pago tiene enlace a <strong>PDF</strong> del recibo.</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">Acciones</h3>
          <ul class="list">
            <li><strong>Generar cuotas</strong> por rango (desde/hasta) y tipo de cuota.</li>
            <li><strong>Registrar nuevo pago</strong> desde la ficha del alumno.</li>
            <li>Eliminar cuota (si no está pagada) desde la tabla de cuotas.</li>
          </ul>
        </div>
      </div>
      <p class="notice info">Las tablas soportan carga paginada por AJAX con botones “Ver más”.</p>
    </section>

    <!-- Foto y ficheros -->
    <section id="foto" class="section">
      <h2>Foto y ficheros</h2>
      <ul class="list">
        <li>Las fotos se suben al directorio <span class="kbd">/uploads</span> y se eliminan del disco si borras el músico.</li>
        <li>Formatos típicos de imagen; se conserva la foto anterior si no subes otra.</li>
      </ul>
    </section>

    <!-- Bajas y eliminación -->
    <section id="bajas" class="section">
      <h2>Bajas y eliminación</h2>
      <ul class="list">
        <li>Al marcar <em>No activo</em>, se guarda <strong>fecha de baja</strong> automáticamente.</li>
        <li>Eliminar un músico borra sus relaciones (grupos/instrumentos) y su foto del disco si existía.</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section id="faq" class="section">
      <h2>FAQ</h2>
      <div class="grid-2">
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">¿Cómo asigno varios instrumentos?</h3>
          <p>Usa el selector múltiple de la sección <em>Asignación</em> del formulario (Ctrl/Cmd + clic).</p>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">¿Dónde veo los pagos y cuotas?</h3>
          <p>En la <em>Ficha del músico</em>, dentro del bloque de <strong>Resumen financiero</strong>.</p>
        </div>
        <div class="card">
          <h3 style="margin:.1rem 0 .35rem;">¿Puedo filtrar por grupo y estado a la vez?</h3>
          <p>Sí. El listado soporta ambos filtros simultáneamente además de búsqueda por texto.</p>
        </div>
      </div>
    </section>

    <div class="section" style="display:flex;gap:10px;flex-wrap:wrap;">
      <a class="cta" href="/alumnos"><span class="pill">← Volver al listado</span></a>
      <a class="cta" href="/"><span class="pill">← Volver al inicio</span></a>
    </div>
  </div>
</div>

