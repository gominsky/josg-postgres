<% title = 'Ausencias'; hero = false %>

<div class="header-compact">
  <h1 class="h1-titulo">Tipos de ausencia</h1>
  <a href="/ausencias/nuevo" class="btn-main-blanco">+ Añadir</a>
</div>

<% if (!items || items.length === 0) { %>
  <p class="text-muted mt-3 text-center">No hay tipos de ausencia registrados.</p>
<% } else { %>
  <div class="dashboard-grid">
    <% items.forEach(i => { %>
      <a href="/ausencias/editar/<%= i.id %>" class="card activo card--josg" style="text-decoration:none;">
        <div class="alumno-nombre"><%= i.tipo %></div>
      </a>
    <% }) %>
  </div>
<% } %>

<div class="volver-bloque-izquierda">
  <a href="/configuracion" class="enlace-final">← Volver a configuración</a>
</div>
