<% title = 'Ausencias' %>
<% hero = false %>
<div class="header-compact">
  <h1 class="h1-titulo">Tipos de ausencia</h1>
  <a href="/ausencias/nuevo" class="btn-main-blanco">+ Añadir</a>
</div>

<% if (items.length === 0) { %>
  <p class="enlace-final" style="text-align: center; margin-top: 2rem;">No hay ausencias registradas.</p>
<% } else { %>
  <div class="dashboard-grid">
    <% items.forEach(i => { %>
      <a href="/ausencias/editar/<%= i.id %>" class="card-oro" style="text-decoration: none;">
        <div style="font-weight: 600; font-size: 1rem;"><%= i.tipo %></div>
      </a>
    <% }) %>
  </div>
<% } %>

<div class="volver-bloque-izquierda">
  <a href="/configuracion" class="enlace-final">← Volver a configuración</a>
</div>